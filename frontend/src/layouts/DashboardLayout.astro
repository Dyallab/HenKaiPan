---
import "../styles/global.css";
export interface Props {
    title?: string;
    active?: string;
}
const { title = "Dashboard", active = "dashboard" } = Astro.props;

const navGroups = [
    {
        label: "Overview",
        items: [
            {
                id: "dashboard",
                label: "Dashboard",
                href: "/dashboard",
                icon: "dashboard",
            },
            {
                id: "reports",
                label: "Reports",
                href: "/dashboard/reports",
                icon: "bar_chart",
            },
        ],
    },
    {
        label: "Operations",
        items: [
            {
                id: "findings",
                label: "Findings",
                href: "/dashboard/findings",
                icon: "biotech",
            },
            {
                id: "scans",
                label: "Scans",
                href: "/dashboard/scans",
                icon: "security_update_good",
            },
            {
                id: "vulns",
                label: "Vulnerabilities",
                href: "/dashboard/vulns",
                icon: "crisis_alert",
            },
            {
                id: "apps",
                label: "Apps",
                href: "/dashboard/apps",
                icon: "apps",
            },
            {
                id: "repos",
                label: "Repositories",
                href: "/dashboard/repos",
                icon: "hub",
            },
        ],
    },
    {
        label: "Governance",
        items: [
            {
                id: "compliance",
                label: "Compliance",
                href: "/dashboard/compliance",
                icon: "verified_user",
            },
        ],
    },
    {
        label: "Knowledge",
        items: [
            {
                id: "knowledge",
                label: "Knowledge Base",
                href: "/dashboard/knowledge",
                icon: "menu_book",
            },
        ],
    },
    {
        label: "Administration",
        items: [
            {
                id: "settings",
                label: "Settings",
                href: "/dashboard/settings",
                icon: "settings",
            },
        ],
    },
];
---

<!doctype html>
<html lang="en" class="dark h-full">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title} — HenKaiPan</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0"
            rel="stylesheet"
        />
        <style>
            body {
                font-family: "Inter", sans-serif;
            }
            .material-symbols-outlined {
                font-variation-settings:
                    "FILL" 0,
                    "wght" 400,
                    "GRAD" 0,
                    "opsz" 24;
                vertical-align: middle;
                line-height: 1;
            }
            .ms-fill {
                font-variation-settings:
                    "FILL" 1,
                    "wght" 400,
                    "GRAD" 0,
                    "opsz" 24;
            }
        </style>
    </head>
    <body
        class="bg-background text-on-background h-screen flex overflow-hidden"
    >
        <!-- Sidebar -->
        <aside
            class="w-64 shrink-0 border-r border-slate-800 bg-slate-950/90 backdrop-blur-lg flex flex-col py-4 h-full"
        >
            <!-- Logo -->
            <div class="px-6 mb-8 flex items-center gap-3">
                <div
                    class="w-8 h-8 bg-sky-500 rounded flex items-center justify-center shrink-0"
                >
                    <span
                        class="material-symbols-outlined ms-fill text-slate-950 text-xl"
                        >security</span
                    >
                </div>
                <div>
                    <p
                        class="text-sky-500 font-black tracking-tighter text-xl leading-none"
                    >
                        HenKaiPan
                    </p>
                    <p
                        class="text-[10px] text-slate-500 uppercase tracking-[0.2em] mt-0.5"
                    >
                        Security Platform
                    </p>
                </div>
            </div>

            <!-- Nav -->
            <nav class="flex-1 overflow-y-auto px-3 space-y-5">
                {
                    navGroups.map((group) => (
                        <section>
                            <p class="px-2 pb-2 text-[10px] font-bold uppercase tracking-[0.22em] text-slate-600">
                                {group.label}
                            </p>
                            <div class="space-y-0.5">
                                {group.items.map((item) => (
                                    <a
                                        href={item.href}
                                        class={`group flex items-center gap-3 rounded-xl px-3 py-3 text-[11px] font-bold uppercase tracking-[0.18em] transition-all duration-150 ${
                                            active === item.id
                                                ? "bg-sky-500/10 text-sky-400 ring-1 ring-sky-500/20"
                                                : "text-slate-400 hover:bg-slate-900/80 hover:text-slate-100"
                                        }`}
                                    >
                                        <span
                                            class={`material-symbols-outlined text-xl ${
                                                active === item.id
                                                    ? "text-sky-400"
                                                    : "text-slate-500 group-hover:text-slate-200"
                                            }`}
                                        >
                                            {item.icon}
                                        </span>
                                        <span class="truncate">{item.label}</span>
                                    </a>
                                ))}
                            </div>
                        </section>
                    ))
                }
            </nav>

            <!-- Footer -->
            <div class="px-4 pt-4 border-t border-slate-800 space-y-1">
                <button
                    id="run-scan-btn"
                    onclick="window.location.href='/dashboard/scans'"
                    class="w-full bg-slate-900 hover:bg-slate-800 text-sky-500 border border-slate-800 py-2.5 rounded text-xs font-bold uppercase tracking-widest transition-colors flex items-center justify-center gap-2 mb-2"
                >
                    <span class="material-symbols-outlined text-sm"
                        >rocket_launch</span
                    >
                    Run Global Scan
                </button>
                <a
                    href="#"
                    class="flex items-center gap-3 px-2 py-2 text-slate-500 hover:text-sky-500 text-xs font-bold uppercase tracking-wider transition-colors"
                >
                    <span class="material-symbols-outlined text-sm"
                        >menu_book</span
                    >
                    Documentation
                </a>
                <button
                    id="logout-btn"
                    class="flex items-center gap-3 w-full text-left px-2 py-2 text-slate-500 hover:text-red-400 text-xs font-bold uppercase tracking-wider transition-colors"
                >
                    <span class="material-symbols-outlined text-sm">logout</span
                    >
                    Log Out
                </button>
            </div>
        </aside>

        <!-- Main area -->
        <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
            <!-- Top bar -->
            <header
                class="shrink-0 flex justify-between items-center px-6 h-16 bg-slate-950/80 backdrop-blur-md border-b border-slate-800 z-40"
            >
                <h2 class="text-lg font-semibold text-on-background">
                    {title}
                </h2>
                <div class="flex items-center gap-3">
                    <button
                        class="p-2 text-slate-400 hover:text-sky-500 rounded-full transition-colors"
                    >
                        <span class="material-symbols-outlined text-xl"
                            >notifications</span
                        >
                    </button>
                    <div
                        class="w-8 h-8 rounded-full border border-sky-500/40 bg-surface-container flex items-center justify-center"
                    >
                        <span
                            class="material-symbols-outlined text-sky-500 text-lg"
                            >person</span
                        >
                    </div>
                </div>
            </header>

            <!-- Page content -->
            <main class="flex-1 overflow-auto px-8 py-6">
                <slot />
            </main>
        </div>

        <script>
            document
                .getElementById("logout-btn")
                ?.addEventListener("click", () => {
                    localStorage.removeItem("aspm_token");
                    window.location.href = "/login";
                });

            if (!localStorage.getItem("aspm_token")) {
                window.location.href = "/login";
            }
        </script>
    </body>
</html>
