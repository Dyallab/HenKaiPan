---
import "../styles/global.css";
export interface Props {
    title?: string;
    active?: string;
}
const { title = "Dashboard", active = "dashboard" } = Astro.props;

const navGroups = [
    {
        label: "Overview",
        items: [
            {
                id: "dashboard",
                label: "Dashboard",
                href: "/dashboard",
                icon: "dashboard",
            },
            {
                id: "reports",
                label: "Reports",
                href: "/dashboard/reports",
                icon: "bar_chart",
            },
        ],
    },
    {
        label: "Operations",
        items: [
            {
                id: "findings",
                label: "Findings",
                href: "/dashboard/findings",
                icon: "biotech",
            },
            {
                id: "scans",
                label: "Scans",
                href: "/dashboard/scans",
                icon: "security_update_good",
            },
            {
                id: "schedules",
                label: "Schedules",
                href: "/dashboard/schedules",
                icon: "event_repeat",
            },
            {
                id: "vulns",
                label: "Vulnerabilities",
                href: "/dashboard/vulns",
                icon: "crisis_alert",
            },
            {
                id: "apps",
                label: "Apps",
                href: "/dashboard/apps",
                icon: "apps",
            },
            {
                id: "projects",
                label: "Projects",
                href: "/dashboard/projects",
                icon: "folder_open",
            },
        ],
    },
    {
        label: "Governance",
        items: [
            {
                id: "compliance",
                label: "Compliance",
                href: "/dashboard/compliance",
                icon: "verified_user",
            },
            {
                id: "audit",
                label: "Audit Log",
                href: "/dashboard/audit",
                icon: "fact_check",
            },
            {
                id: "inventory",
                label: "Asset Inventory",
                href: "/dashboard/inventory",
                icon: "inventory",
            },
        ],
    },
    {
        label: "Knowledge",
        items: [
            {
                id: "knowledge",
                label: "Knowledge Base",
                href: "/dashboard/knowledge",
                icon: "menu_book",
            },
        ],
    },
    {
        label: "Administration",
        items: [
            {
                id: "system",
                label: "System",
                href: "/dashboard/system",
                icon: "monitoring",
            },
            {
                id: "settings",
                label: "Settings",
                href: "/dashboard/settings",
                icon: "settings",
            },
        ],
    },
];
---

<!doctype html>
<html lang="en" class="dark h-full">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title} — HenKaiPan</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0"
            rel="stylesheet"
        />
        <style>
            body {
                font-family: "Inter", sans-serif;
            }
            .material-symbols-outlined {
                font-variation-settings:
                    "FILL" 0,
                    "wght" 400,
                    "GRAD" 0,
                    "opsz" 24;
                vertical-align: middle;
                line-height: 1;
            }
            .ms-fill {
                font-variation-settings:
                    "FILL" 1,
                    "wght" 400,
                    "GRAD" 0,
                    "opsz" 24;
            }
        </style>
    </head>
    <body
        class="bg-background text-on-background h-screen flex overflow-hidden"
    >
        <!-- Sidebar -->
        <aside
            class="w-64 shrink-0 border-r border-slate-800 bg-slate-950/90 backdrop-blur-lg flex flex-col py-4 h-full"
        >
            <!-- Logo -->
            <div class="px-6 mb-8 flex items-center gap-3">
                <div
                    class="w-8 h-8 bg-sky-500 rounded flex items-center justify-center shrink-0"
                >
                    <span
                        class="material-symbols-outlined ms-fill text-slate-950 text-xl"
                        >security</span
                    >
                </div>
                <div>
                    <p
                        class="text-sky-500 font-black tracking-tighter text-xl leading-none"
                    >
                        HenKaiPan
                    </p>
                    <p
                        class="text-[10px] text-slate-500 uppercase tracking-[0.2em] mt-0.5"
                    >
                        Security Platform
                    </p>
                </div>
            </div>

            <!-- Nav -->
            <nav class="flex-1 overflow-y-auto px-3 space-y-5">
                {
                    navGroups.map((group) => (
                        <section>
                            <p class="px-2 pb-2 text-[10px] font-bold uppercase tracking-[0.22em] text-slate-600">
                                {group.label}
                            </p>
                            <div class="space-y-0.5">
                                {group.items.map((item) => (
                                    <a
                                        href={item.href}
                                        class={`group flex items-center gap-3 rounded-xl px-3 py-3 text-[11px] font-bold uppercase tracking-[0.18em] transition-all duration-150 ${
                                            active === item.id
                                                ? "bg-sky-500/10 text-sky-400 ring-1 ring-sky-500/20"
                                                : "text-slate-400 hover:bg-slate-900/80 hover:text-slate-100"
                                        }`}
                                    >
                                        <span
                                            class={`material-symbols-outlined text-xl ${
                                                active === item.id
                                                    ? "text-sky-400"
                                                    : "text-slate-500 group-hover:text-slate-200"
                                            }`}
                                        >
                                            {item.icon}
                                        </span>
                                        <span class="truncate">{item.label}</span>
                                    </a>
                                ))}
                            </div>
                        </section>
                    ))
                }
            </nav>

            <!-- Footer -->
            <div class="px-4 pt-4 border-t border-slate-800 space-y-1">
                <button
                    id="run-scan-btn"
                    onclick="window.location.href='/dashboard/scans'"
                    class="w-full bg-slate-900 hover:bg-slate-800 text-sky-500 border border-slate-800 py-2.5 rounded text-xs font-bold uppercase tracking-widest transition-colors flex items-center justify-center gap-2 mb-2"
                >
                    <span class="material-symbols-outlined text-sm"
                        >rocket_launch</span
                    >
                    Run Global Scan
                </button>
                <button
                    id="logout-btn"
                    class="flex items-center gap-3 w-full text-left px-2 py-2 text-slate-500 hover:text-red-400 text-xs font-bold uppercase tracking-wider transition-colors"
                >
                    <span class="material-symbols-outlined text-sm">logout</span
                    >
                    Log Out
                </button>
            </div>
        </aside>

        <!-- Main area -->
        <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
            <!-- Top bar -->
            <header
                class="shrink-0 flex justify-between items-center px-6 h-16 bg-slate-950/80 backdrop-blur-md border-b border-slate-800 z-40"
            >
                <h2 class="text-lg font-semibold text-on-background">
                    {title}
                </h2>
                <div class="flex items-center gap-3">
                    <!-- Notifications bell -->
                    <div class="relative">
                        <button
                            id="notifications-btn"
                            class="p-2 text-slate-400 hover:text-sky-500 rounded-full transition-colors relative"
                        >
                            <span class="material-symbols-outlined text-xl"
                                >notifications</span
                            >
                            <span
                                id="notification-badge"
                                class="hidden absolute top-1 right-1 w-4 h-4 bg-red-500 text-white text-[10px] font-bold rounded-full items-center justify-center"
                            ></span>
                        </button>
                        
                        <!-- Notifications dropdown -->
                        <div
                            id="notifications-dropdown"
                            class="hidden absolute right-0 mt-2 w-96 bg-slate-900 border border-slate-700 rounded-2xl shadow-2xl z-50 max-h-[600px] overflow-auto"
                        >
                            <div class="p-4 border-b border-slate-700">
                                <div class="flex items-center justify-between">
                                    <h3 class="text-sm font-bold text-on-background">Notifications</h3>
                                    <button
                                        id="mark-all-read-btn"
                                        class="text-xs text-sky-400 hover:text-sky-300"
                                    >
                                        Mark all as read
                                    </button>
                                </div>
                            </div>
                            <div id="notifications-list" class="divide-y divide-slate-800">
                                <!-- Notifications will be rendered here -->
                            </div>
                            <div id="no-notifications" class="hidden p-8 text-center text-sm text-slate-500">
                                No notifications yet
                            </div>
                        </div>
                    </div>
                    
                    <div
                        class="w-8 h-8 rounded-full border border-sky-500/40 bg-surface-container flex items-center justify-center"
                    >
                        <span
                            class="material-symbols-outlined text-sky-500 text-lg"
                            >person</span
                        >
                    </div>
                </div>
            </header>

            <!-- Page content -->
            <main class="flex-1 overflow-auto px-8 py-6">
                <slot />
            </main>
        </div>

        <script>
            import { api } from "../lib/api";

            let unreadCount = 0;
            let notificationsDropdownOpen = false;

            // Global API error → toast (skip 404s — callers handle these silently)
            window.addEventListener("api-error", ((e: CustomEvent) => {
                if (e.detail.silent) return;
                import("../lib/toast").then(({ toast }) => {
                    toast(e.detail.message, "error");
                });
            }) as EventListener);

            document
                .getElementById("logout-btn")
                ?.addEventListener("click", async () => {
                    try {
                        await api.logout();
                    } finally {
                        window.location.href = "/login";
                    }
                });

            // Notifications functionality
            async function loadUnreadCount() {
                try {
                    const { count } = await api.getUnreadNotificationCount();
                    unreadCount = count;
                    updateNotificationBadge();
                } catch (error) {
                    // Silent fail - notifications might not be available
                }
            }

            function updateNotificationBadge() {
                const badge = document.getElementById("notification-badge")!;
                if (unreadCount > 0) {
                    badge.textContent = unreadCount > 99 ? "99+" : unreadCount.toString();
                    badge.classList.remove("hidden");
                    badge.classList.add("flex");
                } else {
                    badge.classList.add("hidden");
                    badge.classList.remove("flex");
                }
            }

            async function loadNotifications() {
                const list = document.getElementById("notifications-list")!;
                const noNotif = document.getElementById("no-notifications")!;
                
                try {
                    const { notifications } = await api.getNotifications({ page: 1, limit: 20 });
                    
                    if (notifications.length === 0) {
                        list.classList.add("hidden");
                        noNotif.classList.remove("hidden");
                        return;
                    }
                    
                    noNotif.classList.add("hidden");
                    list.classList.remove("hidden");
                    
                    list.innerHTML = notifications.map((n: any) => `
                        <div class="p-4 hover:bg-slate-800/50 transition-colors cursor-pointer ${n.read ? 'opacity-60' : ''}" data-id="${n.id}" data-finding-id="${n.entity_id || ''}">
                            <div class="flex items-start gap-3">
                                <span class="material-symbols-outlined text-lg ${n.read ? 'text-slate-500' : 'text-sky-400'}">
                                    ${n.type === 'finding_assignment' ? 'assignment' : 'notifications'}
                                </span>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-semibold text-on-background">${n.title}</p>
                                    <p class="text-xs text-slate-400 mt-1">${n.message}</p>
                                    <p class="text-[10px] text-slate-500 mt-2">${new Date(n.created_at).toLocaleString()}</p>
                                </div>
                                ${!n.read ? '<span class="w-2 h-2 bg-sky-500 rounded-full shrink-0"></span>' : ''}
                            </div>
                        </div>
                    `).join("");
                    
                    // Add click handlers to mark as read and navigate to finding
                    list.querySelectorAll("[data-id]").forEach((el: Element) => {
                        el.addEventListener("click", async () => {
                            const id = (el as HTMLElement).dataset.id;
                            const findingId = (el as HTMLElement).dataset.findingId;
                            if (!id) return;
                            
                            try {
                                await api.markNotificationAsRead(id);
                                el.classList.add("opacity-60");
                                el.querySelector(".w-2.h-2")?.remove();
                                unreadCount = Math.max(0, unreadCount - 1);
                                updateNotificationBadge();
                                
                                // Navigate to finding if it's a finding assignment notification
                                if (findingId) {
                                    window.location.href = `/dashboard/findings/detail?id=${encodeURIComponent(findingId)}`;
                                }
                            } catch (error) {
                                console.error("Failed to mark notification as read", error);
                            }
                        });
                    });
                } catch (error) {
                    list.innerHTML = '<p class="p-4 text-sm text-red-400">Failed to load notifications</p>';
                }
            }

            // Toggle notifications dropdown
            document.getElementById("notifications-btn")?.addEventListener("click", async (e) => {
                e.stopPropagation();
                const dropdown = document.getElementById("notifications-dropdown")!;
                
                if (!notificationsDropdownOpen) {
                    await loadNotifications();
                    dropdown.classList.remove("hidden");
                    notificationsDropdownOpen = true;
                } else {
                    dropdown.classList.add("hidden");
                    notificationsDropdownOpen = false;
                }
            });

            // Mark all as read
            document.getElementById("mark-all-read-btn")?.addEventListener("click", async (e) => {
                e.stopPropagation();
                try {
                    await api.markAllNotificationsAsRead();
                    unreadCount = 0;
                    updateNotificationBadge();
                    await loadNotifications();
                } catch (error) {
                    console.error("Failed to mark all as read", error);
                }
            });

            // Close dropdown when clicking outside
            document.addEventListener("click", () => {
                if (notificationsDropdownOpen) {
                    document.getElementById("notifications-dropdown")?.classList.add("hidden");
                    notificationsDropdownOpen = false;
                }
            });

            // Load unread count on page load
            loadUnreadCount();
            
            // Poll for new notifications every 30 seconds
            setInterval(loadUnreadCount, 30000);

            (async () => {
                try {
                    await api.getMe();
                } catch {
                    window.location.href = "/login";
                }
            })();
        </script>
    </body>
</html>
