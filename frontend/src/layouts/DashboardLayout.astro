---
import "../styles/global.css";
export interface Props {
    title?: string;
    active?: string;
}
const { title = "Dashboard", active = "dashboard" } = Astro.props;

const navGroups = [
    {
        label: "Overview",
        items: [
            { id: "dashboard", label: "Dashboard", href: "/dashboard", icon: "dashboard" },
            { id: "reports", label: "Reports", href: "/dashboard/reports", icon: "bar_chart" },
        ],
    },
    {
        label: "Operations",
        items: [
            { id: "findings", label: "Findings", href: "/dashboard/findings", icon: "biotech" },
            { id: "scans", label: "Scans", href: "/dashboard/scans", icon: "security_update_good" },
            { id: "schedules", label: "Schedules", href: "/dashboard/schedules", icon: "event_repeat" },
            { id: "vulns", label: "Vulnerabilities", href: "/dashboard/vulns", icon: "crisis_alert" },
            { id: "apps", label: "Apps", href: "/dashboard/apps", icon: "apps" },
            { id: "projects", label: "Projects", href: "/dashboard/projects", icon: "folder_open" },
        ],
    },
    {
        label: "Governance",
        items: [
            { id: "audit", label: "Audit Log", href: "/dashboard/audit", icon: "fact_check" },
            { id: "inventory", label: "Asset Inventory", href: "/dashboard/inventory", icon: "inventory" },
            { id: "compliance", label: "Compliance", href: "/dashboard/compliance", icon: "verified_user", requiredRole: "admin" },
        ],
    },
    {
        label: "Knowledge",
        items: [
            { id: "knowledge", label: "Knowledge Base", href: "/dashboard/knowledge", icon: "menu_book" },
        ],
    },
    {
        label: "Administration",
        requiredRole: "admin",
        items: [
            { id: "system", label: "System", href: "/dashboard/system", icon: "monitoring" },
            { id: "scanner-health", label: "Scanner Health", href: "/dashboard/scanner-health", icon: "network_node" },
            { id: "settings", label: "Settings", href: "/dashboard/settings", icon: "settings" },
        ],
    },
];
---

<!doctype html>
<html lang="en" class="dark h-full">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title} — HenKaiPan</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@300;400;500;600&display=swap"
            rel="stylesheet"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,300,0,0"
            rel="stylesheet"
        />
        <style>
            :root {
                --font-aeonik: 'Montserrat', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            }
            body {
                font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            }
            .material-symbols-outlined {
                font-variation-settings:
                    "FILL" 0,
                    "wght" 300,
                    "GRAD" 0,
                    "opsz" 24;
                vertical-align: middle;
                line-height: 1;
            }
            .ms-fill {
                font-variation-settings:
                    "FILL" 1,
                    "wght" 300,
                    "GRAD" 0,
                    "opsz" 24;
            }
        </style>
    </head>
    <body class="bg-deep-space text-ghost-white h-screen flex overflow-hidden">
        <!-- Sidebar -->
        <aside class="w-56 shrink-0 border-r border-white/10 bg-deep-space flex flex-col h-full">
            <!-- Logo -->
            <div class="px-5 py-3 flex items-center gap-3 border-b border-white/10" onclick="window.scrollTo({top: 0, behavior: 'smooth'})" style="cursor: pointer;">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0 bg-white/5 border border-white/10">
                    <span class="material-symbols-outlined text-iridescent-glow text-lg">security</span>
                </div>
                <div>
                    <p class="text-ghost-white font-aeonik font-normal tracking-tight text-xl leading-none">
                        HenKaiPan
                    </p>
                    <p class="text-[10px] text-iron-slate uppercase tracking-[0.2em] mt-0.5">
                        Security Platform
                    </p>
                </div>
            </div>

            <!-- Nav -->
            <nav class="flex-1 overflow-y-auto px-2 space-y-4 py-3">
                {navGroups.map((group) => (
                    <section data-required-role={group.requiredRole}>
                        <p class="px-2 pb-1 text-[9px] font-semibold uppercase tracking-[0.2em] text-iron-slate/50">
                            {group.label}
                        </p>
                        <div class="space-y-px">
                            {group.items.map((item) => (
                                <a
                                    href={item.href}
                                    data-required-role={item.requiredRole || undefined}
                                    class={`group flex items-center gap-2.5 rounded-lg px-2.5 py-2 text-[11px] font-medium uppercase tracking-[0.18em] transition-all duration-150 ${
                                        active === item.id
                                            ? "bg-white/5 text-ghost-white border border-white/10"
                                            : "text-iron-slate hover:bg-white/[0.03] hover:text-ghost-white"
                                    }`}
                                >
                                    <span
                                        class={`material-symbols-outlined text-lg ${
                                            active === item.id
                                                ? "text-iridescent-glow"
                                                : "text-iron-slate group-hover:text-ghost-white"
                                        }`}
                                    >
                                        {item.icon}
                                    </span>
                                    <span class="truncate">{item.label}</span>
                                </a>
                            ))}
                        </div>
                    </section>
                ))}
            </nav>

            <!-- Footer -->
            <div class="px-3 pt-3 pb-2 border-t border-white/10 space-y-1">
                <button
                    id="logout-btn"
                    class="flex items-center gap-3 w-full text-left px-2 py-1.5 text-iron-slate hover:text-vivid-crimson text-[10px] font-medium uppercase tracking-wider transition-colors"
                >
                    <span class="material-symbols-outlined text-sm">logout</span>
                    Log Out
                </button>
                <div id="sidebar-version" class="hidden px-2 py-1">
                    <span class="text-[9px] text-iron-slate/50 font-mono tracking-tight"></span>
                </div>
            </div>
        </aside>

        <!-- Main area -->
        <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
            <!-- Top bar -->
            <header class="shrink-0 flex justify-between items-center px-6 h-12 bg-deep-space border-b border-white/10 z-40">
                <h2 class="text-base font-medium text-ghost-white">
                    {title}
                </h2>
                <div class="flex items-center gap-3">
                    <!-- Notifications bell -->
                    <div class="relative">
                        <button
                            id="notifications-btn"
                            class="p-2 text-iron-slate hover:text-iridescent-glow rounded-full transition-colors relative"
                        >
                            <span class="material-symbols-outlined text-xl">notifications</span>
                            <span
                                id="notification-badge"
                                class="hidden absolute top-1 right-1 w-4 h-4 bg-vivid-crimson text-ghost-white text-[10px] font-bold rounded-full items-center justify-center"
                            ></span>
                        </button>

                        <!-- Notifications dropdown -->
                        <div
                            id="notifications-dropdown"
                            class="hidden absolute right-0 mt-2 w-96 bg-shadow-tint border border-white/10 rounded-xl shadow-2xl z-50 max-h-[600px] overflow-auto"
                        >
                            <div class="p-4 border-b border-white/10">
                                <div class="flex items-center justify-between">
                                    <h3 class="text-sm font-medium text-ghost-white">Notifications</h3>
                                    <button
                                        id="mark-all-read-btn"
                                        class="text-xs text-iridescent-glow hover:text-ghost-white"
                                    >
                                        Mark all as read
                                    </button>
                                </div>
                            </div>
                            <div id="notifications-list" class="divide-y divide-white/10">
                                <!-- Notifications will be rendered here -->
                            </div>
                            <div id="no-notifications" class="hidden p-8 text-center text-sm text-iron-slate">
                                No notifications yet
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center gap-2">
                        <span id="username-display" class="text-xs text-iron-slate font-medium"></span>
                        <div class="w-8 h-8 rounded-full border border-white/10 bg-white/5 flex items-center justify-center">
                            <span class="material-symbols-outlined text-iridescent-glow text-lg">person</span>
                        </div>
                    </div>
                </div>
            </header>

            <!-- Page content -->
            <main class="flex-1 overflow-auto px-6 py-5">
                <slot />
            </main>
        </div>

        <script>
            import { api } from "@lib/api";
            import { getSSEClient } from "@lib/sse";

            let unreadCount = 0;
            let notificationsDropdownOpen = false;
            let currentUser: { username: string; role: string } | null = null;

            // Load current user info
            (async () => {
                try {
                    currentUser = await api.getMe();
                    // Show username in top bar
                    const nameEl = document.getElementById("username-display");
                    if (nameEl && currentUser) {
                        nameEl.textContent = currentUser.username;
                        sessionStorage.setItem("hkp_role", currentUser.role);
                    }
                    // Hide nav groups that require a role the current user doesn't have
                    document.querySelectorAll<HTMLElement>('[data-required-role]').forEach(el => {
                        if (currentUser?.role !== el.dataset.requiredRole) {
                            el.remove();
                        }
                    });
                } catch {}
            })();

            window.addEventListener("api-error", ((e: CustomEvent) => {
                if (e.detail.silent) return;
                import("../lib/toast").then(({ toast }) => {
                    toast(e.detail.message, "error");
                });
            }) as EventListener);

            document.getElementById("logout-btn")?.addEventListener("click", async () => {
                try {
                    await api.logout();
                } finally {
                    window.location.href = "/login";
                }
            });

            async function loadUnreadCount() {
                try {
                    const { count } = await api.getUnreadNotificationCount();
                    unreadCount = count;
                    updateNotificationBadge();
                } catch (error) {}
            }

            function updateNotificationBadge() {
                const badge = document.getElementById("notification-badge")!;
                if (unreadCount > 0) {
                    badge.textContent = unreadCount > 99 ? "99+" : unreadCount.toString();
                    badge.classList.remove("hidden");
                    badge.classList.add("flex");
                } else {
                    badge.classList.add("hidden");
                    badge.classList.remove("flex");
                }
            }

            async function loadNotifications() {
                const list = document.getElementById("notifications-list")!;
                const noNotif = document.getElementById("no-notifications")!;

                try {
                    const { notifications } = await api.getNotifications({ page: 1, limit: 20 });

                    if (notifications.length === 0) {
                        list.classList.add("hidden");
                        noNotif.classList.remove("hidden");
                        return;
                    }

                    noNotif.classList.add("hidden");
                    list.classList.remove("hidden");

                    list.innerHTML = notifications.map((n: any) => `
                        <div class="p-4 hover:bg-white/[0.03] transition-colors cursor-pointer ${n.read ? 'opacity-60' : ''}" data-id="${n.id}" data-finding-id="${n.entity_id || ''}">
                            <div class="flex items-start gap-3">
                                <span class="material-symbols-outlined text-lg ${n.read ? 'text-iron-slate' : 'text-iridescent-glow'}">
                                    ${n.type === 'finding_assignment' ? 'assignment' : 'notifications'}
                                </span>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-medium text-ghost-white">${n.title}</p>
                                    <p class="text-xs text-iron-slate mt-1">${n.message}</p>
                                    <p class="text-[10px] text-iron-slate/60 mt-2">${new Date(n.created_at).toLocaleString()}</p>
                                </div>
                                ${!n.read ? '<span class="w-2 h-2 bg-iridescent-glow rounded-full shrink-0"></span>' : ''}
                            </div>
                        </div>
                    `).join("");

                    list.querySelectorAll("[data-id]").forEach((el: Element) => {
                        el.addEventListener("click", async () => {
                            const id = (el as HTMLElement).dataset.id;
                            const findingId = (el as HTMLElement).dataset.findingId;
                            if (!id) return;

                            try {
                                await api.markNotificationAsRead(id);
                                el.classList.add("opacity-60");
                                el.querySelector(".w-2.h-2")?.remove();
                                unreadCount = Math.max(0, unreadCount - 1);
                                updateNotificationBadge();

                                if (findingId) {
                                    window.location.href = `/dashboard/findings/detail?id=${encodeURIComponent(findingId)}`;
                                }
                            } catch (error) {
                                console.error("Failed to mark notification as read", error);
                            }
                        });
                    });
                } catch (error) {
                    list.innerHTML = '<p class="p-4 text-sm text-vivid-crimson">Failed to load notifications</p>';
                }
            }

            document.getElementById("notifications-btn")?.addEventListener("click", async (e) => {
                e.stopPropagation();
                const dropdown = document.getElementById("notifications-dropdown")!;

                if (!notificationsDropdownOpen) {
                    await loadNotifications();
                    dropdown.classList.remove("hidden");
                    notificationsDropdownOpen = true;
                } else {
                    dropdown.classList.add("hidden");
                    notificationsDropdownOpen = false;
                }
            });

            document.getElementById("mark-all-read-btn")?.addEventListener("click", async (e) => {
                e.stopPropagation();
                try {
                    await api.markAllNotificationsAsRead();
                    unreadCount = 0;
                    updateNotificationBadge();
                    await loadNotifications();
                } catch (error) {
                    console.error("Failed to mark all as read", error);
                }
            });

            document.addEventListener("click", () => {
                if (notificationsDropdownOpen) {
                    document.getElementById("notifications-dropdown")?.classList.add("hidden");
                    notificationsDropdownOpen = false;
                }
            });

            loadUnreadCount();

            const sseClient = getSSEClient();
            sseClient.connect();
            sseClient.on("notification_created", () => {
                unreadCount++;
                updateNotificationBadge();
            });

            // Auth guard: wait for currentUser to load, redirect on failure
            (async () => {
                // Give the first getMe() call a moment to complete
                for (let i = 0; i < 50; i++) {
                    if (currentUser) return;
                    await new Promise(r => setTimeout(r, 100));
                }
                window.location.href = "/login";
            })();

            // ── Version display + update check ──
            (async () => {
                try {
                    const verEl = document.getElementById("sidebar-version");
                    const verSpan = verEl?.querySelector("span");
                    if (!verEl || !verSpan) return;

                    const version = await api.get("/api/version");
                    const v = version.version || "dev";
                    verSpan.textContent = v;
                    verEl.classList.remove("hidden");

                    // Only check for updates if not dev build
                    if (v === "dev") return;

                    const check = await api.get("/api/version/check");
                    if (!check.update_available) return;

                    // Show once per version (localStorage)
                    const notified = localStorage.getItem("hkp_notified_version");
                    if (notified === check.latest_version) return;

                    localStorage.setItem("hkp_notified_version", check.latest_version);

                    verSpan.textContent = `${v} · ↑ ${check.latest_version}`;

                    // Create top-left toast
                    const toastEl = document.createElement("div");
                    toastEl.className = "fixed top-4 left-4 z-50 flex items-center gap-3 bg-amber-500/10 border border-amber-500/20 rounded-lg px-4 py-3 max-w-sm animate-slide-in";
                    toastEl.setAttribute("role", "alert");

                    const icon = document.createElement("span");
                    icon.className = "material-symbols-outlined ms-fill text-xl text-amber-400";
                    icon.textContent = "new_releases";

                    const msg = document.createElement("span");
                    msg.className = "text-sm text-amber-300";
                    msg.textContent = `New version available: ${check.latest_version}`;

                    const link = document.createElement("a");
                    link.href = check.latest_url || "#";
                    link.target = "_blank";
                    link.className = "text-xs font-bold text-amber-400 hover:text-amber-300 underline transition-colors shrink-0";
                    link.textContent = "View release →";

                    const closeBtn = document.createElement("button");
                    closeBtn.className = "ml-auto text-amber-400/60 hover:text-amber-300 transition-colors";
                    closeBtn.setAttribute("aria-label", "Dismiss");
                    closeBtn.innerHTML = '<span class="material-symbols-outlined ms-fill text-lg">close</span>';
                    closeBtn.onclick = () => {
                        toastEl.style.animation = "slide-out 300ms ease-out forwards";
                        setTimeout(() => toastEl.remove(), 300);
                    };

                    toastEl.appendChild(icon);
                    toastEl.appendChild(msg);
                    toastEl.appendChild(link);
                    toastEl.appendChild(closeBtn);
                    document.body.appendChild(toastEl);

                    // Auto-dismiss after 15s
                    setTimeout(() => {
                        if (document.body.contains(toastEl)) {
                            toastEl.style.animation = "slide-out 300ms ease-out forwards";
                            setTimeout(() => toastEl.remove(), 300);
                        }
                    }, 15000);
                } catch {
                    // Silently ignore — version check is non-critical
                }
            })();
        </script>
    </body>
</html>
