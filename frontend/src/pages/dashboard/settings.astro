                <div
                    id="create-team-form"
                    class="hidden bg-surface-container border border-outline-variant/20 rounded-xl p-6 space-y-4"
                >
                    <h4 class="font-bold text-on-background">Create Team</h4>
                    <div class="flex gap-3">
                        <input
                            id="new-team-name"
                            type="text"
                            placeholder="Team name (e.g. AppSec)"
                            class="flex-1 bg-slate-950 border border-slate-800 rounded-lg px-3 py-2 text-sm text-on-background focus:ring-1 focus:ring-cyan-500 outline-none"
                        />
                        <button
                            id="save-new-team"
                            class="px-4 py-2 bg-cyan-500 hover:bg-cyan-400 text-slate-950 rounded-lg text-sm font-bold transition-all"
                            >Create</button
                        >
                        <button
                            id="cancel-create-team"
                            class="px-4 py-2 bg-slate-900 border border-slate-800 text-slate-400 rounded-lg text-sm font-bold hover:bg-slate-800 transition-all"
                            >Cancel</button
                        >
                    </div>
                    <div
                        id="create-team-msg"
                        class="hidden text-xs font-medium"
                    >
                    </div>
                </div>

                <!-- Team list -->
                <div id="team-list" class="space-y-4">
                    <div class="text-xs text-slate-500 animate-pulse">
                        Loading teams...
                    </div>
                </div>
            </section>

            <!-- License -->
            <section
                id="section-license"
                class="settings-section hidden space-y-6"
            >
                <div class="border-b border-slate-800 pb-4">
                    <h2 class="text-xl font-bold text-on-background">
                        License
                    </h2>
                    <p class="text-sm text-slate-400 mt-1">
                        Manage your self-hosted license key.
                    </p>
                </div>

                <div
                    class="bg-surface-container border border-outline-variant/20 rounded-xl p-6 space-y-4"
                >
                    <div class="flex items-start gap-4">
                        <div
                            id="license-status-icon"
                            class="w-12 h-12 rounded-xl bg-slate-900 border border-slate-800 flex items-center justify-center shrink-0"
                        >
                            <span
                                class="material-symbols-outlined text-slate-500 text-2xl"
                                >badge</span
                            >
                        </div>
                        <div class="flex-1">
                            <h3
                                id="license-status"
                                class="font-bold text-on-background"
                            >
                                Loading...
                            </h3>
                            <p
                                id="license-message"
                                class="text-sm text-slate-400 mt-1"
                            >
                            </p>
                            <div
                                id="license-details"
                                class="mt-4 grid grid-cols-2 gap-4 text-sm hidden"
                            >
                                <div>
                                    <p class="text-xs text-slate-500">Email</p>
                                    <p
                                        id="license-email"
                                        class="text-slate-300"
                                    >
                                    </p>
                                </div>
                                <div>
                                    <p class="text-xs text-slate-500">
                                        Expires
                                    </p>
                                    <p
                                        id="license-expires"
                                        class="text-slate-300"
                                    >
                                    </p>
                                </div>
                            </div>
                            <div
                                id="license-features"
                                class="mt-4 flex flex-wrap gap-2 hidden"
                            >
                            </div>
                        </div>
                    </div>

                    <div class="pt-4 border-t border-slate-800">
                        <h4 class="font-bold text-on-background mb-3">
                            Update License Key
                        </h4>
                        <div class="flex gap-3">
                            <input
                                id="license-key-input"
                                type="text"
                                placeholder="Paste your license key here"
                                class="flex-1 bg-slate-950 border border-slate-800 rounded-lg px-3 py-2 text-sm font-mono text-on-background focus:ring-1 focus:ring-cyan-500 outline-none"
                            />
                            <button
                                id="save-license-btn"
                                class="px-4 py-2 bg-cyan-500 hover:bg-cyan-400 text-slate-950 rounded-lg text-sm font-bold transition-all"
                            >
                                Save
                            </button>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </div>
</DashboardLayout>

<script>
    import { toast } from "../../lib/toast";

    // --- Section switching ---
    const navBtns =
        document.querySelectorAll<HTMLButtonElement>(".settings-nav");
    const sections =
        document.querySelectorAll<HTMLElement>(".settings-section");

    navBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            const target = btn.dataset.section!;

            navBtns.forEach((b) => {
                b.className = `settings-nav w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-semibold text-left transition-all ${
                    b.dataset.section === target
                        ? "bg-cyan-500/10 text-cyan-400"
                        : "text-slate-400 hover:bg-slate-900 hover:text-slate-200"
                }`;
            });

            sections.forEach((s) => {
                s.classList.toggle("hidden", s.id !== `section-${target}`);
            });
        });
    });

    // --- General: save settings ---
    document.getElementById("save-general")!.addEventListener("click", () => {
        const orgName = (
            document.getElementById("org-name") as HTMLInputElement
        ).value;
        const apiUrl = (document.getElementById("api-url") as HTMLInputElement)
            .value;
        const adminUser = (
            document.getElementById("admin-user") as HTMLInputElement
        ).value;

        localStorage.setItem("aspm_org_name", orgName);
        localStorage.setItem("aspm_api_url", apiUrl);
        localStorage.setItem("aspm_admin_user", adminUser);

        const msg = document.getElementById("save-general-msg")!;
        msg.textContent = "✓ Settings saved.";
        msg.className = "text-xs font-medium text-secondary";
        msg.classList.remove("hidden");
        setTimeout(() => msg.classList.add("hidden"), 3000);
    });

    // Load saved general settings
    const savedOrg = localStorage.getItem("aspm_org_name");
    const savedUrl = localStorage.getItem("aspm_api_url");
    const savedUser = localStorage.getItem("aspm_admin_user");
    if (savedOrg)
        (document.getElementById("org-name") as HTMLInputElement).value =
            savedOrg;
    if (savedUrl)
        (document.getElementById("api-url") as HTMLInputElement).value =
            savedUrl;
    if (savedUser)
        (document.getElementById("admin-user") as HTMLInputElement).value =
            savedUser;

    function setToggleState(btn: HTMLButtonElement, enabled: boolean) {
        btn.setAttribute("aria-pressed", String(enabled));
        btn.className = `toggle-btn relative w-10 h-5 rounded-full transition-all ${enabled ? "bg-cyan-500" : "bg-slate-700"}`;
        const dot = btn.querySelector("span") as HTMLElement;
        dot.className = `absolute top-0.5 w-4 h-4 bg-white rounded-full transition-all ${enabled ? "right-0.5" : "left-0.5"}`;
    }

    import { api } from "../../lib/api";

    document
        .getElementById("danger-logout")!
        .addEventListener("click", async () => {
            try {
                await api.logout();
            } finally {
                window.location.href = "/login";
            }
        });

    document
        .getElementById("danger-clear")!
        .addEventListener("click", async () => {
            if (!confirm("Clear all locally stored settings?")) return;

            try {
                await api.logout();
            } catch {}

            [
                "aspm_org_name",
                "aspm_api_url",
                "aspm_admin_user",
                "aspm_webhooks",
            ].forEach((k) => localStorage.removeItem(k));
            window.location.href = "/login";
        });

    // ---------- Users ----------
    type User = Awaited<ReturnType<typeof api.getUsers>>[number];
    type Team = Awaited<ReturnType<typeof api.getTeams>>[number];
    type NotificationSettings = Awaited<
        ReturnType<typeof api.getNotificationSettings>
    >;

    async function loadNotificationSettings() {
        try {
            const settings = await api.getNotificationSettings();
            (
                document.getElementById(
                    "email-recipients",
                ) as HTMLTextAreaElement
            ).value = (settings.email_recipients ?? []).join(", ");
            document
                .querySelectorAll<HTMLButtonElement>(".toggle-btn")
                .forEach((btn) => {
                    const key = btn.dataset
                        .notificationKey as keyof NotificationSettings;
                    if (!key) return;
                    setToggleState(btn, Boolean(settings[key]));
                });
        } catch (e: any) {
            const msg = document.getElementById("notification-msg")!;
            msg.textContent =
                e.message ?? "Failed to load notification settings.";
            msg.className = "text-xs text-error";
            msg.classList.remove("hidden");
        }
    }

    document
        .getElementById("save-email-recipients")!
        .addEventListener("click", async () => {
            const btn = document.getElementById(
                "save-email-recipients",
            ) as HTMLButtonElement;
            const msg = document.getElementById("recipients-msg")!;
            const raw = (
                document.getElementById(
                    "email-recipients",
                ) as HTMLTextAreaElement
            ).value;
            const email_recipients = raw
                .split(",")
                .map((v) => v.trim())
                .filter(Boolean);

            btn.disabled = true;
            msg.classList.add("hidden");

            try {
                const settings = await api.updateNotificationSettings({
                    email_recipients,
                });
                (
                    document.getElementById(
                        "email-recipients",
                    ) as HTMLTextAreaElement
                ).value = (settings.email_recipients ?? []).join(", ");
                msg.textContent = "Recipients saved.";
                msg.className = "text-xs text-secondary";
                msg.classList.remove("hidden");
            } catch (e: any) {
                msg.textContent = e.message ?? "Failed to save recipients.";
                msg.className = "text-xs text-error";
                msg.classList.remove("hidden");
            } finally {
                btn.disabled = false;
            }
        });

    document
        .querySelectorAll<HTMLButtonElement>(".toggle-btn")
        .forEach((btn) => {
            btn.addEventListener("click", async () => {
                const key = btn.dataset.notificationKey;
                if (!key) return;
                const next = btn.getAttribute("aria-pressed") !== "true";
                btn.disabled = true;
                try {
                    const settings = await api.updateNotificationSettings({
                        [key]: next,
                    } as Partial<NotificationSettings>);
                    setToggleState(btn, Boolean((settings as any)[key]));
                    const msg = document.getElementById("notification-msg")!;
                    msg.textContent = "Notification preferences saved.";
                    msg.className = "text-xs text-secondary";
                    msg.classList.remove("hidden");
                } catch (e: any) {
                    const msg = document.getElementById("notification-msg")!;
                    msg.textContent =
                        e.message ?? "Failed to save notification settings.";
                    msg.className = "text-xs text-error";
                    msg.classList.remove("hidden");
                } finally {
                    btn.disabled = false;
                }
            });
        });

    document
        .getElementById("test-email-btn")!
        .addEventListener("click", async () => {
            const btn = document.getElementById(
                "test-email-btn",
            ) as HTMLButtonElement;
            const msg = document.getElementById("notification-msg")!;
            btn.disabled = true;
            btn.textContent = "Sending...";
            msg.classList.add("hidden");

            try {
                const result = await api.testNotificationEmail();
                msg.textContent = result.message ?? "Test email queued.";
                msg.className = "text-xs text-secondary";
                msg.classList.remove("hidden");
            } catch (e: any) {
                msg.textContent = e.message ?? "Failed to queue test email.";
                msg.className = "text-xs text-error";
                msg.classList.remove("hidden");
            } finally {
                btn.disabled = false;
                btn.textContent = "Send test email";
            }
        });

    async function loadJiraIntegration() {
        try {
            const integration = await api.getJiraIntegration();
            (
                document.getElementById("jira-base-url") as HTMLInputElement
            ).value = integration.base_url ?? "";
            (
                document.getElementById("jira-user-email") as HTMLInputElement
            ).value = integration.user_email ?? "";
            (
                document.getElementById("jira-project-key") as HTMLInputElement
            ).value = integration.project_key ?? "";
            (
                document.getElementById("jira-issue-type") as HTMLInputElement
            ).value = integration.issue_type ?? "Task";
            (document.getElementById("jira-labels") as HTMLInputElement).value =
                (integration.labels ?? []).join(", ");
            (
                document.getElementById("jira-enabled") as HTMLInputElement
            ).checked = integration.enabled;
            document.getElementById("jira-token-state")!.textContent =
                integration.has_token
                    ? `Saved token: ${integration.token_masked ?? "configured"}`
                    : "No token saved yet.";
        } catch (e: any) {
            const msg = document.getElementById("jira-msg")!;
            msg.textContent = e.message ?? "Failed to load Jira integration.";
            msg.className = "text-xs text-error";
            msg.classList.remove("hidden");
        }
    }

    document
        .getElementById("save-jira")!
        .addEventListener("click", async () => {
            const btn = document.getElementById(
                "save-jira",
            ) as HTMLButtonElement;
            const msg = document.getElementById("jira-msg")!;
            btn.disabled = true;
            msg.classList.add("hidden");

            try {
                const tokenInput = (
                    document.getElementById(
                        "jira-api-token",
                    ) as HTMLInputElement
                ).value.trim();
                const integration = await api.updateJiraIntegration({
                    base_url: (
                        document.getElementById(
                            "jira-base-url",
                        ) as HTMLInputElement
                    ).value.trim(),
                    user_email: (
                        document.getElementById(
                            "jira-user-email",
                        ) as HTMLInputElement
                    ).value.trim(),
                    project_key: (
                        document.getElementById(
                            "jira-project-key",
                        ) as HTMLInputElement
                    ).value.trim(),
                    issue_type:
                        (
                            document.getElementById(
                                "jira-issue-type",
                            ) as HTMLInputElement
                        ).value.trim() || "Task",
                    labels: (
                        document.getElementById(
                            "jira-labels",
                        ) as HTMLInputElement
                    ).value
                        .split(",")
                        .map((value) => value.trim())
                        .filter(Boolean),
                    enabled: (
                        document.getElementById(
                            "jira-enabled",
                        ) as HTMLInputElement
                    ).checked,
                    ...(tokenInput ? { token: tokenInput } : {}),
                });
                (
                    document.getElementById(
                        "jira-api-token",
                    ) as HTMLInputElement
                ).value = "";
                document.getElementById("jira-token-state")!.textContent =
                    integration.has_token
                        ? `Saved token: ${integration.token_masked ?? "configured"}`
                        : "No token saved yet.";
                msg.textContent = "Jira integration saved.";
                msg.className = "text-xs text-secondary";
                msg.classList.remove("hidden");
            } catch (e: any) {
                msg.textContent =
                    e.message ?? "Failed to save Jira integration.";
                msg.className = "text-xs text-error";
                msg.classList.remove("hidden");
            } finally {
                btn.disabled = false;
            }
        });

    let allUsers: User[] = [];

    function roleChip(role: string) {
        const cls =
            role === "admin"
                ? "text-red-400 bg-red-500/10 border-red-500/20"
                : role === "analyst"
                  ? "text-cyan-400 bg-cyan-500/10 border-cyan-500/20"
                  : "text-slate-400 bg-slate-500/10 border-slate-500/20";
        return `<span class="text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded border ${cls}">${role}</span>`;
    }

    async function loadUsers() {
        try {
            allUsers = await api.getUsers();
        } catch {
            allUsers = [];
        }

        const el = document.getElementById("user-list")!;
        if (!allUsers.length) {
            el.innerHTML =
                '<p class="text-xs text-slate-500">No users found.</p>';
            return;
        }
        el.innerHTML = `
      <div class="bg-surface-container border border-outline-variant/20 rounded-xl overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-outline-variant/20 text-left">
              <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500">User</th>
              <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500">Email</th>
              <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500">Role</th>
              <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500">Last Login</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody>
            ${allUsers
                .map(
                    (u) => `
              <tr class="border-b border-outline-variant/10 hover:bg-slate-900/30 transition-colors" data-user-id="${u.id}">
                <td class="px-4 py-3">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-cyan-500/20 border border-cyan-500/20 flex items-center justify-center text-cyan-400 text-xs font-bold">
                      ${u.username.slice(0, 2).toUpperCase()}
                    </div>
                    <span class="font-semibold text-on-background">${u.username}</span>
                  </div>
                </td>
                <td class="px-4 py-3 text-slate-400 text-xs font-mono">${u.email}</td>
                <td class="px-4 py-3">${roleChip(u.role)}</td>
                <td class="px-4 py-3 text-xs text-slate-500">${u.last_login ? new Date(u.last_login).toLocaleDateString() : "—"}</td>
                <td class="px-4 py-3 text-right">
                  <select class="role-change-select bg-slate-950 border border-slate-800 rounded px-2 py-1 text-xs text-on-background mr-2" data-uid="${u.id}">
                    <option value="analyst" ${u.role === "analyst" ? "selected" : ""}>Analyst</option>
                    <option value="viewer"  ${u.role === "viewer" ? "selected" : ""}>Viewer</option>
                    <option value="admin"   ${u.role === "admin" ? "selected" : ""}>Admin</option>
                  </select>
                  <button class="delete-user-btn text-slate-600 hover:text-error transition-colors" data-uid="${u.id}">
                    <span class="material-symbols-outlined text-sm">delete</span>
                  </button>
                </td>
              </tr>
            `,
                )
                .join("")}
          </tbody>
        </table>
      </div>`;

        el.querySelectorAll<HTMLSelectElement>(".role-change-select").forEach(
            (sel) => {
                sel.addEventListener("change", async () => {
                    try {
                        await api.updateUser(sel.dataset.uid!, {
                            role: sel.value,
                        });
                        await loadUsers();
                    } catch (e: any) {
                        alert(e.message);
                    }
                });
            },
        );

        el.querySelectorAll<HTMLButtonElement>(".delete-user-btn").forEach(
            (btn) => {
                btn.addEventListener("click", async () => {
                    if (!confirm("Delete this user?")) return;
                    try {
                        await api.deleteUser(btn.dataset.uid!);
                        await loadUsers();
                    } catch (e: any) {
                        alert(e.message);
                    }
                });
            },
        );
    }

    document
        .getElementById("show-create-user")!
        .addEventListener("click", () => {
            document
                .getElementById("create-user-form")!
                .classList.remove("hidden");
        });
    document
        .getElementById("cancel-create-user")!
        .addEventListener("click", () => {
            document
                .getElementById("create-user-form")!
                .classList.add("hidden");
        });
    document
        .getElementById("save-new-user")!
        .addEventListener("click", async () => {
            const username = (
                document.getElementById("new-username") as HTMLInputElement
            ).value.trim();
            const email = (
                document.getElementById("new-email") as HTMLInputElement
            ).value.trim();
            const password = (
                document.getElementById("new-password") as HTMLInputElement
            ).value;
            const role = (
                document.getElementById("new-role") as HTMLSelectElement
            ).value;
            const msg = document.getElementById("create-user-msg")!;
            try {
                await api.createUser(username, email, password, role);
                msg.textContent = "✓ User created.";
                msg.className = "text-xs font-medium text-secondary";
                msg.classList.remove("hidden");
                document
                    .getElementById("create-user-form")!
                    .classList.add("hidden");
                await loadUsers();
            } catch (e: any) {
                msg.textContent = e.message;
                msg.className = "text-xs font-medium text-error";
                msg.classList.remove("hidden");
            }
            setTimeout(() => msg.classList.add("hidden"), 4000);
        });

    // ---------- Teams ----------
    let allTeams: Team[] = [];

    async function loadTeams() {
        try {
            allTeams = await api.getTeams();
        } catch {
            allTeams = [];
        }

        const el = document.getElementById("team-list")!;
        if (!allTeams.length) {
            el.innerHTML =
                '<p class="text-xs text-slate-500">No teams yet.</p>';
            return;
        }
        el.innerHTML = allTeams
            .map(
                (t) => `
      <div class="bg-surface-container border border-outline-variant/20 rounded-xl p-5 space-y-4" data-team-id="${t.id}">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-lg bg-purple-500/10 border border-purple-500/20 flex items-center justify-center">
              <span class="material-symbols-outlined text-purple-400 text-lg">groups</span>
            </div>
            <div>
              <p class="font-bold text-on-background">${t.name}</p>
              <p class="text-xs text-slate-500">${t.members.length} member${t.members.length !== 1 ? "s" : ""}</p>
            </div>
          </div>
          <button class="delete-team-btn text-slate-600 hover:text-error transition-colors" data-tid="${t.id}">
            <span class="material-symbols-outlined text-sm">delete</span>
          </button>
        </div>

        ${
            t.members.length > 0
                ? `
        <div class="flex flex-wrap gap-2">
          ${t.members
              .map(
                  (m) => `
            <div class="flex items-center gap-2 bg-slate-950 border border-slate-800 rounded-full px-3 py-1">
              <div class="w-5 h-5 rounded-full bg-cyan-500/20 flex items-center justify-center text-cyan-400 text-[9px] font-bold">
                ${m.username.slice(0, 2).toUpperCase()}
              </div>
              <span class="text-xs text-on-background">${m.username}</span>
              <button class="remove-member-btn text-slate-600 hover:text-error transition-colors ml-1" data-tid="${t.id}" data-uid="${m.id}">
                <span class="material-symbols-outlined text-xs">close</span>
              </button>
            </div>
          `,
              )
              .join("")}
        </div>`
                : ""
        }

        <div class="flex gap-2 pt-1">
          <select class="add-member-select flex-1 bg-slate-950 border border-slate-800 rounded-lg px-3 py-1.5 text-xs text-on-background focus:ring-1 focus:ring-cyan-500 outline-none" data-tid="${t.id}">
            <option value="">— Add member —</option>
            ${allUsers
                .filter((u) => !t.members.find((m) => m.id === u.id))
                .map(
                    (u) =>
                        `<option value="${u.id}">${u.username} (${u.role})</option>`,
                )
                .join("")}
          </select>
          <button class="add-member-btn px-3 py-1.5 bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 rounded-lg text-xs font-bold hover:bg-cyan-500/20 transition-all" data-tid="${t.id}">
            Add
          </button>
        </div>
      </div>
    `,
            )
            .join("");

        el.querySelectorAll<HTMLButtonElement>(".delete-team-btn").forEach(
            (btn) => {
                btn.addEventListener("click", async () => {
                    if (!confirm("Delete this team?")) return;
                    await api.deleteTeam(btn.dataset.tid!);
                    await loadTeams();
                });
            },
        );

        el.querySelectorAll<HTMLButtonElement>(".remove-member-btn").forEach(
            (btn) => {
                btn.addEventListener("click", async () => {
                    await api.removeTeamMember(
                        btn.dataset.tid!,
                        btn.dataset.uid!,
                    );
                    await loadTeams();
                });
            },
        );

        el.querySelectorAll<HTMLButtonElement>(".add-member-btn").forEach(
            (btn) => {
                btn.addEventListener("click", async () => {
                    const sel = el.querySelector<HTMLSelectElement>(
                        `.add-member-select[data-tid="${btn.dataset.tid}"]`,
                    )!;
                    if (!sel.value) return;
                    await api.addTeamMember(btn.dataset.tid!, sel.value);
                    await loadTeams();
                });
            },
        );
    }

    document
        .getElementById("show-create-team")!
        .addEventListener("click", () => {
            document
                .getElementById("create-team-form")!
