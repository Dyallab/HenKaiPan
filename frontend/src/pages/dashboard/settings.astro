                msg.className = "text-xs font-medium text-error";
                msg.classList.remove("hidden");
            }
        });

    async function loadPolicies() {
        const el = document.getElementById("policy-list")!;
        let policies: Policy[] = [];
        try {
            policies = await api.getPolicies();
        } catch {
            policies = [];
        }

        if (!policies.length) {
            el.innerHTML =
                '<p class="text-xs text-slate-500">No policies configured.</p>';
            return;
        }
        el.innerHTML = policies
            .map(
                (p) => `
      <div class="bg-surface-container border border-outline-variant/20 rounded-xl p-5 space-y-3" data-policy-id="${p.id}">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-cyan-400 text-base">policy</span>
            </div>
            <div>
              <p class="font-bold text-sm text-on-background">${p.name}</p>
              <p class="text-[10px] text-slate-500">${p.conditions.length} condition${p.conditions.length !== 1 ? "s" : ""} · ${p.actions.length} action${p.actions.length !== 1 ? "s" : ""}</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <button
              class="toggle-policy-btn relative w-10 h-5 rounded-full transition-all ${p.enabled ? "bg-cyan-500" : "bg-slate-700"}"
              aria-pressed="${p.enabled}" data-pid="${p.id}">
              <span class="absolute top-0.5 w-4 h-4 bg-white rounded-full transition-all ${p.enabled ? "right-0.5" : "left-0.5"}"></span>
            </button>
            <button class="delete-policy-btn text-slate-600 hover:text-error transition-colors" data-pid="${p.id}">
              <span class="material-symbols-outlined text-sm">delete</span>
            </button>
          </div>
        </div>
        ${
            p.conditions.length
                ? `
        <div class="flex flex-wrap gap-1.5">
          ${p.conditions.map((c) => `<span class="text-[10px] font-mono bg-slate-900 border border-slate-800 rounded px-2 py-0.5 text-slate-300">${c.field} ${c.op} "${c.value}"</span>`).join("")}
        </div>`
                : ""
        }
        ${
            p.actions.length
                ? `
        <div class="flex flex-wrap gap-1.5">
          ${p.actions.map((a) => `<span class="text-[10px] font-mono bg-cyan-500/10 border border-cyan-500/20 rounded px-2 py-0.5 text-cyan-300">${a.type} → "${a.value}"</span>`).join("")}
        </div>`
                : ""
        }
      </div>
    `,
            )
            .join("");

        el.querySelectorAll<HTMLButtonElement>(".toggle-policy-btn").forEach(
            (btn) => {
                btn.addEventListener("click", async () => {
                    const enabled = btn.getAttribute("aria-pressed") !== "true";
                    await api.updatePolicy(btn.dataset.pid!, enabled);
                    await loadPolicies();
                });
            },
        );
        el.querySelectorAll<HTMLButtonElement>(".delete-policy-btn").forEach(
            (btn) => {
                btn.addEventListener("click", async () => {
                    if (!confirm("Delete this policy?")) return;
                    await api.deletePolicy(btn.dataset.pid!);
                    await loadPolicies();
                });
            },
        );
    }

