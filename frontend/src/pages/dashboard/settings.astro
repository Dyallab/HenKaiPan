---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Settings" active="settings">
    <div class="flex gap-8 h-full">
        <!-- Settings nav -->
        <aside class="w-56 shrink-0">
            <p
                class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-4 px-2"
            >
                Configuration
            </p>
            <nav class="space-y-1">
                {
                    [
                        {
                            id: "general",
                            label: "General",
                            icon: "manage_accounts",
                        },
                        {
                            id: "integrations",
                            label: "Integrations",
                            icon: "integration_instructions",
                        },
                        {
                            id: "notifications",
                            label: "Notifications",
                            icon: "notifications_active",
                        },
                        {
                            id: "security",
                            label: "Security",
                            icon: "shield_lock",
                        },
                        {
                            id: "tokens",
                            label: "API Tokens",
                            icon: "vpn_key",
                        },
                        { id: "users", label: "Users", icon: "group" },
                        { id: "teams", label: "Teams", icon: "groups" },
                        { id: "policies", label: "Policies", icon: "policy" },
                        {
                            id: "suppressions",
                            label: "Suppressions",
                            icon: "do_not_disturb_on",
                        },
                        { id: "license", label: "License", icon: "badge" },
                    ].map((s) => (
                        <button
                            data-section={s.id}
                            class={`settings-nav w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-semibold text-left transition-all ${
                                s.id === "general"
                                    ? "bg-cyan-500/10 text-cyan-400"
                                    : "text-slate-400 hover:bg-slate-900 hover:text-slate-200"
                            }`}
                        >
                            <span class="material-symbols-outlined text-xl">
                                {s.icon}
                            </span>
                            {s.label}
                        </button>
                    ))
                }
            </nav>
        </aside>

        <!-- Content -->
        <div class="flex-1 min-w-0 space-y-10">
            <!-- General -->
            <section id="section-general" class="settings-section space-y-6">
                <div class="border-b border-slate-800 pb-4">
                    <h2 class="text-xl font-bold text-on-background">
                        General Settings
                    </h2>
                    <p class="text-sm text-slate-400 mt-1">
                        Platform identity and API configuration.
                    </p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <div class="col-span-2 space-y-5">
                        <div
                            class="bg-surface-container border border-outline-variant/20 rounded-xl p-6 space-y-5"
                        >
                            <div class="space-y-2">
                                <label
                                    class="block text-[10px] font-bold uppercase tracking-widest text-slate-500"
                                    >Platform Name</label
                                >
                                <input
                                    id="org-name"
                                    type="text"
                                    value="HenKaiPan — Security Posture Manager"
                                    class="w-full bg-slate-950 border border-slate-800 rounded-lg px-4 py-2.5 text-on-background text-sm focus:ring-2 focus:ring-cyan-500 outline-none transition-all"
                                />
                            </div>
                            <div class="space-y-2">
                                <label
                                    class="block text-[10px] font-bold uppercase tracking-widest text-slate-500"
                                    >API Base URL</label
                                >
                                <input
                                    id="api-url"
                                    type="text"
                                    value="http://localhost:8080"
                                    class="w-full bg-slate-950 border border-slate-800 rounded-lg px-4 py-2.5 text-on-background text-sm focus:ring-2 focus:ring-cyan-500 outline-none font-mono transition-all"
                                />
                            </div>
                            <div class="space-y-2">
                                <label
                                    class="block text-[10px] font-bold uppercase tracking-widest text-slate-500"
                                    >Admin Username</label
                                >
                                <input
                                    id="admin-user"
                                    type="text"
                                    value="admin"
                                    class="w-full bg-slate-950 border border-slate-800 rounded-lg px-4 py-2.5 text-on-background text-sm focus:ring-2 focus:ring-cyan-500 outline-none transition-all"
                                />
                            </div>
                        </div>
                        <button
                            id="save-general"
                            class="bg-cyan-500 hover:bg-cyan-400 text-slate-950 font-bold px-6 py-2.5 rounded-lg text-sm transition-all active:scale-95"
                        >
                            Save Changes
                        </button>
                        <div
                            id="save-general-msg"
                            class="hidden text-xs font-medium"
                        >
                        </div>
                    </div>
                    <div class="space-y-4">
                        <div
                            class="bg-surface-container border border-outline-variant/20 rounded-xl p-6 text-center space-y-4"
                        >
                            <div
                                class="w-20 h-20 rounded-xl mx-auto bg-cyan-500 flex items-center justify-center"
                            >
                                <span
                                    class="material-symbols-outlined ms-fill text-slate-950 text-4xl"
                                    >security</span
                                >
                            </div>
                            <div>
                                <h4 class="font-bold text-on-background">
                                    Hen Kai Pan
                                </h4>
                                <p class="text-xs text-slate-500 mt-1">
                                    Application Security Posture Manager
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Integrations -->
            <section
                id="section-integrations"
                class="settings-section hidden space-y-6"
            >
                <div class="border-b border-slate-800 pb-4">
                    <h2 class="text-xl font-bold text-on-background">
                        Integrations
                    </h2>
                    <p class="text-sm text-slate-400 mt-1">
                        Scanner availability and external service connections.
                    </p>
                </div>

                <!-- Scanner status -->
                <div>
                    <p
                        class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-4"
                    >
                        Available Scanners
                    </p>
                    <div
                        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"
                    >
                        {
                            [
                                {
                                    name: "semgrep",
                                    label: "Semgrep",
                                    type: "SAST",
                                    icon: "code",
                                    color: "text-cyan-400",
                                    desc: "Static analysis for 30+ languages.",
                                },
                                {
                                    name: "trivy",
                                    label: "Trivy",
                                    type: "SCA",
                                    icon: "inventory_2",
                                    color: "text-purple-400",
                                    desc: "CVEs in dependencies and containers.",
                                },
                                {
                                    name: "trufflehog",
                                    label: "TruffleHog",
                                    type: "Secrets",
                                    icon: "key",
                                    color: "text-amber-400",
                                    desc: "Leaked credentials and API keys.",
                                },
                                {
                                    name: "gosec",
                                    label: "Gosec",
                                    type: "SAST",
                                    icon: "code",
                                    color: "text-cyan-400",
                                    desc: "Go security checker.",
                                },
                                {
                                    name: "gitleaks",
                                    label: "Gitleaks",
                                    type: "Secrets",
                                    icon: "key",
                                    color: "text-amber-400",
                                    desc: "Secret detection in git history.",
                                },
                                {
                                    name: "grype",
                                    label: "Grype",
                                    type: "SCA",
                                    icon: "inventory_2",
                                    color: "text-purple-400",
                                    desc: "Vulnerability scanner for container images.",
                                },
                                {
                                    name: "checkov",
                                    label: "Checkov",
                                    type: "IaC",
                                    icon: "cloud",
                                    color: "text-green-400",
                                    desc: "Terraform, CloudFormation, Kubernetes.",
                                },
                                {
                                    name: "nuclei",
                                    label: "Nuclei",
                                    type: "DAST",
                                    icon: "language",
                                    color: "text-orange-400",
                                    desc: "Fast web vulnerability scanner.",
                                },
                            ].map((s) => (
                                <div class="bg-surface-container border border-outline-variant/20 rounded-xl p-5 flex flex-col gap-3 hover:border-cyan-500/30 transition-all">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 bg-surface-container-lowest rounded-lg border border-outline-variant/20 flex items-center justify-center shrink-0">
                                            <span
                                                class={`material-symbols-outlined text-xl ${s.color}`}
                                            >
                                                {s.icon}
                                            </span>
                                        </div>
                                        <div class="min-w-0">
                                            <p class="font-bold text-sm text-on-background">
                                                {s.label}
                                            </p>
                                            <span
                                                class={`text-[10px] font-bold uppercase tracking-wider px-1.5 py-0.5 rounded border ${
                                                    s.type === "SAST"
                                                        ? "text-cyan-400 bg-cyan-500/10 border-cyan-500/20"
                                                        : s.type === "SCA"
                                                          ? "text-purple-400 bg-purple-500/10 border-purple-500/20"
                                                          : s.type === "Secrets"
                                                            ? "text-amber-400 bg-amber-500/10 border-amber-500/20"
                                                            : s.type === "IaC"
                                                              ? "text-green-400 bg-green-500/10 border-green-500/20"
                                                              : "text-orange-400 bg-orange-500/10 border-orange-500/20"
                                                }`}
                                            >
                                                {s.type}
                                            </span>
                                        </div>
                                    </div>
                                    <p class="text-xs text-slate-500 leading-relaxed">
                                        {s.desc}
                                    </p>
                                    <div class="flex items-center gap-2 mt-auto pt-2">
                                        <div class="w-1.5 h-1.5 rounded-full bg-secondary shadow-[0_0_6px_rgba(78,222,163,0.5)]" />
                                        <span class="font-mono text-[10px] text-slate-600 ml-auto">
                                            {s.name}
                                        </span>
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>

                <div>
                    <p
                        class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-4"
                    >
                        Jira Cloud
                    </p>
                    <div
                        class="bg-surface-container border border-outline-variant/20 rounded-xl p-6 space-y-4"
                    >
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="space-y-2 md:col-span-2">
                                <label
                                    class="block text-[10px] font-bold uppercase tracking-widest text-slate-500"
                                    >Base URL</label
                                >
                                <input
                                    id="jira-base-url"
                                    type="url"
                                    placeholder="https://your-team.atlassian.net"
                                    class="w-full bg-slate-950 border border-slate-800 rounded-lg px-4 py-2.5 text-on-background text-sm focus:ring-2 focus:ring-cyan-500 outline-none font-mono transition-all"
                                />
                            </div>
                            <div class="space-y-2">
                                <label
                                    class="block text-[10px] font-bold uppercase tracking-widest text-slate-500"
                                    >User Email</label
                                >
                                <input
                                    id="jira-user-email"
                                    type="email"
                                    placeholder="security@company.com"
                                    class="w-full bg-slate-950 border border-slate-800 rounded-lg px-4 py-2.5 text-on-background text-sm focus:ring-2 focus:ring-cyan-500 outline-none transition-all"
                                />
                            </div>
                            <div class="space-y-2">
                                <label
                                    class="block text-[10px] font-bold uppercase tracking-widest text-slate-500"
                                    >API Token</label
                                >
                                <input
                                    id="jira-api-token"
                                    type="password"
                                    placeholder="Atlassian API token"
                                    class="w-full bg-slate-950 border border-slate-800 rounded-lg px-4 py-2.5 text-on-background text-sm focus:ring-2 focus:ring-cyan-500 outline-none font-mono transition-all"
                                />
                            </div>
                            <div class="space-y-2">
                                <label
                                    class="block text-[10px] font-bold uppercase tracking-widest text-slate-500"
                                    >Project Key</label
                                >
                                <input
                                    id="jira-project-key"
                                    type="text"
                                    placeholder="SEC"
                                    class="w-full bg-slate-950 border border-slate-800 rounded-lg px-4 py-2.5 text-on-background text-sm focus:ring-2 focus:ring-cyan-500 outline-none font-mono transition-all"
                                />
                            </div>
                            <div class="space-y-2">
                                <label
                                    class="block text-[10px] font-bold uppercase tracking-widest text-slate-500"
                                    >Issue Type</label
                                >
                                <input
                                    id="jira-issue-type"
                                    type="text"
                                    placeholder="Task"
                                    class="w-full bg-slate-950 border border-slate-800 rounded-lg px-4 py-2.5 text-on-background text-sm focus:ring-2 focus:ring-cyan-500 outline-none transition-all"
                                />
                            </div>
                            <div class="space-y-2 md:col-span-2">
                                <label
                                    class="block text-[10px] font-bold uppercase tracking-widest text-slate-500"
                                    >Default Labels</label
                                >
                                <input
                                    id="jira-labels"
                                    type="text"
                                    placeholder="security, aspm, backlog"
                                    class="w-full bg-slate-950 border border-slate-800 rounded-lg px-4 py-2.5 text-on-background text-sm focus:ring-2 focus:ring-cyan-500 outline-none transition-all"
                                />
                                <p class="text-xs text-slate-500">
                                    Comma-separated labels added when creating
                                    tickets from findings.
                                </p>
                            </div>
                        </div>

                        <label class="flex items-start gap-3 cursor-pointer">
                            <input
                                id="jira-enabled"
                                type="checkbox"
                                class="mt-1 rounded border-slate-600 bg-surface-container text-cyan-400 focus:ring-0 cursor-pointer"
                            />
                            <div>
                                <p
                                    class="text-sm text-on-background font-medium"
                                >
                                    Enable Jira ticket creation
                                </p>
                                <p
                                    id="jira-token-state"
                                    class="text-xs text-slate-500 mt-1"
                                >
                                    No token saved yet.
                                </p>
                            </div>
                        </label>

                        <div class="flex items-center gap-3">
                            <button
                                id="save-jira"
                                class="px-4 py-2.5 bg-cyan-500 hover:bg-cyan-400 text-slate-950 rounded-lg font-bold text-sm transition-all active:scale-95"
                                >Save Jira Integration</button
                            >
                            <p id="jira-msg" class="text-xs hidden"></p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Notifications -->
            <section
                id="section-notifications"
                class="settings-section hidden space-y-6"
            >
                <div class="border-b border-slate-800 pb-4">
                    <h2 class="text-xl font-bold text-on-background">
                        Notifications & Webhooks
                    </h2>
                    <p class="text-sm text-slate-400 mt-1">
                        Configure scan completion alerts and external service
                        hooks.
                    </p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Alert toggles -->
                    <div
                        class="bg-surface-container border border-outline-variant/20 rounded-xl p-6 space-y-5"
                    >
                        <h4
                            class="font-bold text-on-background flex items-center gap-2"
                        >
                            <span
                                class="material-symbols-outlined text-cyan-400 text-xl"
                                >mail</span
                            >
                            Alert Preferences
                        </h4>
                        <div class="space-y-4">
                            {
                                [
                                    {
                                        id: "alert-critical",
                                        key: "alert_critical",
                                        label: "Critical Findings",
                                        sub: "Alert on any critical severity detection",
                                        default: true,
                                    },
                                    {
                                        id: "alert-high",
                                        key: "alert_high",
                                        label: "High Findings",
                                        sub: "Alert on high severity findings",
                                        default: true,
                                    },
                                    {
                                        id: "alert-complete",
                                        key: "alert_scan_complete",
                                        label: "Scan Completed",
                                        sub: "Notify when a scan finishes",
                                        default: true,
                                    },
                                    {
                                        id: "alert-failed",
                                        key: "alert_scan_failed",
                                        label: "Scan Failed",
                                        sub: "Notify when a scan encounters an error",
                                        default: true,
                                    },
                                    {
                                        id: "alert-sla-breach",
                                        key: "alert_sla_breach",
                                        label: "SLA Breaches",
                                        sub: "Notify when open findings exceed their SLA deadline",
                                        default: true,
                                    },
                                ].map((a) => (
                                    <div class="flex items-center justify-between">
                                        <div>
                                            <p class="text-sm font-semibold text-on-background">
                                                {a.label}
                                            </p>
                                            <p class="text-xs text-slate-500">
                                                {a.sub}
                                            </p>
                                        </div>
                                        <button
                                            data-toggle={a.id}
                                            data-notification-key={a.key}
                                            class={`toggle-btn relative w-10 h-5 rounded-full transition-all ${a.default ? "bg-cyan-500" : "bg-slate-700"}`}
                                            aria-pressed={String(a.default)}
                                        >
                                            <span
                                                class={`absolute top-0.5 w-4 h-4 bg-white rounded-full transition-all ${a.default ? "right-0.5" : "left-0.5"}`}
                                            />
                                        </button>
                                    </div>
                                ))
                            }
                        </div>
                        <div
                            class="space-y-3 rounded-xl border border-outline-variant/20 bg-slate-950/40 p-4"
                        >
                            <div>
                                <p
                                    class="text-sm font-semibold text-on-background"
                                >
                                    Email recipients
                                </p>
                                <p class="text-xs text-slate-500">
                                    Comma-separated emails stored in DB. Prod
                                    source of truth.
                                </p>
                            </div>
                            <textarea
                                id="email-recipients"
                                rows="3"
                                placeholder="alice@company.com, bob@company.com"
                                class="w-full bg-slate-950 border border-slate-800 rounded-lg px-3 py-2 text-xs text-on-background font-mono focus:ring-1 focus:ring-cyan-500 outline-none"
                            ></textarea>
                            <div class="flex items-center gap-3">
                                <button
                                    id="save-email-recipients"
                                    class="px-3 py-2 bg-cyan-500 hover:bg-cyan-400 text-slate-950 rounded-lg text-xs font-bold transition-all active:scale-95"
                                >
                                    Save recipients
                                </button>
                                <p id="recipients-msg" class="text-xs hidden">
                                </p>
                            </div>
                        </div>
                        <div class="flex items-center gap-3">
                            <button
                                id="test-email-btn"
                                class="px-3 py-2 bg-surface-container-high border border-outline-variant/20 text-on-surface rounded-lg text-xs font-bold hover:bg-slate-800 transition-all"
                            >
                                Send test email
                            </button>
                            <p class="text-[11px] text-slate-500">
                                Sends a message to the configured SMTP
                                recipients.
                            </p>
                        </div>
                        <p id="notification-msg" class="text-xs hidden"></p>
                    </div>

                    <!-- Webhooks -->
                    <div
                        class="bg-surface-container border border-outline-variant/20 rounded-xl p-6 space-y-5"
                    >
                        <div class="flex items-center justify-between">
                            <h4
                                class="font-bold text-on-background flex items-center gap-2"
                            >
                                <span
                                    class="material-symbols-outlined text-secondary text-xl"
                                    >webhook</span
                                >
                                Webhooks
                            </h4>
                            <button
                                id="add-webhook-btn"
                                class="text-xs text-cyan-400 font-bold hover:underline"
                                >+ Add New</button
                            >
                        </div>

                        <div
                            class="rounded-xl border border-cyan-500/15 bg-cyan-500/5 p-4 space-y-3"
                        >
                            <div class="flex items-center gap-2 text-cyan-300">
                                <span
                                    class="material-symbols-outlined text-base"
                                    >info</span
                                >
                                <p
                                    class="text-xs font-bold uppercase tracking-[0.22em]"
                                >
                                    Delivery types
                                </p>
                            </div>
                            <div class="grid gap-3 md:grid-cols-3 text-xs">
                                <div
                                    class="rounded-lg border border-outline-variant/20 bg-slate-950/50 p-3 space-y-1.5"
                                >
                                    <p class="font-semibold text-on-background">
                                        Generic
                                    </p>
                                    <p class="text-slate-500">
                                        Receives the raw JSON envelope with <span
                                            class="font-mono text-slate-300"
                                            >event</span
                                        >, <span
                                            class="font-mono text-slate-300"
                                            >data</span
                                        >, and <span
                                            class="font-mono text-slate-300"
                                            >timestamp</span
                                        >.
                                    </p>
                                </div>
                                <div
                                    class="rounded-lg border border-outline-variant/20 bg-slate-950/50 p-3 space-y-1.5"
                                >
                                    <p class="font-semibold text-on-background">
                                        Slack
                                    </p>
                                    <p class="text-slate-500">
                                        Receives a Slack-compatible message body
                                        with <span
                                            class="font-mono text-slate-300"
                                            >text</span
                                        > and <span
                                            class="font-mono text-slate-300"
                                            >blocks</span
                                        >.
                                    </p>
                                </div>
                                <div
                                    class="rounded-lg border border-outline-variant/20 bg-slate-950/50 p-3 space-y-1.5"
                                >
                                    <p class="font-semibold text-on-background">
                                        Discord
                                    </p>
                                    <p class="text-slate-500">
                                        Receives a Discord-compatible message
                                        with <span
                                            class="font-mono text-slate-300"
                                            >content</span
                                        > and <span
                                            class="font-mono text-slate-300"
                                            >embeds</span
                                        >.
                                    </p>
                                </div>
                            </div>
                            <pre
                                id="generic-webhook-example"
                                class="overflow-auto rounded-lg border border-outline-variant/20 bg-slate-950 px-3 py-3 text-[11px] text-slate-300 font-mono whitespace-pre-wrap">{`{
  "event": "finding.critical",
  "data": { "title": "Hardcoded secret", "severity": "critical" },
  "timestamp": "2026-04-25T04:47:25Z"
}`}</pre>
                        </div>

                        <!-- Add webhook form -->
                        <div
                            id="webhook-form"
                            class="hidden space-y-3 pb-4 border-b border-slate-800"
                        >
                            <input
                                id="webhook-label"
                                type="text"
                                placeholder="Label (e.g. Slack #security)"
                                class="w-full bg-slate-950 border border-slate-800 rounded-lg px-3 py-2 text-xs text-on-background focus:ring-1 focus:ring-cyan-500 outline-none"
                            />
                            <input
                                id="webhook-url"
                                type="url"
                                placeholder="https://hooks.example.com/..."
                                class="w-full bg-slate-950 border border-slate-800 rounded-lg px-3 py-2 text-xs text-on-background font-mono focus:ring-1 focus:ring-cyan-500 outline-none"
                            />
                            <div class="grid gap-3 md:grid-cols-2">
                                <div class="space-y-1.5">
                                    <label
                                        class="block text-[10px] font-bold uppercase tracking-widest text-slate-500"
                                        >Delivery Type</label
                                    >
                                    <select
                                        id="webhook-delivery-type"
                                        class="w-full bg-slate-950 border border-slate-800 rounded-lg px-3 py-2 text-xs text-on-background focus:ring-1 focus:ring-cyan-500 outline-none"
                                    >
                                        <option value="generic"
                                            >Generic JSON</option
                                        >
