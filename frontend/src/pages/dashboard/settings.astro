    // ---------- Webhooks ----------
    import type { Webhook } from "../../lib/api";

    function webhookTypeMeta(type: Webhook["delivery_type"] | string) {
        switch (type) {
            case "slack":
                return {
                    label: "Slack",
                    badge: "text-emerald-300 bg-emerald-500/10 border-emerald-500/20",
                    help: "Slack mode sends a Slack-compatible payload with text and blocks.",
                };
            case "discord":
                return {
                    label: "Discord",
                    badge: "text-indigo-300 bg-indigo-500/10 border-indigo-500/20",
                    help: "Discord mode sends content plus embeds so the webhook can render a native Discord message.",
                };
            default:
                return {
                    label: "Generic JSON",
                    badge: "text-cyan-300 bg-cyan-500/10 border-cyan-500/20",
                    help: "Generic mode posts the raw ASPM event envelope to your endpoint.",
                };
        }
    }

    function refreshWebhookDeliveryHelp() {
        const deliveryType = (
            document.getElementById(
                "webhook-delivery-type",
            ) as HTMLSelectElement
        ).value as Webhook["delivery_type"];
        document.getElementById("webhook-delivery-help")!.textContent =
            webhookTypeMeta(deliveryType).help;
    }

    document
        .getElementById("webhook-delivery-type")!
        .addEventListener("change", refreshWebhookDeliveryHelp);
    refreshWebhookDeliveryHelp();

    document
        .getElementById("add-webhook-btn")!
        .addEventListener("click", () => {
            document.getElementById("webhook-form")!.classList.remove("hidden");
        });
    document.getElementById("cancel-webhook")!.addEventListener("click", () => {
        document.getElementById("webhook-form")!.classList.add("hidden");
    });
    document
        .getElementById("save-webhook")!
        .addEventListener("click", async () => {
            const label = (
                document.getElementById("webhook-label") as HTMLInputElement
            ).value.trim();
            const url = (
                document.getElementById("webhook-url") as HTMLInputElement
            ).value.trim();
            const deliveryType = (
                document.getElementById(
                    "webhook-delivery-type",
                ) as HTMLSelectElement
            ).value as Webhook["delivery_type"];

            if (!label || !url) {
                alert("Label and URL are required");
                return;
            }

            try {
                await api.createWebhook({
                    label,
                    url,
                    delivery_type: deliveryType,
                    events: [
                        "finding.critical",
                        "finding.high",
                        "finding.sla_breach",
                        "scan.completed",
                        "scan.failed",
                    ],
                });
                document
                    .getElementById("webhook-form")!
                    .classList.add("hidden");
                (
                    document.getElementById("webhook-label") as HTMLInputElement
                ).value = "";
                (
                    document.getElementById("webhook-url") as HTMLInputElement
                ).value = "";
                (
                    document.getElementById(
                        "webhook-delivery-type",
                    ) as HTMLSelectElement
                ).value = "generic";
                refreshWebhookDeliveryHelp();
                await loadWebhooks();
            } catch (e: any) {
                alert("Failed to create webhook: " + e.message);
            }
        });

    async function loadWebhooks() {
        const el = document.getElementById("webhook-list");
        if (!el) {
            console.error("webhook-list element not found");
            return;
        }
        let webhooks: Webhook[] = [];
        try {
            console.log("Loading webhooks...");
            webhooks = await api.getWebhooks();
            console.log("Loaded webhooks:", webhooks);
        } catch (e: any) {
            console.error("Failed to load webhooks:", e);
            webhooks = [];
        }

        if (!webhooks.length) {
            el.innerHTML =
                '<p class="text-xs text-slate-500">No webhooks configured.</p>';
            return;
        }
        el.innerHTML = webhooks
            .map(
                (w) => `
      ${(() => {
          const type = webhookTypeMeta(w.delivery_type);
          return `
      <div class="bg-surface-container border border-outline-variant/20 rounded-xl p-5 flex items-center justify-between" data-webhook-id="${w.id}">
        <div class="flex items-center gap-3 min-w-0">
          <div class="w-8 h-8 rounded-lg bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-cyan-400 text-base">webhook</span>
          </div>
          <div class="min-w-0">
            <p class="font-bold text-sm text-on-background">${w.label}</p>
            <p class="text-[10px] text-slate-500 font-mono truncate">${w.url}</p>
            <div class="flex flex-wrap gap-1.5 mt-1">
              <span class="text-[10px] font-bold uppercase tracking-wider rounded border px-2 py-0.5 ${type.badge}">${type.label}</span>
              ${w.events.map((e) => `<span class="text-[10px] font-mono bg-slate-900 border border-slate-800 rounded px-2 py-0.5 text-slate-300">${e}</span>`).join("")}
              ${w.enabled ? `<span class="text-[10px] text-secondary font-bold">● enabled</span>` : `<span class="text-[10px] text-slate-500">○ disabled</span>`}
              <span class="text-[10px] text-slate-500">${w.delivery_count} delivered${w.error_count > 0 ? ` · ${w.error_count} errors` : ""}</span>
            </div>
            <p class="mt-2 text-[11px] text-slate-500">${type.help}</p>
          </div>
        </div>
        <div class="flex items-center gap-2 ml-4 shrink-0">
          <button class="test-webhook-btn text-slate-600 hover:text-cyan-400 transition-colors text-xs font-bold" data-wid="${w.id}">
            Test
          </button>
          <button class="toggle-webhook-btn relative w-10 h-5 rounded-full transition-all ${w.enabled ? "bg-cyan-500" : "bg-slate-700"}" data-wid="${w.id}" aria-pressed="${w.enabled}">
            <span class="absolute top-0.5 w-4 h-4 bg-white rounded-full transition-all ${w.enabled ? "right-0.5" : "left-0.5"}"></span>
          </button>
          <button class="delete-webhook-btn text-slate-600 hover:text-error transition-colors" data-wid="${w.id}">
            <span class="material-symbols-outlined text-sm">delete</span>
          </button>
        </div>
      </div>
    `;
      })()}`,
            )
            .join("");

        el.querySelectorAll<HTMLButtonElement>(".test-webhook-btn").forEach(
            (btn) => {
                btn.addEventListener("click", async () => {
                    btn.disabled = true;
                    btn.textContent = "Sending...";
                    try {
                        const result = await api.testWebhook(btn.dataset.wid!);
                        alert("Test webhook queued successfully!");
                    } catch (e: any) {
                        alert("Failed to test webhook: " + e.message);
                    } finally {
                        btn.disabled = false;
                        btn.textContent = "Test";
                    }
                });
            },
        );
        el.querySelectorAll<HTMLButtonElement>(".toggle-webhook-btn").forEach(
            (btn) => {
                btn.addEventListener("click", async () => {
                    const enabled = btn.getAttribute("aria-pressed") !== "true";
                    await api.updateWebhook(btn.dataset.wid!, { enabled });
                    await loadWebhooks();
                });
            },
        );
        el.querySelectorAll<HTMLButtonElement>(".delete-webhook-btn").forEach(
            (btn) => {
                btn.addEventListener("click", async () => {
                    if (!confirm("Delete this webhook?")) return;
                    await api.deleteWebhook(btn.dataset.wid!);
                    await loadWebhooks();
                });
            },
        );
    }

    async function loadLicense() {
        const statusIcon = document.getElementById("license-status-icon");
        const status = document.getElementById("license-status");
        const message = document.getElementById("license-message");
        const details = document.getElementById("license-details");
        const features = document.getElementById("license-features");

        try {
            const data = await api.get("/api/license");

            if (data.valid) {
                statusIcon.className =
                    "w-12 h-12 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center shrink-0";
                statusIcon.innerHTML =
                    '<span class="material-symbols-outlined text-emerald-500 text-2xl">check_circle</span>';
                status.textContent = "License Active";
                status.className = "font-bold text-emerald-400";
                message.textContent =
                    "Your self-hosted license is valid and active.";

                document.getElementById("license-email").textContent =
                    data.email;
                document.getElementById("license-expires").textContent =
                    new Date(data.expiry).toLocaleDateString();
                details.classList.remove("hidden");

                if (data.features && data.features.length > 0) {
                    features.innerHTML = data.features
                        .map(
                            (f) =>
                                `<span class="text-[10px] font-bold uppercase tracking-wider rounded border border-emerald-500/20 bg-emerald-500/10 px-2 py-0.5 text-emerald-400">${f}</span>`,
                        )
                        .join("");
                    features.classList.remove("hidden");
                }
            } else if (data.status === "expired") {
                statusIcon.className =
                    "w-12 h-12 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center shrink-0";
                statusIcon.innerHTML =
                    '<span class="material-symbols-outlined text-amber-500 text-2xl">error</span>';
                status.textContent = "License Expired";
                status.className = "font-bold text-amber-400";
                message.textContent = data.message;
            } else {
                statusIcon.className =
                    "w-12 h-12 rounded-xl bg-slate-900 border border-slate-800 flex items-center justify-center shrink-0";
                statusIcon.innerHTML =
                    '<span class="material-symbols-outlined text-slate-500 text-2xl">badge</span>';
                status.textContent =
                    data.status === "inactive"
                        ? "No License"
                        : "Invalid License";
                status.className = "font-bold text-slate-300";
                message.textContent =
                    data.message ||
                    "No license key configured. Set LICENSE_KEY environment variable.";
            }
        } catch (e: any) {
            status.textContent = "Failed to load";
            status.className = "font-bold text-rose-400";
            message.textContent = e.message;
        }
    }

    loadNotificationSettings();
    loadJiraIntegration();
    loadLicense();
    loadTokens();
    loadProjectsForToken();

    // --- Token modal handlers ---
    document
        .getElementById("create-token-btn")!
        .addEventListener("click", () => {
            (
                document.getElementById("token-name-input") as HTMLInputElement
            ).value = "";
            (
                document.getElementById(
                    "token-project-select",
                ) as HTMLSelectElement
            ).value = "";
            document
                .getElementById("create-token-modal")!
                .classList.remove("hidden");
        });
    document
        .getElementById("close-token-modal")!
        .addEventListener("click", () => {
            document
                .getElementById("create-token-modal")!
                .classList.add("hidden");
        });
    document
        .getElementById("cancel-token-btn")!
        .addEventListener("click", () => {
            document
                .getElementById("create-token-modal")!
                .classList.add("hidden");
        });
    document
        .getElementById("create-token-overlay")!
        .addEventListener("click", () => {
            document
                .getElementById("create-token-modal")!
                .classList.add("hidden");
        });
    document
        .getElementById("close-token-created-modal")!
        .addEventListener("click", () => {
            document
                .getElementById("token-created-modal")!
                .classList.add("hidden");
        });
    document
        .getElementById("token-created-overlay")!
        .addEventListener("click", () => {
            document
                .getElementById("token-created-modal")!
                .classList.add("hidden");
        });
    document.getElementById("done-token-btn")!.addEventListener("click", () => {
        document.getElementById("token-created-modal")!.classList.add("hidden");
    });
    document.getElementById("copy-token-btn")!.addEventListener("click", () => {
        const token =
            (document.getElementById("new-token-display") as HTMLElement)
                .textContent || "";
        navigator.clipboard
            .writeText(token)
            .then(() => {
                toast("Token copied to clipboard", "success");
            })
            .catch(() => {
                toast("Failed to copy token", "error");
            });
    });
    document
        .getElementById("submit-token-btn")!
        .addEventListener("click", async () => {
            const name = (
                document.getElementById("token-name-input") as HTMLInputElement
            ).value.trim();
            const projectId = (
                document.getElementById(
                    "token-project-select",
                ) as HTMLSelectElement
            ).value;
            if (!name) {
                toast("Token name is required", "error");
                return;
            }
            const btn = document.getElementById(
                "submit-token-btn",
            ) as HTMLButtonElement;
            btn.disabled = true;
            try {
                const res = await api.createToken({
                    name,
                    project_id: projectId || undefined,
                });
                document
                    .getElementById("create-token-modal")!
                    .classList.add("hidden");
                (
                    document.getElementById("new-token-display") as HTMLElement
                ).textContent = res.token;
                document
                    .getElementById("token-created-modal")!
                    .classList.remove("hidden");
                await loadTokens();
            } catch (e: any) {
                toast(e.message || "Failed to create token", "error");
            } finally {
                btn.disabled = false;
            }
        });

    async function loadProjectsForToken() {
        try {
            const projects = await api.getProjects();
            const sel = document.getElementById(
                "token-project-select",
            ) as HTMLSelectElement;
            sel.innerHTML = '<option value="">All projects</option>';
            (projects || []).forEach((p: any) => {
                sel.innerHTML += `<option value="${p.id}">${p.name}</option>`;
            });
        } catch (e) {
            /* ignore */
        }
    }

    async function loadTokens() {
        const container = document.getElementById("tokens-container")!;
        try {
            const { tokens } = await api.getTokens();
            if (tokens.length === 0) {
                container.innerHTML =
                    '<div class="text-center py-8 text-slate-500 text-sm">No tokens created yet. Create one to use the CI/CD integration.</div>';
                return;
            }
            container.innerHTML = tokens
                .map((t) => {
                    const projectLabel = t.project_id
                        ? `Project-scoped`
                        : "All projects";
                    const createdAt = t.created_at
                        ? new Date(t.created_at).toLocaleDateString()
                        : "—";
                    const lastUsed = t.last_used_at
                        ? new Date(t.last_used_at).toLocaleDateString()
                        : "Never";
                    return `<div class="bg-surface-container border border-outline-variant/20 rounded-xl p-5 flex items-center justify-between gap-4">
                    <div class="flex items-center gap-3 min-w-0">
                        <div class="w-10 h-10 bg-cyan-500/10 rounded-lg border border-cyan-500/20 flex items-center justify-center shrink-0">
                            <span class="material-symbols-outlined text-cyan-400">vpn_key</span>
                        </div>
                        <div class="min-w-0">
                            <p class="font-bold text-sm text-on-background truncate">${t.name}</p>
                            <p class="text-xs text-slate-500 font-mono">${t.prefix}••••••••</p>
                            <p class="text-xs text-slate-500 mt-0.5">${projectLabel} · Created ${createdAt} · Last used ${lastUsed}</p>
                        </div>
                    </div>
                    <button class="revoke-token-btn shrink-0 px-3 py-1.5 border border-rose-500/30 text-rose-400 rounded-lg text-xs font-bold hover:bg-rose-500/10 transition-all" data-id="${t.id}" data-name="${t.name}">Revoke</button>
                </div>`;
                })
                .join("");
            container.querySelectorAll(".revoke-token-btn").forEach((btn) => {
                btn.addEventListener("click", async () => {
                    const id = (btn as HTMLElement).dataset.id!;
                    const name = (btn as HTMLElement).dataset.name!;
                    if (
                        !confirm(
                            `Revoke token "${name}"? This cannot be undone.`,
                        )
                    )
                        return;
                    try {
                        await api.deleteToken(id);
                        toast("Token revoked", "success");
                        await loadTokens();
                    } catch (e: any) {
                        toast(e.message || "Failed to revoke token", "error");
                    }
                });
            });
        } catch (e: any) {
            container.innerHTML = `<div class="text-center py-8 text-rose-400 text-sm">Failed to load tokens: ${e.message}</div>`;
        }
    }

    // Load webhooks after DOM is ready
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", loadWebhooks);
    } else {
        loadWebhooks();
    }
</script>
