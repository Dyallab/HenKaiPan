    // ---------- Policies ----------
    import type { Policy, PolicyCondition, PolicyAction } from "../../lib/api";

    let conditionRows: PolicyCondition[] = [];
    let actionRows: PolicyAction[] = [];

    function renderConditionRow(idx: number, c: PolicyCondition) {
        return `<div class="flex gap-2 items-center" data-cond-idx="${idx}">
      <select class="cond-field bg-slate-950 border border-slate-800 rounded px-2 py-1.5 text-xs text-on-background focus:ring-1 focus:ring-cyan-500 outline-none" data-idx="${idx}">
        <option value="severity"  ${c.field === "severity" ? "selected" : ""}>Severity</option>
        <option value="scanner"   ${c.field === "scanner" ? "selected" : ""}>Scanner</option>
        <option value="rule_id"   ${c.field === "rule_id" ? "selected" : ""}>Rule ID</option>
        <option value="file_path" ${c.field === "file_path" ? "selected" : ""}>File Path</option>
      </select>
      <select class="cond-op bg-slate-950 border border-slate-800 rounded px-2 py-1.5 text-xs text-on-background focus:ring-1 focus:ring-cyan-500 outline-none" data-idx="${idx}">
        <option value="eq"       ${c.op === "eq" ? "selected" : ""}>equals</option>
        <option value="contains" ${c.op === "contains" ? "selected" : ""}>contains</option>
      </select>
      <input class="cond-value flex-1 bg-slate-950 border border-slate-800 rounded px-2 py-1.5 text-xs text-on-background focus:ring-1 focus:ring-cyan-500 outline-none" type="text" placeholder="value" value="${c.value}" data-idx="${idx}" />
      <button class="del-cond text-slate-600 hover:text-error transition-colors" data-idx="${idx}">
        <span class="material-symbols-outlined text-sm">close</span>
      </button>
    </div>`;
    }

    function renderActionRow(idx: number, a: PolicyAction) {
        return `<div class="flex gap-2 items-center" data-action-idx="${idx}">
      <select class="action-type bg-slate-950 border border-slate-800 rounded px-2 py-1.5 text-xs text-on-background focus:ring-1 focus:ring-cyan-500 outline-none" data-idx="${idx}">
        <option value="set_status" ${a.type === "set_status" ? "selected" : ""}>Set Status</option>
        <option value="assign"     ${a.type === "assign" ? "selected" : ""}>Assign To</option>
      </select>
      <input class="action-value flex-1 bg-slate-950 border border-slate-800 rounded px-2 py-1.5 text-xs text-on-background focus:ring-1 focus:ring-cyan-500 outline-none" type="text" placeholder="${a.type === "set_status" ? "open|in_review|accepted_risk|fixed|verified" : "username"}" value="${a.value}" data-idx="${idx}" />
      <button class="del-action text-slate-600 hover:text-error transition-colors" data-idx="${idx}">
        <span class="material-symbols-outlined text-sm">close</span>
      </button>
    </div>`;
    }

    function rebindConditionHandlers() {
        const cl = document.getElementById("conditions-list")!;
        cl.querySelectorAll<HTMLSelectElement>(".cond-field").forEach((s) => {
            s.onchange = () => {
                conditionRows[+s.dataset.idx!].field = s.value as any;
            };
        });
        cl.querySelectorAll<HTMLSelectElement>(".cond-op").forEach((s) => {
            s.onchange = () => {
                conditionRows[+s.dataset.idx!].op = s.value as any;
            };
        });
        cl.querySelectorAll<HTMLInputElement>(".cond-value").forEach((i) => {
            i.oninput = () => {
                conditionRows[+i.dataset.idx!].value = i.value;
            };
        });
        cl.querySelectorAll<HTMLButtonElement>(".del-cond").forEach((b) => {
            b.onclick = () => {
                conditionRows.splice(+b.dataset.idx!, 1);
                renderConditionsUI();
            };
        });
    }

    function renderConditionsUI() {
        const cl = document.getElementById("conditions-list")!;
        cl.innerHTML =
            conditionRows.map((c, i) => renderConditionRow(i, c)).join("") ||
            '<p class="text-xs text-slate-600">No conditions — policy matches all findings.</p>';
        rebindConditionHandlers();
    }

    function rebindActionHandlers() {
        const al = document.getElementById("actions-list")!;
        al.querySelectorAll<HTMLSelectElement>(".action-type").forEach((s) => {
            s.onchange = () => {
                actionRows[+s.dataset.idx!].type = s.value as any;
            };
        });
        al.querySelectorAll<HTMLInputElement>(".action-value").forEach((i) => {
            i.oninput = () => {
                actionRows[+i.dataset.idx!].value = i.value;
            };
        });
        al.querySelectorAll<HTMLButtonElement>(".del-action").forEach((b) => {
            b.onclick = () => {
                actionRows.splice(+b.dataset.idx!, 1);
                renderActionsUI();
            };
        });
    }

    function renderActionsUI() {
        const al = document.getElementById("actions-list")!;
        al.innerHTML =
            actionRows.map((a, i) => renderActionRow(i, a)).join("") ||
            '<p class="text-xs text-slate-600">No actions.</p>';
        rebindActionHandlers();
    }

    document.getElementById("add-condition")!.addEventListener("click", () => {
        conditionRows.push({ field: "severity", op: "eq", value: "" });
        renderConditionsUI();
    });
    document.getElementById("add-action")!.addEventListener("click", () => {
        actionRows.push({ type: "set_status", value: "" });
        renderActionsUI();
    });
    document
        .getElementById("show-create-policy")!
        .addEventListener("click", () => {
            conditionRows = [];
            actionRows = [];
            renderConditionsUI();
            renderActionsUI();
            (document.getElementById("policy-name") as HTMLInputElement).value =
                "";
            document.getElementById("policy-msg")!.classList.add("hidden");
