---
import DashboardLayout from '@layouts/DashboardLayout.astro';
---
<DashboardLayout title="Vulnerability Inventory" active="vulns">

  <!-- Breadcrumbs -->
  <div class="flex items-center gap-2 text-xs text-slate-500 uppercase tracking-[0.22em] font-bold mb-4">
    <a href="/dashboard" class="hover:text-cyan-300 transition-colors">Dashboard</a>
    <span>/</span>
    <span class="text-slate-400">Vulnerabilities</span>
  </div>

  <!-- Header -->
  <div class="flex items-center justify-between mb-5">
    <div>
      <h1 class="text-xl font-black text-on-background tracking-tight">Vulnerability Inventory</h1>
      <p class="text-sm text-slate-400 mt-0.5">Vulnerabilities grouped across scans and engines — see every finding at a glance.</p>
    </div>
    <div id="vuln-summary" class="flex gap-3 text-right">
      <div>
        <div id="sum-total" class="text-2xl font-black text-on-background">—</div>
        <div class="text-[10px] font-bold uppercase tracking-widest text-slate-500">Unique Vulns</div>
      </div>
      <div class="w-px bg-slate-800"></div>
      <div>
        <div id="sum-critical" class="text-2xl font-black text-vivid-crimson">—</div>
        <div class="text-[10px] font-bold uppercase tracking-widest text-slate-500">Critical</div>
      </div>
      <div class="w-px bg-slate-800"></div>
      <div>
        <div id="sum-findings" class="text-2xl font-black text-goldenrod">—</div>
        <div class="text-[10px] font-bold uppercase tracking-widest text-slate-500">Total Findings</div>
      </div>
    </div>
  </div>

  <!-- Filters -->
  <div class="flex flex-wrap gap-3 mb-4">
    <fieldset class="flex flex-wrap items-center gap-2 rounded-lg border border-outline-variant/30 bg-surface-container px-2.5 py-1.5">
      <legend class="px-1 text-[10px] font-bold uppercase tracking-widest text-slate-500">Severity</legend>
            <label class="inline-flex items-center gap-2 rounded-full border border-vivid-crimson/20 bg-vivid-crimson/10 px-2.5 py-1 text-xs font-semibold text-vivid-crimson cursor-pointer">
              <input type="checkbox" value="critical" data-severity-filter class="h-3.5 w-3.5 rounded border-vivid-crimson/40 bg-transparent text-vivid-crimson focus:ring-0" />
              Critical
            </label>
            <label class="inline-flex items-center gap-2 rounded-full border border-goldenrod/20 bg-goldenrod/10 px-2.5 py-1 text-xs font-semibold text-goldenrod cursor-pointer">
              <input type="checkbox" value="high" data-severity-filter class="h-3.5 w-3.5 rounded border-goldenrod/40 bg-transparent text-goldenrod focus:ring-0" />
              High
            </label>
            <label class="inline-flex items-center gap-2 rounded-full border border-spectrum-flare/20 bg-spectrum-flare/10 px-2.5 py-1 text-xs font-semibold text-spectrum-flare cursor-pointer">
              <input type="checkbox" value="medium" data-severity-filter class="h-3.5 w-3.5 rounded border-spectrum-flare/40 bg-transparent text-spectrum-flare focus:ring-0" />
              Medium
            </label>
            <label class="inline-flex items-center gap-2 rounded-full border border-emerald-green/20 bg-emerald-green/10 px-2.5 py-1 text-xs font-semibold text-emerald-green cursor-pointer">
              <input type="checkbox" value="low" data-severity-filter class="h-3.5 w-3.5 rounded border-emerald-green/40 bg-transparent text-emerald-green focus:ring-0" />
              Low
            </label>
            <label class="inline-flex items-center gap-2 rounded-full border border-iron-slate/20 bg-iron-slate/10 px-2.5 py-1 text-xs font-semibold text-iron-slate cursor-pointer">
              <input type="checkbox" value="info" data-severity-filter class="h-3.5 w-3.5 rounded border-iron-slate/40 bg-transparent text-iron-slate focus:ring-0" />
              Info
            </label>
    </fieldset>

    <fieldset class="flex flex-wrap items-center gap-2 rounded-lg border border-outline-variant/30 bg-surface-container px-2.5 py-1.5">
      <legend class="px-1 text-[10px] font-bold uppercase tracking-widest text-slate-500">Engine</legend>
            <label class="inline-flex items-center gap-2 rounded-full border border-purple-500/20 bg-purple-500/10 px-2.5 py-1 text-xs font-semibold text-purple-400 cursor-pointer">
              <input type="checkbox" value="sca" data-engine-filter class="h-3.5 w-3.5 rounded border-purple-500/40 bg-transparent text-purple-400 focus:ring-0" />
              SCA
            </label>
            <label class="inline-flex items-center gap-2 rounded-full border border-blue-500/20 bg-blue-500/10 px-2.5 py-1 text-xs font-semibold text-blue-400 cursor-pointer">
              <input type="checkbox" value="sast" data-engine-filter class="h-3.5 w-3.5 rounded border-blue-500/40 bg-transparent text-blue-400 focus:ring-0" />
              SAST
            </label>
            <label class="inline-flex items-center gap-2 rounded-full border border-red-500/20 bg-red-500/10 px-2.5 py-1 text-xs font-semibold text-red-400 cursor-pointer">
              <input type="checkbox" value="secrets" data-engine-filter class="h-3.5 w-3.5 rounded border-red-500/40 bg-transparent text-red-400 focus:ring-0" />
              Secrets
            </label>
            <label class="inline-flex items-center gap-2 rounded-full border border-amber-500/20 bg-amber-500/10 px-2.5 py-1 text-xs font-semibold text-amber-400 cursor-pointer">
              <input type="checkbox" value="iac" data-engine-filter class="h-3.5 w-3.5 rounded border-amber-500/40 bg-transparent text-amber-400 focus:ring-0" />
              IaC
            </label>
            <label class="inline-flex items-center gap-2 rounded-full border border-cyan-500/20 bg-cyan-500/10 px-2.5 py-1 text-xs font-semibold text-cyan-400 cursor-pointer">
              <input type="checkbox" value="containers" data-engine-filter class="h-3.5 w-3.5 rounded border-cyan-500/40 bg-transparent text-cyan-400 focus:ring-0" />
              Containers
            </label>
            <label class="inline-flex items-center gap-2 rounded-full border border-green-500/20 bg-green-500/10 px-2.5 py-1 text-xs font-semibold text-green-400 cursor-pointer">
              <input type="checkbox" value="dast" data-engine-filter class="h-3.5 w-3.5 rounded border-green-500/40 bg-transparent text-green-400 focus:ring-0" />
              DAST
            </label>
    </fieldset>

    <div class="relative flex-1 min-w-[180px]">
      <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 text-base">search</span>
      <input id="filter-q" type="text" placeholder="Search CVE, rule ID, title, or package…"
        class="w-full bg-surface-container border border-outline-variant/30 text-on-background rounded-lg pl-9 pr-4 py-2 text-sm focus:outline-none focus:border-cyan-500 transition-all placeholder:text-slate-600" />
    </div>

    <select id="filter-project" class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-cyan-500 transition-all min-w-[160px]">
      <option value="">All Projects</option>
    </select>

    <label class="flex items-center gap-2 px-3 py-2 bg-surface-container border border-outline-variant/30 rounded-lg cursor-pointer">
      <input id="filter-open" type="checkbox" checked class="rounded border-slate-600 bg-surface-container text-amber-400 focus:ring-0 cursor-pointer" />
      <span class="text-sm text-on-background font-medium">Open only</span>
    </label>

    <button id="filter-btn" class="px-4 py-2 bg-cyan-500 hover:bg-cyan-400 text-slate-950 font-bold rounded-lg text-sm transition-all active:scale-95">
      Search
    </button>
    <button id="clear-btn" class="px-3 py-2 text-slate-500 hover:text-slate-300 text-sm transition-colors">Clear</button>
  </div>

  <!-- Table -->
  <div class="bg-surface-container border border-outline-variant/20 rounded-xl overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-outline-variant/20 text-left">
          <th class="px-3 py-2.5 text-[10px] font-bold uppercase tracking-widest text-slate-500 w-6"></th>
          <th class="px-3 py-2.5 text-[10px] font-bold uppercase tracking-widest text-slate-500">Severity</th>
          <th class="px-3 py-2.5 text-[10px] font-bold uppercase tracking-widest text-slate-500">Vulnerability</th>
          <th class="px-3 py-2.5 text-[10px] font-bold uppercase tracking-widest text-slate-500">Engine</th>
          <th class="px-3 py-2.5 text-[10px] font-bold uppercase tracking-widest text-slate-500">Scanners</th>
          <th class="px-3 py-2.5 text-[10px] font-bold uppercase tracking-widest text-slate-500 text-center">Findings</th>
          <th class="px-3 py-2.5 text-[10px] font-bold uppercase tracking-widest text-slate-500 text-center">Confidence</th>
          <th class="px-3 py-2.5 text-[10px] font-bold uppercase tracking-widest text-slate-500 text-center">Status</th>
        </tr>
      </thead>
      <tbody id="vuln-tbody">
        <tr><td colspan="8" class="px-4 py-12 text-center text-slate-500 text-sm animate-pulse">Loading vulnerabilities…</td></tr>
      </tbody>
    </table>
  </div>

  <div id="pagination" class="flex items-center justify-between mt-3 text-sm text-slate-400 hidden">
    <span id="page-info"></span>
    <div class="flex gap-2">
      <button id="prev-btn" class="px-3 py-1.5 bg-surface-container border border-outline-variant/20 rounded-lg hover:bg-slate-800 transition-all disabled:opacity-40">← Prev</button>
      <button id="next-btn" class="px-3 py-1.5 bg-surface-container border border-outline-variant/20 rounded-lg hover:bg-slate-800 transition-all disabled:opacity-40">Next →</button>
    </div>
  </div>

</DashboardLayout>

<script>
  import { api, type AffectedFinding } from '@lib/api';
  import type { VulnSummary } from '@lib/api';
  import { toast } from '@lib/toast';

  const SEV_COLOR: Record<string, string> = {
    critical: 'text-vivid-crimson bg-vivid-crimson/10 border-vivid-crimson/20',
    high:     'text-goldenrod bg-goldenrod/10 border-goldenrod/20',
    medium:   'text-spectrum-flare bg-spectrum-flare/10 border-spectrum-flare/20',
    low:      'text-emerald-green bg-emerald-green/10 border-emerald-green/20',
    info:     'text-iron-slate bg-iron-slate/10 border-iron-slate/20',
  };

  const ENGINE_LABEL: Record<string, string> = {
    sca: 'SCA',
    sast: 'SAST',
    secrets: 'Secrets',
    iac: 'IaC',
    containers: 'Containers',
    dast: 'DAST',
  };

  const ENGINE_COLOR: Record<string, string> = {
    sca: 'bg-purple-500/10 border-purple-500/20 text-purple-400',
    sast: 'bg-blue-500/10 border-blue-500/20 text-blue-400',
    secrets: 'bg-red-500/10 border-red-500/20 text-red-400',
    iac: 'bg-amber-500/10 border-amber-500/20 text-amber-400',
    containers: 'bg-cyan-500/10 border-cyan-500/20 text-cyan-400',
    dast: 'bg-green-500/10 border-green-500/20 text-green-400',
  };

  function sevChip(s: string) {
    return `<span class="text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded border ${SEV_COLOR[s] ?? SEV_COLOR.info}">${s}</span>`;
  }

  function confBadge(score: number | null | undefined) {
    if (score == null) return '<span class="text-slate-600 text-[10px]">—</span>';
    const pct = Math.round(score * 100);
    const color = pct >= 70 ? 'text-emerald-green' : pct >= 40 ? 'text-goldenrod' : 'text-slate-500';
    return `<span class="${color} text-xs font-bold">${pct}%</span>`;
  }

  const STATUS_OPTIONS = ['open', 'in_review', 'accepted_risk', 'fixed', 'verified'];
  const STATUS_LABELS: Record<string, string> = {
    open: 'Open',
    in_review: 'In Review',
    accepted_risk: 'Accepted Risk',
    fixed: 'Fixed',
    verified: 'Verified',
  };

  let currentPage = 1;
  let totalVulns  = 0;
  const PAGE_LIMIT = 100;
  const expandedRows = new Set<string>();
  const loadedFindings = new Map<string, AffectedFinding[]>();

  function selectedSeverities() {
    return Array.from(document.querySelectorAll<HTMLInputElement>('[data-severity-filter]:checked')).map((input) => input.value);
  }

  function selectedEngines() {
    return Array.from(document.querySelectorAll<HTMLInputElement>('[data-engine-filter]:checked')).map((input) => input.value);
  }

  async function loadProjects() {
    try {
      const projects = await api.getProjects();
      const select = document.getElementById('filter-project') as HTMLSelectElement;
      select.innerHTML = '<option value="">All Projects</option>' +
        projects.map(p => `<option value="${p.id}">${p.name}</option>`).join('');
    } catch { /* projects unavailable */ }
  }

  async function load() {
    const severity = selectedSeverities();
    const engines  = selectedEngines();
    const q        = (document.getElementById('filter-q')        as HTMLInputElement).value.trim();
    const onlyOpen = (document.getElementById('filter-open')     as HTMLInputElement).checked;
    const projectId = (document.getElementById('filter-project') as HTMLSelectElement).value;

    const tbody = document.getElementById('vuln-tbody')!;
        tbody.innerHTML = `<tr><td colspan="8" class="px-4 py-12 text-center text-slate-500 text-sm animate-pulse">Loading…</td></tr>`;

    try {
      // If multiple engines selected, we need to make multiple calls or pick one
      // For simplicity, if none selected, fetch all; if one selected, filter by it
      const engineType = engines.length === 1 ? engines[0] : undefined;

      const { vulnerabilities: vulns, total } = await api.getVulnerabilities(severity, q, onlyOpen, currentPage, PAGE_LIMIT, engineType, projectId);
      totalVulns = total;

      document.getElementById('sum-total')!.textContent    = String(total);
      document.getElementById('sum-critical')!.textContent = String(vulns.filter(v => v.severity === 'critical').length);
      const totalFindings = vulns.reduce((s, v) => s + v.finding_count, 0);
      document.getElementById('sum-findings')!.textContent = String(totalFindings);

      if (!vulns.length) {
        tbody.innerHTML = `<tr><td colspan="8" class="px-4 py-12 text-center text-slate-500 text-sm">No vulnerabilities match your filters.</td></tr>`;
        return;
      }

      tbody.innerHTML = vulns.map(v => buildRow(v)).join('');

      // Re-attach expand listeners
      tbody.querySelectorAll<HTMLTableRowElement>('.vuln-row').forEach(row => {
        row.addEventListener('click', () => toggleExpand(row.dataset.vulnId!, tbody));
      });

      // Re-expand previously expanded rows
      for (const vid of expandedRows) {
        const row = tbody.querySelector(`[data-vuln-id="${CSS.escape(vid)}"]`);
        if (row) await expandRow(vid, tbody, row as HTMLTableRowElement);
      }

      // Attach status change handlers
      tbody.querySelectorAll<HTMLSelectElement>('.vuln-status-select').forEach(sel => {
        sel.addEventListener('change', async () => {
          const vulnId = sel.dataset.vulnId!;
          const newStatus = sel.value;
          const oldStatus = sel.dataset.currentStatus;
          try {
            await api.updateVulnerabilityStatus(vulnId, newStatus);
            sel.dataset.currentStatus = newStatus;
            toast(`Status updated to ${STATUS_LABELS[newStatus] ?? newStatus}`, 'success');
          } catch (e: any) {
            sel.value = oldStatus!;
            toast(e.message ?? 'Failed to update status', 'error');
          }
        });
      });

      updatePagination();
    } catch (e: any) {
      tbody.innerHTML = `<tr><td colspan="8" class="px-4 py-8 text-center text-error text-sm">${e.message}</td></tr>`;
    }
  }

  function buildRow(v: VulnSummary) {
    const isCVE = !!v.cve_id;
    const idDisplay = isCVE
      ? `<a href="https://nvd.nist.gov/vuln/detail/${v.cve_id}" target="_blank" rel="noopener"
            class="font-mono text-xs text-red-400 hover:underline" onclick="event.stopPropagation()">${v.cve_id}</a>`
      : v.rule_id
        ? `<span class="font-mono text-xs text-slate-400">${v.rule_id}</span>`
        : `<span class="font-mono text-xs text-slate-400">${v.vuln_uid.slice(0,8)}…</span>`;

    const cweChip = v.cwe_id
      ? `<a href="https://cwe.mitre.org/data/definitions/${v.cwe_id.replace('CWE-','')}.html"
            target="_blank" rel="noopener"
            class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-purple-500/10 border border-purple-500/20 text-purple-400 hover:bg-purple-500/20"
            onclick="event.stopPropagation()">${v.cwe_id}</a>`
      : '';

    const engineBadge = `<span class="text-[10px] font-bold uppercase px-1.5 py-0.5 rounded border ${ENGINE_COLOR[v.engine_type] ?? 'bg-slate-800 text-slate-400 border-slate-700'}">${ENGINE_LABEL[v.engine_type] ?? v.engine_type}</span>`;

    const scannerChips = (v.scanner_coverage ?? []).map(s =>
      `<span class="text-[10px] font-mono px-1.5 py-0.5 rounded bg-slate-800 text-slate-400 border border-slate-700">${s}</span>`
    ).join(' ');

    const isExpanded = expandedRows.has(v.id);

    return `
      <tr class="vuln-row border-b border-outline-variant/10 hover:bg-slate-900/30 transition-colors cursor-pointer select-none"
          data-vuln-id="${v.id}">
        <td class="px-3 py-2.5">
          <span class="material-symbols-outlined text-sm text-slate-500 expand-icon transition-transform ${isExpanded ? 'rotate-90' : ''}">chevron_right</span>
        </td>
        <td class="px-3 py-2.5">${sevChip(v.severity)}</td>
        <td class="px-3 py-2.5 max-w-md">
          <div class="flex items-center gap-2 flex-wrap">
            ${idDisplay}
            ${cweChip}
            ${engineBadge}
          </div>
          <p class="text-xs text-slate-300 mt-0.5 truncate max-w-xs" title="${v.title}">${v.title}</p>
          ${v.pkg_name ? `<span class="text-[10px] font-mono text-slate-500">${v.pkg_name}${v.pkg_version ? '@' + v.pkg_version : ''}</span>` : ''}
        </td>
        <td class="px-3 py-2.5">${engineBadge}</td>
        <td class="px-3 py-2.5"><div class="flex gap-1 flex-wrap">${scannerChips}</div></td>
        <td class="px-3 py-2.5 text-center">
          <span class="inline-flex items-center justify-center w-8 h-8 rounded-full ${v.finding_count > 0 ? 'bg-goldenrod/10 text-goldenrod font-bold border border-goldenrod/20' : 'text-slate-500'} text-sm">${v.finding_count}</span>
        </td>
        <td class="px-3 py-2.5 text-center">${confBadge(v.confidence_score)}</td>
        <td class="px-3 py-2.5 text-center">
          <select class="vuln-status-select text-[10px] font-bold uppercase tracking-wider bg-surface-container border border-outline-variant/30 text-on-background rounded px-1 py-0.5 focus:outline-none focus:border-cyan-500 cursor-pointer"
            data-vuln-id="${v.id}" data-current-status="${v.status}" onclick="event.stopPropagation()">
            ${STATUS_OPTIONS.map(s => `<option value="${s}" ${v.status === s ? 'selected' : ''}>${STATUS_LABELS[s]}</option>`).join('')}
          </select>
        </td>
      </tr>`;
  }

  async function toggleExpand(vulnId: string, tbody: HTMLElement) {
    const row = tbody.querySelector<HTMLTableRowElement>(`[data-vuln-id="${CSS.escape(vulnId)}"]`);
    if (!row) return;

    const existingDetail = tbody.querySelector(`[data-detail-for="${CSS.escape(vulnId)}"]`);
    if (existingDetail) {
      existingDetail.remove();
      expandedRows.delete(vulnId);
      row.querySelector('.expand-icon')?.classList.remove('rotate-90');
      return;
    }

    expandedRows.add(vulnId);
    row.querySelector('.expand-icon')?.classList.add('rotate-90');
    await expandRow(vulnId, tbody, row as HTMLTableRowElement);
  }

  async function expandRow(vulnId: string, tbody: HTMLElement, row: HTMLTableRowElement) {
    const detailId = `detail-${vulnId.replace(/[^a-z0-9]/gi, '_')}`;
    if (tbody.querySelector(`[data-detail-for="${CSS.escape(vulnId)}"]`)) return;

    const placeholder = document.createElement('tr');
    placeholder.dataset.detailFor = vulnId;
    placeholder.innerHTML = `
      <td colspan="8" class="px-6 pb-4 pt-2 bg-slate-950/60">
        <div class="text-xs text-slate-500 animate-pulse">Loading findings…</div>
      </td>`;
    row.insertAdjacentElement('afterend', placeholder);

    let findings: AffectedFinding[];
    if (loadedFindings.has(vulnId)) {
      findings = loadedFindings.get(vulnId)!;
    } else {
      try {
        findings = await api.getVulnerabilityAffected(vulnId);
        loadedFindings.set(vulnId, findings);
      } catch {
        findings = [];
      }
    }

    if (!findings.length) {
      placeholder.innerHTML = `
        <td colspan="8" class="px-5 pb-4 pt-2 bg-slate-950/60">
          <p class="text-xs text-slate-500">No findings linked to this vulnerability.</p>
        </td>`;
      return;
    }

    // Group findings by project
    const byProject = new Map<string, AffectedFinding[]>();
    for (const f of findings) {
      const key = f.project_id;
      if (!byProject.has(key)) byProject.set(key, []);
      byProject.get(key)!.push(f);
    }

    placeholder.innerHTML = `
      <td colspan="8" class="px-5 pb-4 pt-2 bg-slate-950/60">
        <div class="space-y-3">
          <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-3">
            Affected Resources (${findings.length} findings across ${byProject.size} project${byProject.size > 1 ? 's' : ''})
          </p>
          ${Array.from(byProject.entries()).map(([pid, pfindings]) => {
            const first = pfindings[0];
            const resourceLabel = first.app_name
              ? `${first.app_name} → ${first.project_name}`
              : first.project_name;
            return `
              <div class="mb-2">
                <div class="flex items-center gap-2 mb-2">
                  <span class="material-symbols-outlined text-sm text-cyan-400">folder</span>
                  <span class="text-xs font-bold text-on-background">${resourceLabel}</span>
                  <span class="text-[10px] text-slate-500 font-mono">${pfindings.length} finding${pfindings.length > 1 ? 's' : ''}</span>
                </div>
                <div class="grid gap-2 ml-6">
                  ${pfindings.map(f => buildFindingCard(f)).join('')}
                </div>
              </div>`;
          }).join('')}
        </div>
      </td>`;
  }

  function buildFindingCard(f: AffectedFinding) {
    const STATUS_STYLE: Record<string, string> = {
      open: 'bg-red-400 shadow-[0_0_6px_rgba(248,113,113,0.5)]',
      in_review: 'bg-amber-400 shadow-[0_0_6px_rgba(251,191,36,0.4)]',
      accepted_risk: 'bg-purple-400',
      fixed: 'bg-emerald-400 shadow-[0_0_6px_rgba(52,211,153,0.4)]',
      verified: 'bg-emerald-400 shadow-[0_0_6px_rgba(52,211,153,0.4)]',
    };
    const dot = `<span class="w-2 h-2 rounded-full inline-block shrink-0 ${STATUS_STYLE[f.status] ?? 'bg-slate-400'}"></span>`;

    const filePath = f.file_path
      ? `<span class="font-mono text-[10px] text-slate-500 truncate max-w-xs" title="${f.file_path}">${f.file_path.replace(/^.*aspm-scan-[a-f0-9-]+\//, '/')}</span>`
      : '';

    return `
      <div class="flex items-center gap-3 p-2.5 bg-surface-container border border-outline-variant/20 rounded-lg hover:border-cyan-500/20 transition-all">
        <div class="flex items-center gap-2 shrink-0">
          ${dot}
          <span class="material-symbols-outlined text-slate-500 text-base">bug_report</span>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-semibold text-on-background truncate">${f.title}</p>
          <div class="flex items-center gap-2 mt-0.5">
            <span class="text-[10px] font-mono text-slate-400">${f.scanner}</span>
            ${filePath}
          </div>
        </div>
        <div class="flex items-center gap-2 text-xs shrink-0">
          <span class="${f.status === 'open' ? 'text-vivid-crimson font-bold' : f.status === 'fixed' ? 'text-emerald-green' : 'text-slate-400'}">${f.status}</span>
        </div>
      </div>`;
  }

  function updatePagination() {
    const pag = document.getElementById('pagination')!;
    if (totalVulns <= PAGE_LIMIT) {
      pag.classList.add('hidden');
      return;
    }
    pag.classList.remove('hidden');
    const totalPages = Math.ceil(totalVulns / PAGE_LIMIT);
    document.getElementById('page-info')!.textContent = `Page ${currentPage} of ${totalPages} (${totalVulns} total)`;
    (document.getElementById('prev-btn') as HTMLButtonElement).disabled = currentPage <= 1;
    (document.getElementById('next-btn') as HTMLButtonElement).disabled = currentPage >= totalPages;
  }

  document.getElementById('filter-btn')!.addEventListener('click', () => { currentPage = 1; load(); });
  document.getElementById('filter-open')!.addEventListener('change', () => { currentPage = 1; load(); });
  document.getElementById('filter-q')!.addEventListener('keydown', e => {
    if ((e as KeyboardEvent).key === 'Enter') { currentPage = 1; load(); }
  });
  document.getElementById('clear-btn')!.addEventListener('click', () => {
    document.querySelectorAll<HTMLInputElement>('[data-severity-filter]').forEach((input) => {
      input.checked = false;
    });
    document.querySelectorAll<HTMLInputElement>('[data-engine-filter]').forEach((input) => {
      input.checked = false;
    });
    (document.getElementById('filter-q')        as HTMLInputElement).value  = '';
    (document.getElementById('filter-open')     as HTMLInputElement).checked = true;
    (document.getElementById('filter-project') as HTMLSelectElement).value = '';
    currentPage = 1;
    load();
  });
  document.getElementById('prev-btn')!.addEventListener('click', () => { currentPage--; load(); });
  document.getElementById('next-btn')!.addEventListener('click', () => { currentPage++; load(); });

  loadProjects();
  load();
</script>