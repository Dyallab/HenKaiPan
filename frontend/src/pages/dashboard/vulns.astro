---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---
<DashboardLayout title="Vulnerability Inventory" active="vulns">

  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-black text-on-background tracking-tight">Vulnerability Inventory</h1>
      <p class="text-sm text-slate-400 mt-1">Vulnerabilities grouped by CVE/rule — see every affected repo at a glance.</p>
    </div>
    <div id="vuln-summary" class="flex gap-4 text-right">
      <div>
        <div id="sum-total" class="text-2xl font-black text-on-background">—</div>
        <div class="text-[10px] font-bold uppercase tracking-widest text-slate-500">Unique Vulns</div>
      </div>
      <div class="w-px bg-slate-800"></div>
      <div>
        <div id="sum-critical" class="text-2xl font-black text-red-400">—</div>
        <div class="text-[10px] font-bold uppercase tracking-widest text-slate-500">Critical</div>
      </div>
      <div class="w-px bg-slate-800"></div>
      <div>
        <div id="sum-repos" class="text-2xl font-black text-amber-400">—</div>
        <div class="text-[10px] font-bold uppercase tracking-widest text-slate-500">Max Repos Hit</div>
      </div>
    </div>
  </div>

  <!-- Filters -->
  <div class="flex flex-wrap gap-3 mb-5">
    <select id="filter-severity" class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-sky-500 transition-all">
      <option value="">All Severities</option>
      <option value="critical">Critical</option>
      <option value="high">High</option>
      <option value="medium">Medium</option>
      <option value="low">Low</option>
      <option value="info">Info</option>
    </select>

    <div class="relative flex-1 min-w-[220px]">
      <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 text-base">search</span>
      <input id="filter-q" type="text" placeholder="Search CVE, rule ID, or title…"
        class="w-full bg-surface-container border border-outline-variant/30 text-on-background rounded-lg pl-9 pr-4 py-2 text-sm focus:outline-none focus:border-sky-500 transition-all placeholder:text-slate-600" />
    </div>

    <label class="flex items-center gap-2 px-3 py-2 bg-surface-container border border-outline-variant/30 rounded-lg cursor-pointer">
      <input id="filter-open" type="checkbox" checked class="rounded border-slate-600 bg-surface-container text-amber-400 focus:ring-0 cursor-pointer" />
      <span class="text-sm text-on-background font-medium">Open only</span>
    </label>

    <button id="filter-btn" class="px-4 py-2 bg-sky-500 hover:bg-sky-400 text-slate-950 font-bold rounded-lg text-sm transition-all active:scale-95">
      Search
    </button>
    <button id="clear-btn" class="px-3 py-2 text-slate-500 hover:text-slate-300 text-sm transition-colors">Clear</button>
  </div>

  <!-- Table -->
  <div class="bg-surface-container border border-outline-variant/20 rounded-xl overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-outline-variant/20 text-left">
          <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500 w-6"></th>
          <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500">Severity</th>
          <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500">Vulnerability</th>
          <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500">Scanners</th>
          <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500 text-center">Repos Hit</th>
          <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500 text-center">Open</th>
          <th class="px-4 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500 text-center">Fixed</th>
        </tr>
      </thead>
      <tbody id="vuln-tbody">
        <tr><td colspan="7" class="px-4 py-12 text-center text-slate-500 text-sm animate-pulse">Loading vulnerabilities…</td></tr>
      </tbody>
    </table>
  </div>

  <div id="pagination" class="flex items-center justify-between mt-4 text-sm text-slate-400 hidden">
    <span id="page-info"></span>
    <div class="flex gap-2">
      <button id="prev-btn" class="px-3 py-1.5 bg-surface-container border border-outline-variant/20 rounded-lg hover:bg-slate-800 transition-all disabled:opacity-40">← Prev</button>
      <button id="next-btn" class="px-3 py-1.5 bg-surface-container border border-outline-variant/20 rounded-lg hover:bg-slate-800 transition-all disabled:opacity-40">Next →</button>
    </div>
  </div>

</DashboardLayout>

<script>
  import { api } from '../../lib/api';
  import type { VulnSummary, AffectedRepo } from '../../lib/api';

  const SEV_COLOR: Record<string, string> = {
    critical: 'text-red-400 bg-red-500/10 border-red-500/20',
    high:     'text-orange-400 bg-orange-500/10 border-orange-500/20',
    medium:   'text-amber-400 bg-amber-500/10 border-amber-500/20',
    low:      'text-blue-400 bg-blue-500/10 border-blue-500/20',
    info:     'text-slate-400 bg-slate-500/10 border-slate-500/20',
  };

  const STATUS_COLOR: Record<string, string> = {
    open:          'text-red-400',
    in_review:     'text-amber-400',
    accepted_risk: 'text-purple-400',
    fixed:         'text-emerald-400',
    verified:      'text-emerald-400',
  };

  function sevChip(s: string) {
    return `<span class="text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded border ${SEV_COLOR[s] ?? SEV_COLOR.info}">${s}</span>`;
  }

  function fmtDeadline(iso?: string) {
    if (!iso) return '';
    const d = new Date(iso);
    const now = new Date();
    const diff = Math.floor((d.getTime() - now.getTime()) / 86400000);
    const label = d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
    if (diff < 0) return `<span class="text-red-400 text-[10px] font-bold">⚠ Overdue (${label})</span>`;
    if (diff === 0) return `<span class="text-amber-400 text-[10px] font-bold">Due today</span>`;
    return `<span class="text-slate-400 text-[10px]">Due ${label}</span>`;
  }

  let currentPage = 1;
  let totalVulns  = 0;
  const PAGE_LIMIT = 100;
  const expandedRows = new Set<string>();
  const loadedAffected = new Map<string, AffectedRepo[]>();

  async function load() {
    const severity = (document.getElementById('filter-severity') as HTMLSelectElement).value;
    const q        = (document.getElementById('filter-q')        as HTMLInputElement).value.trim();
    const onlyOpen = (document.getElementById('filter-open')     as HTMLInputElement).checked;

    const tbody = document.getElementById('vuln-tbody')!;
    tbody.innerHTML = `<tr><td colspan="7" class="px-4 py-12 text-center text-slate-500 text-sm animate-pulse">Loading…</td></tr>`;

    try {
      const { vulnerabilities: vulns, total } = await api.getVulnerabilities(severity, q, onlyOpen, currentPage, PAGE_LIMIT);
      totalVulns = total;

      document.getElementById('sum-total')!.textContent    = String(total);
      document.getElementById('sum-critical')!.textContent = String(vulns.filter(v => v.severity === 'critical').length);
      const maxRepos = vulns.reduce((m, v) => Math.max(m, v.affected_count), 0);
      document.getElementById('sum-repos')!.textContent = String(maxRepos);

      if (!vulns.length) {
        tbody.innerHTML = `<tr><td colspan="7" class="px-4 py-12 text-center text-slate-500 text-sm">No vulnerabilities match your filters.</td></tr>`;
        return;
      }

      tbody.innerHTML = vulns.map(v => buildRow(v)).join('');

      // Re-attach expand listeners
      tbody.querySelectorAll<HTMLTableRowElement>('.vuln-row').forEach(row => {
        row.addEventListener('click', () => toggleExpand(row.dataset.vulnId!, tbody));
      });

      // Re-expand previously expanded rows
      for (const vid of expandedRows) {
        const row = tbody.querySelector(`[data-vuln-id="${CSS.escape(vid)}"]`);
        if (row) await expandRow(vid, tbody, row as HTMLTableRowElement);
      }

      updatePagination();
    } catch (e: any) {
      tbody.innerHTML = `<tr><td colspan="7" class="px-4 py-8 text-center text-error text-sm">${e.message}</td></tr>`;
    }
  }

  function buildRow(v: VulnSummary) {
    const isCVE = !!v.cve_id;
    const idDisplay = isCVE
      ? `<a href="https://nvd.nist.gov/vuln/detail/${v.cve_id}" target="_blank" rel="noopener"
            class="font-mono text-xs text-red-400 hover:underline" onclick="event.stopPropagation()">${v.cve_id}</a>`
      : `<span class="font-mono text-xs text-slate-400">${v.vuln_id}</span>`;

    const cweChip = v.cwe_id
      ? `<a href="https://cwe.mitre.org/data/definitions/${v.cwe_id.replace('CWE-','')}.html"
            target="_blank" rel="noopener"
            class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-purple-500/10 border border-purple-500/20 text-purple-400 hover:bg-purple-500/20"
            onclick="event.stopPropagation()">${v.cwe_id}</a>`
      : '';

    const scannerChips = v.scanners.map(s =>
      `<span class="text-[10px] font-mono px-1.5 py-0.5 rounded bg-slate-800 text-slate-400 border border-slate-700">${s}</span>`
    ).join(' ');

    const openClass  = v.open_count  > 0 ? 'text-red-400 font-bold' : 'text-slate-500';
    const fixedClass = v.fixed_count > 0 ? 'text-emerald-400 font-bold' : 'text-slate-500';
    const isExpanded = expandedRows.has(v.vuln_id);

    return `
      <tr class="vuln-row border-b border-outline-variant/10 hover:bg-slate-900/30 transition-colors cursor-pointer select-none"
          data-vuln-id="${v.vuln_id}">
        <td class="px-4 py-3">
          <span class="material-symbols-outlined text-sm text-slate-500 expand-icon transition-transform ${isExpanded ? 'rotate-90' : ''}">chevron_right</span>
        </td>
        <td class="px-4 py-3">${sevChip(v.severity)}</td>
        <td class="px-4 py-3 max-w-md">
          <div class="flex items-center gap-2 flex-wrap">
            ${idDisplay}
            ${cweChip}
          </div>
          <p class="text-xs text-slate-300 mt-0.5 truncate max-w-xs" title="${v.title}">${v.title}</p>
        </td>
        <td class="px-4 py-3"><div class="flex gap-1 flex-wrap">${scannerChips}</div></td>
        <td class="px-4 py-3 text-center">
          <span class="inline-flex items-center justify-center w-8 h-8 rounded-full ${v.affected_count > 0 ? 'bg-amber-500/10 text-amber-400 font-bold border border-amber-500/20' : 'text-slate-500'} text-sm">${v.affected_count}</span>
        </td>
        <td class="px-4 py-3 text-center"><span class="${openClass}">${v.open_count}</span></td>
        <td class="px-4 py-3 text-center"><span class="${fixedClass}">${v.fixed_count}</span></td>
      </tr>`;
  }

  async function toggleExpand(vulnId: string, tbody: HTMLElement) {
    const row = tbody.querySelector<HTMLTableRowElement>(`[data-vuln-id="${CSS.escape(vulnId)}"]`);
    if (!row) return;

    const existingDetail = tbody.querySelector(`[data-detail-for="${CSS.escape(vulnId)}"]`);
    if (existingDetail) {
      existingDetail.remove();
      expandedRows.delete(vulnId);
      row.querySelector('.expand-icon')?.classList.remove('rotate-90');
      return;
    }

    expandedRows.add(vulnId);
    row.querySelector('.expand-icon')?.classList.add('rotate-90');
    await expandRow(vulnId, tbody, row);
  }

  async function expandRow(vulnId: string, tbody: HTMLElement, row: HTMLTableRowElement) {
    const detailId = `detail-${vulnId.replace(/[^a-z0-9]/gi, '_')}`;
    if (tbody.querySelector(`[data-detail-for="${CSS.escape(vulnId)}"]`)) return;

    const placeholder = document.createElement('tr');
    placeholder.dataset.detailFor = vulnId;
    placeholder.innerHTML = `
      <td colspan="7" class="px-6 pb-4 pt-2 bg-slate-950/60">
        <div class="text-xs text-slate-500 animate-pulse">Loading affected repositories…</div>
      </td>`;
    row.insertAdjacentElement('afterend', placeholder);

    let affected: AffectedRepo[];
    if (loadedAffected.has(vulnId)) {
      affected = loadedAffected.get(vulnId)!;
    } else {
      try {
        affected = await api.getVulnerabilityAffected(vulnId);
        loadedAffected.set(vulnId, affected);
      } catch {
        affected = [];
      }
    }

    placeholder.innerHTML = `
      <td colspan="7" class="px-6 pb-5 pt-2 bg-slate-950/60">
        ${affected.length === 0
          ? '<p class="text-xs text-slate-500">No affected repositories found.</p>'
          : `<div class="space-y-2">
              <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-3">
                Affected Repositories (${affected.length})
              </p>
              <div class="grid gap-2">
                ${affected.map(a => buildAffectedCard(a)).join('')}
              </div>
            </div>`
        }
      </td>`;
  }

  function buildAffectedCard(a: AffectedRepo) {
    const worstStatus = a.statuses.includes('open')          ? 'open' :
                        a.statuses.includes('in_review')     ? 'in_review' :
                        a.statuses.includes('accepted_risk') ? 'accepted_risk' :
                        a.statuses.includes('fixed')         ? 'fixed' : 'verified';

    const statusDot = `<span class="w-2 h-2 rounded-full inline-block shrink-0 ${
      worstStatus === 'open'          ? 'bg-red-400 shadow-[0_0_6px_rgba(248,113,113,0.5)]' :
      worstStatus === 'in_review'     ? 'bg-amber-400 shadow-[0_0_6px_rgba(251,191,36,0.4)]' :
      worstStatus === 'accepted_risk' ? 'bg-purple-400' :
                                        'bg-emerald-400 shadow-[0_0_6px_rgba(52,211,153,0.4)]'
    }"></span>`;

    const assigneeBadges = a.assignees.length
      ? a.assignees.map(u =>
          `<span class="text-[10px] bg-sky-500/10 border border-sky-500/20 text-sky-400 px-2 py-0.5 rounded font-medium">${u}</span>`
        ).join(' ')
      : '<span class="text-[10px] text-slate-600">unassigned</span>';

    const openBar = a.finding_count > 0
      ? `<div class="w-24 h-1.5 rounded-full bg-slate-800 overflow-hidden">
           <div class="h-full rounded-full ${a.open_count > 0 ? 'bg-red-400' : 'bg-emerald-400'}" style="width:${Math.round((a.fixed_count/a.finding_count)*100)}%"></div>
         </div>`
      : '';

    return `
      <div class="flex items-center gap-4 p-3 bg-surface-container border border-outline-variant/20 rounded-lg hover:border-sky-500/20 transition-all">
        <div class="flex items-center gap-2 shrink-0">
          ${statusDot}
          <span class="material-symbols-outlined text-slate-500 text-base">source</span>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-semibold text-on-background truncate">${a.repo_name}</p>
          <p class="text-[10px] font-mono text-slate-600 truncate">${a.repo_url}</p>
        </div>
        <div class="flex items-center gap-2 text-xs shrink-0">
          ${assigneeBadges}
        </div>
        <div class="flex items-center gap-3 text-xs shrink-0">
          ${openBar}
          <span class="text-red-400 font-bold">${a.open_count} open</span>
          <span class="text-emerald-400">${a.fixed_count} fixed</span>
        </div>
        <div class="shrink-0">
          ${fmtDeadline(a.nearest_deadline)}
        </div>
      </div>`;
  }

  function updatePagination() {
    const pag = document.getElementById('pagination')!;
    if (totalVulns <= PAGE_LIMIT) {
      pag.classList.add('hidden');
      return;
    }
    pag.classList.remove('hidden');
    const totalPages = Math.ceil(totalVulns / PAGE_LIMIT);
    document.getElementById('page-info')!.textContent = `Page ${currentPage} of ${totalPages} (${totalVulns} total)`;
    (document.getElementById('prev-btn') as HTMLButtonElement).disabled = currentPage <= 1;
    (document.getElementById('next-btn') as HTMLButtonElement).disabled = currentPage >= totalPages;
  }

  document.getElementById('filter-btn')!.addEventListener('click', () => { currentPage = 1; load(); });
  document.getElementById('filter-open')!.addEventListener('change', () => { currentPage = 1; load(); });
  document.getElementById('filter-q')!.addEventListener('keydown', e => {
    if ((e as KeyboardEvent).key === 'Enter') { currentPage = 1; load(); }
  });
  document.getElementById('clear-btn')!.addEventListener('click', () => {
    (document.getElementById('filter-severity') as HTMLSelectElement).value = '';
    (document.getElementById('filter-q')        as HTMLInputElement).value  = '';
    (document.getElementById('filter-open')     as HTMLInputElement).checked = true;
    currentPage = 1;
    load();
  });
  document.getElementById('prev-btn')!.addEventListener('click', () => { currentPage--; load(); });
  document.getElementById('next-btn')!.addEventListener('click', () => { currentPage++; load(); });

  load();
</script>
