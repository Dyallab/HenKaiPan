---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Security Findings" active="findings">
  <div id="sla-bar" class="grid grid-cols-2 xl:grid-cols-4 gap-3 mb-6 hidden">
    <button id="sla-overdue" class="text-left bg-red-500/10 border border-red-500/20 rounded-xl p-4 hover:bg-red-500/15 transition-all">
      <p class="text-2xl font-black text-red-400" id="sla-overdue-count">0</p>
      <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mt-1">Overdue</p>
    </button>
    <button id="sla-today" class="text-left bg-amber-500/10 border border-amber-500/20 rounded-xl p-4 hover:bg-amber-500/15 transition-all">
      <p class="text-2xl font-black text-amber-400" id="sla-today-count">0</p>
      <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mt-1">Due Today</p>
    </button>
    <div class="bg-surface-container-low border border-outline-variant/20 rounded-xl p-4">
      <p class="text-2xl font-black text-emerald-400" id="sla-ontrack-count">0</p>
      <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mt-1">On Track</p>
    </div>
    <div class="bg-surface-container-low border border-outline-variant/20 rounded-xl p-4">
      <p class="text-2xl font-black text-slate-400" id="sla-nodeadline-count">0</p>
      <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mt-1">No Deadline</p>
    </div>
  </div>

  <div class="bg-surface-container-low border border-outline-variant/20 rounded-2xl p-4 lg:p-5 mb-4">
    <div class="flex flex-wrap gap-3 items-center">
      <fieldset class="flex flex-wrap items-center gap-2 rounded-lg border border-outline-variant/30 bg-surface-container px-3 py-2">
        <legend class="px-1 text-[10px] font-bold uppercase tracking-widest text-slate-500">Severity</legend>
        <label class="inline-flex items-center gap-2 rounded-full border border-red-500/20 bg-red-500/10 px-2.5 py-1 text-xs font-semibold text-red-300 cursor-pointer">
          <input type="checkbox" value="critical" data-severity-filter class="h-3.5 w-3.5 rounded border-red-500/40 bg-transparent text-red-400 focus:ring-0" />
          Critical
        </label>
        <label class="inline-flex items-center gap-2 rounded-full border border-orange-500/20 bg-orange-500/10 px-2.5 py-1 text-xs font-semibold text-orange-300 cursor-pointer">
          <input type="checkbox" value="high" data-severity-filter class="h-3.5 w-3.5 rounded border-orange-500/40 bg-transparent text-orange-400 focus:ring-0" />
          High
        </label>
        <label class="inline-flex items-center gap-2 rounded-full border border-amber-500/20 bg-amber-500/10 px-2.5 py-1 text-xs font-semibold text-amber-300 cursor-pointer">
          <input type="checkbox" value="medium" data-severity-filter class="h-3.5 w-3.5 rounded border-amber-500/40 bg-transparent text-amber-400 focus:ring-0" />
          Medium
        </label>
        <label class="inline-flex items-center gap-2 rounded-full border border-sky-500/20 bg-sky-500/10 px-2.5 py-1 text-xs font-semibold text-sky-300 cursor-pointer">
          <input type="checkbox" value="low" data-severity-filter class="h-3.5 w-3.5 rounded border-sky-500/40 bg-transparent text-sky-400 focus:ring-0" />
          Low
        </label>
        <label class="inline-flex items-center gap-2 rounded-full border border-slate-500/20 bg-slate-500/10 px-2.5 py-1 text-xs font-semibold text-slate-300 cursor-pointer">
          <input type="checkbox" value="info" data-severity-filter class="h-3.5 w-3.5 rounded border-slate-500/40 bg-transparent text-slate-400 focus:ring-0" />
          Info
        </label>
      </fieldset>
      <select id="filter-category" class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-sky-500 transition-all">
        <option value="">All categories</option>
        <option value="sast">SAST</option>
        <option value="sca">SCA</option>
        <option value="secrets">Secrets</option>
        <option value="iac">IaC</option>
        <option value="containers">Containers</option>
        <option value="dast">DAST</option>
      </select>
      <select id="filter-file" class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-sky-500 transition-all">
        <option value="">All files</option>
      </select>
      <select id="filter-scanner" class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-sky-500 transition-all">
        <option value="">All scanners</option>
        <option value="semgrep">semgrep</option>
        <option value="gosec">gosec</option>
        <option value="trivy">trivy</option>
        <option value="grype">grype</option>
        <option value="osv-scanner">osv-scanner</option>
        <option value="trufflehog">trufflehog</option>
        <option value="gitleaks">gitleaks</option>
        <option value="checkov">checkov</option>
        <option value="tfsec">tfsec</option>
        <option value="kics">kics</option>
        <option value="trivy-image">trivy-image</option>
        <option value="grype-image">grype-image</option>
        <option value="nuclei">nuclei</option>
      </select>
      <select id="filter-status" class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-sky-500 transition-all">
        <option value="">All statuses</option>
        <option value="open">Open</option>
        <option value="in_review">In Review</option>
        <option value="accepted_risk">Accepted Risk</option>
        <option value="fixed">Fixed</option>
        <option value="verified">Verified</option>
      </select>
      <select id="sort-credibility" class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-sky-500 transition-all">
        <option value="">Sort: Default</option>
        <option value="confidence_desc">Confidence (High-Low)</option>
        <option value="confidence_asc">Confidence (Low-High)</option>
        <option value="corroborated">Most Corroborated</option>
      </select>
      <div class="relative">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 text-base pointer-events-none">search</span>
        <input id="filter-cve" type="text" placeholder="CVE-YYYY-NNNNN"
          class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg pl-9 pr-3 py-2 text-sm w-44 focus:outline-none focus:border-sky-500 transition-all placeholder:text-slate-600 font-mono" />
      </div>
      <label class="flex items-center gap-2 text-sm text-slate-400 cursor-pointer select-none">
        <input id="filter-overdue" type="checkbox" class="rounded border-slate-600 bg-surface-container text-red-400 focus:ring-0 focus:ring-offset-0 cursor-pointer" />
        <span>Overdue</span>
      </label>
      <button id="filter-btn" class="flex items-center gap-2 px-4 py-2 bg-slate-900 border border-slate-800 text-on-background rounded-lg hover:bg-slate-800 transition-colors text-sm font-semibold">
        <span class="material-symbols-outlined text-base">filter_list</span>
        Filter
      </button>
      <button id="clear-btn" class="px-3 py-2 text-slate-500 hover:text-slate-300 text-sm transition-colors">Clear</button>
      <span id="findings-total" class="text-xs text-slate-500 ml-auto font-mono"></span>
    </div>
  </div>

  <div class="bg-surface-container-low border border-outline-variant/20 rounded-2xl overflow-hidden">
    <div class="px-6 py-4 border-b border-outline-variant/20 flex items-center justify-between gap-4">
      <div>
        <p class="text-[10px] font-bold uppercase tracking-[0.24em] text-slate-500">Findings</p>
        <p class="text-sm text-slate-400 mt-1">Open a dedicated detail view to triage, inspect evidence, and generate remediation.</p>
      </div>
    </div>
    <div id="findings-table" class="overflow-x-auto">
      <p class="px-6 py-4 text-sm text-slate-500">Loading...</p>
    </div>
  </div>
</DashboardLayout>

<script>
  import { api } from '../../lib/api';
  import type { Finding } from '../../lib/api';

  const SEV_STYLES: Record<string, string> = {
    critical: 'text-red-400 bg-red-500/10 border-red-500/20',
    high:     'text-orange-400 bg-orange-500/10 border-orange-500/20',
    medium:   'text-amber-400 bg-amber-500/10 border-amber-500/20',
    low:      'text-sky-400 bg-sky-500/10 border-sky-500/20',
    info:     'text-slate-400 bg-slate-500/10 border-slate-500/20',
  };

  const STATUS_STYLES: Record<string, string> = {
    open:          'text-slate-300 bg-slate-500/10 border-slate-500/20',
    in_review:     'text-sky-400 bg-sky-500/10 border-sky-500/20',
    accepted_risk: 'text-amber-400 bg-amber-500/10 border-amber-500/20',
    fixed:         'text-emerald-400 bg-emerald-500/10 border-emerald-500/20',
    verified:      'text-teal-400 bg-teal-500/10 border-teal-500/20',
  };

  const STATUS_LABELS: Record<string, string> = {
    open: 'Open',
    in_review: 'In Review',
    accepted_risk: 'Accepted Risk',
    fixed: 'Fixed',
    verified: 'Verified',
  };

  const SCANNER_TYPE: Record<string, { label: string; color: string }> = {
    semgrep:    { label: 'SAST',    color: 'text-sky-400 bg-sky-500/10 border-sky-500/20' },
    gosec:      { label: 'SAST',    color: 'text-sky-400 bg-sky-500/10 border-sky-500/20' },
    trivy:      { label: 'SCA',     color: 'text-purple-400 bg-purple-500/10 border-purple-500/20' },
    grype:      { label: 'SCA',     color: 'text-purple-400 bg-purple-500/10 border-purple-500/20' },
    'osv-scanner': { label: 'SCA',  color: 'text-purple-400 bg-purple-500/10 border-purple-500/20' },
    trufflehog: { label: 'Secrets', color: 'text-amber-400 bg-amber-500/10 border-amber-500/20' },
    gitleaks:   { label: 'Secrets', color: 'text-amber-400 bg-amber-500/10 border-amber-500/20' },
    checkov:    { label: 'IaC',     color: 'text-emerald-400 bg-emerald-500/10 border-emerald-500/20' },
    tfsec:      { label: 'IaC',     color: 'text-emerald-400 bg-emerald-500/10 border-emerald-500/20' },
    kics:       { label: 'IaC',     color: 'text-emerald-400 bg-emerald-500/10 border-emerald-500/20' },
    'trivy-image': { label: 'Container', color: 'text-fuchsia-400 bg-fuchsia-500/10 border-fuchsia-500/20' },
    'grype-image': { label: 'Container', color: 'text-fuchsia-400 bg-fuchsia-500/10 border-fuchsia-500/20' },
    nuclei:     { label: 'DAST',    color: 'text-orange-400 bg-orange-500/10 border-orange-500/20' },
  };

  function scannerType(scanner: string) {
    return SCANNER_TYPE[scanner] ?? { label: scanner.toUpperCase(), color: 'text-slate-400 bg-slate-500/10 border-slate-500/20' };
  }

	function slaDisplay(f: Finding): string {
    if (!f.sla_deadline) return '<span class="text-xs text-slate-500">No SLA</span>';
    const resolved = f.status === 'fixed' || f.status === 'verified' || f.status === 'accepted_risk';
    if (resolved) {
      return `<span class="text-xs text-slate-500">${new Date(f.sla_deadline).toLocaleDateString()}</span>`;
    }
    const diff = new Date(f.sla_deadline).getTime() - Date.now();
    if (diff < 0) {
      return `<span class="inline-flex items-center px-2 py-1 text-[10px] font-bold rounded border bg-red-500/10 text-red-400 border-red-500/20">Overdue</span>`;
    }
    if (diff < 24 * 60 * 60 * 1000) {
      return `<span class="inline-flex items-center px-2 py-1 text-[10px] font-bold rounded border bg-amber-500/10 text-amber-400 border-amber-500/20">Due Soon</span>`;
    }
    return `<span class="text-xs text-slate-500">${new Date(f.sla_deadline).toLocaleDateString()}</span>`;
  }

  function escapeHTML(value: string): string {
    return value
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');
  }

  function safeExternalURL(value: string): string | null {
    try {
      const url = new URL(value);
      if (url.protocol !== 'http:' && url.protocol !== 'https:') {
        return null;
      }
      return url.toString();
    } catch {
      return null;
    }
  }

  function jiraDisplay(f: Finding): string {
    const issue = f.jira_issue;
    if (!issue?.issue_key) {
      return '<span class="text-xs text-slate-600">—</span>';
    }
    const issueKey = escapeHTML(issue.issue_key);
    const issueURL = issue.issue_url ? safeExternalURL(issue.issue_url) : null;
    if (!issueURL) {
      return `<span class="inline-flex items-center gap-1.5 px-2 py-1 text-[10px] font-bold rounded uppercase tracking-wider border border-blue-500/20 bg-blue-500/10 text-blue-300">${issueKey}</span>`;
    }
    return `
      <a href="${escapeHTML(issueURL)}" target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 px-2 py-1 text-[10px] font-bold rounded uppercase tracking-wider border border-blue-500/20 bg-blue-500/10 text-blue-300 hover:bg-blue-500/15 hover:text-blue-200 transition-all">
        ${issueKey}
        <span class="material-symbols-outlined text-sm">open_in_new</span>
      </a>`;
  }

  function selectedSeverities() {
    return Array.from(document.querySelectorAll<HTMLInputElement>('[data-severity-filter]:checked')).map((input) => input.value);
  }

  async function loadFindings() {
    const severity = selectedSeverities();
    const category = (document.getElementById('filter-category') as HTMLSelectElement).value;
    const scanner  = (document.getElementById('filter-scanner') as HTMLSelectElement).value;
    const status   = (document.getElementById('filter-status') as HTMLSelectElement).value;
    const cve_id   = (document.getElementById('filter-cve') as HTMLInputElement).value.trim();
    const overdue  = (document.getElementById('filter-overdue') as HTMLInputElement).checked;
    const file_path = (document.getElementById('filter-file') as HTMLSelectElement).value;
    const sortBy   = (document.getElementById('sort-credibility') as HTMLSelectElement).value;

    const { findings, total } = await api.getFindings(severity, scanner, 1, 50, status, overdue, category, cve_id, false, file_path);
    
    // Apply client-side sorting by credibility
    if (sortBy) {
      findings.sort((a, b) => {
        if (sortBy === 'confidence_desc') {
          return (b.confidence_score ?? 0) - (a.confidence_score ?? 0);
        } else if (sortBy === 'confidence_asc') {
          return (a.confidence_score ?? 0) - (b.confidence_score ?? 0);
        } else if (sortBy === 'corroborated') {
          return (b.corroboration_count ?? 0) - (a.corroboration_count ?? 0);
        }
        return 0;
      });
    }
    
    document.getElementById('findings-total')!.textContent = `${total} total`;

    const el = document.getElementById('findings-table')!;
    if (!findings.length) {
      el.innerHTML = '<p class="px-6 py-4 text-sm text-slate-500">No findings.</p>';
      return;
    }

    el.innerHTML = `
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-950/50 border-b border-slate-800">
            <th class="text-left px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">Finding</th>
			<th class="text-left px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">Severity</th>
            <th class="text-left px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">Status</th>
            <th class="text-left px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500 hidden xl:table-cell">Scanner</th>
            <th class="text-left px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500 hidden 2xl:table-cell">Credibility</th>
            <th class="text-left px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500 hidden xl:table-cell">SLA</th>
            <th class="text-left px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500 hidden lg:table-cell">Jira</th>
            <th class="text-right px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">Detail</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-800/50">
          ${findings.map((f) => {
            const sev = SEV_STYLES[f.severity] ?? SEV_STYLES.info;
            const stat = STATUS_STYLES[f.status] ?? STATUS_STYLES.open;
			const scanner = scannerType(f.scanner);
            const hasCorroboration = (f.corroboration_count ?? 0) > 0;
            const confidenceBadge = f.confidence_score != null && f.confidence_score > 0.5
              ? `<span class="px-2 py-1 text-[10px] font-bold rounded uppercase tracking-wider border border-emerald-500/20 bg-emerald-500/10 text-emerald-300" title="Confidence: ${(f.confidence_score * 100).toFixed(0)}%">High</span>`
              : f.confidence_score != null && f.confidence_score < 0.5
              ? `<span class="px-2 py-1 text-[10px] font-bold rounded uppercase tracking-wider border border-slate-500/20 bg-slate-500/10 text-slate-400" title="Confidence: ${(f.confidence_score * 100).toFixed(0)}%">Low</span>`
              : '';
            const corrobBadge = hasCorroboration
              ? `<span class="px-2 py-1 text-[10px] font-bold rounded uppercase tracking-wider border border-blue-500/20 bg-blue-500/10 text-blue-300" title="Corroborated by ${f.corroboration_count} scanner(s)">+${f.corroboration_count}</span>`
              : '';
			return `
              <tr class="group hover:bg-slate-900/30 transition-colors ${f.false_positive ? 'opacity-50' : ''}">
                <td class="px-6 py-4">
                  <a href="/dashboard/findings/detail?id=${encodeURIComponent(f.id)}" class="block">
                    <p class="font-bold text-on-background group-hover:text-sky-300 transition-colors">${f.title}</p>
                    <p class="text-xs text-slate-500 mt-0.5 truncate max-w-sm">${f.description ?? ''}</p>
                     <div class="flex items-center gap-2 mt-2 flex-wrap">
                       <span class="px-2 py-1 text-[10px] font-bold rounded uppercase tracking-wider border ${scanner.color}">${scanner.label}</span>
                       ${f.ai_analyzed ? '<span class="px-2 py-1 text-[10px] font-bold rounded uppercase tracking-wider border border-purple-500/20 bg-purple-500/10 text-purple-300">AI analyzed</span>' : ''}
                       ${hasCorroboration ? '<span class="px-2 py-1 text-[10px] font-bold rounded uppercase tracking-wider border border-blue-500/20 bg-blue-500/10 text-blue-300">Corroborated</span>' : ''}
                       ${f.assigned_to ? `<span class="text-[11px] text-sky-400/80">Owner: ${f.assigned_to}</span>` : ''}
                     </div>
                   </a>
                 </td>
				 <td class="px-6 py-4"><span class="px-2 py-1 text-[10px] font-bold rounded uppercase tracking-wider border ${sev}">${f.severity}</span></td>
                <td class="px-6 py-4"><span class="px-2 py-1 text-[10px] font-bold rounded tracking-wider border ${stat}">${STATUS_LABELS[f.status] ?? f.status}</span></td>
                <td class="px-6 py-4 hidden xl:table-cell"><span class="font-mono text-xs text-slate-400">${f.scanner}</span></td>
                <td class="px-6 py-4 hidden 2xl:table-cell">
                  <div class="flex items-center gap-1 flex-wrap">
                    ${confidenceBadge}
                    ${corrobBadge}
                  </div>
                </td>
                <td class="px-6 py-4 hidden xl:table-cell">${slaDisplay(f)}</td>
                <td class="px-6 py-4 hidden lg:table-cell">${jiraDisplay(f)}</td>
                <td class="px-6 py-4 text-right">
                  <a href="/dashboard/findings/detail?id=${encodeURIComponent(f.id)}" class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg border border-sky-500/20 bg-sky-500/5 text-sky-300 text-xs font-bold uppercase tracking-wider hover:bg-sky-500/10 transition-all">
                    Open
                    <span class="material-symbols-outlined text-sm">arrow_forward</span>
                  </a>
                </td>
              </tr>`;
          }).join('')}
        </tbody>
      </table>`;
  }

  async function loadSLA() {
    try {
      const s = await api.getSLASummary();
      document.getElementById('sla-overdue-count')!.textContent = String(s.overdue);
      document.getElementById('sla-today-count')!.textContent = String(s.due_today);
      document.getElementById('sla-ontrack-count')!.textContent = String(s.on_track);
      document.getElementById('sla-nodeadline-count')!.textContent = String(s.no_deadline);
      document.getElementById('sla-bar')!.classList.remove('hidden');
    } catch {
      // optional summary
    }
  }

  document.getElementById('filter-btn')!.addEventListener('click', loadFindings);
  document.getElementById('filter-overdue')!.addEventListener('change', loadFindings);
  document.getElementById('sort-credibility')!.addEventListener('change', loadFindings);
  document.getElementById('filter-cve')!.addEventListener('keydown', (e) => {
    if ((e as KeyboardEvent).key === 'Enter') loadFindings();
  });
  document.getElementById('sla-overdue')!.addEventListener('click', () => {
    (document.getElementById('filter-overdue') as HTMLInputElement).checked = true;
    loadFindings();
  });
  document.getElementById('sla-today')!.addEventListener('click', () => {
    (document.getElementById('filter-overdue') as HTMLInputElement).checked = false;
    (document.getElementById('filter-status') as HTMLSelectElement).value = 'open';
    loadFindings();
  });
  document.getElementById('clear-btn')!.addEventListener('click', () => {
    document.querySelectorAll<HTMLInputElement>('[data-severity-filter]').forEach((input) => {
      input.checked = false;
    });
    (document.getElementById('filter-category') as HTMLSelectElement).value = '';
    (document.getElementById('filter-scanner') as HTMLSelectElement).value = '';
    (document.getElementById('filter-status') as HTMLSelectElement).value = '';
    (document.getElementById('filter-cve') as HTMLInputElement).value = '';
    (document.getElementById('filter-overdue') as HTMLInputElement).checked = false;
    (document.getElementById('filter-file') as HTMLSelectElement).value = '';
    (document.getElementById('sort-credibility') as HTMLSelectElement).value = '';
    loadFindings();
  });

  async function loadFileOptions() {
    try {
      const files = await api.getUniqueFiles();
      const select = document.getElementById('filter-file') as HTMLSelectElement;
      files.forEach((file) => {
        const opt = document.createElement('option');
        opt.value = file;
        opt.textContent = file;
        select.appendChild(opt);
      });
    } catch {
      // no files
    }
  }

  loadSLA();
  loadFileOptions();
  loadFindings();
</script>
