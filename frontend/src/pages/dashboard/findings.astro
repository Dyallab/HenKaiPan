---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---
<DashboardLayout title="Security Findings" active="findings">

  <!-- SLA summary bar -->
  <div id="sla-bar" class="grid grid-cols-4 gap-3 mb-6 hidden">
    <div id="sla-overdue"   class="bg-red-500/10 border border-red-500/20 rounded-xl p-4 text-center cursor-pointer hover:bg-red-500/15 transition-all">
      <p class="text-2xl font-black text-red-400" id="sla-overdue-count">0</p>
      <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mt-1">Overdue</p>
    </div>
    <div id="sla-today" class="bg-amber-500/10 border border-amber-500/20 rounded-xl p-4 text-center cursor-pointer hover:bg-amber-500/15 transition-all">
      <p class="text-2xl font-black text-amber-400" id="sla-today-count">0</p>
      <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mt-1">Due Today</p>
    </div>
    <div class="bg-surface-container-low border border-outline-variant/20 rounded-xl p-4 text-center">
      <p class="text-2xl font-black text-emerald-400" id="sla-ontrack-count">0</p>
      <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mt-1">On Track</p>
    </div>
    <div class="bg-surface-container-low border border-outline-variant/20 rounded-xl p-4 text-center">
      <p class="text-2xl font-black text-slate-400" id="sla-nodeadline-count">0</p>
      <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mt-1">No Deadline</p>
    </div>
  </div>

  <!-- Filters -->
  <div class="flex gap-3 mb-4 flex-wrap items-center">
    <select id="filter-severity" class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-sky-500 transition-all">
      <option value="">All severities</option>
      <option value="critical">Critical</option>
      <option value="high">High</option>
      <option value="medium">Medium</option>
      <option value="low">Low</option>
      <option value="info">Info</option>
    </select>
    <select id="filter-category" class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-sky-500 transition-all">
      <option value="">All categories</option>
      <option value="sast">SAST</option>
      <option value="sca">SCA</option>
      <option value="secrets">Secrets</option>
      <option value="iac">IaC</option>
      <option value="containers">Containers</option>
      <option value="dast">DAST</option>
    </select>
    <select id="filter-scanner" class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-sky-500 transition-all">
      <option value="">All scanners</option>
      <option value="semgrep">semgrep</option>
      <option value="gosec">gosec</option>
      <option value="trivy">trivy</option>
      <option value="grype">grype</option>
      <option value="osv-scanner">osv-scanner</option>
      <option value="trufflehog">trufflehog</option>
      <option value="gitleaks">gitleaks</option>
      <option value="checkov">checkov</option>
      <option value="tfsec">tfsec</option>
      <option value="kics">kics</option>
      <option value="trivy-image">trivy-image</option>
      <option value="grype-image">grype-image</option>
      <option value="nuclei">nuclei</option>
    </select>
    <select id="filter-status" class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-sky-500 transition-all">
      <option value="">All statuses</option>
      <option value="open">Open</option>
      <option value="in_review">In Review</option>
      <option value="accepted_risk">Accepted Risk</option>
      <option value="fixed">Fixed</option>
      <option value="verified">Verified</option>
    </select>
    <div class="relative">
      <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 text-base pointer-events-none">search</span>
      <input id="filter-cve" type="text" placeholder="CVE-YYYY-NNNNN"
        class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg pl-9 pr-3 py-2 text-sm w-44 focus:outline-none focus:border-sky-500 transition-all placeholder:text-slate-600 font-mono" />
    </div>
    <label class="flex items-center gap-2 text-sm text-slate-400 cursor-pointer select-none">
      <input id="filter-overdue" type="checkbox" class="rounded border-slate-600 bg-surface-container text-red-400 focus:ring-0 focus:ring-offset-0 cursor-pointer" />
      <span>Overdue</span>
    </label>
    <button id="filter-btn" class="flex items-center gap-2 px-4 py-2 bg-slate-900 border border-slate-800 text-on-background rounded-lg hover:bg-slate-800 transition-colors text-sm font-semibold">
      <span class="material-symbols-outlined text-base">filter_list</span>
      Filter
    </button>
    <button id="clear-btn" class="px-3 py-2 text-slate-500 hover:text-slate-300 text-sm transition-colors">Clear</button>
    <span id="findings-total" class="text-xs text-slate-500 ml-auto font-mono"></span>
  </div>

  <!-- Findings table -->
  <div class="bg-surface-container-low border border-outline-variant/20 rounded-xl overflow-hidden">
    <div id="findings-table" class="overflow-x-auto">
      <p class="px-6 py-4 text-sm text-slate-500">Loading...</p>
    </div>
  </div>

</DashboardLayout>

<!-- Triage modal -->
<div id="triage-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4">
  <div class="bg-surface-container border border-outline-variant/30 rounded-xl w-full max-w-lg max-h-[90vh] overflow-auto">
    <div class="px-6 py-4 border-b border-outline-variant/20 flex items-center justify-between">
      <h3 class="text-sm font-bold text-on-background">Triage Finding</h3>
      <button id="triage-close" class="text-slate-500 hover:text-on-background transition-colors text-xl leading-none">×</button>
    </div>
    <div class="px-6 py-5 space-y-5">

      <!-- Finding info (read-only) -->
      <div>
        <p id="triage-title" class="text-sm font-semibold text-on-background"></p>
        <div class="flex gap-2 mt-2 flex-wrap">
          <span id="triage-severity" class="text-[10px] font-bold capitalize px-2 py-1 rounded border"></span>
          <span id="triage-scanner" class="font-mono text-xs text-slate-400 bg-surface-container-low border border-outline-variant/20 px-2.5 py-1 rounded"></span>
          <span id="triage-cve" class="hidden"></span>
          <span id="triage-cwe" class="hidden"></span>
        </div>
        <p id="triage-desc" class="text-xs text-slate-500 mt-2"></p>
      </div>

      <!-- SLA info -->
      <div id="triage-sla-row" class="hidden">
        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">SLA Deadline</p>
        <p id="triage-sla" class="text-sm"></p>
      </div>

      <!-- Status -->
      <div>
        <label class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-2 block">Status</label>
        <select id="triage-status" class="w-full bg-surface-container-low border border-outline-variant/30 text-on-background rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-sky-500 transition-all">
          <option value="open">Open</option>
          <option value="in_review">In Review</option>
          <option value="accepted_risk">Accepted Risk</option>
          <option value="fixed">Fixed</option>
          <option value="verified">Verified</option>
        </select>
      </div>

      <!-- Assigned to -->
      <div>
        <label class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-2 block">Assigned To</label>
        <input id="triage-assigned" list="users-datalist" type="text" placeholder="username or email"
          class="w-full bg-surface-container-low border border-outline-variant/30 text-on-background rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-all placeholder:text-slate-600" />
        <datalist id="users-datalist"></datalist>
      </div>

      <!-- False positive -->
      <label class="flex items-center gap-3 cursor-pointer">
        <input id="triage-fp" type="checkbox" class="rounded border-slate-600 bg-surface-container text-amber-400 focus:ring-0 cursor-pointer" />
        <div>
          <p class="text-sm text-on-background font-medium">False Positive</p>
          <p class="text-xs text-slate-500">Mark this finding as a false positive</p>
        </div>
      </label>

      <!-- Notes -->
      <div>
        <label class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-2 block">Notes</label>
        <textarea id="triage-notes" rows="3" placeholder="Add context, remediation notes, risk acceptance reason..."
          class="w-full bg-surface-container-low border border-outline-variant/30 text-on-background rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-all placeholder:text-slate-600 resize-none"></textarea>
      </div>

      <!-- Error -->
      <p id="triage-error" class="hidden text-sm text-red-400"></p>
    </div>

    <div class="px-6 py-4 border-t border-outline-variant/20 flex items-center justify-between gap-3">
      <div class="flex items-center gap-2">
        <button id="kb-remediate-btn"
          class="flex items-center gap-1.5 px-4 py-2 text-purple-400 border border-purple-500/20 bg-purple-500/5 rounded-lg text-sm font-bold hover:bg-purple-500/10 transition-all active:scale-95">
          <span class="material-symbols-outlined text-sm">auto_awesome</span>
          <span id="kb-btn-label">Remediation Guide</span>
        </button>
        <a id="kb-view-link" href="#" target="_blank"
          class="hidden items-center gap-1.5 px-3 py-2 text-emerald-400 border border-emerald-500/20 bg-emerald-500/5 rounded-lg text-sm font-bold hover:bg-emerald-500/10 transition-all">
          <span class="material-symbols-outlined text-sm">open_in_new</span>View Guide
        </a>
      </div>
      <div class="flex gap-3">
        <button id="triage-cancel" class="px-5 py-2 bg-slate-900 border border-slate-800 text-on-background rounded-lg text-sm font-bold hover:bg-slate-800 transition-colors">
          Cancel
        </button>
        <button id="triage-save" class="flex items-center gap-2 px-5 py-2 bg-sky-500 text-slate-950 rounded-lg text-sm font-bold hover:bg-sky-400 transition-all active:scale-95">
          <span class="material-symbols-outlined text-sm">save</span>
          Save
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  import { api } from '../../lib/api';
  import type { Finding } from '../../lib/api';

  const SEV_STYLES: Record<string, string> = {
    critical: 'text-red-400 bg-red-500/10 border-red-500/20',
    high:     'text-orange-400 bg-orange-500/10 border-orange-500/20',
    medium:   'text-amber-400 bg-amber-500/10 border-amber-500/20',
    low:      'text-sky-400 bg-sky-500/10 border-sky-500/20',
    info:     'text-slate-400 bg-slate-500/10 border-slate-500/20',
  };

  const STATUS_STYLES: Record<string, string> = {
    open:          'text-slate-400 bg-slate-500/10 border-slate-500/20',
    in_review:     'text-sky-400 bg-sky-500/10 border-sky-500/20',
    accepted_risk: 'text-amber-400 bg-amber-500/10 border-amber-500/20',
    fixed:         'text-emerald-400 bg-emerald-500/10 border-emerald-500/20',
    verified:      'text-teal-400 bg-teal-500/10 border-teal-500/20',
  };

  const STATUS_LABELS: Record<string, string> = {
    open:          'Open',
    in_review:     'In Review',
    accepted_risk: 'Accepted Risk',
    fixed:         'Fixed',
    verified:      'Verified',
  };

  const SCANNER_TYPE: Record<string, { label: string; color: string }> = {
    semgrep:    { label: 'SAST',    color: 'text-sky-400 bg-sky-500/10 border-sky-500/20' },
    gosec:      { label: 'SAST',    color: 'text-sky-400 bg-sky-500/10 border-sky-500/20' },
    trivy:      { label: 'SCA',     color: 'text-purple-400 bg-purple-500/10 border-purple-500/20' },
    grype:      { label: 'SCA',     color: 'text-purple-400 bg-purple-500/10 border-purple-500/20' },
    trufflehog: { label: 'Secrets', color: 'text-amber-400 bg-amber-500/10 border-amber-500/20' },
    gitleaks:   { label: 'Secrets', color: 'text-amber-400 bg-amber-500/10 border-amber-500/20' },
    checkov:    { label: 'IaC',     color: 'text-green-400 bg-green-500/10 border-green-500/20' },
    tfsec:      { label: 'IaC',     color: 'text-green-400 bg-green-500/10 border-green-500/20' },
    nuclei:     { label: 'DAST',    color: 'text-orange-400 bg-orange-500/10 border-orange-500/20' },
  };

  function slaDisplay(f: Finding): string {
    if (!f.sla_deadline) return '';
    const resolved = f.status === 'fixed' || f.status === 'verified' || f.status === 'accepted_risk';
    if (resolved) {
      return `<span class="text-xs text-slate-500">${new Date(f.sla_deadline).toLocaleDateString()}</span>`;
    }
    const now  = Date.now();
    const dead = new Date(f.sla_deadline).getTime();
    const diff = dead - now;
    if (diff < 0) {
      return `<span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-red-500/10 text-red-400 border border-red-500/20">Overdue</span>
              <span class="text-xs text-red-400/70 ml-1">${new Date(f.sla_deadline).toLocaleDateString()}</span>`;
    }
    if (diff < 24 * 60 * 60 * 1000) {
      return `<span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-amber-500/10 text-amber-400 border border-amber-500/20">Due Soon</span>
              <span class="text-xs text-amber-400/70 ml-1">${new Date(f.sla_deadline).toLocaleString()}</span>`;
    }
    return `<span class="text-xs text-slate-500">${new Date(f.sla_deadline).toLocaleDateString()}</span>`;
  }

  let currentFindingId = '';

  async function loadFindings() {
    const severity = (document.getElementById('filter-severity') as HTMLSelectElement).value;
    const category = (document.getElementById('filter-category') as HTMLSelectElement).value;
    const scanner  = (document.getElementById('filter-scanner')  as HTMLSelectElement).value;
    const status   = (document.getElementById('filter-status')   as HTMLSelectElement).value;
    const cve_id   = (document.getElementById('filter-cve')      as HTMLInputElement).value.trim();
    const overdue  = (document.getElementById('filter-overdue')  as HTMLInputElement).checked;

    const { findings, total } = await api.getFindings(severity, scanner, 1, 50, status, overdue, category, cve_id);
    document.getElementById('findings-total')!.textContent = `${total} total`;

    const el = document.getElementById('findings-table')!;
    if (!findings.length) {
      el.innerHTML = '<p class="px-6 py-4 text-sm text-slate-500">No findings.</p>';
      return;
    }

    el.innerHTML = `
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-950/50 border-b border-slate-800">
            <th class="text-left px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">Finding</th>
            <th class="text-left px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">Severity</th>
            <th class="text-left px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">Status</th>
            <th class="text-left px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500 hidden lg:table-cell">Type</th>
            <th class="text-left px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500 hidden md:table-cell">Scanner</th>
            <th class="text-left px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500 hidden xl:table-cell">SLA</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-800/50">
          ${findings.map((f, i) => {
            const sev    = SEV_STYLES[f.severity] ?? SEV_STYLES.info;
            const stat   = STATUS_STYLES[f.status] ?? STATUS_STYLES.open;
            const type   = SCANNER_TYPE[f.scanner] ?? { label: f.scanner.toUpperCase(), color: 'text-slate-400 bg-slate-500/10 border-slate-500/20' };
            const isOpen = f.status === 'open' || f.status === 'in_review';
            return `
              <tr class="hover:bg-slate-900/30 transition-colors cursor-pointer ${f.false_positive ? 'opacity-50' : ''}" data-idx="${i}">
                <td class="px-6 py-4">
                  <p class="font-bold text-on-background">${f.title}</p>
                  <p class="text-xs text-slate-500 mt-0.5 truncate max-w-sm">${f.description ?? ''}</p>
                  ${f.assigned_to ? `<p class="text-xs text-sky-500/70 mt-0.5">→ ${f.assigned_to}</p>` : ''}
                </td>
                <td class="px-6 py-4">
                  <span class="px-2 py-1 text-[10px] font-bold rounded uppercase tracking-wider border ${sev}">${f.severity}</span>
                </td>
                <td class="px-6 py-4">
                  <span class="px-2 py-1 text-[10px] font-bold rounded capitalize tracking-wider border ${stat}">${STATUS_LABELS[f.status] ?? f.status}</span>
                </td>
                <td class="px-6 py-4 hidden lg:table-cell">
                  <span class="px-2 py-1 text-[10px] font-bold rounded uppercase tracking-wider border ${type.color}">${type.label}</span>
                </td>
                <td class="px-6 py-4 hidden md:table-cell">
                  <span class="font-mono text-xs text-slate-400">${f.scanner}</span>
                </td>
                <td class="px-6 py-4 hidden xl:table-cell">${slaDisplay(f)}</td>
              </tr>`;
          }).join('')}
        </tbody>
      </table>`;

    // store findings for modal access
    (window as any).__findings = findings;

    el.querySelectorAll('tr[data-idx]').forEach(row => {
      row.addEventListener('click', () => {
        openTriage(findings[parseInt((row as HTMLElement).dataset.idx!)]);
      });
    });
  }

  // ── Triage modal ─────────────────────────────────────────────────────────────

  function openTriage(f: Finding) {
    currentFindingId = f.id;

    document.getElementById('triage-title')!.textContent = f.title;

    const sevEl = document.getElementById('triage-severity')!;
    sevEl.textContent = f.severity;
    sevEl.className   = `text-[10px] font-bold capitalize px-2 py-1 rounded border ${SEV_STYLES[f.severity] ?? ''}`;

    document.getElementById('triage-scanner')!.textContent = f.scanner;
    document.getElementById('triage-desc')!.textContent    = f.description || '';

    const cveEl = document.getElementById('triage-cve')!;
    const cweEl = document.getElementById('triage-cwe')!;
    if (f.cve_id) {
      cveEl.innerHTML = `<a href="https://nvd.nist.gov/vuln/detail/${f.cve_id}" target="_blank" rel="noopener"
        class="font-mono text-xs font-bold text-red-400 bg-red-500/10 border border-red-500/20 px-2.5 py-1 rounded hover:bg-red-500/20 transition-colors">${f.cve_id}</a>`;
      cveEl.classList.remove('hidden');
    } else {
      cveEl.innerHTML = ''; cveEl.classList.add('hidden');
    }
    if (f.cwe_id) {
      const cweNum = f.cwe_id.match(/\d+/)?.[0] ?? '';
      const href = cweNum ? `https://cwe.mitre.org/data/definitions/${cweNum}.html` : '#';
      cweEl.innerHTML = `<a href="${href}" target="_blank" rel="noopener"
        class="font-mono text-xs font-bold text-purple-400 bg-purple-500/10 border border-purple-500/20 px-2.5 py-1 rounded hover:bg-purple-500/20 transition-colors">${f.cwe_id}</a>`;
      cweEl.classList.remove('hidden');
    } else {
      cweEl.innerHTML = ''; cweEl.classList.add('hidden');
    }

    const slaRow = document.getElementById('triage-sla-row')!;
    if (f.sla_deadline) {
      slaRow.classList.remove('hidden');
      document.getElementById('triage-sla')!.innerHTML = slaDisplay(f);
    } else {
      slaRow.classList.add('hidden');
    }

    (document.getElementById('triage-status')   as HTMLSelectElement).value    = f.status ?? 'open';
    (document.getElementById('triage-assigned')  as HTMLInputElement).value    = f.assigned_to ?? '';
    (document.getElementById('triage-fp')        as HTMLInputElement).checked  = f.false_positive ?? false;
    (document.getElementById('triage-notes')     as HTMLTextAreaElement).value = f.notes ?? '';

    const viewLink = document.getElementById('kb-view-link') as HTMLAnchorElement;
    if (f.remediation_slug) {
      viewLink.href = `/dashboard/knowledge?slug=${encodeURIComponent(f.remediation_slug)}`;
      viewLink.classList.remove('hidden');
      viewLink.classList.add('flex');
    } else {
      viewLink.classList.add('hidden');
      viewLink.classList.remove('flex');
    }

    document.getElementById('triage-error')!.classList.add('hidden');
    document.getElementById('triage-modal')!.classList.remove('hidden');
  }

  document.getElementById('triage-close')!.addEventListener('click', () => {
    document.getElementById('triage-modal')!.classList.add('hidden');
  });
  document.getElementById('triage-cancel')!.addEventListener('click', () => {
    document.getElementById('triage-modal')!.classList.add('hidden');
  });
  document.getElementById('triage-modal')!.addEventListener('click', e => {
    if (e.target === e.currentTarget) document.getElementById('triage-modal')!.classList.add('hidden');
  });

  document.getElementById('triage-save')!.addEventListener('click', async () => {
    const btn = document.getElementById('triage-save') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Saving…';

    const errEl = document.getElementById('triage-error')!;
    errEl.classList.add('hidden');

    try {
      const status      = (document.getElementById('triage-status')   as HTMLSelectElement).value;
      const assigned_to = (document.getElementById('triage-assigned')  as HTMLInputElement).value.trim() || undefined;
      const false_positive = (document.getElementById('triage-fp')    as HTMLInputElement).checked;
      const notes       = (document.getElementById('triage-notes')    as HTMLTextAreaElement).value.trim() || undefined;

      await api.updateFinding(currentFindingId, { status, assigned_to, false_positive, notes });
      document.getElementById('triage-modal')!.classList.add('hidden');
      loadFindings();
    } catch (err: any) {
      errEl.textContent = err.message;
      errEl.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btn.innerHTML = '<span class="material-symbols-outlined text-sm">save</span> Save';
    }
  });

  // ── SLA bar ──────────────────────────────────────────────────────────────────

  async function loadSLA() {
    try {
      const s = await api.getSLASummary();
      document.getElementById('sla-overdue-count')!.textContent  = String(s.overdue);
      document.getElementById('sla-today-count')!.textContent    = String(s.due_today);
      document.getElementById('sla-ontrack-count')!.textContent  = String(s.on_track);
      document.getElementById('sla-nodeadline-count')!.textContent = String(s.no_deadline);
      document.getElementById('sla-bar')!.classList.remove('hidden');
    } catch { /* SLA bar is optional */ }
  }

  // SLA shortcuts: click overdue → filter by overdue
  document.getElementById('sla-overdue')!.addEventListener('click', () => {
    (document.getElementById('filter-overdue') as HTMLInputElement).checked = true;
    loadFindings();
  });
  document.getElementById('sla-today')!.addEventListener('click', () => {
    (document.getElementById('filter-overdue') as HTMLInputElement).checked = false;
    (document.getElementById('filter-status')  as HTMLSelectElement).value  = 'open';
    loadFindings();
  });

  document.getElementById('filter-btn')!.addEventListener('click', loadFindings);
  document.getElementById('filter-overdue')!.addEventListener('change', loadFindings);
  document.getElementById('filter-cve')!.addEventListener('keydown', (e) => {
    if ((e as KeyboardEvent).key === 'Enter') loadFindings();
  });

  document.getElementById('clear-btn')!.addEventListener('click', () => {
    (document.getElementById('filter-severity') as HTMLSelectElement).value = '';
    (document.getElementById('filter-category') as HTMLSelectElement).value = '';
    (document.getElementById('filter-scanner')  as HTMLSelectElement).value = '';
    (document.getElementById('filter-status')   as HTMLSelectElement).value = '';
    (document.getElementById('filter-cve')      as HTMLInputElement).value  = '';
    (document.getElementById('filter-overdue')  as HTMLInputElement).checked = false;
    loadFindings();
  });

  loadSLA();
  loadFindings();

  // Populate assignment datalist from users API
  api.getUsers().then(users => {
    const dl = document.getElementById('users-datalist')!;
    dl.innerHTML = users.map(u => `<option value="${u.username}">${u.username} — ${u.email}</option>`).join('');
  }).catch(() => {});

  // Remediation Guide button
  document.getElementById('kb-remediate-btn')!.addEventListener('click', async () => {
    if (!currentFindingId) return;
    const btn   = document.getElementById('kb-remediate-btn') as HTMLButtonElement;
    const label = document.getElementById('kb-btn-label')!;
    btn.disabled = true;
    label.textContent = 'Generating…';
    // Open tab synchronously to avoid popup blocker (async calls lose user gesture context)
    const win = window.open('data:text/html,<html><head><title>Generating…</title></head><body style="background:%230f172a;color:%2394a3b8;font-family:sans-serif;display:flex;flex-direction:column;align-items:center;justify-content:center;height:100vh;margin:0;gap:12px"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="%236366f1" stroke-width="2"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg><p style="margin:0;font-size:14px">Generating remediation guide…</p></body></html>', '_blank');
    try {
      const { article } = await api.aiRemediate(currentFindingId);
      const url = `/dashboard/knowledge?slug=${encodeURIComponent(article.slug)}`;
      if (win) win.location.href = url;
      const viewLink = document.getElementById('kb-view-link') as HTMLAnchorElement;
      viewLink.href = url;
      viewLink.classList.remove('hidden');
      viewLink.classList.add('flex');
    } catch (e: any) {
      if (win) win.close();
      label.textContent = e.message.includes('API_KEY') ? 'API key not set' : 'Failed — retry';
      setTimeout(() => { label.textContent = 'Remediation Guide'; btn.disabled = false; }, 3000);
      return;
    }
    label.textContent = 'Remediation Guide';
    btn.disabled = false;
  });
</script>
