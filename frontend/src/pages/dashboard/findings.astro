---
import DashboardLayout from '@layouts/DashboardLayout.astro';
---

<DashboardLayout title="Security Findings" active="findings">
  <div id="sla-bar" class="grid grid-cols-2 xl:grid-cols-4 gap-3 mb-4 hidden">
    <button id="sla-overdue" class="text-left bg-red-500/10 border border-red-500/20 rounded-xl p-4 hover:bg-red-500/15 transition-all">
      <p class="text-2xl font-black text-red-400" id="sla-overdue-count">0</p>
      <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mt-1">Overdue</p>
    </button>
    <button id="sla-today" class="text-left bg-amber-500/10 border border-amber-500/20 rounded-xl p-4 hover:bg-amber-500/15 transition-all">
      <p class="text-2xl font-black text-amber-400" id="sla-today-count">0</p>
      <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mt-1">Due Today</p>
    </button>
    <div class="bg-surface-container-low border border-outline-variant/20 rounded-xl p-4">
      <p class="text-2xl font-black text-emerald-400" id="sla-ontrack-count">0</p>
      <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mt-1">On Track</p>
    </div>
    <div class="bg-surface-container-low border border-outline-variant/20 rounded-xl p-4">
      <p class="text-2xl font-black text-slate-400" id="sla-nodeadline-count">0</p>
      <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mt-1">No Deadline</p>
    </div>
  </div>

  <div class="bg-surface-container-low border border-outline-variant/20 rounded-2xl p-3 lg:p-4 mb-3">
    <div class="flex flex-wrap gap-3 items-center">
      <fieldset class="flex flex-wrap items-center gap-2 rounded-lg border border-outline-variant/30 bg-surface-container px-3 py-2">
        <legend class="px-1 text-[10px] font-bold uppercase tracking-widest text-slate-500">Severity</legend>
        <label class="inline-flex items-center gap-2 rounded-full border border-vivid-crimson/20 bg-vivid-crimson/10 px-2.5 py-1 text-xs font-semibold text-vivid-crimson cursor-pointer">
          <input type="checkbox" value="critical" data-severity-filter class="h-3.5 w-3.5 rounded border-vivid-crimson/40 bg-transparent text-vivid-crimson focus:ring-0" />
          Critical
        </label>
        <label class="inline-flex items-center gap-2 rounded-full border border-goldenrod/20 bg-goldenrod/10 px-2.5 py-1 text-xs font-semibold text-goldenrod cursor-pointer">
          <input type="checkbox" value="high" data-severity-filter class="h-3.5 w-3.5 rounded border-goldenrod/40 bg-transparent text-goldenrod focus:ring-0" />
          High
        </label>
        <label class="inline-flex items-center gap-2 rounded-full border border-spectrum-flare/20 bg-spectrum-flare/10 px-2.5 py-1 text-xs font-semibold text-spectrum-flare cursor-pointer">
          <input type="checkbox" value="medium" data-severity-filter class="h-3.5 w-3.5 rounded border-spectrum-flare/40 bg-transparent text-spectrum-flare focus:ring-0" />
          Medium
        </label>
        <label class="inline-flex items-center gap-2 rounded-full border border-emerald-green/20 bg-emerald-green/10 px-2.5 py-1 text-xs font-semibold text-emerald-green cursor-pointer">
          <input type="checkbox" value="low" data-severity-filter class="h-3.5 w-3.5 rounded border-emerald-green/40 bg-transparent text-emerald-green focus:ring-0" />
          Low
        </label>
        <label class="inline-flex items-center gap-2 rounded-full border border-iron-slate/20 bg-iron-slate/10 px-2.5 py-1 text-xs font-semibold text-iron-slate cursor-pointer">
          <input type="checkbox" value="info" data-severity-filter class="h-3.5 w-3.5 rounded border-iron-slate/40 bg-transparent text-iron-slate focus:ring-0" />
          Info
        </label>
      </fieldset>
      <select id="filter-category" class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-cyan-500 transition-all">
        <option value="">All categories</option>
        <option value="sast">SAST</option>
        <option value="sca">SCA</option>
        <option value="secrets">Secrets</option>
        <option value="iac">IaC</option>
        <option value="containers">Containers</option>
        <option value="dast">DAST</option>
      </select>
      <select id="filter-file" class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-cyan-500 transition-all">
        <option value="">All files</option>
      </select>
      <select id="filter-scanner" class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-cyan-500 transition-all">
        <option value="">All scanners</option>
        <option value="semgrep">semgrep</option>
        <option value="gosec">gosec</option>
        <option value="trivy">trivy</option>
        <option value="grype">grype</option>
        <option value="osv-scanner">osv-scanner</option>
        <option value="trufflehog">trufflehog</option>
        <option value="gitleaks">gitleaks</option>
        <option value="checkov">checkov</option>
        <option value="tfsec">tfsec</option>
        <option value="kics">kics</option>
        <option value="trivy-image">trivy-image</option>
        <option value="grype-image">grype-image</option>
        <option value="nuclei">nuclei</option>
      </select>
      <select id="filter-status" class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-cyan-500 transition-all">
        <option value="">All statuses</option>
        <option value="open">Open</option>
        <option value="in_review">In Review</option>
        <option value="accepted_risk">Accepted Risk</option>
        <option value="fixed">Fixed</option>
        <option value="verified">Verified</option>
      </select>
      <select id="sort-credibility" class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-cyan-500 transition-all">
        <option value="">Sort: Default</option>
        <option value="confidence_desc">Confidence (High-Low)</option>
        <option value="confidence_asc">Confidence (Low-High)</option>
        <option value="corroborated">Most Corroborated</option>
      </select>
      <div class="relative">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 text-base pointer-events-none">search</span>
        <input id="filter-cve" type="text" placeholder="CVE-YYYY-NNNNN"
          class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg pl-9 pr-3 py-2 text-sm w-44 focus:outline-none focus:border-cyan-500 transition-all placeholder:text-slate-600 font-mono" />
      </div>
      <label class="flex items-center gap-2 text-sm text-slate-400 cursor-pointer select-none">
        <input id="filter-overdue" type="checkbox" class="rounded border-slate-600 bg-surface-container text-red-400 focus:ring-0 focus:ring-offset-0 cursor-pointer" />
        <span>Overdue</span>
      </label>
      <button id="filter-btn" class="flex items-center gap-2 px-4 py-2 bg-slate-900 border border-slate-800 text-on-background rounded-lg hover:bg-slate-800 transition-colors text-sm font-semibold">
        <span class="material-symbols-outlined text-base">filter_list</span>
        Filter
      </button>
      <button id="clear-btn" class="px-3 py-2 text-slate-500 hover:text-slate-300 text-sm transition-colors">Clear</button>
      <span id="findings-total" class="text-xs text-slate-500 ml-auto font-mono"></span>
    </div>
  </div>

  <div class="bg-surface-container-low border border-outline-variant/20 rounded-2xl overflow-hidden">
    <div class="px-5 py-3 border-b border-outline-variant/20 flex items-center justify-between gap-4">
      <div>
        <p class="text-[10px] font-bold uppercase tracking-[0.24em] text-slate-500">Findings</p>
        <p class="text-sm text-slate-400 mt-1">Open a dedicated detail view to triage, inspect evidence, and generate remediation.</p>
      </div>
      <div id="bulk-actions" class="hidden items-center gap-3 flex-wrap">
        <span class="text-xs text-slate-400 whitespace-nowrap"><span id="selected-count">0</span> selected</span>
        <select id="bulk-status" class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-cyan-500 transition-all">
          <option value="">Change status...</option>
          <option value="open">Open</option>
          <option value="in_review">In Review</option>
          <option value="accepted_risk">Accepted Risk</option>
          <option value="fixed">Fixed</option>
          <option value="verified">Verified</option>
        </select>
        <select id="bulk-assign" class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-cyan-500 transition-all min-w-[140px]">
          <option value="">Assign to...</option>
          <option value="__clear__">— Clear assignee —</option>
        </select>
        <textarea id="bulk-notes" placeholder="Add notes…"
          class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-cyan-500 transition-all placeholder:text-slate-600 resize-none h-9 w-48"></textarea>
        <button id="bulk-apply" class="inline-flex items-center gap-1.5 px-4 py-2 bg-cyan-500 hover:bg-cyan-400 text-slate-950 rounded-lg text-xs font-bold uppercase tracking-wider transition-colors">
          Apply
        </button>
        <button id="bulk-clear" class="px-3 py-2 text-slate-500 hover:text-slate-300 text-sm transition-colors">Clear</button>
      </div>
    </div>
    <div id="findings-table" class="overflow-x-auto">
      <p class="px-5 py-3 text-sm text-slate-500">Loading...</p>
    </div>
  </div>
</DashboardLayout>

<script>
  import { api } from '@lib/api';
  import type { Finding } from '@lib/api';
  import { getCurrentUser, canWrite } from '@lib/auth';

  // Ensure user is loaded before checking write access
  await getCurrentUser();
  let selectedFindingIds: Set<string> = new Set();
  const hasWriteAccess = canWrite();

  if (!hasWriteAccess) {
    document.getElementById('bulk-actions')?.remove();
    document.getElementById('select-all-findings')?.closest('th')?.remove();
  }

  const SEV_STYLES: Record<string, string> = {
    critical: 'text-vivid-crimson bg-vivid-crimson/10 border-vivid-crimson/20',
    high:     'text-goldenrod bg-goldenrod/10 border-goldenrod/20',
    medium:   'text-spectrum-flare bg-spectrum-flare/10 border-spectrum-flare/20',
    low:      'text-emerald-green bg-emerald-green/10 border-emerald-green/20',
    info:     'text-iron-slate bg-iron-slate/10 border-iron-slate/20',
  };

  const STATUS_STYLES: Record<string, string> = {
    open:          'text-vivid-crimson bg-vivid-crimson/10 border-vivid-crimson/20',
    in_review:     'text-iridescent-glow bg-iridescent-glow/10 border-iridescent-glow/20',
    accepted_risk: 'text-goldenrod bg-goldenrod/10 border-goldenrod/20',
    fixed:         'text-emerald-green bg-emerald-green/10 border-emerald-green/20',
    verified:      'text-emerald-green bg-emerald-green/10 border-emerald-green/20',
  };

  const STATUS_LABELS: Record<string, string> = {
    open: 'Open',
    in_review: 'In Review',
    accepted_risk: 'Accepted Risk',
    fixed: 'Fixed',
    verified: 'Verified',
  };

  const SCANNER_TYPE: Record<string, { label: string; color: string }> = {
    semgrep:    { label: 'SAST',    color: 'text-cyan-400 bg-cyan-500/10 border-cyan-500/20' },
    gosec:      { label: 'SAST',    color: 'text-cyan-400 bg-cyan-500/10 border-cyan-500/20' },
    trivy:      { label: 'SCA',     color: 'text-purple-400 bg-purple-500/10 border-purple-500/20' },
    grype:      { label: 'SCA',     color: 'text-purple-400 bg-purple-500/10 border-purple-500/20' },
    'osv-scanner': { label: 'SCA',  color: 'text-purple-400 bg-purple-500/10 border-purple-500/20' },
    trufflehog: { label: 'Secrets', color: 'text-amber-400 bg-amber-500/10 border-amber-500/20' },
    gitleaks:   { label: 'Secrets', color: 'text-amber-400 bg-amber-500/10 border-amber-500/20' },
    checkov:    { label: 'IaC',     color: 'text-emerald-400 bg-emerald-500/10 border-emerald-500/20' },
    tfsec:      { label: 'IaC',     color: 'text-emerald-400 bg-emerald-500/10 border-emerald-500/20' },
    kics:       { label: 'IaC',     color: 'text-emerald-400 bg-emerald-500/10 border-emerald-500/20' },
    'trivy-image': { label: 'Container', color: 'text-fuchsia-400 bg-fuchsia-500/10 border-fuchsia-500/20' },
    'grype-image': { label: 'Container', color: 'text-fuchsia-400 bg-fuchsia-500/10 border-fuchsia-500/20' },
    nuclei:     { label: 'DAST',    color: 'text-orange-400 bg-orange-500/10 border-orange-500/20' },
  };

  function scannerType(scanner: string) {
    return SCANNER_TYPE[scanner] ?? { label: scanner.toUpperCase(), color: 'text-slate-400 bg-slate-500/10 border-slate-500/20' };
  }

	function slaDisplay(f: Finding): string {
    if (!f.sla_deadline) return '<span class="text-xs text-slate-500">No SLA</span>';
    const resolved = f.status === 'fixed' || f.status === 'verified' || f.status === 'accepted_risk';
    if (resolved) {
      return `<span class="text-xs text-slate-500">${new Date(f.sla_deadline).toLocaleDateString()}</span>`;
    }
    const diff = new Date(f.sla_deadline).getTime() - Date.now();
    if (diff < 0) {
      return `<span class="inline-flex items-center px-2 py-1 text-[10px] font-bold rounded border bg-red-500/10 text-red-400 border-red-500/20">Overdue</span>`;
    }
    if (diff < 24 * 60 * 60 * 1000) {
      return `<span class="inline-flex items-center px-2 py-1 text-[10px] font-bold rounded border bg-amber-500/10 text-amber-400 border-amber-500/20">Due Soon</span>`;
    }
    return `<span class="text-xs text-slate-500">${new Date(f.sla_deadline).toLocaleDateString()}</span>`;
  }

  function escapeHTML(value: string): string {
    return value
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');
  }

  function safeExternalURL(value: string): string | null {
    try {
      const url = new URL(value);
      if (url.protocol !== 'http:' && url.protocol !== 'https:') {
        return null;
      }
      return url.toString();
    } catch {
      return null;
    }
  }

  function jiraDisplay(f: Finding): string {
    const issue = f.jira_issue;
    if (!issue?.issue_key) {
      return '<span class="text-xs text-slate-600">—</span>';
    }
    const issueKey = escapeHTML(issue.issue_key);
    const issueURL = issue.issue_url ? safeExternalURL(issue.issue_url) : null;
    if (!issueURL) {
      return `<span class="inline-flex items-center gap-1.5 px-2 py-1 text-[10px] font-bold rounded uppercase tracking-wider border border-blue-500/20 bg-blue-500/10 text-blue-300">${issueKey}</span>`;
    }
    return `
      <a href="${escapeHTML(issueURL)}" target="_blank" rel="noreferrer" class="inline-flex items-center gap-1.5 px-2 py-1 text-[10px] font-bold rounded uppercase tracking-wider border border-blue-500/20 bg-blue-500/10 text-blue-300 hover:bg-blue-500/15 hover:text-blue-200 transition-all">
        ${issueKey}
        <span class="material-symbols-outlined text-sm">open_in_new</span>
      </a>`;
  }

  function selectedSeverities() {
    return Array.from(document.querySelectorAll<HTMLInputElement>('[data-severity-filter]:checked')).map((input) => input.value);
  }

  async function loadFindings() {
    const severity = selectedSeverities();
    const category = (document.getElementById('filter-category') as HTMLSelectElement).value;
    const scanner  = (document.getElementById('filter-scanner') as HTMLSelectElement).value;
    const status   = (document.getElementById('filter-status') as HTMLSelectElement).value;
    const cve_id   = (document.getElementById('filter-cve') as HTMLInputElement).value.trim();
    const overdue  = (document.getElementById('filter-overdue') as HTMLInputElement).checked;
    const file_path = (document.getElementById('filter-file') as HTMLSelectElement).value;
    const sortBy   = (document.getElementById('sort-credibility') as HTMLSelectElement).value;

    let findings: Finding[] = [];
    let total = 0;
    try {
      const result = await api.getFindings(severity, scanner, 1, 50, status, overdue, category, cve_id, false, file_path);
      findings = result.findings;
      total = result.total;
    } catch (error: any) {
      const el = document.getElementById('findings-table')!;
      el.innerHTML = `<div class="flex flex-col items-center justify-center py-12 text-center">
        <span class="material-symbols-outlined text-red-400 text-5xl mb-3">error</span>
        <p class="text-red-300 font-semibold text-lg">Failed to load findings</p>
        <p class="text-slate-500 text-sm mt-1">${escapeHTML(error?.message ?? 'Unknown error')}</p>
        <button onclick="loadFindings()" class="inline-flex items-center gap-2 mt-4 px-4 py-2 bg-cyan-500/10 text-cyan-400 border border-cyan-500/20 rounded-lg text-xs font-bold uppercase tracking-wider hover:bg-cyan-500/20 transition-colors">
          <span class="material-symbols-outlined text-sm">refresh</span>
          Retry
        </button>
      </div>`;
      document.getElementById('findings-total')!.textContent = '';
      return;
    }
    
    // Apply client-side sorting by credibility
    if (sortBy) {
      findings.sort((a, b) => {
        if (sortBy === 'confidence_desc') {
          return (b.confidence_score ?? 0) - (a.confidence_score ?? 0);
        } else if (sortBy === 'confidence_asc') {
          return (a.confidence_score ?? 0) - (b.confidence_score ?? 0);
        } else if (sortBy === 'corroborated') {
          return (b.corroboration_count ?? 0) - (a.corroboration_count ?? 0);
        }
        return 0;
      });
    }
    
    document.getElementById('findings-total')!.textContent = `${total} total`;

    const el = document.getElementById('findings-table')!;
    if (!findings.length) {
      el.innerHTML = `<div class="flex flex-col items-center justify-center py-12 text-center">
        <span class="material-symbols-outlined text-slate-700 text-5xl mb-3">biotech</span>
        <p class="text-slate-400 font-semibold text-lg">No findings yet</p>
        <p class="text-slate-600 text-sm mt-1">Run a scan to see security findings here.</p>
        <a href="/dashboard/scans" class="inline-flex items-center gap-2 mt-4 px-4 py-2 bg-cyan-500/10 text-cyan-400 border border-cyan-500/20 rounded-lg text-xs font-bold uppercase tracking-wider hover:bg-cyan-500/20 transition-colors">
          <span class="material-symbols-outlined text-sm">security_update_good</span>
          Run a Scan
        </a>
      </div>`;
      return;
    }

    el.innerHTML = `
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-950/50 border-b border-slate-800">
              ${hasWriteAccess ? `<th class="text-left px-5 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500 w-12">
              <input type="checkbox" id="select-all-findings" class="h-4 w-4 rounded border-slate-600 bg-surface-container text-cyan-400 focus:ring-0" />
            </th>` : ''}
            <th class="text-left px-5 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500">Finding</th>
			<th class="text-left px-5 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500">Severity</th>
            <th class="text-left px-5 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500">Status</th>
            <th class="text-left px-5 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500 hidden xl:table-cell">Scanner</th>
            <th class="text-left px-5 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500 hidden 2xl:table-cell">Credibility</th>
            <th class="text-left px-5 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500 hidden xl:table-cell">SLA</th>
            <th class="text-left px-5 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500 hidden lg:table-cell">Jira</th>
            <th class="text-right px-5 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500">Detail</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-800/50">
          ${findings.map((f) => {
            const sev = SEV_STYLES[f.severity] ?? SEV_STYLES.info;
            const stat = STATUS_STYLES[f.status] ?? STATUS_STYLES.open;
			const scanner = scannerType(f.scanner);
            const hasCorroboration = (f.corroboration_count ?? 0) > 0;
            const confidenceBadge = f.confidence_score != null && f.confidence_score > 0.5
              ? `<span class="px-2 py-1 text-[10px] font-bold rounded uppercase tracking-wider border border-emerald-500/20 bg-emerald-500/10 text-emerald-300" title="Confidence: ${(f.confidence_score * 100).toFixed(0)}%">High</span>`
              : f.confidence_score != null && f.confidence_score < 0.5
              ? `<span class="px-2 py-1 text-[10px] font-bold rounded uppercase tracking-wider border border-slate-500/20 bg-slate-500/10 text-slate-400" title="Confidence: ${(f.confidence_score * 100).toFixed(0)}%">Low</span>`
              : '';
            const corrobBadge = hasCorroboration
              ? `<span class="px-2 py-1 text-[10px] font-bold rounded uppercase tracking-wider border border-blue-500/20 bg-blue-500/10 text-blue-300" title="Corroborated by ${f.corroboration_count} scanner(s)">+${f.corroboration_count}</span>`
              : '';
            const corroboratingScanners = f.corroborating_scanners
              ? `<span class="text-[10px] text-slate-500 font-mono" title="Corroborated by: ${escapeHTML(f.corroborating_scanners)}">${f.corroborating_scanners.split(',').slice(0, 2).join(', ')}${f.corroborating_scanners.split(',').length > 2 ? '…' : ''}</span>`
              : '';
			return `
              <tr class="group hover:bg-slate-900/30 transition-colors cursor-pointer ${f.false_positive ? 'opacity-50' : ''}" data-finding-id="${f.id}">
                ${hasWriteAccess ? `<td class="px-5 py-3" onclick="event.stopPropagation()">
                  <input type="checkbox" data-finding-id="${f.id}" class="finding-checkbox h-4 w-4 rounded border-slate-600 bg-surface-container text-cyan-400 focus:ring-0" />
                </td>` : ''}
                <td class="px-5 py-3">
                  <a href="/dashboard/findings/detail?id=${encodeURIComponent(f.id)}" class="block" onclick="event.stopPropagation()">
                    <p class="font-bold text-on-background group-hover:text-cyan-300 transition-colors">${f.title}</p>
                    <p class="text-xs text-slate-500 mt-0.5 truncate max-w-sm">${f.description ?? ''}</p>
                     <div class="flex items-center gap-2 mt-1.5 flex-wrap">
                       <span class="px-2 py-1 text-[10px] font-bold rounded uppercase tracking-wider border ${scanner.color}">${scanner.label}</span>
                       ${f.ai_analyzed ? '<span class="px-2 py-1 text-[10px] font-bold rounded uppercase tracking-wider border border-purple-500/20 bg-purple-500/10 text-purple-300">AI analyzed</span>' : ''}
                        ${hasCorroboration ? `<span class="px-2 py-1 text-[10px] font-bold rounded uppercase tracking-wider border border-blue-500/20 bg-blue-500/10 text-blue-300" title="Corroborated by: ${f.corroborating_scanners || 'other scanners'}">Corroborated${f.corroborating_scanners ? ' (' + f.corroborating_scanners.split(',').slice(0, 2).join(', ') + ')' : ''}</span>` : ''}
                       ${f.assigned_to ? `<span class="text-[11px] text-cyan-400/80">Owner: ${f.assigned_to}</span>` : ''}
                     </div>
                   </a>
                 </td>
				 <td class="px-5 py-3"><span class="px-2 py-1 text-[10px] font-bold rounded uppercase tracking-wider border ${sev}">${f.severity}</span></td>
                <td class="px-5 py-3"><span class="px-2 py-1 text-[10px] font-bold rounded tracking-wider border ${stat}">${STATUS_LABELS[f.status] ?? f.status}</span></td>
                <td class="px-5 py-3 hidden xl:table-cell"><span class="font-mono text-xs text-slate-400">${f.scanner}</span></td>
                <td class="px-5 py-3 hidden 2xl:table-cell">
                  <div class="flex items-center gap-1 flex-wrap">
                    ${confidenceBadge}
                    ${corrobBadge}
                    ${corroboratingScanners}
                  </div>
                </td>
                <td class="px-5 py-3 hidden xl:table-cell">${slaDisplay(f)}</td>
                <td class="px-5 py-3 hidden lg:table-cell">${jiraDisplay(f)}</td>
                <td class="px-5 py-3 text-right">
                  <a href="/dashboard/findings/detail?id=${encodeURIComponent(f.id)}" class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg border border-cyan-500/20 bg-cyan-500/5 text-cyan-300 text-xs font-bold uppercase tracking-wider hover:bg-cyan-500/10 transition-all" onclick="event.stopPropagation()">
                    Open
                    <span class="material-symbols-outlined text-sm">arrow_forward</span>
                  </a>
                </td>
              </tr>`;
          }).join('')}
        </tbody>
      </table>`;

    // Setup checkbox handlers (skip for viewers)
    if (hasWriteAccess) {
    const selectAllCheckbox = document.getElementById('select-all-findings') as HTMLInputElement;
    const checkboxes = document.querySelectorAll('.finding-checkbox') as NodeListOf<HTMLInputElement>;
    
    selectAllCheckbox?.addEventListener('change', () => {
      checkboxes.forEach(cb => {
        (cb as HTMLInputElement).checked = selectAllCheckbox.checked;
      });
      updateBulkActions();
    });

    checkboxes.forEach(cb => {
      cb.addEventListener('change', () => {
        updateBulkActions();
      });
    });
    }

    // Setup row click handlers - navigate to detail page
    const rows = document.querySelectorAll('tr[data-finding-id]');
    rows.forEach(row => {
      row.addEventListener('click', () => {
        const findingId = row.getAttribute('data-finding-id');
        if (findingId) {
          window.location.href = `/dashboard/findings/detail?id=${encodeURIComponent(findingId)}`;
        }
      });
    });
  }

  async function loadSLA() {
    try {
      const s = await api.getSLASummary();
      document.getElementById('sla-overdue-count')!.textContent = String(s.overdue);
      document.getElementById('sla-today-count')!.textContent = String(s.due_today);
      document.getElementById('sla-ontrack-count')!.textContent = String(s.on_track);
      document.getElementById('sla-nodeadline-count')!.textContent = String(s.no_deadline);
      document.getElementById('sla-bar')!.classList.remove('hidden');
    } catch {
      // optional
    }
  }

  function updateBulkActions() {
    const checkboxes = document.querySelectorAll('.finding-checkbox:checked') as NodeListOf<HTMLInputElement>;
    const bulkActions = document.getElementById('bulk-actions')!;
    const selectedCount = document.getElementById('selected-count')!;
    
    if (checkboxes.length > 0) {
      bulkActions.classList.remove('hidden');
      bulkActions.classList.add('flex');
      selectedCount.textContent = String(checkboxes.length);
    } else {
      bulkActions.classList.add('hidden');
      bulkActions.classList.remove('flex');
    }
  }

  function getSelectedFindingIds(): string[] {
    const checkboxes = document.querySelectorAll('.finding-checkbox:checked') as NodeListOf<HTMLInputElement>;
    return Array.from(checkboxes).map(cb => cb.dataset.findingId || '');
  }

  if (hasWriteAccess) {
  document.getElementById('bulk-clear')!.addEventListener('click', () => {
    document.querySelectorAll('.finding-checkbox').forEach(cb => {
      (cb as HTMLInputElement).checked = false;
    });
    const selectAll = document.getElementById('select-all-findings') as HTMLInputElement;
    if (selectAll) selectAll.checked = false;
    updateBulkActions();
  });

  document.getElementById('bulk-apply')!.addEventListener('click', async () => {
    const ids = getSelectedFindingIds();
    if (!ids.length) {
      alert('No findings selected');
      return;
    }

    const statusEl = document.getElementById('bulk-status') as HTMLSelectElement;
    const assignEl = document.getElementById('bulk-assign') as HTMLSelectElement;
    const notesEl = document.getElementById('bulk-notes') as HTMLTextAreaElement;

    const data: { ids: string[]; status?: string; assigned_to?: string; notes?: string } = { ids };

    if (statusEl.value) {
      data.status = statusEl.value;
    }

    if (assignEl.value && assignEl.value !== '') {
      data.assigned_to = assignEl.value === '__clear__' ? '' : assignEl.value;
    }

    if (notesEl.value.trim()) {
      data.notes = notesEl.value.trim();
    }

    if (!data.status && data.assigned_to === undefined && !data.notes) {
      alert('Please select a status, assignee, or add notes');
      return;
    }

    try {
      const result = await api.bulkUpdateFindings(data);
      alert(`Updated ${result.updated} findings`);
      document.querySelectorAll('.finding-checkbox').forEach(cb => {
        (cb as HTMLInputElement).checked = false;
      });
      const selectAll = document.getElementById('select-all-findings') as HTMLInputElement;
      if (selectAll) selectAll.checked = false;
      statusEl.value = '';
      assignEl.value = '';
      notesEl.value = '';
      updateBulkActions();
      loadFindings();
    } catch (error: any) {
      alert(error.message ?? 'Failed to update findings');
    }
  });
  }

  document.getElementById('filter-btn')!.addEventListener('click', loadFindings);
  document.getElementById('filter-overdue')!.addEventListener('change', loadFindings);
  document.getElementById('sort-credibility')!.addEventListener('change', loadFindings);
  document.getElementById('filter-cve')!.addEventListener('keydown', (e) => {
    if ((e as KeyboardEvent).key === 'Enter') loadFindings();
  });
  document.getElementById('sla-overdue')!.addEventListener('click', () => {
    (document.getElementById('filter-overdue') as HTMLInputElement).checked = true;
    loadFindings();
  });
  document.getElementById('sla-today')!.addEventListener('click', () => {
    (document.getElementById('filter-overdue') as HTMLInputElement).checked = false;
    (document.getElementById('filter-status') as HTMLSelectElement).value = 'open';
    loadFindings();
  });
  document.getElementById('clear-btn')!.addEventListener('click', () => {
    document.querySelectorAll<HTMLInputElement>('[data-severity-filter]').forEach((input) => {
      input.checked = false;
    });
    (document.getElementById('filter-category') as HTMLSelectElement).value = '';
    (document.getElementById('filter-scanner') as HTMLSelectElement).value = '';
    (document.getElementById('filter-status') as HTMLSelectElement).value = '';
    (document.getElementById('filter-cve') as HTMLInputElement).value = '';
    (document.getElementById('filter-overdue') as HTMLInputElement).checked = false;
    (document.getElementById('filter-file') as HTMLSelectElement).value = '';
    (document.getElementById('sort-credibility') as HTMLSelectElement).value = '';
    loadFindings();
  });

  async function loadFileOptions() {
    try {
      const files = await api.getUniqueFiles();
      const select = document.getElementById('filter-file') as HTMLSelectElement;
      files.forEach((file) => {
        const opt = document.createElement('option');
        opt.value = file;
        opt.textContent = file;
        select.appendChild(opt);
      });
    } catch {
      // no files
    }
  }

  async function loadUsers() {
    try {
      const users = await api.getUsers();
      const select = document.getElementById('bulk-assign') as HTMLSelectElement;
      users.forEach((u) => {
        const opt = document.createElement('option');
        opt.value = u.username;
        opt.textContent = `${u.username}${u.email ? ` (${u.email})` : ''}`;
        select.appendChild(opt);
      });
    } catch {
      // users not available
    }
  }

  loadSLA();
  loadFileOptions();
  loadUsers();
  loadFindings();
</script>
