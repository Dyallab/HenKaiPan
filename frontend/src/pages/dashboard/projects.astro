---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---
<DashboardLayout title="Projects" active="projects">

<!-- Header -->
<div class="flex items-center justify-between mb-5">
  <div>
    <h1 class="text-xl font-bold text-white">Projects</h1>
    <p class="text-slate-400 text-sm mt-0.5">Manage your scanned projects and connections</p>
  </div>
  <div class="flex items-center gap-2">
    <button id="open-bulk-add"
      class="flex items-center gap-2 bg-slate-800 hover:bg-slate-700 text-slate-300 font-bold text-xs uppercase tracking-widest px-3.5 py-2 rounded transition-colors border border-slate-700/50">
      <span class="material-symbols-outlined text-lg">download</span>
      Bulk Add
    </button>
    <button id="open-create-project"
      class="flex items-center gap-2 bg-cyan-500 hover:bg-cyan-400 text-slate-950 font-bold text-xs uppercase tracking-widest px-3.5 py-2 rounded transition-colors">
      <span class="material-symbols-outlined text-lg">add</span>
      New Project
    </button>
  </div>
</div>

<!-- Filter tabs -->
<div class="flex gap-2 mb-4">
  <button data-filter="" class="filter-tab px-3 py-1.5 rounded text-xs font-bold uppercase tracking-widest transition-colors bg-cyan-500 text-slate-950">All</button>
  <button data-filter="with_app" class="filter-tab px-3 py-1.5 rounded text-xs font-bold uppercase tracking-widest transition-colors bg-slate-800 text-slate-400 hover:text-white">With App</button>
  <button data-filter="without_app" class="filter-tab px-3 py-1.5 rounded text-xs font-bold uppercase tracking-widest transition-colors bg-slate-800 text-slate-400 hover:text-white">Standalone</button>
  <div class="flex-1"></div>
  <button id="coverage-filter" class="px-3 py-1.5 rounded text-xs font-bold uppercase tracking-widest transition-colors bg-slate-800 text-slate-400 hover:text-white border border-outline-variant/20">
    <span class="material-symbols-outlined text-sm align-middle mr-1">warning</span>
    Needs Coverage
  </button>
</div>

<!-- Projects list -->
<div id="projects-list" class="bg-surface-container-low border border-outline-variant/20 rounded-xl overflow-hidden">
  <p class="px-5 py-3 text-sm text-slate-500">Loading...</p>
</div>

<!-- Empty state -->
<div id="empty-state" class="hidden flex-col items-center justify-center py-16 text-center">
  <span class="material-symbols-outlined text-slate-700 text-6xl mb-4">folder_open</span>
  <p class="text-slate-400 font-semibold text-lg">No projects yet</p>
  <p class="text-slate-600 text-sm mt-1">Create your first project to start scanning.</p>
</div>

<!-- Create Project Modal -->
<div id="modal-create-project" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm">
  <div class="bg-slate-900 border border-slate-700 rounded-xl w-full max-w-md p-6 shadow-2xl">
    <h3 class="text-lg font-bold text-white mb-1">New Project</h3>
    <p class="text-slate-500 text-xs mb-5">Connect a repository to start scanning</p>
    <div class="space-y-4">
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1.5">Name *</label>
        <input id="project-name" type="text" placeholder="e.g. API Service"
          class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-cyan-500" />
      </div>
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1.5">Description</label>
        <input id="project-desc" type="text" placeholder="Optional"
          class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-cyan-500" />
      </div>
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1.5">Repository URL *</label>
        <input id="project-repo-url" type="text" placeholder="https://github.com/org/repo"
          class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-cyan-500" />
      </div>
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1.5">Default Branch</label>
        <input id="project-branch" type="text" placeholder="main" value="main"
          class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-cyan-500" />
      </div>
    </div>
    <div id="project-error" class="hidden mt-3 text-red-400 text-xs"></div>
    <div class="flex gap-3 mt-6">
      <button id="cancel-create-project" class="flex-1 bg-slate-800 hover:bg-slate-700 text-slate-300 text-xs font-bold uppercase tracking-widest py-2.5 rounded transition-colors">Cancel</button>
      <button id="submit-create-project" class="flex-1 bg-cyan-500 hover:bg-cyan-400 text-slate-950 text-xs font-bold uppercase tracking-widest py-2.5 rounded transition-colors">Create</button>
    </div>
  </div>
</div>

<!-- GitHub Token Modal -->
<div id="token-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center z-50">
  <div class="bg-slate-900 border border-slate-700 rounded-xl p-6 w-full max-w-md">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-bold text-white">Configure GitHub Token</h3>
      <button id="close-token-modal" class="text-slate-400 hover:text-slate-200">
        <span class="material-symbols-outlined text-xl">close</span>
      </button>
    </div>
    <p class="text-sm text-slate-400 mb-4">
      Enter a GitHub Personal Access Token to clone private repositories. The token will be encrypted and stored securely.
    </p>
    <div class="space-y-4">
      <div>
        <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">Project</label>
        <p id="modal-project-name" class="text-sm font-semibold text-white"></p>
      </div>
      <div>
        <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">GitHub Token</label>
        <input
          id="github-token-input"
          type="password"
          placeholder="ghp_..."
          class="w-full bg-slate-950 border border-slate-800 rounded-lg px-4 py-2.5 text-white text-sm focus:ring-2 focus:ring-cyan-500 outline-none font-mono transition-all"
        />
        <p class="text-xs text-slate-500 mt-1">
          Create a token with <span class="font-mono text-cyan-400">repo</span> scope at <a href="https://github.com/settings/tokens" target="_blank" class="text-cyan-400 hover:underline">github.com/settings/tokens</a>
        </p>
      </div>
      <div class="flex gap-3 pt-2">
        <button
          id="save-github-token"
          class="flex-1 px-4 py-2 bg-cyan-500 hover:bg-cyan-400 text-slate-950 rounded-lg text-sm font-bold transition-all active:scale-95"
        >
          Save Token
        </button>
        <button
          id="remove-github-token"
          class="px-4 py-2 bg-red-500/10 hover:bg-red-500/20 text-red-400 border border-red-500/20 rounded-lg text-sm font-bold transition-all"
        >
          Remove
        </button>
      </div>
      <div id="token-msg" class="hidden text-sm"></div>
    </div>
  </div>
</div>

<!-- Bulk Add Modal -->
<div id="modal-bulk-add" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm">
  <div class="bg-slate-900 border border-slate-700 rounded-xl w-full max-w-2xl p-6 shadow-2xl max-h-[90vh] flex flex-col">
    <div class="flex items-center justify-between mb-1">
      <h3 class="text-lg font-bold text-white">Bulk Add Projects from GitHub</h3>
      <button id="close-bulk-add" class="text-slate-400 hover:text-slate-200">
        <span class="material-symbols-outlined text-xl">close</span>
      </button>
    </div>
    <p class="text-slate-500 text-xs mb-5">Import multiple repos from GitHub using a pattern</p>

    <div class="space-y-4">
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1.5">Pattern *</label>
        <input id="bulk-pattern" type="text" placeholder="e.g. facebook/* or @torvalds/* or org/repo-* or https://github.com/org/repo"
          class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-cyan-500 font-mono" />
        <p class="text-xs text-slate-500 mt-1">
          Examples: <code class="text-cyan-400">facebook/*</code> (all org repos),
          <code class="text-cyan-400">@torvalds/*</code> (all user repos),
          <code class="text-cyan-400">go-gitea/gitea-*</code> (prefix match),
          or any GitHub search query
        </p>
      </div>
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1.5">GitHub Token (optional)</label>
        <input id="bulk-token" type="password" placeholder="ghp_... for higher rate limits and private repos"
          class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-cyan-500 font-mono" />
      </div>
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1.5">Max repos</label>
        <input id="bulk-limit" type="number" value="50" min="1" max="500"
          class="w-24 bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm text-white focus:outline-none focus:border-cyan-500" />
      </div>
    </div>

    <!-- Preview area -->
    <div id="bulk-preview" class="hidden mt-4 flex-1 min-h-0">
      <div class="flex items-center justify-between mb-2">
        <p id="bulk-preview-count" class="text-sm font-bold text-white"></p>
        <button id="bulk-select-all" class="text-xs text-cyan-400 hover:underline hidden">Select all</button>
      </div>
      <div id="bulk-preview-list" class="max-h-48 overflow-y-auto bg-slate-950 rounded-lg border border-slate-800 divide-y divide-slate-800">
      </div>
    </div>

    <div id="bulk-error" class="hidden mt-3 text-red-400 text-xs"></div>

    <div class="flex gap-3 mt-5">
      <button id="cancel-bulk-add" class="flex-1 bg-slate-800 hover:bg-slate-700 text-slate-300 text-xs font-bold uppercase tracking-widest py-2.5 rounded transition-colors">Cancel</button>
      <button id="bulk-preview-btn" class="bg-slate-700 hover:bg-slate-600 text-slate-200 text-xs font-bold uppercase tracking-widest px-4 py-2.5 rounded transition-colors">Preview</button>
      <button id="submit-bulk-add" class="flex-1 bg-cyan-500 hover:bg-cyan-400 text-slate-950 text-xs font-bold uppercase tracking-widest py-2.5 rounded transition-colors disabled:opacity-50 disabled:cursor-not-allowed" disabled>Import</button>
    </div>
  </div>
</div>

<!-- Edit Project Modal -->
<div id="modal-edit-project" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm">
  <div class="bg-slate-900 border border-slate-700 rounded-xl w-full max-w-md p-6 shadow-2xl">
    <h3 class="text-lg font-bold text-white mb-1">Edit Project</h3>
    <p id="edit-project-name-label" class="text-cyan-400 text-xs mb-5"></p>
    <div class="space-y-4">
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1.5">Name *</label>
        <input id="edit-project-name" type="text"
          class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-cyan-500" />
      </div>
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1.5">Description</label>
        <input id="edit-project-desc" type="text" placeholder="Optional"
          class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-cyan-500" />
      </div>
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1.5">Repository URL</label>
        <input id="edit-project-repo" type="text" placeholder="https://github.com/org/repo"
          class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-cyan-500" />
      </div>
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1.5">Default Branch</label>
        <input id="edit-project-branch" type="text" placeholder="main"
          class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-cyan-500" />
      </div>
    </div>
    <div id="edit-project-error" class="hidden mt-3 text-red-400 text-xs"></div>
    <div class="flex gap-3 mt-6">
      <button id="cancel-edit-project" class="flex-1 bg-slate-800 hover:bg-slate-700 text-slate-300 text-xs font-bold uppercase tracking-widest py-2.5 rounded transition-colors">Cancel</button>
      <button id="submit-edit-project" class="flex-1 bg-cyan-500 hover:bg-cyan-400 text-slate-950 text-xs font-bold uppercase tracking-widest py-2.5 rounded transition-colors">Save Changes</button>
    </div>
  </div>
</div>

</DashboardLayout>

<script>
import { api } from '../../lib/api.ts';
import type { Project, ProjectCoverage, CoverageReport } from '../../lib/api.ts';

let allProjects: Project[] = [];
let coverageData: Map<string, ProjectCoverage> = new Map();
let currentFilter = '';
let showCoverageOnly = false;
let currentProjectId: string | null = null;

async function loadCoverage() {
  const report = await api.getCoverageReport().catch(() => null);
  if (report) {
    coverageData = new Map(report.projects.map(p => [p.project_id, p]));
  }
}

function openEditProjectModal(name: string, desc: string, repo: string, branch: string) {
  document.getElementById('edit-project-name-label')!.textContent = name;
  (document.getElementById('edit-project-name') as HTMLInputElement).value = name;
  (document.getElementById('edit-project-desc') as HTMLInputElement).value = desc;
  (document.getElementById('edit-project-repo') as HTMLInputElement).value = repo;
  (document.getElementById('edit-project-branch') as HTMLInputElement).value = branch;
  document.getElementById('edit-project-error')!.classList.add('hidden');
  document.getElementById('modal-edit-project')!.classList.remove('hidden');
}

async function loadProjects() {
  await loadCoverage();
  allProjects = await api.getProjects(currentFilter).catch(() => []);
  renderProjects();
}

function getCoverageBadge(coverage?: ProjectCoverage) {
  if (!coverage) return '';
  if (coverage.never_scanned) {
    return '<span class="text-xs text-red-400 bg-red-500/10 border border-red-500/20 px-2 py-0.5 rounded font-bold flex items-center gap-1"><span class="material-symbols-outlined text-sm">warning</span>Never Scanned</span>';
  }
  if (coverage.days_since_scan !== undefined) {
    if (coverage.days_since_scan > 30) {
      return `<span class="text-xs text-amber-400 bg-amber-500/10 border border-amber-500/20 px-2 py-0.5 rounded font-bold flex items-center gap-1"><span class="material-symbols-outlined text-sm">schedule</span>${coverage.days_since_scan}d ago</span>`;
    }
    if (coverage.days_since_scan > 7) {
      return `<span class="text-xs text-cyan-400 bg-cyan-500/10 border border-cyan-500/20 px-2 py-0.5 rounded font-bold flex items-center gap-1"><span class="material-symbols-outlined text-sm">schedule</span>${coverage.days_since_scan}d ago</span>`;
    }
    return '<span class="text-xs text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-2 py-0.5 rounded font-bold flex items-center gap-1"><span class="material-symbols-outlined text-sm">check_circle</span>Recent</span>';
  }
  return '';
}

function shouldShowProject(p: Project) {
  if (showCoverageOnly) {
    const coverage = coverageData.get(p.id);
    return coverage && (coverage.never_scanned || (coverage.days_since_scan !== undefined && coverage.days_since_scan > 7));
  }
  return true;
}

function renderProjects() {
  const container = document.getElementById('projects-list')!;
  const emptyState = document.getElementById('empty-state')!;

  const filteredProjects = allProjects.filter(shouldShowProject);

  if (!filteredProjects.length) {
    container.innerHTML = '';
    if (showCoverageOnly) {
      emptyState.innerHTML = `
        <span class="material-symbols-outlined text-slate-700 text-6xl mb-4">check_circle</span>
        <p class="text-slate-400 font-semibold text-lg">All projects covered!</p>
        <p class="text-slate-600 text-sm mt-1">No projects need coverage attention.</p>
      `;
    } else {
      emptyState.innerHTML = `
        <span class="material-symbols-outlined text-slate-700 text-6xl mb-4">folder_open</span>
        <p class="text-slate-400 font-semibold text-lg">No projects yet</p>
        <p class="text-slate-600 text-sm mt-1">Create your first project to start scanning.</p>
      `;
    }
    emptyState.classList.remove('hidden');
    emptyState.classList.add('flex');
    return;
  }
  emptyState.classList.add('hidden');
  emptyState.classList.remove('flex');

  container.innerHTML = `<div class="divide-y divide-slate-800/50">
    ${filteredProjects.map(p => {
      const coverage = coverageData.get(p.id);
      return `
      <div class="px-5 py-3 flex items-center justify-between hover:bg-slate-900/20 transition-colors">
        <div class="min-w-0">
          <div class="flex items-center gap-2 mb-1 flex-wrap">
            <span class="material-symbols-outlined text-slate-500 text-base">folder_open</span>
            <p class="text-sm font-bold text-white">${p.name}</p>
            ${p.has_token ? '<span class="material-symbols-outlined text-green-400 text-base" title="GitHub token configured">key</span>' : ''}
            ${!p.app_id ? '<span class="text-xs text-amber-500/70 bg-amber-500/10 px-2 py-0.5 rounded font-bold">Standalone</span>' : ''}
            ${getCoverageBadge(coverage)}
          </div>
          <p class="text-xs text-slate-500 font-mono truncate max-w-md">${p.repo_url || 'No URL configured'}</p>
          <div class="flex items-center gap-1.5 mt-1">
            <span class="text-[10px] text-slate-600 font-mono select-all">${p.id}</span>
            <button type="button" data-copy-id="${p.id}" class="copy-id-btn text-slate-600 hover:text-cyan-400 transition-colors p-0.5" title="Copy project ID">
              <span class="material-symbols-outlined text-sm">content_copy</span>
            </button>
          </div>
        </div>
        <div class="flex items-center gap-3 shrink-0 ml-4">
          <a href="/dashboard/scans?project=${encodeURIComponent(p.id)}"
             class="flex items-center gap-1.5 px-3 py-1.5 bg-cyan-500/10 text-cyan-400 border border-cyan-500/20 rounded text-xs font-bold uppercase tracking-wider hover:bg-cyan-500/20 transition-colors">
            <span class="material-symbols-outlined text-sm">security_update_good</span>
            Scan
          </a>
          <button
            type="button"
            data-configure-token="${p.id}"
            data-project-name="${p.name}"
            data-project-has-token="${p.has_token}"
            class="flex items-center gap-1.5 px-3 py-1.5 bg-cyan-500/10 text-cyan-400 border border-cyan-500/20 rounded text-xs font-bold uppercase tracking-wider hover:bg-cyan-500/20 transition-colors"
          >
            <span class="material-symbols-outlined text-sm">${p.has_token ? 'key' : 'key_off'}</span>
            ${p.has_token ? 'Token Set' : 'Set Token'}
          </button>
          <button
            type="button"
            data-edit-project="${p.id}"
            data-project-name="${p.name}"
            data-project-desc="${p.description || ''}"
            data-project-repo="${p.repo_url || ''}"
            data-project-branch="${p.default_branch || ''}"
            class="flex items-center gap-1.5 px-3 py-1.5 bg-slate-700/50 text-slate-300 border border-slate-600/30 rounded text-xs font-bold uppercase tracking-wider hover:bg-slate-700 transition-colors"
          >
            <span class="material-symbols-outlined text-sm">edit</span>
            Edit
          </button>
          <button
            type="button"
            data-delete-project="${p.id}"
            data-project-name="${p.name}"
            class="flex items-center gap-1.5 px-3 py-1.5 bg-red-500/10 text-red-400 border border-red-500/20 rounded text-xs font-bold uppercase tracking-wider hover:bg-red-500/20 transition-colors"
          >
            <span class="material-symbols-outlined text-sm">delete</span>
            Delete
          </button>
          <p class="text-xs text-slate-600 font-mono">${new Date(p.created_at).toLocaleDateString()}</p>
        </div>
      </div>
    `}).join('')}
  </div>`;

  // Configure token buttons
  container.querySelectorAll('[data-configure-token]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const target = btn as HTMLElement;
      currentProjectId = target.dataset.configureToken || null;
      const projectName = target.dataset.projectName || '';
      const hasToken = target.dataset.projectHasToken === 'true';

      document.getElementById('modal-project-name')!.textContent = projectName;
      const tokenInput = document.getElementById('github-token-input') as HTMLInputElement;
      tokenInput.value = '';
      tokenInput.placeholder = hasToken ? '••••••••••••' : 'ghp_...';

      const removeBtn = document.getElementById('remove-github-token')!;
      removeBtn.classList.toggle('hidden', !hasToken);

      const msg = document.getElementById('token-msg')!;
      msg.className = 'hidden text-sm';
      msg.textContent = '';

      document.getElementById('token-modal')!.classList.remove('hidden');
    });
  });

  // Edit project buttons
  container.querySelectorAll('[data-edit-project]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      currentProjectId = el.dataset.editProject || null;
      const name = el.dataset.projectName || '';
      const desc = el.dataset.projectDesc || '';
      const repo = el.dataset.projectRepo || '';
      const branch = el.dataset.projectBranch || '';
      openEditProjectModal(name, desc, repo, branch);
    });
  });

  // Delete project buttons
  container.querySelectorAll('[data-delete-project]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const target = btn as HTMLElement;
      const projectId = target.dataset.deleteProject;
      const projectName = target.dataset.projectName || 'this project';
      if (!projectId) return;
      if (!confirm(`Delete ${projectName}?`)) return;

      try {
        await api.deleteProject(projectId);
        await loadProjects();
      } catch (err) {
        const message = err instanceof Error ? err.message : 'Failed to delete project';
        alert(message);
      }
    });
  });
}

// Filter tabs
document.querySelectorAll('.filter-tab').forEach(btn => {
  btn.addEventListener('click', () => {
    currentFilter = (btn as HTMLElement).dataset.filter || '';
    document.querySelectorAll('.filter-tab').forEach(b => {
      b.className = `filter-tab px-3 py-1.5 rounded text-xs font-bold uppercase tracking-widest transition-colors bg-slate-800 text-slate-400 hover:text-white`;
    });
    btn.className = `filter-tab px-3 py-1.5 rounded text-xs font-bold uppercase tracking-widest transition-colors bg-cyan-500 text-slate-950`;
    showCoverageOnly = false;
    document.getElementById('coverage-filter')!.className = 'px-3 py-1.5 rounded text-xs font-bold uppercase tracking-widest transition-colors bg-slate-800 text-slate-400 hover:text-white border border-outline-variant/20';
    loadProjects();
  });
});

// Coverage filter button
document.getElementById('coverage-filter')!.addEventListener('click', () => {
  showCoverageOnly = !showCoverageOnly;
  const btn = document.getElementById('coverage-filter')!;
  if (showCoverageOnly) {
    btn.className = 'px-3 py-1.5 rounded text-xs font-bold uppercase tracking-widest transition-colors bg-red-500/20 text-red-400 border border-red-500/30';
    document.querySelectorAll('.filter-tab').forEach(b => {
      b.className = `filter-tab px-3 py-1.5 rounded text-xs font-bold uppercase tracking-widest transition-colors bg-slate-800 text-slate-400 hover:text-white`;
    });
  } else {
    btn.className = 'px-3 py-1.5 rounded text-xs font-bold uppercase tracking-widest transition-colors bg-slate-800 text-slate-400 hover:text-white border border-outline-variant/20';
  }
  renderProjects();
});

// Modal close
document.getElementById('close-token-modal')!.addEventListener('click', () => {
  document.getElementById('token-modal')!.classList.add('hidden');
  currentProjectId = null;
});

// Save token
document.getElementById('save-github-token')!.addEventListener('click', async () => {
  if (!currentProjectId) return;

  const tokenInput = document.getElementById('github-token-input') as HTMLInputElement;
  const token = tokenInput.value.trim();
  const msg = document.getElementById('token-msg')!;

  if (!token) {
    msg.textContent = 'Token is required';
    msg.className = 'text-sm text-red-400';
    return;
  }

  try {
    await api.updateProjectGitHubToken(currentProjectId, token);
    msg.textContent = 'Token saved successfully';
    msg.className = 'text-sm text-emerald-400';
    setTimeout(() => {
      document.getElementById('token-modal')!.classList.add('hidden');
      loadProjects();
    }, 1000);
  } catch (err) {
    const message = err instanceof Error ? err.message : 'Failed to save token';
    msg.textContent = message;
    msg.className = 'text-sm text-red-400';
  }
});

// Remove token
document.getElementById('remove-github-token')!.addEventListener('click', async () => {
  if (!currentProjectId) return;

  const msg = document.getElementById('token-msg')!;

  if (!confirm('Remove the GitHub token for this project?')) return;

  try {
    await api.updateProjectGitHubToken(currentProjectId, '');
    msg.textContent = 'Token removed';
    msg.className = 'text-sm text-emerald-400';
    setTimeout(() => {
      document.getElementById('token-modal')!.classList.add('hidden');
      loadProjects();
    }, 1000);
  } catch (err) {
    const message = err instanceof Error ? err.message : 'Failed to remove token';
    msg.textContent = message;
    msg.className = 'text-sm text-red-400';
  }
});

// Close modals on backdrop click
document.getElementById('token-modal')!.addEventListener('click', (e) => {
  if (e.target === e.currentTarget) {
    document.getElementById('token-modal')!.classList.add('hidden');
    currentProjectId = null;
  }
});
document.getElementById('modal-edit-project')!.addEventListener('click', (e) => {
  if (e.target === e.currentTarget) document.getElementById('modal-edit-project')!.classList.add('hidden');
});

// Edit Project modal
document.getElementById('cancel-edit-project')!.addEventListener('click', () => {
  document.getElementById('modal-edit-project')!.classList.add('hidden');
});
document.getElementById('submit-edit-project')!.addEventListener('click', async () => {
  const pid = currentProjectId;
  if (!pid) return;
  const name = (document.getElementById('edit-project-name') as HTMLInputElement).value.trim();
  const desc = (document.getElementById('edit-project-desc') as HTMLInputElement).value.trim();
  const repo = (document.getElementById('edit-project-repo') as HTMLInputElement).value.trim();
  const branch = (document.getElementById('edit-project-branch') as HTMLInputElement).value.trim();
  const errEl = document.getElementById('edit-project-error')!;
  if (!name) { errEl.textContent = 'Name is required.'; errEl.classList.remove('hidden'); return; }
  try {
    await api.updateProject(pid, { name, description: desc, repo_url: repo, default_branch: branch || 'main' });
    document.getElementById('modal-edit-project')!.classList.add('hidden');
    await loadProjects();
  } catch (e: any) {
    errEl.textContent = e.message; errEl.classList.remove('hidden');
  }
});

// Create Project modal
document.getElementById('open-create-project')!.addEventListener('click', () => {
  (document.getElementById('project-name') as HTMLInputElement).value = '';
  (document.getElementById('project-desc') as HTMLInputElement).value = '';
  (document.getElementById('project-repo-url') as HTMLInputElement).value = '';
  (document.getElementById('project-branch') as HTMLInputElement).value = 'main';
  document.getElementById('project-error')!.classList.add('hidden');
  document.getElementById('modal-create-project')!.classList.remove('hidden');
});

document.getElementById('cancel-create-project')!.addEventListener('click', () => {
  document.getElementById('modal-create-project')!.classList.add('hidden');
});

document.getElementById('submit-create-project')!.addEventListener('click', async () => {
  const name = (document.getElementById('project-name') as HTMLInputElement).value.trim();
  const desc = (document.getElementById('project-desc') as HTMLInputElement).value.trim();
  const repoUrl = (document.getElementById('project-repo-url') as HTMLInputElement).value.trim();
  const branch = (document.getElementById('project-branch') as HTMLInputElement).value.trim() || 'main';
  const errEl = document.getElementById('project-error')!;
  if (!name) { errEl.textContent = 'Name is required.'; errEl.classList.remove('hidden'); return; }
  if (!repoUrl) { errEl.textContent = 'Repository URL is required.'; errEl.classList.remove('hidden'); return; }
  try {
    await api.createProject({ name, description: desc, repo_url: repoUrl, default_branch: branch, provider: 'git' });
    document.getElementById('modal-create-project')!.classList.add('hidden');
    await loadProjects();
  } catch (e: any) {
    errEl.textContent = e.message; errEl.classList.remove('hidden');
  }
});

// Close create modal on backdrop click
document.getElementById('modal-create-project')!.addEventListener('click', (e) => {
  if (e.target === e.currentTarget) (e.currentTarget as HTMLElement).classList.add('hidden');
});

// ── Bulk Add Modal ──
let bulkRepos: Array<{ name: string; repo_url: string }> = [];

document.getElementById('open-bulk-add')!.addEventListener('click', () => {
  (document.getElementById('bulk-pattern') as HTMLInputElement).value = '';
  (document.getElementById('bulk-token') as HTMLInputElement).value = '';
  (document.getElementById('bulk-limit') as HTMLInputElement).value = '50';
  document.getElementById('bulk-error')!.classList.add('hidden');
  document.getElementById('bulk-preview')!.classList.add('hidden');
  document.getElementById('submit-bulk-add')!.setAttribute('disabled', 'disabled');
  document.getElementById('modal-bulk-add')!.classList.remove('hidden');
  bulkRepos = [];
});

function closeBulkAdd() {
  document.getElementById('modal-bulk-add')!.classList.add('hidden');
}

document.getElementById('close-bulk-add')!.addEventListener('click', closeBulkAdd);
document.getElementById('cancel-bulk-add')!.addEventListener('click', closeBulkAdd);
document.getElementById('modal-bulk-add')!.addEventListener('click', (e) => {
  if (e.target === e.currentTarget) closeBulkAdd();
});

// Preview: resolve pattern without creating
document.getElementById('bulk-preview-btn')!.addEventListener('click', async () => {
  const pattern = (document.getElementById('bulk-pattern') as HTMLInputElement).value.trim();
  const token = (document.getElementById('bulk-token') as HTMLInputElement).value.trim();
  const limit = parseInt((document.getElementById('bulk-limit') as HTMLInputElement).value) || 50;
  const errEl = document.getElementById('bulk-error')!;

  if (!pattern) {
    errEl.textContent = 'Pattern is required';
    errEl.classList.remove('hidden');
    return;
  }

  // Show loading state
  const previewBtn = document.getElementById('bulk-preview-btn')!;
  previewBtn.textContent = 'Searching...';
  previewBtn.setAttribute('disabled', 'disabled');

  errEl.classList.add('hidden');

  try {
    const result = await api.bulkCreateProjects({ pattern, github_token: token || undefined, limit, preview: true });
    bulkRepos = result.projects.map(p => ({ name: p.name, repo_url: p.repo_url }));

    const previewDiv = document.getElementById('bulk-preview')!;
    const previewList = document.getElementById('bulk-preview-list')!;
    const countEl = document.getElementById('bulk-preview-count')!;

    if (bulkRepos.length === 0) {
      errEl.textContent = 'No repos found matching that pattern';
      errEl.classList.remove('hidden');
      previewDiv.classList.add('hidden');
      (document.getElementById('submit-bulk-add') as HTMLButtonElement).disabled = true;
      return;
    }

    countEl.textContent = `${bulkRepos.length} repositor${bulkRepos.length === 1 ? 'y' : 'ies'} found`;
    previewList.innerHTML = bulkRepos.map(r => `
      <div class="flex items-center gap-2 px-3 py-2">
        <span class="material-symbols-outlined text-slate-500 text-base">inventory_2</span>
        <span class="text-sm text-white font-mono">${r.name}</span>
        <span class="text-xs text-slate-500 ml-auto truncate max-w-xs">${r.repo_url}</span>
      </div>
    `).join('');

    previewDiv.classList.remove('hidden');
    (document.getElementById('submit-bulk-add') as HTMLButtonElement).disabled = false;
  } catch (err: any) {
    errEl.textContent = err.message || 'Failed to fetch repos';
    errEl.classList.remove('hidden');
  } finally {
    previewBtn.textContent = 'Preview';
    previewBtn.removeAttribute('disabled');
  }
});

// Submit: actually create projects
document.getElementById('submit-bulk-add')!.addEventListener('click', async () => {
  const pattern = (document.getElementById('bulk-pattern') as HTMLInputElement).value.trim();
  const token = (document.getElementById('bulk-token') as HTMLInputElement).value.trim();
  const limit = parseInt((document.getElementById('bulk-limit') as HTMLInputElement).value) || 50;
  const submitBtn = document.getElementById('submit-bulk-add') as HTMLButtonElement;
  const errEl = document.getElementById('bulk-error')!;

  if (!pattern || bulkRepos.length === 0) return;

  submitBtn.textContent = 'Importing...';
  submitBtn.disabled = true;
  errEl.classList.add('hidden');

  try {
    const result = await api.bulkCreateProjects({ pattern, github_token: token || undefined, limit });
    closeBulkAdd();

    // Show summary
    const parts: string[] = [];
    if (result.created > 0) parts.push(`${result.created} created`);
    if (result.skipped > 0) parts.push(`${result.skipped} skipped (already exist)`);
    if (result.errors > 0) parts.push(`${result.errors} errors`);

    // Reload project list
    await loadProjects();

    // Brief toast-like feedback
    const msg = parts.join(', ') || 'No changes';
    const toast = document.createElement('div');
    toast.className = 'fixed bottom-4 right-4 z-50 bg-slate-800 border border-slate-700 text-white text-sm px-4 py-3 rounded-xl shadow-2xl animate-fade-in';
    toast.textContent = `Import complete: ${msg}`;
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 4000);
  } catch (err: any) {
    errEl.textContent = err.message || 'Import failed';
    errEl.classList.remove('hidden');
    submitBtn.textContent = 'Import';
    submitBtn.disabled = false;
  }
});

// ── Copy project ID to clipboard ──
document.getElementById('projects-list')!.addEventListener('click', async (e) => {
  const btn = (e.target as HTMLElement).closest('[data-copy-id]') as HTMLElement | null;
  if (!btn) return;
  const id = btn.dataset.copyId!;
  try {
    await navigator.clipboard.writeText(id);
    const icon = btn.querySelector('.material-symbols-outlined')!;
    icon.textContent = 'check';
    btn.classList.remove('text-slate-600', 'hover:text-cyan-400');
    btn.classList.add('text-emerald-400');
    setTimeout(() => {
      icon.textContent = 'content_copy';
      btn.classList.add('text-slate-600', 'hover:text-cyan-400');
      btn.classList.remove('text-emerald-400');
    }, 2000);
  } catch {
    // Fallback: select the text manually
    const parent = btn.closest('[data-copy-id]')!.parentElement!;
    const span = parent.querySelector('.select-all') as HTMLElement;
    if (span) {
      const range = document.createRange();
      range.selectNodeContents(span);
      const sel = window.getSelection();
      sel?.removeAllRanges();
      sel?.addRange(range);
    }
  }
});

loadProjects();
</script>
