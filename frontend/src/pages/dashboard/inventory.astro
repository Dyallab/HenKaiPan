---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---
<DashboardLayout title="Asset Inventory" active="inventory">

  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-white">Asset Inventory</h1>
      <p class="text-slate-400 text-sm mt-1">Complete overview of projects, apps, scanners, and security coverage</p>
    </div>
    <div class="flex gap-3">
      <select id="filter-type" class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-cyan-500 transition-all">
        <option value="">All asset types</option>
        <option value="app">Apps</option>
        <option value="project">Projects</option>
      </select>
      <select id="filter-team" class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-cyan-500 transition-all">
        <option value="">All teams</option>
      </select>
      <button id="filter-btn" class="flex items-center gap-2 px-4 py-2 bg-slate-900 border border-slate-800 text-on-background rounded-lg hover:bg-slate-800 transition-colors text-sm font-semibold">
        <span class="material-symbols-outlined text-base">filter_list</span>
        Filter
      </button>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-surface-container-low border border-outline-variant/20 rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <span class="material-symbols-outlined text-cyan-400 text-2xl">folder_open</span>
        <span id="count-apps" class="text-3xl font-black text-cyan-400">0</span>
      </div>
      <p class="text-sm text-slate-400">Total Apps</p>
    </div>
    <div class="bg-surface-container-low border border-outline-variant/20 rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <span class="material-symbols-outlined text-emerald-400 text-2xl">code</span>
        <span id="count-projects" class="text-3xl font-black text-emerald-400">0</span>
      </div>
      <p class="text-sm text-slate-400">Total Projects</p>
    </div>
    <div class="bg-surface-container-low border border-outline-variant/20 rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <span class="material-symbols-outlined text-purple-400 text-2xl">radar</span>
        <span id="count-scans" class="text-3xl font-black text-purple-400">0</span>
      </div>
      <p class="text-sm text-slate-400">Scans Executed</p>
    </div>
    <div class="bg-surface-container-low border border-outline-variant/20 rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <span class="material-symbols-outlined text-amber-400 text-2xl">shield</span>
        <span id="coverage-pct" class="text-3xl font-black text-amber-400">0%</span>
      </div>
      <p class="text-sm text-slate-400">Scanner Coverage</p>
    </div>
  </div>

  <!-- Inventory Table -->
  <div class="bg-surface-container-low border border-outline-variant/20 rounded-2xl overflow-hidden">
    <div class="px-6 py-4 border-b border-outline-variant/20 flex items-center justify-between gap-4">
      <div>
        <p class="text-[10px] font-bold uppercase tracking-[0.24em] text-slate-500">Assets</p>
        <p class="text-sm text-slate-400 mt-1">Projects and apps with security coverage status</p>
      </div>
      <span id="inventory-total" class="text-xs text-slate-500 font-mono"></span>
    </div>
    <div id="inventory-table" class="overflow-x-auto">
      <p class="px-6 py-4 text-sm text-slate-500">Loading...</p>
    </div>
  </div>

</DashboardLayout>

<script>
  import { api } from '../../lib/api';

  let allApps: any[] = [];
  let allTeams: any[] = [];

  function formatDate(dateStr?: string): string {
    if (!dateStr) return 'Never';
    return new Date(dateStr).toLocaleDateString();
  }

  function scannerBadges(scanners: string[]): string {
    if (!scanners.length) return '<span class="text-xs text-slate-500 italic">No scans</span>';
    return scanners.map(s => `<span class="text-[10px] text-slate-300 bg-slate-700 px-2 py-0.5 rounded font-mono">${s}</span>`).join('');
  }

  function coverageBadge(coverage: { total: number; scanned: number }): string {
    const pct = coverage.total > 0 ? Math.round((coverage.scanned / coverage.total) * 100) : 0;
    const color = pct >= 80 ? 'text-emerald-400 bg-emerald-500/10 border-emerald-500/20' : pct >= 50 ? 'text-amber-400 bg-amber-500/10 border-amber-500/20' : 'text-red-400 bg-red-500/10 border-red-500/20';
    return `<span class="inline-flex items-center px-2.5 py-1 rounded border text-[10px] font-bold uppercase tracking-wider ${color}">${pct}% covered</span>`;
  }

  function severityDot(count: number, color: string): string {
    return count > 0 ? `<span class="w-2 h-2 rounded-full ${color}" title="${count} findings"></span>` : '';
  }

  async function loadInventory() {
    const filterType = (document.getElementById('filter-type') as HTMLSelectElement).value;
    const filterTeam = (document.getElementById('filter-team') as HTMLSelectElement).value;

    try {
      const [apps, teams, metrics] = await Promise.all([
        api.getApps(),
        api.getTeams(),
        api.getTeamMetrics(),
      ]);

      allApps = apps;
      allTeams = teams;

      // Populate team filter
      const teamSel = document.getElementById('filter-team') as HTMLSelectElement;
      if (teamSel.options.length === 1) {
        teamSel.innerHTML = '<option value="">All teams</option>' + teams.map((t: any) => `<option value="${t.id}">${t.name}</option>`).join('');
      }

      // Filter
      let filteredApps = apps;
      if (filterTeam) {
        filteredApps = apps.filter(a => a.team_id === filterTeam);
      }

      // Build flat inventory list
      const inventory: any[] = [];
      
      // Add apps
      if (!filterType || filterType === 'app') {
        filteredApps.forEach(app => {
          const projectCount = app.projects?.length || 0;
          const repoCount = app.projects?.filter((p: any) => p.repo_id).length || 0;
          inventory.push({
            type: 'app',
            id: app.id,
            name: app.name,
            description: app.description || 'No description',
            team: app.team_name || 'Unassigned',
            projectCount,
            repoCount,
            createdAt: app.created_at,
            children: app.projects || [],
          });
        });
      }

      // Add standalone projects
      if (!filterType || filterType === 'project') {
        const standaloneProjects = filteredApps.flatMap(app => 
          (app.projects || []).filter((p: any) => !p.repo_id).map((p: any) => ({
            type: 'project',
            id: p.id,
            name: p.name,
            description: p.description || 'No description',
            team: app.team_name || 'Unassigned',
            app: app.name,
            repo: null,
            createdAt: p.created_at,
          }))
        );
        inventory.push(...standaloneProjects);
      }

      // Calculate summary
      const totalApps = filteredApps.length;
      const totalProjects = filteredApps.reduce((acc, app) => acc + (app.projects?.length || 0), 0);
      const totalScans = metrics.reduce((acc: number, m: any) => acc + m.app_count + m.project_count, 0);
      const projectsWithRepo = filteredApps.reduce((acc, app) => acc + (app.projects?.filter((p: any) => p.repo_id).length || 0), 0);
      const coveragePct = totalProjects > 0 ? Math.round((projectsWithRepo / totalProjects) * 100) : 0;

      document.getElementById('count-apps')!.textContent = String(totalApps);
      document.getElementById('count-projects')!.textContent = String(totalProjects);
      document.getElementById('count-scans')!.textContent = String(totalScans);
      document.getElementById('coverage-pct')!.textContent = `${coveragePct}%`;

      // Render table
      const el = document.getElementById('inventory-table')!;
      document.getElementById('inventory-total')!.textContent = `${inventory.length} total`;

      if (!inventory.length) {
        el.innerHTML = '<p class="px-6 py-4 text-sm text-slate-500">No assets found.</p>';
        return;
      }

      el.innerHTML = `
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-slate-950/50 border-b border-slate-800">
              <th class="text-left px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">Type</th>
              <th class="text-left px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">Name</th>
              <th class="text-left px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">Team</th>
              <th class="text-left px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">Coverage</th>
              <th class="text-left px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">Last Activity</th>
              <th class="text-left px-6 py-4 text-[10px] font-bold uppercase tracking-widest text-slate-500">Details</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-800/50">
            ${inventory.map((item: any) => {
              if (item.type === 'app') {
                const projectCoverage = { total: item.projectCount, scanned: item.repoCount };
                return `
                  <tr class="hover:bg-slate-900/30 transition-colors">
                    <td class="px-6 py-4">
                      <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded border text-[10px] font-bold uppercase tracking-wider text-cyan-400 bg-cyan-500/10 border-cyan-500/20">
                        <span class="material-symbols-outlined text-sm">folder_open</span>
                        App
                      </span>
                    </td>
                    <td class="px-6 py-4">
                      <div>
                        <p class="font-bold text-on-background">${item.name}</p>
                        <p class="text-xs text-slate-500 mt-0.5">${item.description}</p>
                      </div>
                    </td>
                    <td class="px-6 py-4">
                      <span class="text-sm text-slate-400">${item.team}</span>
                    </td>
                    <td class="px-6 py-4">
                      ${coverageBadge(projectCoverage)}
                    </td>
                    <td class="px-6 py-4">
                      <span class="text-xs text-slate-500">${formatDate(item.createdAt)}</span>
                    </td>
                    <td class="px-6 py-4">
                      <div class="flex items-center gap-4 text-xs">
                        <span class="text-slate-400">${item.projectCount} projects</span>
                        <span class="text-slate-400">${item.repoCount} with repo</span>
                      </div>
                    </td>
                  </tr>
                  ${item.children && item.children.length > 0 ? item.children.map((project: any) => `
                    <tr class="hover:bg-slate-900/30 transition-colors bg-slate-900/20">
                      <td class="px-6 py-4">
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded border text-[10px] font-bold uppercase tracking-wider text-emerald-400 bg-emerald-500/10 border-emerald-500/20">
                          <span class="material-symbols-outlined text-sm">code</span>
                          Project
                        </span>
                      </td>
                      <td class="px-6 py-4">
                        <div>
                          <p class="font-bold text-on-background">${project.name}</p>
                          <p class="text-xs text-slate-500 mt-0.5">${project.description || 'No description'}</p>
                          ${project.repo_url ? `<a href="${project.repo_url}" target="_blank" class="text-[10px] text-cyan-400 hover:underline mt-1 block truncate max-w-xs">${project.repo_name || project.repo_url}</a>` : '<p class="text-[10px] text-amber-400 mt-1 italic">No repo connected</p>'}
                        </div>
                      </td>
                      <td class="px-6 py-4">
                        <span class="text-sm text-slate-400">${item.team}</span>
                      </td>
                      <td class="px-6 py-4">
                        ${project.repo_id ? '<span class="text-[10px] text-emerald-400 bg-emerald-500/10 px-2 py-0.5 rounded border border-emerald-500/20">Connected</span>' : '<span class="text-[10px] text-slate-500 bg-slate-700 px-2 py-0.5 rounded">No repo</span>'}
                      </td>
                      <td class="px-6 py-4">
                        <span class="text-xs text-slate-500">${formatDate(project.createdAt)}</span>
                      </td>
                      <td class="px-6 py-4">
                        <span class="text-xs text-slate-400">Parent: ${item.name}</span>
                      </td>
                    </tr>
                  `).join('') : ''}
                `;
              } else {
                return `
                  <tr class="hover:bg-slate-900/30 transition-colors">
                    <td class="px-6 py-4">
                      <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded border text-[10px] font-bold uppercase tracking-wider text-emerald-400 bg-emerald-500/10 border-emerald-500/20">
                        <span class="material-symbols-outlined text-sm">code</span>
                        Project
                      </span>
                    </td>
                    <td class="px-6 py-4">
                      <div>
                        <p class="font-bold text-on-background">${item.name}</p>
                        <p class="text-xs text-slate-500 mt-0.5">${item.description}</p>
                        <p class="text-[10px] text-slate-600 mt-1">App: ${item.app}</p>
                      </div>
                    </td>
                    <td class="px-6 py-4">
                      <span class="text-sm text-slate-400">${item.team}</span>
                    </td>
                    <td class="px-6 py-4">
                      <span class="text-[10px] text-amber-400 bg-amber-500/10 px-2 py-0.5 rounded border border-amber-500/20">No repo</span>
                    </td>
                    <td class="px-6 py-4">
                      <span class="text-xs text-slate-500">${formatDate(item.createdAt)}</span>
                    </td>
                    <td class="px-6 py-4">
                      <span class="text-xs text-slate-400">Standalone</span>
                    </td>
                  </tr>
                `;
              }
            }).join('')}
          </tbody>
        </table>`;
    } catch (e) {
      console.error(e);
    }
  }

  document.getElementById('filter-btn')!.addEventListener('click', loadInventory);

  loadInventory();
</script>
