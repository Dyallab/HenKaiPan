---
import DashboardLayout from '@layouts/DashboardLayout.astro';
---
<DashboardLayout title="Security Scans" active="scans">

  <!-- New scan form -->
  <div class="bg-surface-container-low border border-outline-variant/20 rounded-xl p-5 mb-5">
    <h2 class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-4">New Scan</h2>

    <!-- Tab bar -->
    <div class="flex gap-2 mb-5">
      <button data-tab-trigger="target" class="tab-trigger px-4 py-2 rounded-xl text-sm font-semibold text-slate-300 bg-slate-900/80">
        <span class="material-symbols-outlined text-base align-middle mr-1.5">search</span>
        Target
      </button>
      <button data-tab-trigger="scanner" class="tab-trigger px-4 py-2 rounded-xl text-sm font-semibold text-slate-500 hover:text-slate-200 transition-colors">
        <span class="material-symbols-outlined text-base align-middle mr-1.5">security</span>
        Scanner &amp; Run
      </button>
    </div>

    <form id="scan-form">
      <!-- Panel: Target -->
      <div data-tab-panel="target" class="tab-panel space-y-4">
        <div class="flex gap-3 flex-wrap">
          <!-- Combobox: search apps & projects -->
          <div class="relative flex-1 min-w-56" id="target-combobox">
            <div class="relative">
              <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 text-lg">search</span>
              <input
                id="scan-target-search"
                type="text"
                placeholder="Search app or project..."
                autocomplete="off"
                class="w-full bg-surface-container border border-outline-variant/30 text-on-background rounded-lg pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-all placeholder:text-slate-600"
              />
              <button
                id="scan-target-clear"
                type="button"
                class="hidden absolute right-2 top-1/2 -translate-y-1/2 text-slate-500 hover:text-ghost-white transition-colors p-0.5"
              >
                <span class="material-symbols-outlined text-base">close</span>
              </button>
            </div>

            <!-- Dropdown -->
            <div
              id="scan-target-dropdown"
              class="hidden absolute z-50 mt-1 w-full bg-surface-container border border-outline-variant/30 rounded-xl shadow-2xl max-h-72 overflow-auto"
            ></div>

            <!-- Selection badge (shown inline under combobox) -->
            <div id="scan-target-badge" class="hidden mt-2"></div>
          </div>

        </div>
      </div>

      <!-- Panel: Scanner & Run -->
      <div data-tab-panel="scanner" class="tab-panel hidden space-y-4">
        <!-- Selection summary -->
        <div id="scanner-selection-summary" class="text-sm text-slate-400">
          No target selected. Go to <strong>Target</strong> tab first.
        </div>

        <div class="flex gap-3 flex-wrap items-end">
          <!-- Scanner select -->
          <div class="relative w-72">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 text-lg">tune</span>
            <select
              id="scan-scanner"
              class="w-full bg-surface-container border border-outline-variant/30 text-on-background rounded-lg pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:border-cyan-500 transition-all appearance-none"
            >
              <option value="all">⚡ All Git Scanners</option>
              <option value="sast">🔒 SAST (semgrep + gosec)</option>
              <option value="sca">📦 SCA (trivy + grype + osv)</option>
              <option value="secrets">🔑 Secrets (trufflehog + gitleaks)</option>
              <option value="iac">🏗️ IaC (checkov + tfsec + kics)</option>
              <option value="containers">🐳 Containers (trivy + grype)</option>
              <optgroup label="── Individual Scanners ──">
                <optgroup label="&nbsp;&nbsp;SAST">
                  <option value="semgrep">semgrep</option>
                  <option value="gosec">gosec (Go)</option>
                </optgroup>
                <optgroup label="&nbsp;&nbsp;SCA">
                  <option value="trivy">trivy</option>
                  <option value="grype">grype</option>
                  <option value="osv-scanner">osv-scanner</option>
                </optgroup>
                <optgroup label="&nbsp;&nbsp;Secrets">
                  <option value="trufflehog">trufflehog</option>
                  <option value="gitleaks">gitleaks</option>
                </optgroup>
                <optgroup label="&nbsp;&nbsp;IaC">
                  <option value="checkov">checkov</option>
                  <option value="tfsec">tfsec</option>
                  <option value="kics">kics</option>
                </optgroup>
                <optgroup label="&nbsp;&nbsp;Containers">
                  <option value="trivy-image">trivy image</option>
                  <option value="grype-image">grype image</option>
                </optgroup>
                <optgroup label="&nbsp;&nbsp;DAST">
                  <option value="nuclei">nuclei</option>
                </optgroup>
              </optgroup>
            </select>
          </div>

          <button
            type="submit"
            id="scan-btn"
            class="flex items-center gap-2 px-6 py-2.5 bg-cyan-500 text-slate-950 rounded-lg text-sm font-bold hover:bg-cyan-400 transition-all active:scale-95"
          >
            <span class="material-symbols-outlined text-lg">rocket_launch</span>
            Run New Scan
          </button>
        </div>
      </div>
    </form>

    <div id="scan-msg" class="hidden mt-3 text-sm"></div>
  </div>

  <!-- Scans table -->
  <div class="bg-surface-container-low border border-outline-variant/20 rounded-xl overflow-hidden">
    <div class="px-5 py-3 border-b border-outline-variant/20 flex items-center justify-between">
      <h2 class="text-[10px] font-bold uppercase tracking-widest text-slate-500">All Scans</h2>
      <div class="flex items-center gap-3">
        <span id="scans-total" class="text-xs text-slate-500 font-mono"></span>
        <button
          id="refresh-btn"
          class="flex items-center gap-1.5 px-3 py-1.5 bg-surface-container-high border border-outline-variant/30 text-slate-400 rounded-lg text-xs font-bold hover:text-cyan-400 hover:border-cyan-500/50 transition-all active:scale-95"
          title="Refresh scans"
        >
          <span class="material-symbols-outlined text-sm">sync</span>
          Refresh
        </button>
      </div>
    </div>
    <div id="scans-table" class="overflow-x-auto">
      <p class="px-5 py-3 text-sm text-slate-500">Loading...</p>
    </div>
  </div>

</DashboardLayout>

<script>
  import { api } from '@lib/api';

  const SCANNER_TYPE: Record<string, { label: string; color: string }> = {
    semgrep:       { label: 'SAST',      color: 'text-cyan-400 bg-cyan-500/10 border-cyan-500/20' },
    gosec:         { label: 'SAST',      color: 'text-cyan-400 bg-cyan-500/10 border-cyan-500/20' },
    trivy:         { label: 'SCA',       color: 'text-purple-400 bg-purple-500/10 border-purple-500/20' },
    grype:         { label: 'SCA',       color: 'text-purple-400 bg-purple-500/10 border-purple-500/20' },
    'osv-scanner': { label: 'SCA',       color: 'text-purple-400 bg-purple-500/10 border-purple-500/20' },
    trufflehog:    { label: 'Secrets',   color: 'text-amber-400 bg-amber-500/10 border-amber-500/20' },
    gitleaks:      { label: 'Secrets',   color: 'text-amber-400 bg-amber-500/10 border-amber-500/20' },
    checkov:       { label: 'IaC',       color: 'text-green-400 bg-green-500/10 border-green-500/20' },
    tfsec:         { label: 'IaC',       color: 'text-green-400 bg-green-500/10 border-green-500/20' },
    kics:          { label: 'IaC',       color: 'text-green-400 bg-green-500/10 border-green-500/20' },
    'trivy-image': { label: 'Container', color: 'text-cyan-400 bg-cyan-500/10 border-cyan-500/20' },
    'grype-image': { label: 'Container', color: 'text-cyan-400 bg-cyan-500/10 border-cyan-500/20' },
    nuclei:        { label: 'DAST',      color: 'text-orange-400 bg-orange-500/10 border-orange-500/20' },
    all:           { label: 'All',       color: 'text-slate-300 bg-slate-500/10 border-slate-500/20' },
    sast:          { label: 'SAST',      color: 'text-cyan-400 bg-cyan-500/10 border-cyan-500/20' },
    sca:           { label: 'SCA',       color: 'text-purple-400 bg-purple-500/10 border-purple-500/20' },
    secrets:       { label: 'Secrets',   color: 'text-amber-400 bg-amber-500/10 border-amber-500/20' },
    iac:           { label: 'IaC',       color: 'text-green-400 bg-green-500/10 border-green-500/20' },
    containers:    { label: 'Container', color: 'text-cyan-400 bg-cyan-500/10 border-cyan-500/20' },
  };

  const STATUS_DOT: Record<string, string> = {
    completed: 'bg-emerald-400 shadow-[0_0_6px_rgba(52,211,153,0.5)]',
    running:   'bg-cyan-400 shadow-[0_0_6px_rgba(34,211,238,0.5)]',
    pending:   'bg-amber-400',
    failed:    'bg-red-400 shadow-[0_0_6px_rgba(248,113,113,0.5)]',
  };

  const STATUS_TEXT: Record<string, string> = {
    completed: 'text-emerald-400',
    running:   'text-cyan-400',
    pending:   'text-amber-400',
    failed:    'text-red-400',
  };

  // ── Combobox state ──
  interface ComboboxItem {
    type: 'app' | 'project';
    id: string;
    name: string;
    subtitle: string;
    projectCount?: number;
    repoUrl?: string;
  }

  let allItems: ComboboxItem[] = [];
  let selectedApp: { id: string; name: string; projectCount: number } | null = null;
  let selectedProject: { id: string; name: string; repoUrl: string } | null = null;
  let highlightedIdx = -1;
  let dropdownOpen = false;

  // ── Helpers ──
  function scannerType(scanner: string) {
    return SCANNER_TYPE[scanner] ?? { label: scanner.toUpperCase(), color: 'text-slate-400 bg-slate-500/10 border-slate-500/20' };
  }

  function escapeHtml(s: string): string {
    const div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
  }

  // ── Tabs ──
  function setupTabs() {
    const triggers = Array.from(document.querySelectorAll<HTMLElement>('[data-tab-trigger]'));
    const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-tab-panel]'));

    function activate(tab: string) {
      triggers.forEach(trigger => {
        const active = trigger.dataset.tabTrigger === tab;
        trigger.className = active
          ? 'tab-trigger px-4 py-2 rounded-xl text-sm font-semibold text-slate-300 bg-slate-900/80'
          : 'tab-trigger px-4 py-2 rounded-xl text-sm font-semibold text-slate-500 hover:text-slate-200 transition-colors';
      });
      panels.forEach(panel =>
        panel.classList.toggle('hidden', panel.dataset.tabPanel !== tab),
      );
    }

    triggers.forEach(trigger =>
      trigger.addEventListener('click', () => activate(trigger.dataset.tabTrigger!)),
    );
    activate('target');
  }

  // ── Scans table ──
  async function loadScans() {
    const { scans, total } = await api.getScans(1, 50);
    document.getElementById('scans-total')!.textContent = `${total} total`;

    const el = document.getElementById('scans-table')!;
    if (!scans.length) {
      el.innerHTML = `<div class="flex flex-col items-center justify-center py-12 text-center">
        <span class="material-symbols-outlined text-slate-700 text-5xl mb-3">security_update_good</span>
        <p class="text-slate-400 font-semibold text-lg">No scans yet</p>
        <p class="text-slate-600 text-sm mt-1">Select a project above and run your first scan.</p>
        <p class="text-slate-600 text-xs mt-2">Need a project? <a href="/dashboard/projects" class="text-cyan-400 hover:underline">Create one first →</a></p>
      </div>`;
      return;
    }

    el.innerHTML = `
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-950/50 border-b border-slate-800">
            <th class="text-left px-5 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500">Target</th>
            <th class="text-left px-5 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500">Type</th>
            <th class="text-left px-5 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500">Scanner</th>
            <th class="text-left px-5 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500">Status</th>
            <th class="text-right px-5 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500">Findings</th>
            <th class="text-right px-5 py-3 text-[10px] font-bold uppercase tracking-widest text-slate-500">Started</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-800/50">
          ${scans.map(s => {
            const type = scannerType(s.scanner);
            const dot = STATUS_DOT[s.status] ?? 'bg-slate-600';
            const txt = STATUS_TEXT[s.status] ?? 'text-slate-400';
            return `
              <tr class="hover:bg-slate-900/30 transition-colors">
                <td class="px-5 py-3">
                  <div class="flex flex-col">
                    <a href="/dashboard/scans/detail/?id=${s.id}" class="font-bold text-cyan-400 hover:text-cyan-300 truncate max-w-xs text-sm">${s.target}</a>
                    <span class="text-[10px] text-slate-500 font-mono uppercase mt-0.5">ID: ${s.id}</span>
                  </div>
                </td>
                <td class="px-5 py-3">
                  <span class="px-2 py-1 text-[10px] font-bold rounded uppercase tracking-wider border ${type.color}">${type.label}</span>
                </td>
                <td class="px-5 py-3">
                  <span class="font-mono text-xs text-slate-400">${s.scanner}</span>
                </td>
                <td class="px-5 py-3">
                  <div class="flex items-center gap-2">
                    <div class="w-2 h-2 rounded-full shrink-0 ${dot}"></div>
                    <span class="text-xs font-bold capitalize ${txt}">${s.status}</span>
                  </div>
                </td>
                <td class="px-5 py-3 text-right">
                  <span class="font-mono text-sm text-on-surface-variant">${s.finding_count}</span>
                </td>
                <td class="px-5 py-3 text-right text-xs text-slate-500 font-mono">
                  ${new Date(s.created_at).toLocaleString()}
                </td>
              </tr>`;
          }).join('')}
        </tbody>
      </table>`;
  }

  // ── Combobox ──
  function filterItems(q: string): ComboboxItem[] {
    if (!q.trim()) return allItems.slice(0, 50);
    const lower = q.toLowerCase();
    return allItems.filter(i =>
      i.name.toLowerCase().includes(lower) || i.subtitle.toLowerCase().includes(lower)
    ).slice(0, 100);
  }

  function renderDropdown(items: ComboboxItem[]) {
    const dd = document.getElementById('scan-target-dropdown')!;
    if (!items.length) {
      dd.innerHTML = '<div class="p-4 text-sm text-slate-500 text-center">No results</div>';
      dd.classList.remove('hidden');
      return;
    }

    dd.innerHTML = items.map((item, idx) => {
      const hl = highlightedIdx === idx;
      if (item.type === 'app') {
        return `<button type="button" data-index="${idx}" class="w-full text-left px-4 py-3 flex items-center gap-3 transition-colors ${hl ? 'bg-cyan-500/10' : 'hover:bg-white/[0.04]'} border-b border-white/5 last:border-0">
          <span class="material-symbols-outlined text-cyan-400 text-lg">folder</span>
          <div class="min-w-0 flex-1">
            <div class="text-sm font-medium text-ghost-white truncate">${escapeHtml(item.name)}</div>
            <div class="text-[10px] text-slate-500">${item.projectCount} project${item.projectCount !== 1 ? 's' : ''}</div>
          </div>
          <span class="text-[10px] uppercase tracking-wider text-cyan-500 font-semibold shrink-0">App</span>
        </button>`;
      }
      return `<button type="button" data-index="${idx}" class="w-full text-left px-4 py-3 flex items-center gap-3 transition-colors ${hl ? 'bg-cyan-500/10' : 'hover:bg-white/[0.04]'} border-b border-white/5 last:border-0">
        <span class="material-symbols-outlined text-slate-400 text-lg">description</span>
        <div class="min-w-0 flex-1">
          <div class="text-sm font-medium text-ghost-white truncate">${escapeHtml(item.name)}</div>
          <div class="text-[10px] text-slate-500 truncate">${escapeHtml(item.subtitle)}</div>
        </div>
        <span class="text-[10px] uppercase tracking-wider text-slate-500 font-semibold shrink-0">Project</span>
      </button>`;
    }).join('');
    dd.classList.remove('hidden');
  }

  function updateScannerSummary() {
    const summary = document.getElementById('scanner-selection-summary')!;
    if (selectedApp) {
      summary.innerHTML = `<div class="flex items-center gap-2 text-xs text-cyan-400 bg-cyan-500/10 border border-cyan-500/20 rounded-lg px-3 py-2">
        <span class="material-symbols-outlined text-sm">folder</span>
        Scanning all <strong>${selectedApp.projectCount}</strong> project${selectedApp.projectCount !== 1 ? 's' : ''} in <strong>${escapeHtml(selectedApp.name)}</strong>
      </div>`;
    } else if (selectedProject) {
      summary.innerHTML = `<div class="flex items-center gap-2 text-xs text-slate-300 bg-white/5 border border-white/10 rounded-lg px-3 py-2">
        <span class="material-symbols-outlined text-sm">description</span>
        Scanning project <strong>${escapeHtml(selectedProject.name)}</strong>
        <span class="text-slate-500 ml-1">${escapeHtml(selectedProject.repoUrl)}</span>
      </div>`;
    } else {
      summary.innerHTML = 'No target selected. Select an app or project in the <strong>Target</strong> tab first.';
    }
  }

  function selectItem(item: ComboboxItem) {
    const searchInput = document.getElementById('scan-target-search') as HTMLInputElement;
    const clearBtn = document.getElementById('scan-target-clear')!;
    const badge = document.getElementById('scan-target-badge')!;

    closeDropdown();

    if (item.type === 'app') {
      selectedApp = { id: item.id, name: item.name, projectCount: item.projectCount || 0 };
      selectedProject = null;
      searchInput.value = item.name;
      badge.innerHTML = `<div class="flex items-center gap-2 text-xs text-cyan-400 bg-cyan-500/10 border border-cyan-500/20 rounded-lg px-3 py-1.5">
        <span class="material-symbols-outlined text-sm">folder</span>
        Scanning all <strong>${item.projectCount}</strong> project${item.projectCount !== 1 ? 's' : ''} in <strong>${escapeHtml(item.name)}</strong>
      </div>`;
      badge.classList.remove('hidden');
    } else {
      selectedProject = { id: item.id, name: item.name, repoUrl: item.repoUrl || '' };
      selectedApp = null;
      searchInput.value = item.name;
      badge.innerHTML = `<div class="flex items-center gap-2 text-xs text-slate-300 bg-white/5 border border-white/10 rounded-lg px-3 py-1.5">
        <span class="material-symbols-outlined text-sm">description</span>
        Scanning project <strong>${escapeHtml(item.name)}</strong>
        <span class="text-slate-500 ml-1">${escapeHtml(item.repoUrl || '')}</span>
      </div>`;
      badge.classList.remove('hidden');
    }

    clearBtn.classList.remove('hidden');
    updateScannerSummary();
  }

  function clearSelection() {
    selectedApp = null;
    selectedProject = null;
    const searchInput = document.getElementById('scan-target-search') as HTMLInputElement;
    const badge = document.getElementById('scan-target-badge')!;
    const clearBtn = document.getElementById('scan-target-clear')!;

    searchInput.value = '';
    badge.classList.add('hidden');
    clearBtn.classList.add('hidden');
    searchInput.focus();
    updateScannerSummary();
  }

  function openDropdown() {
    const dd = document.getElementById('scan-target-dropdown')!;
    dd.classList.remove('hidden');
    dropdownOpen = true;
  }

  function closeDropdown() {
    const dd = document.getElementById('scan-target-dropdown')!;
    dd.classList.add('hidden');
    dropdownOpen = false;
    highlightedIdx = -1;
  }

  function handleSearchInput() {
    const searchInput = document.getElementById('scan-target-search') as HTMLInputElement;
    const q = searchInput.value;

    if (selectedApp || selectedProject) {
      const selectedName = selectedApp?.name || selectedProject?.name || '';
      if (q !== selectedName) {
        clearSelection();
      } else {
        return;
      }
    }

    const items = filterItems(q);
    highlightedIdx = -1;
    if (items.length > 0) {
      renderDropdown(items);
      openDropdown();
    } else {
      closeDropdown();
    }
  }

  function handleDropdownClick(e: MouseEvent) {
    const target = (e.target as HTMLElement).closest('[data-index]') as HTMLElement;
    if (!target) return;
    const idx = parseInt(target.dataset.index!, 10);
    const q = (document.getElementById('scan-target-search') as HTMLInputElement).value;
    const items = filterItems(q);
    if (idx >= 0 && idx < items.length) {
      selectItem(items[idx]);
    }
  }

  function handleDropdownKeydown(e: KeyboardEvent) {
    const searchInput = document.getElementById('scan-target-search') as HTMLInputElement;
    const q = searchInput.value;
    const items = filterItems(q);

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (!dropdownOpen) {
        renderDropdown(items);
        openDropdown();
      }
      highlightedIdx = Math.min(highlightedIdx + 1, items.length - 1);
      renderDropdown(items);
      const dd = document.getElementById('scan-target-dropdown')!;
      const btn = dd.querySelector(`[data-index="${highlightedIdx}"]`) as HTMLElement;
      btn?.scrollIntoView({ block: 'nearest' });
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (!dropdownOpen) return;
      highlightedIdx = Math.max(highlightedIdx - 1, 0);
      renderDropdown(items);
      const dd = document.getElementById('scan-target-dropdown')!;
      const btn = dd.querySelector(`[data-index="${highlightedIdx}"]`) as HTMLElement;
      btn?.scrollIntoView({ block: 'nearest' });
    } else if (e.key === 'Enter' && dropdownOpen && highlightedIdx >= 0 && highlightedIdx < items.length) {
      e.preventDefault();
      selectItem(items[highlightedIdx]);
    } else if (e.key === 'Escape') {
      closeDropdown();
    }
  }

  // ── Load combobox data ──
  async function loadComboboxData() {
    const [apps, projects] = await Promise.all([
      api.getApps().catch(() => []),
      api.getProjects().catch(() => []),
    ]);

    const projectAppMap = new Map<string, string>();
    for (const app of apps) {
      for (const p of app.projects || []) {
        projectAppMap.set(p.id, app.name);
      }
    }

    for (const app of apps) {
      const count = (app.projects || []).length;
      allItems.push({
        type: 'app',
        id: app.id,
        name: app.name,
        subtitle: `${count} project${count !== 1 ? 's' : ''}`,
        projectCount: count,
      });
    }

    const knownProjectIds = new Set(projectAppMap.keys());

    for (const p of projects) {
      if (knownProjectIds.has(p.id)) continue;
      allItems.push({
        type: 'project',
        id: p.id,
        name: p.name,
        subtitle: p.repo_url || 'No repository URL',
        repoUrl: p.repo_url || undefined,
      });
    }
  }

  // ── Form submit ──
  document.getElementById('scan-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const scanner = (document.getElementById('scan-scanner') as HTMLSelectElement).value;
    const btn = document.getElementById('scan-btn') as HTMLButtonElement;
    const msg = document.getElementById('scan-msg')!;

    btn.disabled = true;
    btn.innerHTML = '<span class="material-symbols-outlined text-lg" style="animation:spin 1s linear infinite">sync</span> Queuing...';
    msg.className = 'hidden mt-3 text-sm';

    try {
      if (selectedApp) {
        await api.createAppScan(selectedApp.id, scanner);
        msg.textContent = `Scan queued for all ${selectedApp.projectCount} projects in ${selectedApp.name}.`;
        msg.className = 'mt-3 text-sm text-emerald-400';
        clearSelection();
      } else if (selectedProject) {
        await api.createScan(selectedProject.repoUrl, scanner, selectedProject.id);
        msg.textContent = `Scan queued for project ${selectedProject.name}.`;
        msg.className = 'mt-3 text-sm text-emerald-400';
        clearSelection();
      } else {
        msg.textContent = 'Select an app or project before running a scan.';
        msg.className = 'mt-3 text-sm text-red-400';
        btn.disabled = false;
        btn.innerHTML = '<span class="material-symbols-outlined text-lg">rocket_launch</span> Run New Scan';
        return;
      }
      setTimeout(loadScans, 500);
    } catch (err: any) {
      msg.textContent = err.message;
      msg.className = 'mt-3 text-sm text-red-400';
    } finally {
      btn.disabled = false;
      btn.innerHTML = '<span class="material-symbols-outlined text-lg">rocket_launch</span> Run New Scan';
    }
  });

  // ── Event wiring ──
  const searchInput = document.getElementById('scan-target-search') as HTMLInputElement;
  const dropdown = document.getElementById('scan-target-dropdown')!;
  const clearBtn = document.getElementById('scan-target-clear')!;

  searchInput.addEventListener('input', handleSearchInput);
  searchInput.addEventListener('keydown', handleDropdownKeydown);
  searchInput.addEventListener('focus', () => {
    if (searchInput.value && !selectedApp && !selectedProject) {
      handleSearchInput();
    }
  });
  dropdown.addEventListener('click', handleDropdownClick);
  clearBtn.addEventListener('click', clearSelection);

  document.addEventListener('click', (e) => {
    const container = document.getElementById('target-combobox')!;
    if (!container.contains(e.target as Node)) {
      closeDropdown();
    }
  });

  document.getElementById('refresh-btn')!.addEventListener('click', () => {
    const btn = document.getElementById('refresh-btn')!;
    const icon = btn.querySelector('.material-symbols-outlined')!;
    icon.style.animation = 'spin 1s linear infinite';
    loadScans().finally(() => {
      icon.style.animation = '';
    });
  });

  // ── Init ──
  setupTabs();
  loadComboboxData();
  loadScans();
</script>
