---
import DashboardLayout from '@layouts/DashboardLayout.astro';
---
<DashboardLayout title="Apps & Projects" active="apps">

<!-- Header -->
<div class="flex items-center justify-between mb-5">
  <div>
    <h1 class="text-xl font-bold text-white">Apps & Projects</h1>
    <p class="text-slate-400 text-sm mt-0.5">Team → App → Project → Repo hierarchy</p>
  </div>
  <button id="open-create-app"
    class="flex items-center gap-2 bg-cyan-500 hover:bg-cyan-400 text-slate-950 font-bold text-xs uppercase tracking-widest px-3.5 py-2 rounded transition-colors">
    <span class="material-symbols-outlined text-lg">add</span>
    New App
  </button>
</div>

<!-- Search + Team filter -->
<div class="flex gap-3 mb-4">
  <input id="search-apps" type="text" placeholder="Search apps by name..."
    class="flex-1 min-w-0 bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-cyan-500" />
  <div id="team-tabs" class="flex gap-2 flex-wrap"></div>
</div>

<!-- Team metrics banner -->
<div id="team-metrics-row" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-3 mb-5"></div>

<!-- App list -->
<div id="app-list" class="space-y-4"></div>

<!-- Empty state -->
<div id="empty-state" class="hidden flex-col items-center justify-center py-16 text-center">
  <span class="material-symbols-outlined text-slate-700 text-6xl mb-4">apps</span>
  <p class="text-slate-400 font-semibold text-lg">No apps yet</p>
  <p class="text-slate-600 text-sm mt-1">Create your first app to start organizing projects and repos.</p>
</div>

<!-- Create App Modal -->
<div id="modal-create-app" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm">
  <div class="bg-slate-900 border border-slate-700 rounded-xl w-full max-w-md p-6 shadow-2xl">
    <h3 class="text-lg font-bold text-white mb-5">New Application</h3>
    <div class="space-y-4">
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1.5">Name *</label>
        <input id="app-name" type="text" placeholder="e.g. Payment Gateway"
          class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-cyan-500" />
      </div>
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1.5">Description</label>
        <textarea id="app-desc" rows="2" placeholder="Optional description"
          class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-cyan-500 resize-none"></textarea>
      </div>
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1.5">Team</label>
        <select id="app-team"
          class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm text-white focus:outline-none focus:border-cyan-500">
          <option value="">— No team —</option>
        </select>
      </div>
    </div>
    <div id="app-error" class="hidden mt-3 text-red-400 text-xs"></div>
    <div class="flex gap-3 mt-6">
      <button id="cancel-create-app" class="flex-1 bg-slate-800 hover:bg-slate-700 text-slate-300 text-xs font-bold uppercase tracking-widest py-2.5 rounded transition-colors">Cancel</button>
      <button id="submit-create-app" class="flex-1 bg-cyan-500 hover:bg-cyan-400 text-slate-950 text-xs font-bold uppercase tracking-widest py-2.5 rounded transition-colors">Create</button>
    </div>
  </div>
</div>

<!-- Edit App Modal -->
<div id="modal-edit-app" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm">
  <div class="bg-slate-900 border border-slate-700 rounded-xl w-full max-w-md p-6 shadow-2xl">
    <h3 class="text-lg font-bold text-white mb-5">Edit Application</h3>
    <div class="space-y-4">
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1.5">Name *</label>
        <input id="edit-app-name" type="text" placeholder="e.g. Payment Gateway"
          class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-cyan-500" />
      </div>
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1.5">Description</label>
        <textarea id="edit-app-desc" rows="2" placeholder="Optional description"
          class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-cyan-500 resize-none"></textarea>
      </div>
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1.5">Team</label>
        <select id="edit-app-team"
          class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm text-white focus:outline-none focus:border-cyan-500">
          <option value="">— No team —</option>
        </select>
      </div>
    </div>
    <div id="edit-app-error" class="hidden mt-3 text-red-400 text-xs"></div>
    <div class="flex gap-3 mt-6">
      <button id="cancel-edit-app" class="flex-1 bg-slate-800 hover:bg-slate-700 text-slate-300 text-xs font-bold uppercase tracking-widest py-2.5 rounded transition-colors">Cancel</button>
      <button id="submit-edit-app" class="flex-1 bg-cyan-500 hover:bg-cyan-400 text-slate-950 text-xs font-bold uppercase tracking-widest py-2.5 rounded transition-colors">Save Changes</button>
    </div>
  </div>
</div>

<!-- Assign Project Modal (Pattern-based) -->
<div id="modal-create-project" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm">
  <div class="bg-slate-900 border border-slate-700 rounded-xl w-full max-w-lg p-6 shadow-2xl max-h-[90vh] flex flex-col">
    <div class="flex items-center justify-between mb-1">
      <h3 class="text-lg font-bold text-white">Assign Projects to</h3>
      <button id="close-assign-modal" class="text-slate-400 hover:text-slate-200">
        <span class="material-symbols-outlined text-xl">close</span>
      </button>
    </div>
    <p id="project-modal-app-name" class="text-cyan-400 text-xs mb-5"></p>

    <div class="space-y-4">
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1.5">Pattern</label>
        <input id="assign-pattern" type="text" placeholder="e.g. facebook/* or @torvalds/* or org/repo-*"
          class="w-full bg-slate-800 border border-slate-700 rounded px-3 py-2 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-cyan-500 font-mono" />
        <p class="text-xs text-slate-500 mt-1">
          Match existing standalone projects by <code class="text-cyan-400">org/*</code> or <code class="text-cyan-400">@user/*</code> glob pattern on their repo URL
        </p>
      </div>
    </div>

    <!-- Loading -->
    <div id="assign-project-loading" class="hidden py-6 text-center">
      <p class="text-slate-400 text-sm">Searching...</p>
    </div>

    <!-- Preview -->
    <div id="assign-preview" class="hidden mt-3 flex-1 min-h-0">
      <div class="flex items-center justify-between mb-2">
        <p id="assign-preview-count" class="text-sm font-bold text-white"></p>
      </div>
      <div id="assign-preview-list" class="max-h-48 overflow-y-auto bg-slate-950 rounded-lg border border-slate-800 divide-y divide-slate-800"></div>
    </div>

    <div id="project-error" class="hidden mt-3 text-red-400 text-xs"></div>

    <div class="flex gap-3 mt-5">
      <button id="cancel-create-project" class="flex-1 bg-slate-800 hover:bg-slate-700 text-slate-300 text-xs font-bold uppercase tracking-widest py-2.5 rounded transition-colors">Cancel</button>
      <button id="assign-preview-btn" class="bg-slate-700 hover:bg-slate-600 text-slate-200 text-xs font-bold uppercase tracking-widest px-4 py-2.5 rounded transition-colors">Search</button>
      <button id="submit-bulk-assign" class="flex-1 bg-cyan-500 hover:bg-cyan-400 text-slate-950 text-xs font-bold uppercase tracking-widest py-2.5 rounded transition-colors disabled:opacity-50 disabled:cursor-not-allowed" disabled>Assign</button>
    </div>
  </div>
</div>

<script>
import { api, API_BASE } from '@lib/api.ts';
import type { App, TeamMetrics, Team } from '@lib/api.ts';

let allApps: App[] = [];
let allTeams: Team[] = [];
let teamMetrics: TeamMetrics[] = [];
let activeTeamFilter = '';
let pendingProjectAppId = '';
let pendingProjectAppName = '';
let pendingEditAppId = '';
let searchTerm = '';

const scoreColor = (score: number) =>
  score === 0 ? 'text-emerald-green' : score < 100 ? 'text-goldenrod' : score < 500 ? 'text-goldenrod' : 'text-vivid-crimson';

const severityDot = (label: string, count: number, color: string) =>
  count > 0 ? `<span class="flex items-center gap-1 text-xs ${color} font-bold">${count}<span class="text-slate-500 font-normal">${label}</span></span>` : '';

function renderTeamTabs() {
  const container = document.getElementById('team-tabs')!;
  const teams = [...new Set(allApps.map(a => a.team_name).filter(Boolean))] as string[];
  container.innerHTML = `
    <button data-team="" class="team-tab px-3 py-1.5 rounded text-xs font-bold uppercase tracking-widest transition-colors ${activeTeamFilter === '' ? 'bg-cyan-500 text-slate-950' : 'bg-slate-800 text-slate-400 hover:text-white'}">All</button>
    ${teams.map(t => {
      const tid = allApps.find(a => a.team_name === t)?.team_id ?? '';
      return `<button data-team="${tid}" class="team-tab px-3 py-1.5 rounded text-xs font-bold uppercase tracking-widest transition-colors ${activeTeamFilter === tid ? 'bg-cyan-500 text-slate-950' : 'bg-slate-800 text-slate-400 hover:text-white'}">${t}</button>`;
    }).join('')}
    ${allApps.some(a => !a.team_id) ? `<button data-team="__unassigned__" class="team-tab px-3 py-1.5 rounded text-xs font-bold uppercase tracking-widest transition-colors ${activeTeamFilter === '__unassigned__' ? 'bg-cyan-500 text-slate-950' : 'bg-slate-800 text-slate-400 hover:text-white'}">Unassigned</button>` : ''}
  `;
  container.querySelectorAll('.team-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      activeTeamFilter = (btn as HTMLElement).dataset.team ?? '';
      renderTeamTabs();
      renderApps();
    });
  });
}

function renderTeamMetrics() {
  const container = document.getElementById('team-metrics-row')!;
  if (!teamMetrics.length) { container.innerHTML = ''; return; }
  container.innerHTML = teamMetrics.map(m => `
    <div class="bg-slate-900 border border-slate-800 rounded-xl p-3">
      <div class="flex items-start justify-between mb-2">
        <div>
          <p class="text-white font-bold text-sm">${m.team_name}</p>
          <p class="text-slate-500 text-xs mt-0.5">${m.app_count} app${m.app_count !== 1 ? 's' : ''} · ${m.project_count} project${m.project_count !== 1 ? 's' : ''}</p>
        </div>
        <span class="text-xs font-black ${scoreColor(m.score)} bg-slate-800 px-2 py-1 rounded">${m.score}</span>
      </div>
      <div class="flex gap-3 flex-wrap mb-3">
        ${severityDot('C', m.critical, 'text-vivid-crimson')}
        ${severityDot('H', m.high, 'text-goldenrod')}
        ${severityDot('M', m.medium, 'text-spectrum-flare')}
        ${severityDot('L', m.low, 'text-emerald-green')}
        ${!m.critical && !m.high && !m.medium && !m.low ? '<span class="text-emerald-green text-xs font-bold">Clean</span>' : ''}
      </div>
      <div class="flex items-center gap-2">
        <div class="flex-1 bg-slate-800 rounded-full h-1.5">
          <div class="h-1.5 rounded-full ${m.sla_compliance >= 90 ? 'bg-emerald-green' : m.sla_compliance >= 70 ? 'bg-goldenrod' : 'bg-vivid-crimson'}"
            style="width:${m.sla_compliance}%"></div>
        </div>
        <span class="text-xs text-slate-400 shrink-0">${m.sla_compliance.toFixed(0)}% SLA</span>
      </div>
    </div>
  `).join('');
}

function renderApps() {
  const container = document.getElementById('app-list')!;
  const emptyState = document.getElementById('empty-state')!;

  let filtered = allApps;
  if (activeTeamFilter === '__unassigned__') {
    filtered = allApps.filter(a => !a.team_id);
  } else if (activeTeamFilter) {
    filtered = allApps.filter(a => a.team_id === activeTeamFilter);
  }
  if (searchTerm) {
    const q = searchTerm.toLowerCase();
    filtered = filtered.filter(a => a.name.toLowerCase().includes(q));
  }

  if (!filtered.length) {
    container.innerHTML = '';
    emptyState.classList.remove('hidden');
    emptyState.classList.add('flex');
    const title = emptyState.querySelector('p:first-of-type')!;
    const sub = emptyState.querySelector('p:last-of-type')!;
    if (searchTerm || activeTeamFilter) {
      title.textContent = 'No apps match your filter';
      sub.textContent = 'Try a different search or clear the filters.';
    } else {
      title.textContent = 'No apps yet';
      sub.textContent = 'Create your first app to start organizing projects and repos.';
    }
    return;
  }
  emptyState.classList.add('hidden');
  emptyState.classList.remove('flex');

  container.innerHTML = filtered.map(app => `
    <div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden">
      <!-- App header -->
      <div class="flex items-center justify-between px-4 py-3 border-b border-slate-800/60">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-cyan-400 text-base">folder_open</span>
          </div>
          <div>
            <p class="text-white font-bold text-sm">${app.name}</p>
            <p class="text-slate-500 text-xs mt-0.5">
              ${app.team_name ? `<span class="text-cyan-400/70">${app.team_name}</span> · ` : ''}
              ${app.description || '<span class="italic">No description</span>'}
            </p>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-xs text-slate-500">${(app.projects || []).length} project${(app.projects || []).length !== 1 ? 's' : ''}</span>
          <button data-add-project="${app.id}" data-app-name="${app.name}"
            class="flex items-center gap-1 bg-slate-800 hover:bg-slate-700 text-cyan-400 text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded transition-colors">
            <span class="material-symbols-outlined text-sm">add</span>
            Project
          </button>
          <button data-edit-app="${app.id}" data-app-name="${app.name}" data-app-desc="${app.description || ''}" data-app-team="${app.team_id || ''}"
            class="p-1.5 text-slate-600 hover:text-cyan-400 rounded transition-colors" title="Edit app">
            <span class="material-symbols-outlined text-base">edit</span>
          </button>
          <button data-delete-app="${app.id}"
            class="p-1.5 text-slate-600 hover:text-red-400 rounded transition-colors">
            <span class="material-symbols-outlined text-base">delete</span>
          </button>
        </div>
      </div>

      <!-- Projects list -->
      ${(app.projects || []).length ? `
        <div class="divide-y divide-slate-800/50">
          ${app.projects.map(p => `
            <div class="flex items-center justify-between px-4 py-2.5 hover:bg-slate-800/30 transition-colors group">
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-slate-600 text-base">code</span>
                <div>
                  <p class="text-slate-200 text-sm font-medium">${p.name}</p>
                  ${p.repo_url
                    ? `<a href="${p.repo_url}" target="_blank" class="text-xs text-slate-500 hover:text-cyan-400 transition-colors font-mono">${p.repo_url}</a>`
                    : `<span class="text-xs text-slate-600 italic">No URL configured</span>`}
                </div>
              </div>
              <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                ${p.has_token ? '<span class="material-symbols-outlined text-green-400 text-sm" title="Token configured">key</span>' : ''}
                <button data-delete-project="${p.id}" data-app-id="${app.id}"
                  class="p-1 text-slate-600 hover:text-red-400 rounded transition-colors">
                  <span class="material-symbols-outlined text-sm">delete</span>
                </button>
              </div>
            </div>
          `).join('')}
        </div>
      ` : `
        <div class="px-5 py-6 text-center">
          <p class="text-slate-600 text-sm">No projects yet.</p>
        </div>
      `}
    </div>
  `).join('');

  // Assign project buttons
  container.querySelectorAll('[data-add-project]').forEach(btn => {
    btn.addEventListener('click', () => {
      pendingProjectAppId = (btn as HTMLElement).dataset.addProject!;
      pendingProjectAppName = (btn as HTMLElement).dataset.appName!;
      openAssignProjectModal();
    });
  });

  // Edit app
  container.querySelectorAll('[data-edit-app]').forEach(btn => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      pendingEditAppId = el.dataset.editApp!;
      const name = el.dataset.appName!;
      const desc = el.dataset.appDesc || '';
      const teamId = el.dataset.appTeam || '';
      openEditAppModal(name, desc, teamId);
    });
  });

  // Delete app
  container.querySelectorAll('[data-delete-app]').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm('Delete this app and all its projects?')) return;
      await api.deleteApp((btn as HTMLElement).dataset.deleteApp!);
      await loadAll();
    });
  });

  // Delete project
  container.querySelectorAll('[data-delete-project]').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm('Delete this project?')) return;
      const el = btn as HTMLElement;
      await api.deleteProject(el.dataset.deleteProject!);
      await loadAll();
    });
  });
}

let assignPreviewProjects: Array<{ id: string; name: string; repo_url: string }> = [];

async function openAssignProjectModal() {
  const modal = document.getElementById('modal-create-project')!;
  document.getElementById('project-modal-app-name')!.textContent = pendingProjectAppName;
  document.getElementById('project-error')!.classList.add('hidden');
  document.getElementById('assign-project-loading')!.classList.add('hidden');
  document.getElementById('assign-preview')!.classList.add('hidden');
  (document.getElementById('assign-pattern') as HTMLInputElement).value = '';
  (document.getElementById('submit-bulk-assign') as HTMLButtonElement).disabled = true;
  assignPreviewProjects = [];
  modal.classList.remove('hidden');
}

// Search button — find matching projects by pattern
document.getElementById('assign-preview-btn')!.addEventListener('click', async () => {
  const pattern = (document.getElementById('assign-pattern') as HTMLInputElement).value.trim();
  const errEl = document.getElementById('project-error')!;
  const loading = document.getElementById('assign-project-loading')!;

  if (!pattern) {
    errEl.textContent = 'Pattern is required (e.g. facebook/*)';
    errEl.classList.remove('hidden');
    return;
  }

  const btn = document.getElementById('assign-preview-btn')!;
  btn.textContent = 'Searching...';
  (btn as HTMLButtonElement).disabled = true;
  errEl.classList.add('hidden');
  loading.classList.remove('hidden');
  document.getElementById('assign-preview')!.classList.add('hidden');

  try {
    const res = await fetch(`${API_BASE}/api/projects?filter=without_app&pattern=${encodeURIComponent(pattern)}`, {
      credentials: 'include',
      headers: { 'Accept': 'application/json' },
    });
    if (!res.ok) {
      const err = await res.json().catch(() => ({ message: 'Search failed' }));
      throw new Error(err.message || err.error || 'Search failed');
    }
    const projects = await res.json();
    loading.classList.add('hidden');

    if (!projects.length) {
      errEl.textContent = `No standalone projects match "${pattern}"`;
      errEl.classList.remove('hidden');
      (document.getElementById('submit-bulk-assign') as HTMLButtonElement).disabled = true;
      return;
    }

    assignPreviewProjects = projects;
    document.getElementById('assign-preview-count')!.textContent = `${projects.length} project${projects.length !== 1 ? 's' : ''} match`;
    document.getElementById('assign-preview-list')!.innerHTML = projects.map((p: any) => `
      <div class="flex items-center gap-2 px-3 py-2">
        <span class="material-symbols-outlined text-slate-500 text-base">inventory_2</span>
        <span class="text-sm text-white font-mono">${p.name}</span>
        <span class="text-xs text-slate-500 ml-auto truncate max-w-xs">${p.repo_url || ''}</span>
      </div>
    `).join('');
    document.getElementById('assign-preview')!.classList.remove('hidden');
    (document.getElementById('submit-bulk-assign') as HTMLButtonElement).disabled = false;
  } catch (e: any) {
    loading.classList.add('hidden');
    errEl.textContent = e.message || 'Search failed';
    errEl.classList.remove('hidden');
  } finally {
    btn.textContent = 'Search';
    (btn as HTMLButtonElement).disabled = false;
  }
});

function openEditAppModal(name: string, desc: string, teamId: string) {
  const modal = document.getElementById('modal-edit-app')!;
  (document.getElementById('edit-app-name') as HTMLInputElement).value = name;
  (document.getElementById('edit-app-desc') as HTMLTextAreaElement).value = desc;
  (document.getElementById('edit-app-team') as HTMLSelectElement).value = teamId;
  document.getElementById('edit-app-error')!.classList.add('hidden');
  modal.classList.remove('hidden');
}

async function loadAll() {
  [allApps, allTeams, teamMetrics] = await Promise.all([
    api.getApps().catch(() => [] as App[]),
    api.getTeams().catch(() => [] as import('../../lib/api.ts').Team[]),
    api.getTeamMetrics().catch(() => [] as TeamMetrics[]),
  ]);

  // Populate team selects
  const populateTeamSelect = (id: string) => {
    const sel = document.getElementById(id) as HTMLSelectElement;
    sel.innerHTML = '<option value="">— No team —</option>' +
      allTeams.map(t => `<option value="${t.id}">${t.name}</option>`).join('');
  };
  populateTeamSelect('app-team');
  populateTeamSelect('edit-app-team');

  renderTeamTabs();
  renderTeamMetrics();
  renderApps();
}

// Create App modal
document.getElementById('open-create-app')!.addEventListener('click', () => {
  (document.getElementById('app-name') as HTMLInputElement).value = '';
  (document.getElementById('app-desc') as HTMLTextAreaElement).value = '';
  document.getElementById('app-error')!.classList.add('hidden');
  document.getElementById('modal-create-app')!.classList.remove('hidden');
});
document.getElementById('cancel-create-app')!.addEventListener('click', () => {
  document.getElementById('modal-create-app')!.classList.add('hidden');
});
document.getElementById('submit-create-app')!.addEventListener('click', async () => {
  const name = (document.getElementById('app-name') as HTMLInputElement).value.trim();
  const desc = (document.getElementById('app-desc') as HTMLTextAreaElement).value.trim();
  const teamId = (document.getElementById('app-team') as HTMLSelectElement).value || null;
  const errEl = document.getElementById('app-error')!;
  if (!name) { errEl.textContent = 'Name is required.'; errEl.classList.remove('hidden'); return; }
  try {
    await api.createApp(name, desc, teamId);
    document.getElementById('modal-create-app')!.classList.add('hidden');
    await loadAll();
  } catch (e: any) {
    errEl.textContent = e.message; errEl.classList.remove('hidden');
  }
});

// Edit App modal
document.getElementById('cancel-edit-app')!.addEventListener('click', () => {
  document.getElementById('modal-edit-app')!.classList.add('hidden');
});
document.getElementById('submit-edit-app')!.addEventListener('click', async () => {
  const name = (document.getElementById('edit-app-name') as HTMLInputElement).value.trim();
  const desc = (document.getElementById('edit-app-desc') as HTMLTextAreaElement).value.trim();
  const teamId = (document.getElementById('edit-app-team') as HTMLSelectElement).value || null;
  const errEl = document.getElementById('edit-app-error')!;
  if (!name) { errEl.textContent = 'Name is required.'; errEl.classList.remove('hidden'); return; }
  try {
    await api.updateApp(pendingEditAppId, { name, description: desc, team_id: teamId });
    document.getElementById('modal-edit-app')!.classList.add('hidden');
    await loadAll();
  } catch (e: any) {
    errEl.textContent = e.message; errEl.classList.remove('hidden');
  }
});

// Assign Project modal
document.getElementById('cancel-create-project')!.addEventListener('click', () => {
  document.getElementById('modal-create-project')!.classList.add('hidden');
});
document.getElementById('close-assign-modal')!.addEventListener('click', () => {
  document.getElementById('modal-create-project')!.classList.add('hidden');
});
document.getElementById('submit-bulk-assign')!.addEventListener('click', async () => {
  const projectIds = assignPreviewProjects.map(p => p.id);
  const btn = document.getElementById('submit-bulk-assign') as HTMLButtonElement;
  const errEl = document.getElementById('project-error')!;

  if (!projectIds.length) return;

  btn.textContent = 'Assigning...';
  btn.disabled = true;
  errEl.classList.add('hidden');

  try {
    const result = await api.bulkAssignProjects(pendingProjectAppId, projectIds);
    document.getElementById('modal-create-project')!.classList.add('hidden');
    await loadAll();

    const msg = `${result.assigned} project${result.assigned !== 1 ? 's' : ''} assigned`;
    const toast = document.createElement('div');
    toast.className = 'fixed bottom-4 right-4 z-50 bg-slate-800 border border-slate-700 text-white text-sm px-4 py-3 rounded-xl shadow-2xl';
    toast.textContent = msg;
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 4000);
  } catch (e: any) {
    errEl.textContent = e.message || 'Assignment failed';
    errEl.classList.remove('hidden');
    btn.textContent = 'Assign';
    btn.disabled = false;
  }
});

// Search
document.getElementById('search-apps')!.addEventListener('input', (e) => {
  searchTerm = (e.target as HTMLInputElement).value;
  renderApps();
});

// Close modals on backdrop click
['modal-create-app', 'modal-edit-app', 'modal-create-project'].forEach(id => {
  document.getElementById(id)!.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) (e.currentTarget as HTMLElement).classList.add('hidden');
  });
});

loadAll();
</script>

</DashboardLayout>
