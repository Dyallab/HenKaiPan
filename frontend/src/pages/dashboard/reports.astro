---
import DashboardLayout from "@layouts/DashboardLayout.astro";
---

<DashboardLayout title="Executive Reports" active="reports">
    <style is:global>
        @media print {
            html,
            body {
                background: #ffffff !important;
                color: #0f172a !important;
                height: auto !important;
                overflow: visible !important;
            }

            body > aside,
            body > div > header,
            .report-toolbar,
            .report-hide-print,
            #logout-btn {
                display: none !important;
            }

            body > div,
            body > div > main,
            .report-page {
                overflow: visible !important;
                height: auto !important;
                background: #ffffff !important;
            }

            body > div > main {
                padding: 0 !important;
            }

            .report-page {
                max-width: 1100px;
                margin: 0 auto;
                padding: 24px 28px 40px !important;
                color: #0f172a !important;
            }

            .report-card {
                break-inside: avoid;
                page-break-inside: avoid;
                border-color: #cbd5e1 !important;
                background: #ffffff !important;
                box-shadow: none !important;
            }

            .report-kpi,
            #trend-chart svg,
            .status-bar-track,
            .risk-track {
                break-inside: avoid;
            }

            .report-print-title,
            .report-print-subtitle,
            .report-print-copy,
            .report-print-muted,
            .report-print-mono,
            .report-print-table th,
            .report-print-table td,
            .report-print-list li,
            #trend-chart text {
                color: #0f172a !important;
                fill: #0f172a !important;
            }

            #trend-chart line {
                stroke: #cbd5e1 !important;
            }

            .report-accent-soft,
            .report-metric-chip {
                background: #eff6ff !important;
                color: #0f172a !important;
                border-color: #bfdbfe !important;
            }

            .report-print-table {
                width: 100%;
                border-collapse: collapse;
            }

            .report-print-table th,
            .report-print-table td {
                border-bottom: 1px solid #e2e8f0;
                padding: 10px 0;
                text-align: left;
            }

            .report-print-page-break {
                page-break-before: always;
            }

            a[href]:after {
                content: "" !important;
            }
        }
    </style>

    <div class="report-page space-y-6">
        <section
            class="report-card overflow-hidden rounded-2xl border border-white/10 bg-shadow-tint px-5 py-5"
        >
            <div
                class="report-toolbar flex items-start justify-between gap-4 flex-wrap"
            >
                <div>
                    <h1
                        class="report-print-title text-3xl font-light tracking-tight text-ghost-white font-aeonik"
                    >
                        Executive Reports
                    </h1>
                </div>
                <div class="flex items-center gap-2 print:hidden">
                    <button
                        id="print-btn"
                        class="flex items-center gap-2 rounded-lg border border-white/10 bg-white/5 px-4 py-2 text-sm font-medium text-ghost-white transition-colors hover:bg-white/10"
                    >
                        <span class="material-symbols-outlined text-base"
                            >print</span
                        >
                        Print PDF
                    </button>
                </div>
            </div>

            <div class="mt-4 grid gap-3 md:grid-cols-4">
                <div class="rounded-xl border border-white/10 bg-white/5 px-3 py-2.5">
                    <p class="text-[10px] font-medium uppercase tracking-[0.24em] text-iron-slate">Generated</p>
                    <p id="report-generated-at" class="mt-2 text-sm font-medium text-ghost-white">—</p>
                </div>
                    <div class="rounded-xl border border-white/10 bg-white/5 px-3 py-2.5">
                    <p class="text-[10px] font-medium uppercase tracking-[0.24em] text-iron-slate">Trend window</p>
                    <p id="report-window" class="mt-2 text-sm font-medium text-ghost-white">Last 30 days</p>
                </div>
                    <div class="rounded-xl border border-white/10 bg-white/5 px-3 py-2.5">
                    <p class="text-[10px] font-medium uppercase tracking-[0.24em] text-iron-slate">Export scope</p>
                    <p id="report-scope" class="mt-2 text-sm font-medium text-ghost-white">All severities · All statuses</p>
                </div>
                    <div class="rounded-xl border border-white/10 bg-white/5 px-3 py-2.5">
                    <p class="text-[10px] font-medium uppercase tracking-[0.24em] text-iron-slate">Report focus</p>
                    <p id="report-focus" class="mt-2 text-sm font-medium text-ghost-white">SLA, trends, risk</p>
                </div>
            </div>
        </section>

        <!-- Top bar: date range + export -->
        <div
            class="report-toolbar flex items-center justify-between mb-6 flex-wrap gap-3"
        >
            <div class="flex items-center gap-2">
                <label
                    class="text-xs text-slate-500 font-bold uppercase tracking-widest"
                    >Trend window</label
                >
                <select
                    id="days-select"
                    class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-cyan-500 transition-all"
                >
                    <option value="7">Last 7 days</option>
                    <option value="30" selected>Last 30 days</option>
                    <option value="90">Last 90 days</option>
                    <option value="365">Last 365 days</option>
                </select>
            </div>
            <div class="flex items-center gap-2">
                <fieldset
                    class="flex flex-wrap items-center gap-2 rounded-lg border border-outline-variant/30 bg-surface-container px-3 py-2"
                >
                    <legend
                        class="px-1 text-[10px] font-bold uppercase tracking-widest text-slate-500"
                        >Export severities</legend
                    >
                    <label class="inline-flex items-center gap-2 rounded-full border border-vivid-crimson/20 bg-vivid-crimson/10 px-2.5 py-1 text-xs font-medium text-vivid-crimson cursor-pointer">
                        <input type="checkbox" value="critical" data-export-severity class="h-3.5 w-3.5 rounded border-vivid-crimson/40 bg-transparent text-vivid-crimson focus:ring-0" />
                        Critical
                    </label>
                    <label class="inline-flex items-center gap-2 rounded-full border border-goldenrod/20 bg-goldenrod/10 px-2.5 py-1 text-xs font-medium text-goldenrod cursor-pointer">
                        <input type="checkbox" value="high" data-export-severity class="h-3.5 w-3.5 rounded border-goldenrod/40 bg-transparent text-goldenrod focus:ring-0" />
                        High
                    </label>
                    <label class="inline-flex items-center gap-2 rounded-full border border-spectrum-flare/20 bg-spectrum-flare/10 px-2.5 py-1 text-xs font-medium text-spectrum-flare cursor-pointer">
                        <input type="checkbox" value="medium" data-export-severity class="h-3.5 w-3.5 rounded border-spectrum-flare/40 bg-transparent text-spectrum-flare focus:ring-0" />
                        Medium
                    </label>
                    <label class="inline-flex items-center gap-2 rounded-full border border-emerald-green/20 bg-emerald-green/10 px-2.5 py-1 text-xs font-medium text-emerald-green cursor-pointer">
                        <input type="checkbox" value="low" data-export-severity class="h-3.5 w-3.5 rounded border-emerald-green/40 bg-transparent text-emerald-green focus:ring-0" />
                        Low
                    </label>
                    <label class="inline-flex items-center gap-2 rounded-full border border-iron-slate/20 bg-iron-slate/10 px-2.5 py-1 text-xs font-medium text-iron-slate cursor-pointer">
                        <input type="checkbox" value="info" data-export-severity class="h-3.5 w-3.5 rounded border-iron-slate/40 bg-transparent text-iron-slate focus:ring-0" />
                        Info
                    </label>
                </fieldset>
                <select
                    id="export-status"
                    class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-cyan-500 transition-all"
                >
                    <option value="">All statuses</option>
                    <option value="open">Open</option>
                    <option value="in_review">In Review</option>
                    <option value="fixed">Fixed</option>
                    <option value="verified">Verified</option>
                </select>
                <button
                    id="export-btn"
                    class="flex items-center gap-2 px-4 py-2 bg-white/5 border border-white/10 text-ghost-white rounded-lg hover:bg-white/10 transition-colors text-sm font-medium"
                >
                    <span class="material-symbols-outlined text-base"
                        >download</span
                    >
                    Export CSV
                </button>
            </div>
        </div>

        <section class="rounded-2xl border border-white/10 bg-shadow-tint p-4">
            <div class="flex items-start justify-between gap-4 flex-wrap">
                <h2 class="text-lg font-light text-ghost-white font-aeonik">Current exposure snapshot</h2>
            </div>
            <div id="report-summary" class="mt-4 space-y-3 text-sm text-iron-slate">
                <p class="text-iron-slate">Loading summary…</p>
            </div>
        </section>

        <!-- KPI row -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
            <div class="bg-shadow-tint border border-white/10 rounded-xl p-4">
                <p class="text-[10px] font-medium uppercase tracking-widest text-iron-slate mb-1.5">SLA Compliance</p>
                <p id="kpi-sla-pct" class="text-2xl font-light text-ghost-white font-aeonik">—%</p>
                <p id="kpi-sla-sub" class="text-xs text-iron-slate mt-1"></p>
            </div>
            <div class="bg-shadow-tint border border-white/10 rounded-xl p-4">
                <p class="text-[10px] font-medium uppercase tracking-widest text-iron-slate mb-1.5">Overdue SLA</p>
                <p id="kpi-overdue" class="text-2xl font-light text-ghost-white font-aeonik">—</p>
                <p class="text-xs text-iron-slate mt-1">findings past deadline</p>
            </div>
            <div class="bg-shadow-tint border border-white/10 rounded-xl p-4">
                <p class="text-[10px] font-medium uppercase tracking-widest text-iron-slate mb-1.5">Open Findings</p>
                <p id="kpi-open" class="text-2xl font-light text-ghost-white font-aeonik">—</p>
                <p class="text-xs text-iron-slate mt-1">unresolved</p>
            </div>
            <div class="bg-shadow-tint border border-white/10 rounded-xl p-4">
                <p class="text-[10px] font-medium uppercase tracking-widest text-iron-slate mb-1.5">Resolved</p>
                <p id="kpi-resolved" class="text-2xl font-light text-ghost-white font-aeonik">—</p>
                <p class="text-xs text-iron-slate mt-1">fixed or verified</p>
            </div>
        </div>

        <div class="grid grid-cols-1 xl:grid-cols-2 gap-4">
            <!-- Findings trend chart -->
            <div class="bg-shadow-tint border border-white/10 rounded-xl p-4">
                <div class="flex items-center justify-between mb-3">
                    <p class="text-[10px] font-medium uppercase tracking-widest text-iron-slate">Findings Over Time</p>
                    <div class="flex items-center gap-3 text-[10px] font-medium uppercase tracking-widest">
                        <span class="flex items-center gap-1"><span class="w-3 h-0.5 bg-vivid-crimson inline-block rounded"></span>Critical</span>
                        <span class="flex items-center gap-1"><span class="w-3 h-0.5 bg-goldenrod inline-block rounded"></span>High</span>
                        <span class="flex items-center gap-1"><span class="w-3 h-0.5 bg-spectrum-flare inline-block rounded"></span>Medium</span>
                        <span class="flex items-center gap-1"><span class="w-3 h-0.5 bg-emerald-green inline-block rounded"></span>Low</span>
                    </div>
                </div>
                <div
                    id="trend-chart"
                    class="min-h-[160px] flex items-center justify-center"
                >
                    <p class="text-sm text-slate-500">Loading…</p>
                </div>
            </div>

            <!-- Status distribution -->
            <div class="bg-shadow-tint border border-white/10 rounded-xl p-4">
                <p class="text-[10px] font-medium uppercase tracking-widest text-iron-slate mb-3">Finding Status Distribution</p>
                <div id="status-dist" class="space-y-3">
                    <p class="text-sm text-slate-500">Loading…</p>
                </div>
            </div>
        </div>

        <!-- Risk score per repo -->
        <div class="bg-shadow-tint border border-white/10 rounded-xl p-4">
            <p class="text-[10px] font-medium uppercase tracking-widest text-iron-slate mb-4">Risk Score by Project</p>
            <div id="risk-scores">
                <p class="text-sm text-slate-500">Loading…</p>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-4 xl:grid-cols-[1.3fr_0.7fr]">
            <section class="rounded-2xl border border-white/10 bg-shadow-tint p-4">
                <h2 class="text-lg font-light text-ghost-white font-aeonik mb-3">Top unresolved findings</h2>
                <div id="priority-findings" class="overflow-x-auto">
                    <p class="text-sm text-slate-500">Loading findings…</p>
                </div>
            </section>

            <section class="rounded-2xl border border-white/10 bg-shadow-tint p-4">
                <h2 class="text-lg font-light text-ghost-white font-aeonik mb-3">Recommended actions</h2>
                <div id="report-actions" class="space-y-3 text-sm text-iron-slate">
                    <p class="text-iron-slate">Loading actions…</p>
                </div>
            </section>
        </div>
    </div>
</DashboardLayout>

<script>
    import { api } from "@lib/api";
    import type {
        TrendPoint,
        RepoRiskScore,
        Finding,
        SLACompliance,
    } from "@lib/api";

    // ── SVG trend chart ──────────────────────────────────────────────────────────

    function trendChart(points: TrendPoint[]): string {
        if (!points.length)
            return '<p class="text-sm text-slate-500">No findings in this period.</p>';

        const W = 560,
            H = 160;
        const padL = 32,
            padB = 26,
            padT = 8,
            padR = 10;
        const cW = W - padL - padR,
            cH = H - padT - padB;
        const n = points.length;

        const maxVal = Math.max(
            1,
            ...points.flatMap((p) => [p.critical, p.high, p.medium, p.low]),
        );

        const x = (i: number) => padL + (n > 1 ? (i / (n - 1)) * cW : cW / 2);
        const y = (v: number) => padT + cH - (v / maxVal) * cH;
        const pts = (key: keyof TrendPoint) =>
            points.map((p, i) => `${x(i)},${y(p[key] as number)}`).join(" ");

        const series: { key: keyof TrendPoint; color: string }[] = [
{ key: "low", color: "#72ce7b" },
          { key: "medium", color: "#d1aad7" },
          { key: "high", color: "#ffd600" },
          { key: "critical", color: "#ff6467" },
        ];

        // Y axis
        const yStep = maxVal > 0 ? maxVal : 1;
        const yTicks = [0, Math.round(yStep / 2), yStep].map(
            (v) =>
                `<text x="${padL - 6}" y="${y(v) + 4}" text-anchor="end" fill="#475569" font-size="9">${v}</text>
       <line x1="${padL}" x2="${W - padR}" y1="${y(v)}" y2="${y(v)}" stroke="#1e293b" stroke-width="1"/>`,
        );

        // X axis labels (sparse: up to 5)
        const labelIdxs =
            n <= 5
                ? points.map((_, i) => i)
                : Array.from({ length: 5 }, (_, i) =>
                      Math.round((i * (n - 1)) / 4),
                  );
        const xLabels = labelIdxs.map(
            (i) =>
                `<text x="${x(i)}" y="${H - 4}" text-anchor="middle" fill="#475569" font-size="9">${points[i].date.slice(5)}</text>`,
        );

        const lines = series.map(
            (s) =>
                `<polyline points="${pts(s.key)}" fill="none" stroke="${s.color}" stroke-width="2"
         stroke-linejoin="round" stroke-linecap="round"/>`,
        );

        return `<svg viewBox="0 0 ${W} ${H}" class="w-full" xmlns="http://www.w3.org/2000/svg">
      ${yTicks.join("")}
      ${lines.join("")}
      ${xLabels.join("")}
    </svg>`;
    }

    // ── Risk score bars ──────────────────────────────────────────────────────────

    function riskBar(rs: RepoRiskScore, maxScore: number): string {
        const pct = maxScore > 0 ? Math.round((rs.score / maxScore) * 100) : 0;
        const barColors = [
            { threshold: 500, class: "bg-vivid-crimson" },
            { threshold: 100, class: "bg-goldenrod" },
            { threshold: 20, class: "bg-spectrum-flare" },
            { threshold: 0, class: "bg-emerald-green" },
        ];
        const color = barColors.find(t => rs.score >= t.threshold).class;
        const breakdown = [
            rs.critical ? `<span class="text-vivid-crimson">${rs.critical}C</span>` : "",
            rs.high ? `<span class="text-goldenrod">${rs.high}H</span>` : "",
            rs.medium ? `<span class="text-spectrum-flare">${rs.medium}M</span>` : "",
            rs.low ? `<span class="text-emerald-green">${rs.low}L</span>` : "",
        ]
            .filter(Boolean)
            .join(" ");
        return `
      <div class="flex items-center gap-4">
        <div class="w-40 min-w-[10rem] shrink-0">
          <p class="text-sm font-bold text-on-background truncate">${rs.project_name || rs.repo_name}</p>
          <p class="text-xs text-slate-500 font-mono truncate max-w-full">${rs.repo_url}</p>
        </div>
        <div class="flex-1 min-w-0">
          <div class="h-2 bg-surface-container rounded-full overflow-hidden">
            <div class="${color} h-full rounded-full transition-all" style="width:${pct}%"></div>
          </div>
        </div>
        <div class="shrink-0 text-right w-40">
          <span class="text-sm font-black text-on-background font-mono">${rs.score}</span>
          <span class="text-[10px] text-slate-500 ml-1.5 font-mono">${breakdown || "—"}</span>
        </div>
      </div>`;
    }

    // ── Load data ────────────────────────────────────────────────────────────────

    function selectedExportSeverities() {
        return Array.from(
            document.querySelectorAll<HTMLInputElement>(
                "[data-export-severity]:checked",
            ),
        ).map((input) => input.value);
    }

    function severityRank(severity: string): number {
        return (
            (
                { critical: 0, high: 1, medium: 2, low: 3, info: 4 } as Record<
                    string,
                    number
                >
            )[severity] ?? 5
        );
    }

    function formatGeneratedAt(now: Date): string {
        return new Intl.DateTimeFormat("en-US", {
            dateStyle: "medium",
            timeStyle: "short",
        }).format(now);
    }

    function updateReportMeta(days: number) {
        const status = (
            document.getElementById("export-status") as HTMLSelectElement
        ).value;
        const severities = selectedExportSeverities();
        const statusLabel = status ? status.replace("_", " ") : "All statuses";
        const severityLabel = severities.length
            ? severities.join(", ")
            : "All severities";

        document.getElementById("report-generated-at")!.textContent =
            formatGeneratedAt(new Date());
        document.getElementById("report-window")!.textContent =
            `Last ${days} days`;
        document.getElementById("report-scope")!.textContent =
            `${severityLabel} · ${statusLabel}`;
    }

    function renderSummary(
        sla: SLACompliance,
        findings: Finding[],
        risk: RepoRiskScore[],
    ): string {
        const criticalOpen = findings.filter(
            (finding) =>
                finding.severity === "critical" &&
                (finding.status === "open" || finding.status === "in_review"),
        ).length;
        const highOpen = findings.filter(
            (finding) =>
                finding.severity === "high" &&
                (finding.status === "open" || finding.status === "in_review"),
        ).length;
        const mostExposed = risk[0];

        return `
      <div class="grid gap-3 lg:grid-cols-3">
        <article class="rounded-xl border border-white/10 bg-white/5 px-4 py-4">
          <p class="text-[10px] font-medium uppercase tracking-[0.22em] text-iron-slate">SLA posture</p>
          <p class="mt-2 text-sm leading-6 text-ghost-white">${sla.total > 0 ? `${sla.on_time} of ${sla.total} findings on time, <span class="text-vivid-crimson">${sla.overdue}</span> overdue.` : "No SLA-tracked findings yet."}</p>
        </article>
        <article class="rounded-xl border border-white/10 bg-white/5 px-4 py-4">
          <p class="text-[10px] font-medium uppercase tracking-[0.22em] text-iron-slate">Critical pressure</p>
          <p class="mt-2 text-sm leading-6 text-ghost-white">${criticalOpen} critical, ${highOpen} high unresolved findings.</p>
        </article>
        <article class="rounded-xl border border-white/10 bg-white/5 px-4 py-4">
          <p class="text-[10px] font-medium uppercase tracking-[0.22em] text-iron-slate">Highest-risk project</p>
          <p class="mt-2 text-sm leading-6 text-ghost-white">${mostExposed ? `<span class="font-medium">${mostExposed.project_name || mostExposed.repo_name}</span> — score <span class="font-medium">${mostExposed.score}</span>.` : "No data yet."}</p>
        </article>
      </div>`;
    }

    function renderActions(
        sla: SLACompliance,
        findings: Finding[],
        risk: RepoRiskScore[],
    ): string {
        const overdue = findings.filter(
            (finding) =>
                Boolean(finding.sla_deadline) &&
                (finding.status === "open" || finding.status === "in_review"),
        );
        const criticalOpen = findings.filter(
            (finding) =>
                finding.severity === "critical" &&
                (finding.status === "open" || finding.status === "in_review"),
        );
        const topRisk = risk[0];

        const actions = [
            overdue.length
                ? `Triage ${overdue.length} unresolved findings past SLA deadline.`
                : "All SLA-tracked findings are on time.",
            criticalOpen.length
                ? `Escalate ${criticalOpen.length} critical unresolved findings.`
                : "No critical findings open.",
            topRisk
                ? `Prioritize ${topRisk.project_name || topRisk.repo_name} (risk score: ${topRisk.score}).`
                : "No risk data available.",
        ];

        return `<ol class="space-y-2">${actions.map((action, index) => `<li class="flex items-start gap-3 rounded-xl border border-white/10 bg-white/5 px-4 py-3"><span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-iridescent-glow/15 text-xs font-medium text-iridescent-glow shrink-0">${index + 1}</span><span class="text-sm text-ghost-white">${action}</span></li>`).join("")}</ol>`;
    }

    function renderPriorityFindings(findings: Finding[]): string {
        const rows = findings
            .filter(
                (finding) =>
                    finding.status === "open" || finding.status === "in_review",
            )
            .sort((left, right) => {
                const severityDiff =
                    severityRank(left.severity) - severityRank(right.severity);
                if (severityDiff !== 0) return severityDiff;
                return (
                    new Date(right.created_at).getTime() -
                    new Date(left.created_at).getTime()
                );
            })
            .slice(0, 8);

        if (!rows.length) {
            return '<p class="text-sm text-iron-slate">No unresolved findings.</p>';
        }

        return `
      <table class="report-print-table min-w-full text-sm">
        <thead>
          <tr>
            <th class="pr-4">Severity</th>
            <th class="pr-4">Title</th>
            <th class="pr-4">Scanner</th>
            <th class="pr-4">Status</th>
            <th class="pr-4">Created</th>
          </tr>
        </thead>
        <tbody>
          ${rows
              .map(
                  (finding) => `
            <tr>
              <td class="pr-4 font-bold uppercase">${finding.severity}</td>
              <td class="pr-4">${finding.title}</td>
              <td class="pr-4">${finding.scanner}</td>
              <td class="pr-4">${finding.status.replace("_", " ")}</td>
              <td class="pr-4">${new Date(finding.created_at).toLocaleDateString("en-US")}</td>
            </tr>
          `,
              )
              .join("")}
        </tbody>
      </table>`;
    }

    async function load() {
        const days = parseInt(
            (document.getElementById("days-select") as HTMLSelectElement).value,
        );
        updateReportMeta(days);

        const [sla, trends, risk, { findings: allFindings }] =
            await Promise.all([
                api.getSLACompliance(),
                api.getTrends(days),
                api.getRiskScores(),
                api.getFindings("", "", 1, 500),
            ]);

        // KPIs
        const pct = sla.total > 0 ? sla.percent.toFixed(1) : "—";
        const pctColors = [
            { threshold: 90, class: "text-emerald-green" },
            { threshold: 70, class: "text-goldenrod" },
            { threshold: 0, class: "text-vivid-crimson" },
        ];
        const pctColor = pctColors.find(t => sla.percent >= t.threshold).class;
        document.getElementById("kpi-sla-pct")!.textContent =
            sla.total > 0 ? `${pct}%` : "—";
        document.getElementById("kpi-sla-pct")!.className =
            `text-3xl font-black ${pctColor}`;
        document.getElementById("kpi-sla-sub")!.textContent =
            `${sla.on_time} on-time / ${sla.total} tracked`;
        document.getElementById("kpi-overdue")!.textContent = String(
            sla.overdue,
        );

        const openCount = allFindings.filter(
            (f) => f.status === "open" || f.status === "in_review",
        ).length;
        const resolvedCount = allFindings.filter(
            (f) => f.status === "fixed" || f.status === "verified",
        ).length;
        document.getElementById("kpi-open")!.textContent = String(openCount);
        document.getElementById("kpi-resolved")!.textContent =
            String(resolvedCount);
        document.getElementById("report-summary")!.innerHTML = renderSummary(
            sla,
            allFindings,
            risk,
        );
        document.getElementById("report-actions")!.innerHTML = renderActions(
            sla,
            allFindings,
            risk,
        );
        document.getElementById("priority-findings")!.innerHTML =
            renderPriorityFindings(allFindings);

        // Trend chart
        document.getElementById("trend-chart")!.innerHTML = trendChart(trends);

        // Status distribution
        const statusCounts: Record<string, number> = {};
        allFindings.forEach((f) => {
            statusCounts[f.status] = (statusCounts[f.status] ?? 0) + 1;
        });
        const total = allFindings.length || 1;

        const STATUS_META: {
            key: string;
            label: string;
            color: string;
            bar: string;
        }[] = [
            { key: "open", label: "Open", color: "text-vivid-crimson", bar: "bg-vivid-crimson" },
            { key: "in_review", label: "In Review", color: "text-iridescent-glow", bar: "bg-iridescent-glow" },
            { key: "accepted_risk", label: "Accepted Risk", color: "text-goldenrod", bar: "bg-goldenrod" },
            { key: "fixed", label: "Fixed", color: "text-emerald-green", bar: "bg-emerald-green" },
            { key: "verified", label: "Verified", color: "text-emerald-green", bar: "bg-emerald-green" },
        ];

        document.getElementById("status-dist")!.innerHTML = STATUS_META.map(
            (s) => {
                const count = statusCounts[s.key] ?? 0;
                const pct = Math.round((count / total) * 100);
                return `<div>
        <div class="flex justify-between text-xs mb-1.5">
          <span class="${s.color} font-bold">${s.label}</span>
          <span class="font-mono text-slate-400">${count} <span class="text-slate-600">(${pct}%)</span></span>
        </div>
        <div class="status-bar-track h-1.5 bg-surface-container rounded-full overflow-hidden">
          <div class="${s.bar} h-full rounded-full transition-all" style="width:${pct}%"></div>
        </div>
      </div>`;
            },
        ).join("");

        // Risk scores
        const riskEl = document.getElementById("risk-scores")!;
        if (!risk.length) {
            riskEl.innerHTML =
                '<p class="text-sm text-iron-slate">No projects yet.</p>';
        } else {
            const maxScore = risk[0].score || 1;
            riskEl.innerHTML = `<div class="space-y-4">${risk.map((rs) => riskBar(rs, maxScore)).join("")}</div>`;
        }
    }

    document.getElementById("days-select")!.addEventListener("change", load);
    document.getElementById("export-status")!.addEventListener("change", () => {
        const days = parseInt(
            (document.getElementById("days-select") as HTMLSelectElement).value,
        );
        updateReportMeta(days);
    });
    document.querySelectorAll("[data-export-severity]").forEach((input) => {
        input.addEventListener("change", () => {
            const days = parseInt(
                (document.getElementById("days-select") as HTMLSelectElement)
                    .value,
            );
            updateReportMeta(days);
        });
    });
    document.getElementById("print-btn")!.addEventListener("click", () => {
        const days = parseInt(
            (document.getElementById("days-select") as HTMLSelectElement).value,
        );
        updateReportMeta(days);
        window.print();
    });

    document
        .getElementById("export-btn")!
        .addEventListener("click", async (e) => {
            e.preventDefault();
            const sev = selectedExportSeverities();
            const status = (
                document.getElementById("export-status") as HTMLSelectElement
            ).value;
            const btn = document.getElementById(
                "export-btn",
            ) as HTMLAnchorElement;
            btn.textContent = "Exporting…";

            try {
                const url = api.exportFindingsURL(sev, "", status);
                const res = await fetch(url, {
                    credentials: "include",
                });
                if (!res.ok) throw new Error(res.statusText);
                const blob = await res.blob();
                const a = document.createElement("a");
                a.href = URL.createObjectURL(blob);
                a.download = `findings-${new Date().toISOString().slice(0, 10)}.csv`;
                a.click();
                URL.revokeObjectURL(a.href);
            } catch (err: any) {
                alert("Export failed: " + err.message);
            } finally {
                btn.innerHTML =
                    '<span class="material-symbols-outlined text-base">download</span> Export CSV';
            }
        });

    updateReportMeta(
        parseInt(
            (document.getElementById("days-select") as HTMLSelectElement).value,
        ),
    );
    load();
</script>
