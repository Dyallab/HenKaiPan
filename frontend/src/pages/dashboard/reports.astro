---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Executive Reports" active="reports">
    <style is:global>
        @media print {
            html,
            body {
                background: #ffffff !important;
                color: #0f172a !important;
                height: auto !important;
                overflow: visible !important;
            }

            body > aside,
            body > div > header,
            .report-toolbar,
            .report-hide-print,
            #run-scan-btn,
            #logout-btn {
                display: none !important;
            }

            body > div,
            body > div > main,
            .report-page {
                overflow: visible !important;
                height: auto !important;
                background: #ffffff !important;
            }

            body > div > main {
                padding: 0 !important;
            }

            .report-page {
                max-width: 1100px;
                margin: 0 auto;
                padding: 24px 28px 40px !important;
                color: #0f172a !important;
            }

            .report-card {
                break-inside: avoid;
                page-break-inside: avoid;
                border-color: #cbd5e1 !important;
                background: #ffffff !important;
                box-shadow: none !important;
            }

            .report-kpi,
            #trend-chart svg,
            .status-bar-track,
            .risk-track {
                break-inside: avoid;
            }

            .report-print-title,
            .report-print-subtitle,
            .report-print-copy,
            .report-print-muted,
            .report-print-mono,
            .report-print-table th,
            .report-print-table td,
            .report-print-list li,
            #trend-chart text {
                color: #0f172a !important;
                fill: #0f172a !important;
            }

            #trend-chart line {
                stroke: #cbd5e1 !important;
            }

            .report-accent-soft,
            .report-metric-chip {
                background: #eff6ff !important;
                color: #0f172a !important;
                border-color: #bfdbfe !important;
            }

            .report-print-table {
                width: 100%;
                border-collapse: collapse;
            }

            .report-print-table th,
            .report-print-table td {
                border-bottom: 1px solid #e2e8f0;
                padding: 10px 0;
                text-align: left;
            }

            .report-print-page-break {
                page-break-before: always;
            }

            a[href]:after {
                content: "" !important;
            }
        }
    </style>

    <div class="report-page space-y-6">
        <section
            class="report-card overflow-hidden rounded-[1.75rem] border border-sky-500/20 bg-[linear-gradient(135deg,rgba(14,165,233,0.16),rgba(11,19,38,0.92)_58%,rgba(22,163,74,0.12))] px-6 py-6 shadow-[0_20px_60px_rgba(2,8,23,0.25)]"
        >
            <div
                class="report-toolbar flex items-start justify-between gap-4 flex-wrap"
            >
                <div class="max-w-3xl space-y-3">
                    <div class="space-y-2">
                        <h1
                            class="report-print-title text-3xl font-black tracking-tight text-on-background sm:text-4xl"
                        >
                            Browser-ready PDF report
                        </h1>
                        <p
                            class="report-print-copy max-w-2xl text-sm leading-6 text-slate-300 sm:text-[15px]"
                        >
                            Export the current reports surface as a polished PDF
                            directly from the browser. This view is optimized
                            for print, keeps the executive KPIs visible, and
                            adds a concise findings snapshot for leadership
                            reviews.
                        </p>
                    </div>
                </div>
                <div class="flex items-center gap-2 print:hidden">
                    <button
                        id="print-btn"
                        class="flex items-center gap-2 rounded-lg border border-sky-400/30 bg-sky-500 px-4 py-2 text-sm font-black text-slate-950 transition-colors hover:bg-sky-400"
                    >
                        <span class="material-symbols-outlined text-base"
                            >print</span
                        >
                        Print PDF
                    </button>
                </div>
            </div>

            <div class="mt-6 grid gap-3 md:grid-cols-4">
                <div
                    class="report-metric-chip rounded-2xl border border-white/10 bg-white/5 px-4 py-3 backdrop-blur-sm"
                >
                    <p
                        class="report-print-muted text-[10px] font-bold uppercase tracking-[0.24em] text-slate-400"
                    >
                        Generated
                    </p>
                    <p
                        id="report-generated-at"
                        class="report-print-subtitle mt-2 text-sm font-semibold text-on-background"
                    >
                        —
                    </p>
                </div>
                <div
                    class="report-metric-chip rounded-2xl border border-white/10 bg-white/5 px-4 py-3 backdrop-blur-sm"
                >
                    <p
                        class="report-print-muted text-[10px] font-bold uppercase tracking-[0.24em] text-slate-400"
                    >
                        Trend window
                    </p>
                    <p
                        id="report-window"
                        class="report-print-subtitle mt-2 text-sm font-semibold text-on-background"
                    >
                        Last 30 days
                    </p>
                </div>
                <div
                    class="report-metric-chip rounded-2xl border border-white/10 bg-white/5 px-4 py-3 backdrop-blur-sm"
                >
                    <p
                        class="report-print-muted text-[10px] font-bold uppercase tracking-[0.24em] text-slate-400"
                    >
                        Export scope
                    </p>
                    <p
                        id="report-scope"
                        class="report-print-subtitle mt-2 text-sm font-semibold text-on-background"
                    >
                        All severities · All statuses
                    </p>
                </div>
                <div
                    class="report-metric-chip rounded-2xl border border-white/10 bg-white/5 px-4 py-3 backdrop-blur-sm"
                >
                    <p
                        class="report-print-muted text-[10px] font-bold uppercase tracking-[0.24em] text-slate-400"
                    >
                        Report focus
                    </p>
                    <p
                        class="report-print-subtitle mt-2 text-sm font-semibold text-on-background"
                    >
                        SLA, trends, risk, findings
                    </p>
                </div>
            </div>
        </section>

        <!-- Top bar: date range + export -->
        <div
            class="report-toolbar flex items-center justify-between mb-6 flex-wrap gap-3"
        >
            <div class="flex items-center gap-2">
                <label
                    class="text-xs text-slate-500 font-bold uppercase tracking-widest"
                    >Trend window</label
                >
                <select
                    id="days-select"
                    class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-sky-500 transition-all"
                >
                    <option value="7">Last 7 days</option>
                    <option value="30" selected>Last 30 days</option>
                    <option value="90">Last 90 days</option>
                    <option value="365">Last 365 days</option>
                </select>
            </div>
            <div class="flex items-center gap-2">
                <fieldset
                    class="flex flex-wrap items-center gap-2 rounded-lg border border-outline-variant/30 bg-surface-container px-3 py-2"
                >
                    <legend
                        class="px-1 text-[10px] font-bold uppercase tracking-widest text-slate-500"
                        >Export severities</legend
                    >
                    <label
                        class="inline-flex items-center gap-2 rounded-full border border-red-500/20 bg-red-500/10 px-2.5 py-1 text-xs font-semibold text-red-300 cursor-pointer"
                    >
                        <input
                            type="checkbox"
                            value="critical"
                            data-export-severity
                            class="h-3.5 w-3.5 rounded border-red-500/40 bg-transparent text-red-400 focus:ring-0"
                        />
                        Critical
                    </label>
                    <label
                        class="inline-flex items-center gap-2 rounded-full border border-orange-500/20 bg-orange-500/10 px-2.5 py-1 text-xs font-semibold text-orange-300 cursor-pointer"
                    >
                        <input
                            type="checkbox"
                            value="high"
                            data-export-severity
                            class="h-3.5 w-3.5 rounded border-orange-500/40 bg-transparent text-orange-400 focus:ring-0"
                        />
                        High
                    </label>
                    <label
                        class="inline-flex items-center gap-2 rounded-full border border-amber-500/20 bg-amber-500/10 px-2.5 py-1 text-xs font-semibold text-amber-300 cursor-pointer"
                    >
                        <input
                            type="checkbox"
                            value="medium"
                            data-export-severity
                            class="h-3.5 w-3.5 rounded border-amber-500/40 bg-transparent text-amber-400 focus:ring-0"
                        />
                        Medium
                    </label>
                    <label
                        class="inline-flex items-center gap-2 rounded-full border border-sky-500/20 bg-sky-500/10 px-2.5 py-1 text-xs font-semibold text-sky-300 cursor-pointer"
                    >
                        <input
                            type="checkbox"
                            value="low"
                            data-export-severity
                            class="h-3.5 w-3.5 rounded border-sky-500/40 bg-transparent text-sky-400 focus:ring-0"
                        />
                        Low
                    </label>
                    <label
                        class="inline-flex items-center gap-2 rounded-full border border-slate-500/20 bg-slate-500/10 px-2.5 py-1 text-xs font-semibold text-slate-300 cursor-pointer"
                    >
                        <input
                            type="checkbox"
                            value="info"
                            data-export-severity
                            class="h-3.5 w-3.5 rounded border-slate-500/40 bg-transparent text-slate-400 focus:ring-0"
                        />
                        Info
                    </label>
                </fieldset>
                <select
                    id="export-status"
                    class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-sky-500 transition-all"
                >
                    <option value="">All statuses</option>
                    <option value="open">Open</option>
                    <option value="in_review">In Review</option>
                    <option value="fixed">Fixed</option>
                    <option value="verified">Verified</option>
                </select>
                <button
                    id="export-btn"
                    class="flex items-center gap-2 px-4 py-2 bg-slate-900 border border-slate-800 text-on-background rounded-lg hover:bg-slate-800 transition-colors text-sm font-bold"
                >
                    <span class="material-symbols-outlined text-base"
                        >download</span
                    >
                    Export CSV
                </button>
            </div>
        </div>

        <section
            class="report-card rounded-2xl border border-outline-variant/20 bg-surface-container-low/70 p-5"
        >
            <div class="flex items-start justify-between gap-4 flex-wrap">
                <div class="space-y-2">
                    <p
                        class="report-print-muted text-[10px] font-bold uppercase tracking-[0.24em] text-slate-500"
                    >
                        Executive brief
                    </p>
                    <h2
                        class="report-print-title text-xl font-black tracking-tight text-on-background"
                    >
                        Current exposure snapshot
                    </h2>
                </div>
                <p
                    class="report-print-copy max-w-2xl text-sm leading-6 text-slate-400"
                >
                    Built for browser print-to-PDF flows. Filters affect CSV
                    exports, while the snapshot below reflects live platform
                    metrics for leadership reporting and review.
                </p>
            </div>
            <div
                id="report-summary"
                class="report-print-list mt-4 space-y-3 text-sm text-slate-300"
            >
                <p class="text-slate-500">Loading summary…</p>
            </div>
        </section>

        <!-- KPI row -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
            <div
                class="report-card report-kpi bg-surface-container-low border border-outline-variant/20 rounded-xl p-5"
            >
                <p
                    class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-2"
                >
                    SLA Compliance
                </p>
                <p
                    id="kpi-sla-pct"
                    class="text-3xl font-black text-emerald-400"
                >
                    —%
                </p>
                <p id="kpi-sla-sub" class="text-xs text-slate-500 mt-1"></p>
            </div>
            <div
                class="report-card report-kpi bg-surface-container-low border border-outline-variant/20 rounded-xl p-5"
            >
                <p
                    class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-2"
                >
                    Overdue SLA
                </p>
                <p id="kpi-overdue" class="text-3xl font-black text-red-400">
                    —
                </p>
                <p class="text-xs text-slate-500 mt-1">
                    findings past deadline
                </p>
            </div>
            <div
                class="report-card report-kpi bg-surface-container-low border border-outline-variant/20 rounded-xl p-5"
            >
                <p
                    class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-2"
                >
                    Open Findings
                </p>
                <p id="kpi-open" class="text-3xl font-black text-sky-400">—</p>
                <p class="text-xs text-slate-500 mt-1">unresolved</p>
            </div>
            <div
                class="report-card report-kpi bg-surface-container-low border border-outline-variant/20 rounded-xl p-5"
            >
                <p
                    class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-2"
                >
                    Resolved
                </p>
                <p id="kpi-resolved" class="text-3xl font-black text-teal-400">
                    —
                </p>
                <p class="text-xs text-slate-500 mt-1">fixed or verified</p>
            </div>
        </div>

        <div class="grid grid-cols-1 xl:grid-cols-2 gap-6 mb-6">
            <!-- Findings trend chart -->
            <div
                class="report-card bg-surface-container-low border border-outline-variant/20 rounded-xl p-5"
            >
                <div class="flex items-center justify-between mb-4">
                    <h2
                        class="text-[10px] font-bold uppercase tracking-widest text-slate-500"
                    >
                        Findings Over Time
                    </h2>
                    <div
                        class="flex items-center gap-3 text-[10px] font-bold uppercase tracking-widest"
                    >
                        <span class="flex items-center gap-1"
                            ><span
                                class="w-3 h-0.5 bg-red-500 inline-block rounded"
                            ></span>Critical</span
                        >
                        <span class="flex items-center gap-1"
                            ><span
                                class="w-3 h-0.5 bg-orange-500 inline-block rounded"
                            ></span>High</span
                        >
                        <span class="flex items-center gap-1"
                            ><span
                                class="w-3 h-0.5 bg-amber-500 inline-block rounded"
                            ></span>Medium</span
                        >
                        <span class="flex items-center gap-1"
                            ><span
                                class="w-3 h-0.5 bg-sky-400 inline-block rounded"
                            ></span>Low</span
                        >
                    </div>
                </div>
                <div
                    id="trend-chart"
                    class="min-h-[160px] flex items-center justify-center"
                >
                    <p class="text-sm text-slate-500">Loading…</p>
                </div>
            </div>

            <!-- Status distribution -->
            <div
                class="report-card bg-surface-container-low border border-outline-variant/20 rounded-xl p-5"
            >
                <h2
                    class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-4"
                >
                    Finding Status Distribution
                </h2>
                <div id="status-dist" class="space-y-3">
                    <p class="text-sm text-slate-500">Loading…</p>
                </div>
            </div>
        </div>

        <!-- Risk score per repo -->
        <div
            class="report-card bg-surface-container-low border border-outline-variant/20 rounded-xl p-5"
        >
            <h2
                class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-5"
            >
                Risk Score by Repository
            </h2>
            <div id="risk-scores">
                <p class="text-sm text-slate-500">Loading…</p>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-6 xl:grid-cols-[1.3fr_0.7fr]">
            <section
                class="report-card report-print-page-break rounded-2xl border border-outline-variant/20 bg-surface-container-low p-5"
            >
                <div
                    class="mb-4 flex items-start justify-between gap-4 flex-wrap"
                >
                    <div>
                        <p
                            class="report-print-muted text-[10px] font-bold uppercase tracking-[0.24em] text-slate-500"
                        >
                            Priority findings
                        </p>
                        <h2
                            class="report-print-title mt-1 text-lg font-black text-on-background"
                        >
                            Top unresolved findings snapshot
                        </h2>
                    </div>
                    <p
                        class="report-print-copy max-w-xl text-xs leading-5 text-slate-400"
                    >
                        Highest-severity unresolved findings ranked for
                        executive escalation. Ideal for print/PDF appendices.
                    </p>
                </div>
                <div id="priority-findings" class="overflow-x-auto">
                    <p class="text-sm text-slate-500">Loading findings…</p>
                </div>
            </section>

            <section
                class="report-card rounded-2xl border border-outline-variant/20 bg-surface-container-low p-5"
            >
                <p
                    class="report-print-muted text-[10px] font-bold uppercase tracking-[0.24em] text-slate-500"
                >
                    Action cues
                </p>
                <h2
                    class="report-print-title mt-1 text-lg font-black text-on-background"
                >
                    Immediate next moves
                </h2>
                <div
                    id="report-actions"
                    class="report-print-list mt-4 space-y-3 text-sm text-slate-300"
                >
                    <p class="text-slate-500">Loading actions…</p>
                </div>
            </section>
        </div>
    </div>
</DashboardLayout>

<script>
    import { api } from "../../lib/api";
    import type {
        TrendPoint,
        RepoRiskScore,
        Finding,
        SLACompliance,
    } from "../../lib/api";

    // ── SVG trend chart ──────────────────────────────────────────────────────────

    function trendChart(points: TrendPoint[]): string {
        if (!points.length)
            return '<p class="text-sm text-slate-500">No findings in this period.</p>';

        const W = 560,
            H = 160;
        const padL = 32,
            padB = 26,
            padT = 8,
            padR = 10;
        const cW = W - padL - padR,
            cH = H - padT - padB;
        const n = points.length;

        const maxVal = Math.max(
            1,
            ...points.flatMap((p) => [p.critical, p.high, p.medium, p.low]),
        );

        const x = (i: number) => padL + (n > 1 ? (i / (n - 1)) * cW : cW / 2);
        const y = (v: number) => padT + cH - (v / maxVal) * cH;
        const pts = (key: keyof TrendPoint) =>
            points.map((p, i) => `${x(i)},${y(p[key] as number)}`).join(" ");

        const series: { key: keyof TrendPoint; color: string }[] = [
            { key: "low", color: "#38bdf8" },
            { key: "medium", color: "#f59e0b" },
            { key: "high", color: "#f97316" },
            { key: "critical", color: "#ef4444" },
        ];

        // Y axis
        const yStep = maxVal > 0 ? maxVal : 1;
        const yTicks = [0, Math.round(yStep / 2), yStep].map(
            (v) =>
                `<text x="${padL - 6}" y="${y(v) + 4}" text-anchor="end" fill="#475569" font-size="9">${v}</text>
       <line x1="${padL}" x2="${W - padR}" y1="${y(v)}" y2="${y(v)}" stroke="#1e293b" stroke-width="1"/>`,
        );

        // X axis labels (sparse: up to 5)
        const labelIdxs =
            n <= 5
                ? points.map((_, i) => i)
                : Array.from({ length: 5 }, (_, i) =>
                      Math.round((i * (n - 1)) / 4),
                  );
        const xLabels = labelIdxs.map(
            (i) =>
                `<text x="${x(i)}" y="${H - 4}" text-anchor="middle" fill="#475569" font-size="9">${points[i].date.slice(5)}</text>`,
        );

        const lines = series.map(
            (s) =>
                `<polyline points="${pts(s.key)}" fill="none" stroke="${s.color}" stroke-width="2"
         stroke-linejoin="round" stroke-linecap="round"/>`,
        );

        return `<svg viewBox="0 0 ${W} ${H}" class="w-full" xmlns="http://www.w3.org/2000/svg">
      ${yTicks.join("")}
      ${lines.join("")}
      ${xLabels.join("")}
    </svg>`;
    }

    // ── Risk score bars ──────────────────────────────────────────────────────────

    function riskBar(rs: RepoRiskScore, maxScore: number): string {
        const pct = maxScore > 0 ? Math.round((rs.score / maxScore) * 100) : 0;
        const color =
            rs.score >= 500
                ? "bg-red-500"
                : rs.score >= 100
                  ? "bg-orange-500"
                  : rs.score >= 20
                    ? "bg-amber-500"
                    : "bg-sky-500";
        const breakdown = [
            rs.critical
                ? `<span class="text-red-400">${rs.critical}C</span>`
                : "",
            rs.high ? `<span class="text-orange-400">${rs.high}H</span>` : "",
            rs.medium
                ? `<span class="text-amber-400">${rs.medium}M</span>`
                : "",
            rs.low ? `<span class="text-sky-400">${rs.low}L</span>` : "",
        ]
            .filter(Boolean)
            .join(" ");
        return `
      <div class="flex items-center gap-4">
        <div class="w-40 min-w-[10rem] shrink-0">
          <p class="text-sm font-bold text-on-background truncate">${rs.repo_name}</p>
          <p class="text-xs text-slate-500 font-mono truncate max-w-full">${rs.repo_url}</p>
        </div>
        <div class="flex-1 min-w-0">
          <div class="h-2 bg-surface-container rounded-full overflow-hidden">
            <div class="${color} h-full rounded-full transition-all" style="width:${pct}%"></div>
          </div>
        </div>
        <div class="shrink-0 text-right w-40">
          <span class="text-sm font-black text-on-background font-mono">${rs.score}</span>
          <span class="text-[10px] text-slate-500 ml-1.5 font-mono">${breakdown || "—"}</span>
        </div>
      </div>`;
    }

    // ── Load data ────────────────────────────────────────────────────────────────

    function selectedExportSeverities() {
        return Array.from(
            document.querySelectorAll<HTMLInputElement>(
                "[data-export-severity]:checked",
            ),
        ).map((input) => input.value);
    }

    function severityRank(severity: string): number {
        return (
            (
                { critical: 0, high: 1, medium: 2, low: 3, info: 4 } as Record<
                    string,
                    number
                >
            )[severity] ?? 5
        );
    }

    function formatGeneratedAt(now: Date): string {
        return new Intl.DateTimeFormat("en-US", {
            dateStyle: "medium",
            timeStyle: "short",
        }).format(now);
    }

    function updateReportMeta(days: number) {
        const status = (
            document.getElementById("export-status") as HTMLSelectElement
        ).value;
        const severities = selectedExportSeverities();
        const statusLabel = status ? status.replace("_", " ") : "All statuses";
        const severityLabel = severities.length
            ? severities.join(", ")
            : "All severities";

        document.getElementById("report-generated-at")!.textContent =
            formatGeneratedAt(new Date());
        document.getElementById("report-window")!.textContent =
            `Last ${days} days`;
        document.getElementById("report-scope")!.textContent =
            `${severityLabel} · ${statusLabel}`;
    }

    function renderSummary(
        sla: SLACompliance,
        findings: Finding[],
        risk: RepoRiskScore[],
    ): string {
        const criticalOpen = findings.filter(
            (finding) =>
                finding.severity === "critical" &&
                (finding.status === "open" || finding.status === "in_review"),
        ).length;
        const highOpen = findings.filter(
            (finding) =>
                finding.severity === "high" &&
                (finding.status === "open" || finding.status === "in_review"),
        ).length;
        const mostExposed = risk[0];

        return `
      <div class="grid gap-3 lg:grid-cols-3">
        <article class="rounded-2xl border border-outline-variant/20 bg-surface px-4 py-4">
          <p class="text-[10px] font-bold uppercase tracking-[0.22em] text-slate-500">SLA posture</p>
          <p class="mt-2 text-sm leading-6 text-on-background">${sla.total > 0 ? `${sla.on_time} of ${sla.total} tracked findings are on time, with <span class="font-black text-red-400">${sla.overdue}</span> currently overdue.` : "No SLA-tracked findings are available yet."}</p>
        </article>
        <article class="rounded-2xl border border-outline-variant/20 bg-surface px-4 py-4">
          <p class="text-[10px] font-bold uppercase tracking-[0.22em] text-slate-500">Critical pressure</p>
          <p class="mt-2 text-sm leading-6 text-on-background">${criticalOpen} critical and ${highOpen} high unresolved findings currently require active ownership and remediation follow-up.</p>
        </article>
        <article class="rounded-2xl border border-outline-variant/20 bg-surface px-4 py-4">
          <p class="text-[10px] font-bold uppercase tracking-[0.22em] text-slate-500">Highest-risk repository</p>
          <p class="mt-2 text-sm leading-6 text-on-background">${mostExposed ? `<span class="font-black">${mostExposed.repo_name}</span> leads with a score of <span class="font-black">${mostExposed.score}</span>.` : "Risk scoring becomes available once repositories and findings are present."}</p>
        </article>
      </div>`;
    }

    function renderActions(
        sla: SLACompliance,
        findings: Finding[],
        risk: RepoRiskScore[],
    ): string {
        const overdue = findings.filter(
            (finding) =>
                Boolean(finding.sla_deadline) &&
                (finding.status === "open" || finding.status === "in_review"),
        );
        const criticalOpen = findings.filter(
            (finding) =>
                finding.severity === "critical" &&
                (finding.status === "open" || finding.status === "in_review"),
        );
        const topRisk = risk[0];

        const actions = [
            overdue.length
                ? `Triage ${overdue.length} unresolved findings with active SLA deadlines before the next reporting window closes.`
                : "Maintain SLA discipline by reviewing newly opened findings before they become overdue.",
            criticalOpen.length
                ? `Escalate ${criticalOpen.length} critical unresolved findings into an immediate remediation workstream.`
                : "No critical unresolved findings are open right now; sustain the current containment posture.",
            topRisk
                ? `Prioritize ${topRisk.repo_name} for focused remediation because it currently drives the highest aggregate risk score.`
                : "As repositories accumulate findings, add a targeted remediation focus per highest-risk repository.",
        ];

        return `<ol class="space-y-3">${actions.map((action, index) => `<li class="rounded-2xl border border-outline-variant/20 bg-surface px-4 py-3"><span class="mr-2 inline-flex h-6 w-6 items-center justify-center rounded-full bg-sky-500/15 text-xs font-black text-sky-300">${index + 1}</span>${action}</li>`).join("")}</ol>`;
    }

    function renderPriorityFindings(findings: Finding[]): string {
        const rows = findings
            .filter(
                (finding) =>
                    finding.status === "open" || finding.status === "in_review",
            )
            .sort((left, right) => {
                const severityDiff =
                    severityRank(left.severity) - severityRank(right.severity);
                if (severityDiff !== 0) return severityDiff;
                return (
                    new Date(right.created_at).getTime() -
                    new Date(left.created_at).getTime()
                );
            })
            .slice(0, 8);

        if (!rows.length) {
            return '<p class="text-sm text-slate-500">No unresolved findings to include in the printable appendix.</p>';
        }

        return `
      <table class="report-print-table min-w-full text-sm">
        <thead>
          <tr>
            <th class="pr-4">Severity</th>
            <th class="pr-4">Title</th>
            <th class="pr-4">Scanner</th>
            <th class="pr-4">Status</th>
            <th class="pr-4">Created</th>
          </tr>
        </thead>
        <tbody>
          ${rows
              .map(
                  (finding) => `
            <tr>
              <td class="pr-4 font-bold uppercase">${finding.severity}</td>
              <td class="pr-4">${finding.title}</td>
              <td class="pr-4">${finding.scanner}</td>
              <td class="pr-4">${finding.status.replace("_", " ")}</td>
              <td class="pr-4">${new Date(finding.created_at).toLocaleDateString("en-US")}</td>
            </tr>
          `,
              )
              .join("")}
        </tbody>
      </table>`;
    }

    async function load() {
        const days = parseInt(
            (document.getElementById("days-select") as HTMLSelectElement).value,
        );
        updateReportMeta(days);

        const [sla, trends, risk, { findings: allFindings }] =
            await Promise.all([
                api.getSLACompliance(),
                api.getTrends(days),
                api.getRiskScores(),
                api.getFindings("", "", 1, 500),
            ]);

        // KPIs
        const pct = sla.total > 0 ? sla.percent.toFixed(1) : "—";
        const pctColor =
            sla.percent >= 90
                ? "text-emerald-400"
                : sla.percent >= 70
                  ? "text-amber-400"
                  : "text-red-400";
        document.getElementById("kpi-sla-pct")!.textContent =
            sla.total > 0 ? `${pct}%` : "—";
        document.getElementById("kpi-sla-pct")!.className =
            `text-3xl font-black ${pctColor}`;
        document.getElementById("kpi-sla-sub")!.textContent =
            `${sla.on_time} on-time / ${sla.total} tracked`;
        document.getElementById("kpi-overdue")!.textContent = String(
            sla.overdue,
        );

        const openCount = allFindings.filter(
            (f) => f.status === "open" || f.status === "in_review",
        ).length;
        const resolvedCount = allFindings.filter(
            (f) => f.status === "fixed" || f.status === "verified",
        ).length;
        document.getElementById("kpi-open")!.textContent = String(openCount);
        document.getElementById("kpi-resolved")!.textContent =
            String(resolvedCount);
        document.getElementById("report-summary")!.innerHTML = renderSummary(
            sla,
            allFindings,
            risk,
        );
        document.getElementById("report-actions")!.innerHTML = renderActions(
            sla,
            allFindings,
            risk,
        );
        document.getElementById("priority-findings")!.innerHTML =
            renderPriorityFindings(allFindings);

        // Trend chart
        document.getElementById("trend-chart")!.innerHTML = trendChart(trends);

        // Status distribution
        const statusCounts: Record<string, number> = {};
        allFindings.forEach((f) => {
            statusCounts[f.status] = (statusCounts[f.status] ?? 0) + 1;
        });
        const total = allFindings.length || 1;

        const STATUS_META: {
            key: string;
            label: string;
            color: string;
            bar: string;
        }[] = [
            {
                key: "open",
                label: "Open",
                color: "text-slate-400",
                bar: "bg-slate-400",
            },
            {
                key: "in_review",
                label: "In Review",
                color: "text-sky-400",
                bar: "bg-sky-400",
            },
            {
                key: "accepted_risk",
                label: "Accepted Risk",
                color: "text-amber-400",
                bar: "bg-amber-400",
            },
            {
                key: "fixed",
                label: "Fixed",
                color: "text-emerald-400",
                bar: "bg-emerald-400",
            },
            {
                key: "verified",
                label: "Verified",
                color: "text-teal-400",
                bar: "bg-teal-400",
            },
        ];

        document.getElementById("status-dist")!.innerHTML = STATUS_META.map(
            (s) => {
                const count = statusCounts[s.key] ?? 0;
                const pct = Math.round((count / total) * 100);
                return `<div>
        <div class="flex justify-between text-xs mb-1.5">
          <span class="${s.color} font-bold">${s.label}</span>
          <span class="font-mono text-slate-400">${count} <span class="text-slate-600">(${pct}%)</span></span>
        </div>
        <div class="status-bar-track h-1.5 bg-surface-container rounded-full overflow-hidden">
          <div class="${s.bar} h-full rounded-full transition-all" style="width:${pct}%"></div>
        </div>
      </div>`;
            },
        ).join("");

        // Risk scores
        const riskEl = document.getElementById("risk-scores")!;
        if (!risk.length) {
            riskEl.innerHTML =
                '<p class="text-sm text-slate-500">No repos added yet.</p>';
        } else {
            const maxScore = risk[0].score || 1;
            riskEl.innerHTML = `<div class="space-y-4">${risk.map((rs) => riskBar(rs, maxScore)).join("")}</div>`;
        }
    }

    document.getElementById("days-select")!.addEventListener("change", load);
    document.getElementById("export-status")!.addEventListener("change", () => {
        const days = parseInt(
            (document.getElementById("days-select") as HTMLSelectElement).value,
        );
        updateReportMeta(days);
    });
    document.querySelectorAll("[data-export-severity]").forEach((input) => {
        input.addEventListener("change", () => {
            const days = parseInt(
                (document.getElementById("days-select") as HTMLSelectElement)
                    .value,
            );
            updateReportMeta(days);
        });
    });
    document.getElementById("print-btn")!.addEventListener("click", () => {
        const days = parseInt(
            (document.getElementById("days-select") as HTMLSelectElement).value,
        );
        updateReportMeta(days);
        window.print();
    });

    document
        .getElementById("export-btn")!
        .addEventListener("click", async (e) => {
            e.preventDefault();
            const sev = selectedExportSeverities();
            const status = (
                document.getElementById("export-status") as HTMLSelectElement
            ).value;
            const btn = document.getElementById(
                "export-btn",
            ) as HTMLAnchorElement;
            btn.textContent = "Exporting…";

            try {
                const url = api.exportFindingsURL(sev, "", status);
                const res = await fetch(url, {
                    credentials: "include",
                });
                if (!res.ok) throw new Error(res.statusText);
                const blob = await res.blob();
                const a = document.createElement("a");
                a.href = URL.createObjectURL(blob);
                a.download = `findings-${new Date().toISOString().slice(0, 10)}.csv`;
                a.click();
                URL.revokeObjectURL(a.href);
            } catch (err: any) {
                alert("Export failed: " + err.message);
            } finally {
                btn.innerHTML =
                    '<span class="material-symbols-outlined text-base">download</span> Export CSV';
            }
        });

    updateReportMeta(
        parseInt(
            (document.getElementById("days-select") as HTMLSelectElement).value,
        ),
    );
    load();
</script>
