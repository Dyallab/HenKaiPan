---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---
<DashboardLayout title="Executive Reports" active="reports">

  <!-- Top bar: date range + export -->
  <div class="flex items-center justify-between mb-6 flex-wrap gap-3">
    <div class="flex items-center gap-2">
      <label class="text-xs text-slate-500 font-bold uppercase tracking-widest">Trend window</label>
      <select id="days-select" class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-sky-500 transition-all">
        <option value="7">Last 7 days</option>
        <option value="30" selected>Last 30 days</option>
        <option value="90">Last 90 days</option>
        <option value="365">Last 365 days</option>
      </select>
    </div>
    <div class="flex items-center gap-2">
      <fieldset class="flex flex-wrap items-center gap-2 rounded-lg border border-outline-variant/30 bg-surface-container px-3 py-2">
        <legend class="px-1 text-[10px] font-bold uppercase tracking-widest text-slate-500">Export severities</legend>
        <label class="inline-flex items-center gap-2 rounded-full border border-red-500/20 bg-red-500/10 px-2.5 py-1 text-xs font-semibold text-red-300 cursor-pointer">
          <input type="checkbox" value="critical" data-export-severity class="h-3.5 w-3.5 rounded border-red-500/40 bg-transparent text-red-400 focus:ring-0" />
          Critical
        </label>
        <label class="inline-flex items-center gap-2 rounded-full border border-orange-500/20 bg-orange-500/10 px-2.5 py-1 text-xs font-semibold text-orange-300 cursor-pointer">
          <input type="checkbox" value="high" data-export-severity class="h-3.5 w-3.5 rounded border-orange-500/40 bg-transparent text-orange-400 focus:ring-0" />
          High
        </label>
        <label class="inline-flex items-center gap-2 rounded-full border border-amber-500/20 bg-amber-500/10 px-2.5 py-1 text-xs font-semibold text-amber-300 cursor-pointer">
          <input type="checkbox" value="medium" data-export-severity class="h-3.5 w-3.5 rounded border-amber-500/40 bg-transparent text-amber-400 focus:ring-0" />
          Medium
        </label>
        <label class="inline-flex items-center gap-2 rounded-full border border-sky-500/20 bg-sky-500/10 px-2.5 py-1 text-xs font-semibold text-sky-300 cursor-pointer">
          <input type="checkbox" value="low" data-export-severity class="h-3.5 w-3.5 rounded border-sky-500/40 bg-transparent text-sky-400 focus:ring-0" />
          Low
        </label>
        <label class="inline-flex items-center gap-2 rounded-full border border-slate-500/20 bg-slate-500/10 px-2.5 py-1 text-xs font-semibold text-slate-300 cursor-pointer">
          <input type="checkbox" value="info" data-export-severity class="h-3.5 w-3.5 rounded border-slate-500/40 bg-transparent text-slate-400 focus:ring-0" />
          Info
        </label>
      </fieldset>
      <select id="export-status" class="bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-sky-500 transition-all">
        <option value="">All statuses</option>
        <option value="open">Open</option>
        <option value="in_review">In Review</option>
        <option value="fixed">Fixed</option>
        <option value="verified">Verified</option>
      </select>
      <button id="export-btn"
        class="flex items-center gap-2 px-4 py-2 bg-slate-900 border border-slate-800 text-on-background rounded-lg hover:bg-slate-800 transition-colors text-sm font-bold">
        <span class="material-symbols-outlined text-base">download</span>
        Export CSV
      </button>
    </div>
  </div>

  <!-- KPI row -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    <div class="bg-surface-container-low border border-outline-variant/20 rounded-xl p-5">
      <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-2">SLA Compliance</p>
      <p id="kpi-sla-pct" class="text-3xl font-black text-emerald-400">—%</p>
      <p id="kpi-sla-sub" class="text-xs text-slate-500 mt-1"></p>
    </div>
    <div class="bg-surface-container-low border border-outline-variant/20 rounded-xl p-5">
      <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-2">Overdue SLA</p>
      <p id="kpi-overdue" class="text-3xl font-black text-red-400">—</p>
      <p class="text-xs text-slate-500 mt-1">findings past deadline</p>
    </div>
    <div class="bg-surface-container-low border border-outline-variant/20 rounded-xl p-5">
      <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-2">Open Findings</p>
      <p id="kpi-open" class="text-3xl font-black text-sky-400">—</p>
      <p class="text-xs text-slate-500 mt-1">unresolved</p>
    </div>
    <div class="bg-surface-container-low border border-outline-variant/20 rounded-xl p-5">
      <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-2">Resolved</p>
      <p id="kpi-resolved" class="text-3xl font-black text-teal-400">—</p>
      <p class="text-xs text-slate-500 mt-1">fixed or verified</p>
    </div>
  </div>

  <div class="grid grid-cols-1 xl:grid-cols-2 gap-6 mb-6">

    <!-- Findings trend chart -->
    <div class="bg-surface-container-low border border-outline-variant/20 rounded-xl p-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-[10px] font-bold uppercase tracking-widest text-slate-500">Findings Over Time</h2>
        <div class="flex items-center gap-3 text-[10px] font-bold uppercase tracking-widest">
          <span class="flex items-center gap-1"><span class="w-3 h-0.5 bg-red-500 inline-block rounded"></span>Critical</span>
          <span class="flex items-center gap-1"><span class="w-3 h-0.5 bg-orange-500 inline-block rounded"></span>High</span>
          <span class="flex items-center gap-1"><span class="w-3 h-0.5 bg-amber-500 inline-block rounded"></span>Medium</span>
          <span class="flex items-center gap-1"><span class="w-3 h-0.5 bg-sky-400 inline-block rounded"></span>Low</span>
        </div>
      </div>
      <div id="trend-chart" class="min-h-[160px] flex items-center justify-center">
        <p class="text-sm text-slate-500">Loading…</p>
      </div>
    </div>

    <!-- Status distribution -->
    <div class="bg-surface-container-low border border-outline-variant/20 rounded-xl p-5">
      <h2 class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-4">Finding Status Distribution</h2>
      <div id="status-dist" class="space-y-3">
        <p class="text-sm text-slate-500">Loading…</p>
      </div>
    </div>
  </div>

  <!-- Risk score per repo -->
  <div class="bg-surface-container-low border border-outline-variant/20 rounded-xl p-5">
    <h2 class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-5">Risk Score by Repository</h2>
    <div id="risk-scores">
      <p class="text-sm text-slate-500">Loading…</p>
    </div>
  </div>

</DashboardLayout>

<script>
  import { api } from '../../lib/api';
  import type { TrendPoint, RepoRiskScore } from '../../lib/api';

  // ── SVG trend chart ──────────────────────────────────────────────────────────

  function trendChart(points: TrendPoint[]): string {
    if (!points.length) return '<p class="text-sm text-slate-500">No findings in this period.</p>';

    const W = 560, H = 160;
    const padL = 32, padB = 26, padT = 8, padR = 10;
    const cW = W - padL - padR, cH = H - padT - padB;
    const n = points.length;

    const maxVal = Math.max(
      1,
      ...points.flatMap(p => [p.critical, p.high, p.medium, p.low]),
    );

    const x = (i: number) => padL + (n > 1 ? (i / (n - 1)) * cW : cW / 2);
    const y = (v: number) => padT + cH - (v / maxVal) * cH;
    const pts = (key: keyof TrendPoint) =>
      points.map((p, i) => `${x(i)},${y(p[key] as number)}`).join(' ');

    const series: { key: keyof TrendPoint; color: string }[] = [
      { key: 'low',      color: '#38bdf8' },
      { key: 'medium',   color: '#f59e0b' },
      { key: 'high',     color: '#f97316' },
      { key: 'critical', color: '#ef4444' },
    ];

    // Y axis
    const yStep = maxVal > 0 ? maxVal : 1;
    const yTicks = [0, Math.round(yStep / 2), yStep].map(v =>
      `<text x="${padL - 6}" y="${y(v) + 4}" text-anchor="end" fill="#475569" font-size="9">${v}</text>
       <line x1="${padL}" x2="${W - padR}" y1="${y(v)}" y2="${y(v)}" stroke="#1e293b" stroke-width="1"/>`,
    );

    // X axis labels (sparse: up to 5)
    const labelIdxs = n <= 5
      ? points.map((_, i) => i)
      : Array.from({ length: 5 }, (_, i) => Math.round(i * (n - 1) / 4));
    const xLabels = labelIdxs.map(i =>
      `<text x="${x(i)}" y="${H - 4}" text-anchor="middle" fill="#475569" font-size="9">${points[i].date.slice(5)}</text>`,
    );

    const lines = series.map(s =>
      `<polyline points="${pts(s.key)}" fill="none" stroke="${s.color}" stroke-width="2"
         stroke-linejoin="round" stroke-linecap="round"/>`,
    );

    return `<svg viewBox="0 0 ${W} ${H}" class="w-full" xmlns="http://www.w3.org/2000/svg">
      ${yTicks.join('')}
      ${lines.join('')}
      ${xLabels.join('')}
    </svg>`;
  }

  // ── Risk score bars ──────────────────────────────────────────────────────────

  function riskBar(rs: RepoRiskScore, maxScore: number): string {
    const pct = maxScore > 0 ? Math.round((rs.score / maxScore) * 100) : 0;
    const color = rs.score >= 500 ? 'bg-red-500'
      : rs.score >= 100 ? 'bg-orange-500'
      : rs.score >= 20  ? 'bg-amber-500'
      : 'bg-sky-500';
    const breakdown = [
      rs.critical ? `<span class="text-red-400">${rs.critical}C</span>` : '',
      rs.high      ? `<span class="text-orange-400">${rs.high}H</span>` : '',
      rs.medium    ? `<span class="text-amber-400">${rs.medium}M</span>` : '',
      rs.low       ? `<span class="text-sky-400">${rs.low}L</span>` : '',
    ].filter(Boolean).join(' ');
    return `
      <div class="flex items-center gap-4">
        <div class="w-40 min-w-[10rem] shrink-0">
          <p class="text-sm font-bold text-on-background truncate">${rs.repo_name}</p>
          <p class="text-xs text-slate-500 font-mono truncate max-w-full">${rs.repo_url}</p>
        </div>
        <div class="flex-1 min-w-0">
          <div class="h-2 bg-surface-container rounded-full overflow-hidden">
            <div class="${color} h-full rounded-full transition-all" style="width:${pct}%"></div>
          </div>
        </div>
        <div class="shrink-0 text-right w-40">
          <span class="text-sm font-black text-on-background font-mono">${rs.score}</span>
          <span class="text-[10px] text-slate-500 ml-1.5 font-mono">${breakdown || '—'}</span>
        </div>
      </div>`;
  }

  // ── Load data ────────────────────────────────────────────────────────────────

  function selectedExportSeverities() {
    return Array.from(document.querySelectorAll<HTMLInputElement>('[data-export-severity]:checked')).map((input) => input.value);
  }

  async function load() {
    const days = parseInt((document.getElementById('days-select') as HTMLSelectElement).value);

    const [sla, trends, risk, { findings: allFindings }] = await Promise.all([
      api.getSLACompliance(),
      api.getTrends(days),
      api.getRiskScores(),
      api.getFindings('', '', 1, 500),
    ]);

    // KPIs
    const pct = sla.total > 0 ? sla.percent.toFixed(1) : '—';
    const pctColor = sla.percent >= 90 ? 'text-emerald-400' : sla.percent >= 70 ? 'text-amber-400' : 'text-red-400';
    document.getElementById('kpi-sla-pct')!.textContent = sla.total > 0 ? `${pct}%` : '—';
    document.getElementById('kpi-sla-pct')!.className = `text-3xl font-black ${pctColor}`;
    document.getElementById('kpi-sla-sub')!.textContent = `${sla.on_time} on-time / ${sla.total} tracked`;
    document.getElementById('kpi-overdue')!.textContent = String(sla.overdue);

    const openCount     = allFindings.filter(f => f.status === 'open' || f.status === 'in_review').length;
    const resolvedCount = allFindings.filter(f => f.status === 'fixed' || f.status === 'verified').length;
    document.getElementById('kpi-open')!.textContent     = String(openCount);
    document.getElementById('kpi-resolved')!.textContent = String(resolvedCount);

    // Trend chart
    document.getElementById('trend-chart')!.innerHTML = trendChart(trends);

    // Status distribution
    const statusCounts: Record<string, number> = {};
    allFindings.forEach(f => { statusCounts[f.status] = (statusCounts[f.status] ?? 0) + 1; });
    const total = allFindings.length || 1;

    const STATUS_META: { key: string; label: string; color: string; bar: string }[] = [
      { key: 'open',          label: 'Open',          color: 'text-slate-400',   bar: 'bg-slate-400' },
      { key: 'in_review',     label: 'In Review',     color: 'text-sky-400',     bar: 'bg-sky-400' },
      { key: 'accepted_risk', label: 'Accepted Risk', color: 'text-amber-400',   bar: 'bg-amber-400' },
      { key: 'fixed',         label: 'Fixed',         color: 'text-emerald-400', bar: 'bg-emerald-400' },
      { key: 'verified',      label: 'Verified',      color: 'text-teal-400',    bar: 'bg-teal-400' },
    ];

    document.getElementById('status-dist')!.innerHTML = STATUS_META.map(s => {
      const count = statusCounts[s.key] ?? 0;
      const pct   = Math.round((count / total) * 100);
      return `<div>
        <div class="flex justify-between text-xs mb-1.5">
          <span class="${s.color} font-bold">${s.label}</span>
          <span class="font-mono text-slate-400">${count} <span class="text-slate-600">(${pct}%)</span></span>
        </div>
        <div class="h-1.5 bg-surface-container rounded-full overflow-hidden">
          <div class="${s.bar} h-full rounded-full transition-all" style="width:${pct}%"></div>
        </div>
      </div>`;
    }).join('');

    // Risk scores
    const riskEl = document.getElementById('risk-scores')!;
    if (!risk.length) {
      riskEl.innerHTML = '<p class="text-sm text-slate-500">No repos added yet.</p>';
    } else {
      const maxScore = risk[0].score || 1;
      riskEl.innerHTML = `<div class="space-y-4">${risk.map(rs => riskBar(rs, maxScore)).join('')}</div>`;
    }
  }

  document.getElementById('days-select')!.addEventListener('change', load);

  document.getElementById('export-btn')!.addEventListener('click', async (e) => {
    e.preventDefault();
    const sev    = selectedExportSeverities();
    const status = (document.getElementById('export-status') as HTMLSelectElement).value;
    const btn    = document.getElementById('export-btn') as HTMLAnchorElement;
    btn.textContent = 'Exporting…';

    try {
      const token = localStorage.getItem('aspm_token') ?? '';
      const url   = api.exportFindingsURL(sev, '', status);
      const res   = await fetch(url, { headers: { Authorization: `Bearer ${token}` } });
      if (!res.ok) throw new Error(res.statusText);
      const blob = await res.blob();
      const a    = document.createElement('a');
      a.href     = URL.createObjectURL(blob);
      a.download = `findings-${new Date().toISOString().slice(0, 10)}.csv`;
      a.click();
      URL.revokeObjectURL(a.href);
    } catch (err: any) {
      alert('Export failed: ' + err.message);
    } finally {
      btn.innerHTML = '<span class="material-symbols-outlined text-base">download</span> Export CSV';
    }
  });

  load();
</script>
