---
import DashboardLayout from '@layouts/DashboardLayout.astro';
---
<DashboardLayout title="Repositories" active="repos">

  <!-- Add repo form -->
  <div class="bg-surface-container-low border border-outline-variant/20 rounded-xl p-6 mb-6">
    <h2 class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-4">Add Repository</h2>
    <form id="repo-form" class="flex gap-3 flex-wrap">
      <input
        id="repo-name"
        type="text"
        placeholder="my-service"
        class="w-40 bg-surface-container border border-outline-variant/30 text-on-background rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-all placeholder:text-slate-600"
      />
      <div class="relative flex-1 min-w-64">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 text-lg">link</span>
        <input
          id="repo-url"
          type="text"
          placeholder="https://github.com/org/repo"
          class="w-full bg-surface-container border border-outline-variant/30 text-on-background rounded-lg pl-10 pr-4 py-2.5 text-sm focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-all placeholder:text-slate-600"
        />
      </div>
      <button
        type="submit"
        class="flex items-center gap-2 px-6 py-2.5 bg-cyan-500 text-slate-950 rounded-lg text-sm font-bold hover:bg-cyan-400 transition-all active:scale-95"
      >
        <span class="material-symbols-outlined text-lg">add</span>
        Add Repo
      </button>
    </form>
    <div id="repo-msg" class="hidden mt-3 text-sm"></div>
  </div>

  <!-- Repos list -->
  <div class="bg-surface-container-low border border-outline-variant/20 rounded-xl overflow-hidden">
    <div class="px-6 py-4 border-b border-outline-variant/20">
      <h2 class="text-[10px] font-bold uppercase tracking-widest text-slate-500">Repositories</h2>
    </div>
    <div id="repos-list">
      <p class="px-6 py-4 text-sm text-slate-500">Loading...</p>
    </div>
  </div>

  <!-- GitHub Token Modal -->
  <div id="token-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center z-50">
    <div class="bg-surface-container border border-outline-variant/20 rounded-xl p-6 w-full max-w-md">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-bold text-on-background">Configure GitHub Token</h3>
        <button id="close-token-modal" class="text-slate-400 hover:text-slate-200">
          <span class="material-symbols-outlined text-xl">close</span>
        </button>
      </div>
      <p class="text-sm text-slate-400 mb-4">
        Enter a GitHub Personal Access Token to clone private repositories. The token will be encrypted and stored securely.
      </p>
      <div class="space-y-4">
        <div>
          <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">Repository</label>
          <p id="modal-repo-name" class="text-sm font-semibold text-on-background"></p>
        </div>
        <div>
          <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">GitHub Token</label>
          <input
            id="github-token-input"
            type="password"
            placeholder="ghp_..."
            class="w-full bg-slate-950 border border-slate-800 rounded-lg px-4 py-2.5 text-on-background text-sm focus:ring-2 focus:ring-cyan-500 outline-none font-mono transition-all"
          />
          <p class="text-xs text-slate-500 mt-1">
            Create a token with <span class="font-mono text-cyan-400">repo</span> scope at <a href="https://github.com/settings/tokens" target="_blank" class="text-cyan-400 hover:underline">github.com/settings/tokens</a>
          </p>
        </div>
        <div class="flex gap-3 pt-2">
          <button
            id="save-github-token"
            class="flex-1 px-4 py-2 bg-cyan-500 hover:bg-cyan-400 text-slate-950 rounded-lg text-sm font-bold transition-all active:scale-95"
          >
            Save Token
          </button>
          <button
            id="remove-github-token"
            class="px-4 py-2 bg-red-500/10 hover:bg-red-500/20 text-red-400 border border-red-500/20 rounded-lg text-sm font-bold transition-all"
          >
            Remove
          </button>
        </div>
        <div id="token-msg" class="hidden text-sm"></div>
      </div>
    </div>
  </div>

</DashboardLayout>

<script>
  import { api } from '@lib/api';

  let currentRepoId: string | null = null;

  async function loadRepos() {
    const repos = await api.getRepos();
    const el = document.getElementById('repos-list')!;
    const msg = document.getElementById('repo-msg')!;
    if (!repos.length) {
      el.innerHTML = '<p class="px-6 py-4 text-sm text-slate-500">No repos added yet.</p>';
      return;
    }
    el.innerHTML = `<div class="divide-y divide-slate-800/50">
      ${repos.map(r => `
        <div class="px-6 py-4 flex items-center justify-between hover:bg-slate-900/20 transition-colors">
          <div class="min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <span class="material-symbols-outlined text-slate-500 text-base">hub</span>
              <p class="text-sm font-bold text-on-background">${r.name}</p>
              ${r.has_token ? '<span class="material-symbols-outlined text-green-400 text-base" title="GitHub token configured">key</span>' : ''}
            </div>
            <p class="text-xs text-slate-500 font-mono truncate max-w-md">${r.url}</p>
          </div>
          <div class="flex items-center gap-3 shrink-0 ml-4">
            <button
              type="button"
              data-configure-token="${r.id}"
              data-repo-name="${r.name}"
              data-repo-has-token="${r.has_token}"
              class="flex items-center gap-1.5 px-3 py-1.5 bg-cyan-500/10 text-cyan-400 border border-cyan-500/20 rounded text-xs font-bold uppercase tracking-wider hover:bg-cyan-500/20 transition-colors"
            >
              <span class="material-symbols-outlined text-sm">${r.has_token ? 'key' : 'key_off'}</span>
              ${r.has_token ? 'Token Set' : 'Set Token'}
            </button>
            <a href="/dashboard/scans?repo=${encodeURIComponent(r.url)}"
               class="flex items-center gap-1.5 px-3 py-1.5 bg-cyan-500/10 text-cyan-400 border border-cyan-500/20 rounded text-xs font-bold uppercase tracking-wider hover:bg-cyan-500/20 transition-colors">
              <span class="material-symbols-outlined text-sm">security_update_good</span>
              Scan
            </a>
            <button
              type="button"
              data-delete-repo="${r.id}"
              data-repo-name="${r.name}"
              class="flex items-center gap-1.5 px-3 py-1.5 bg-red-500/10 text-red-400 border border-red-500/20 rounded text-xs font-bold uppercase tracking-wider hover:bg-red-500/20 transition-colors"
            >
              <span class="material-symbols-outlined text-sm">delete</span>
              Delete
            </button>
            <p class="text-xs text-slate-600 font-mono">${new Date(r.created_at).toLocaleDateString()}</p>
          </div>
        </div>
      `).join('')}
    </div>`;

    // Configure token buttons
    el.querySelectorAll('[data-configure-token]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const target = btn as HTMLElement;
        currentRepoId = target.dataset.configureToken || null;
        const repoName = target.dataset.repoName || '';
        const hasToken = target.dataset.repoHasToken === 'true';

        document.getElementById('modal-repo-name')!.textContent = repoName;
        const tokenInput = document.getElementById('github-token-input') as HTMLInputElement;
        tokenInput.value = '';
        tokenInput.placeholder = hasToken ? '••••••••••••' : 'ghp_...';
        
        const removeBtn = document.getElementById('remove-github-token')!;
        removeBtn.classList.toggle('hidden', !hasToken);
        
        const msg = document.getElementById('token-msg')!;
        msg.className = 'hidden text-sm';
        msg.textContent = '';

        document.getElementById('token-modal')!.classList.remove('hidden');
      });
    });

    // Delete repo buttons
    el.querySelectorAll('[data-delete-repo]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const target = btn as HTMLElement;
        const repoId = target.dataset.deleteRepo;
        const repoName = target.dataset.repoName || 'this repository';
        if (!repoId) return;
        if (!confirm(`Delete ${repoName}?`)) return;

        try {
          await api.deleteRepo(repoId);
          msg.textContent = 'Repository deleted.';
          msg.className = 'mt-3 text-sm text-emerald-400';
          await loadRepos();
        } catch (err) {
          const message = err instanceof Error ? err.message : 'Failed to delete repository';
          msg.textContent = message;
          msg.className = 'mt-3 text-sm text-red-400';
        }
      });
    });
  }

  // Modal close
  document.getElementById('close-token-modal')!.addEventListener('click', () => {
    document.getElementById('token-modal')!.classList.add('hidden');
    currentRepoId = null;
  });

  // Save token
  document.getElementById('save-github-token')!.addEventListener('click', async () => {
    if (!currentRepoId) return;
    
    const tokenInput = document.getElementById('github-token-input') as HTMLInputElement;
    const token = tokenInput.value.trim();
    const msg = document.getElementById('token-msg')!;

    if (!token) {
      msg.textContent = 'Token is required';
      msg.className = 'text-sm text-red-400';
      return;
    }

    try {
      await api.updateRepoGitHubToken(currentRepoId, token);
      msg.textContent = 'Token saved successfully';
      msg.className = 'text-sm text-emerald-400';
      setTimeout(() => {
        document.getElementById('token-modal')!.classList.add('hidden');
        loadRepos();
      }, 1000);
    } catch (err) {
      const message = err instanceof Error ? err.message : 'Failed to save token';
      msg.textContent = message;
      msg.className = 'text-sm text-red-400';
    }
  });

  // Remove token
  document.getElementById('remove-github-token')!.addEventListener('click', async () => {
    if (!currentRepoId) return;

    const msg = document.getElementById('token-msg')!;
    
    if (!confirm('Remove the GitHub token for this repository?')) return;

    try {
      await api.updateRepoGitHubToken(currentRepoId, '');
      msg.textContent = 'Token removed';
      msg.className = 'text-sm text-emerald-400';
      setTimeout(() => {
        document.getElementById('token-modal')!.classList.add('hidden');
        loadRepos();
      }, 1000);
    } catch (err) {
      const message = err instanceof Error ? err.message : 'Failed to remove token';
      msg.textContent = message;
      msg.className = 'text-sm text-red-400';
    }
  });

  // Close modal on backdrop click
  document.getElementById('token-modal')!.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) {
      document.getElementById('token-modal')!.classList.add('hidden');
      currentRepoId = null;
    }
  });

  // Add repo form
  document.getElementById('repo-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = (document.getElementById('repo-name') as HTMLInputElement).value.trim();
    const url  = (document.getElementById('repo-url') as HTMLInputElement).value.trim();
    const msg  = document.getElementById('repo-msg')!;
    if (!url) return;

    try {
      await api.createRepo(name || url, url);
      msg.textContent = 'Repository added.';
      msg.className = 'mt-3 text-sm text-emerald-400';
      (document.getElementById('repo-name') as HTMLInputElement).value = '';
      (document.getElementById('repo-url') as HTMLInputElement).value = '';
      loadRepos();
    } catch (err: any) {
      msg.textContent = err.message;
      msg.className = 'mt-3 text-sm text-red-400';
    }
  });

  loadRepos();
</script>
