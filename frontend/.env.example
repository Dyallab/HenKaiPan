# API base URL for the backend server.
# In development: "http://localhost:8080"
# In production: empty string (same origin) or "https://aspm.example.com"
# The frontend sends all API requests to this URL.
# IMPORTANT: Must start with PUBLIC_ to be available in browser-side code.
PUBLIC_API_BASE=

# For local development with separate frontend/backend:
# PUBLIC_API_BASE=http://localhost:8080