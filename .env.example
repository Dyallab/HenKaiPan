# ============================================================================
# REQUIRED
# ============================================================================
DATABASE_URL=postgres://aspm:aspm@localhost:5432/aspm?sslmode=disable
POSTGRES_DB=aspm
POSTGRES_USER=aspm
POSTGRES_PASSWORD=aspm
JWT_SECRET=your-secret-jwt-key-change-this-in-production
SECRET_ENCRYPTION_KEY=your-db-secret-encryption-key-change-this-in-production

# ============================================================================
# OPTIONAL: Server
# ============================================================================
PORT=8080                                   # API port (default: 8080)
REDIS_ADDR=localhost:6379                    # Redis address for job queue
REDIS_PASSWORD=                              # Redis password (optional)
COOKIE_SECURE=false                          # true behind HTTPS
FRONTEND_BASE_URL=http://localhost:4321       # Used for external backlinks
LICENSE_KEY=                                 # Self-hosted paid features
LICENSE_SIGNING_SECRET=                      # Required if LICENSE_KEY is set
WEBHOOK_SECRET=                              # Optional: HMAC signature for webhook validation

# ============================================================================
# OPTIONAL: Notifications & Integrations
# ============================================================================
SMTP_HOST=mailpit                            # Dev: mailpit, Prod: smtp-relay.brevo.com
SMTP_PORT=1025                               # Dev: 1025, Prod: 587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=alerts@localhost

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini

CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_MODEL=@cf/meta/llama-3.1-8b-instruct
CF_MODEL_SUMM=@cf/google/gemma-3-12b-it

OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:e4b

AI_REMEDIATION_PROVIDER=cloudflare
AI_SUMMARY_PROVIDER=ollama
AI_VALIDATION_PROVIDER=cloudflare
