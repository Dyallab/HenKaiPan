# ============================================================================
# REQUIRED
# ============================================================================
DATABASE_URL=postgres://aspm:aspm@localhost:5432/aspm?sslmode=disable
POSTGRES_DB=aspm
POSTGRES_USER=aspm
POSTGRES_PASSWORD=aspm
JWT_SECRET=your-secret-jwt-key-change-this-in-production
SECRET_ENCRYPTION_KEY=your-db-secret-encryption-key-change-this-in-production

# ============================================================================
# OPTIONAL: Server
# ============================================================================
PORT=8080                                   # API port (default: 8080)
REDIS_ADDR=localhost:6379                    # Redis address for job queue
REDIS_PASSWORD=                              # Redis password (optional)
# ENABLE_PPROF=true                          # Enable /debug/pprof profiling (dev only, NOT for production)

# ============================================================================
# OPTIONAL: Security (Cookie & CORS)
# ============================================================================
COOKIE_SECURE=false                          # true behind HTTPS (REQUIRED for production)
# COOKIE_DOMAIN=.example.com                # Cookie domain for production (e.g. ".aspm.example.com")
# COOKIE_SAMESITE=lax                       # "lax" (default), "strict", or "none" (requires Secure=true)
# CORS_ALLOWED_ORIGINS=http://localhost:4321 # Comma-separated origins (default: localhost origins)

FRONTEND_BASE_URL=http://localhost:4321       # Used for external backlinks
WEBHOOK_SECRET=                              # Optional: HMAC signature for webhook validation

# ============================================================================
# OPTIONAL: Notifications & Integrations
# ============================================================================
SMTP_HOST=mailpit                            # Dev: mailpit, Prod: smtp-relay.brevo.com
SMTP_PORT=1025                               # Dev: 1025, Prod: 587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=alerts@localhost

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini

CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_MODEL=@cf/meta/llama-3.1-8b-instruct
CF_MODEL_SUMM=@cf/google/gemma-3-12b-it

# Ollama (self-hosted, free tier)
# IMPORTANT: When running in Docker, Ollama must listen on all interfaces (not just localhost)
# Set OLLAMA_HOST=0.0.0.0:11434 in your host system
# See: https://github.com/ollama/ollama/issues/703
# Systemd override: /etc/systemd/system/ollama.service.d/override.conf
#   [Service]
#   Environment="OLLAMA_HOST=0.0.0.0:11434"
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:e4b

AI_REMEDIATION_PROVIDER=cloudflare
AI_SUMMARY_PROVIDER=ollama
AI_VALIDATION_PROVIDER=cloudflare

# ============================================================================
# OPTIONAL: Tier Limits (for Cloud/Enterprise deployments)
# ============================================================================
# Set to -1 for unlimited. Only set these on managed deployments.
# Self-hosted defaults to unlimited.
# HENKAIPAN_MAX_PROJECTS=75
# HENKAIPAN_MAX_USERS=10
# HENKAIPAN_MAX_AI_SCANS=100

# ============================================================================
# OPTIONAL: Telemetry (anonymous usage stats, enabled by default)
# ============================================================================
# HENKAIPAN_TELEMETRY_ENABLED=false   # Set to false to opt out
# HENKAIPAN_TELEMETRY_ENDPOINT=      # Default: https://telemetry.dyallab.com.ar/api/ping

# ============================================================================
# OPTIONAL: Slack Bot Integration (Socket Mode)
# ============================================================================
# SLACK_APP_TOKEN=xapp-...               # Slack App-Level Token with connections:write scope
# SLACK_BOT_TOKEN=xoxb-...               # Slack Bot Token with chat:write, app_mentions:read, users:read scopes
# API_BASE_URL=http://localhost:8080     # HenKaiPan API base URL (used by Slack bot for triage actions)
# API_TOKEN=                             # HenKaiPan API auth token (Bearer token for API calls from Slack bot)
