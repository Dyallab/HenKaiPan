# ============================================================================
# ASPM Configuration (.env)
# ============================================================================
# Copy this file to .env and fill in the values
# Required fields must be set, optional fields have defaults

# ============================================================================
# REQUIRED
# ============================================================================

# Database connection string (PostgreSQL)
DATABASE_URL=postgres://aspm:aspm@localhost:5432/aspm?sslmode=disable

# Database credentials (used by docker-compose for postgres service)
POSTGRES_DB=aspm
POSTGRES_USER=aspm
POSTGRES_PASSWORD=aspm

# JWT secret for authentication
JWT_SECRET=your-secret-jwt-key-change-this-in-production

# Secret key used to encrypt sensitive DB fields at rest (e.g. Jira token)
# openssl rand -hex 32
SECRET_ENCRYPTION_KEY=your-db-secret-encryption-key-change-this-in-production

# Set true behind HTTPS so auth cookie is marked Secure
COOKIE_SECURE=false

# Default admin credentials
ADMIN_USER=admin
ADMIN_PASS=admin

# ============================================================================
# OPTIONAL: Server Configuration
# ============================================================================
# Port to run the API server on (default: 8080)
PORT=8080

# License key for unlocking paid self-hosted features (optional).
# Without this key the app runs in free mode with limited features.
LICENSE_KEY=

# Secret used to sign and verify license keys.
# REQUIRED if you want to use paid license features. Without this, no license
# key can be validated. Keep this secret — anyone with it can generate valid
# license keys for your instances.
LICENSE_SIGNING_SECRET=

# Redis address for background jobs and queue (default: localhost:6379)
REDIS_ADDR=localhost:6379

# Redis password (optional, leave empty if no authentication)
REDIS_PASSWORD=

# Public frontend URL used in external integrations, such as Jira backlinks
# to HenKaiPan finding details (optional; leave empty to disable backlinks)
FRONTEND_BASE_URL=http://localhost:4321

# ==========================================================================
# OPTIONAL: Notifications & Integrations
# ==========================================================================

# GitHub PR summary comments. When GITHUB_TOKEN and GITHUB_PR_NUMBER are set,
# scans against GitHub repository targets post a Markdown findings summary to
# the pull request conversation.
GITHUB_API_URL=https://api.github.com
GITHUB_TOKEN=
GITHUB_PR_NUMBER=

# Optional email notifications.
# Local dev (Mailpit in docker-compose):
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=alerts@localhost
# Production (Brevo): set SMTP_HOST=smtp-relay.brevo.com, SMTP_PORT=587,
# SMTP_USERNAME, SMTP_PASSWORD, and EMAIL_FROM accordingly.

# ============================================================================
# OPTIONAL: AI Provider Configuration
# ============================================================================
# Each AI task (remediation, summary, validation) can use a different provider:
# - OpenRouter (https://openrouter.ai) - Paid, highest quality
# - Cloudflare Workers AI (https://developers.cloudflare.com/workers-ai/) - Paid, cost-effective
# - Ollama (https://ollama.ai) - FREE, self-hosted, requires local Ollama installation
#
# At least one provider must be configured for AI features to work.
# If neither is configured, AI generation will be disabled.
#
# DEFAULT: Ollama (ollama/gemma4:e4b) for free tier, self-hosted usage

# ─────────────────────────────────────────────────────────────────────────
# OpenRouter Configuration (Optional)
# ─────────────────────────────────────────────────────────────────────────
# Get API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk_your_api_key_here

# Default model for OpenRouter tasks
# Full list: https://openrouter.ai/docs#models
OPENROUTER_MODEL=openai/gpt-4.1-mini

# ─────────────────────────────────────────────────────────────────────────
# Cloudflare Workers AI Configuration (Optional)
# ─────────────────────────────────────────────────────────────────────────
# Get credentials from https://dash.cloudflare.com/
CF_ACCOUNT_ID=your_account_id_here
CF_API_TOKEN=your_api_token_here

# Default models for Cloudflare tasks
# Full list: https://developers.cloudflare.com/workers-ai/models/
CF_MODEL=@cf/meta/llama-3.1-8b-instruct
CF_MODEL_SUMM=@cf/google/gemma-3-12b-it

# ─────────────────────────────────────────────────────────────────────────
# Ollama Configuration (Optional - FREE, Self-Hosted)
# ─────────────────────────────────────────────────────────────────────────
# Install Ollama: https://ollama.ai/download
# Pull the model: ollama pull gemma4:e4b
#
# Default: http://localhost:11434 (local Ollama instance)
OLLAMA_URL=http://localhost:11434
#
# Recommended models for summaries:
# - gemma4:e4b (balanced, fast)
# - llama3.2:3b (very fast, lightweight)
# - mistral:7b (good quality, moderate speed)
OLLAMA_MODEL=gemma4:e4b

# ─────────────────────────────────────────────────────────────────────────
# AI Task Provider Selection (Optional)
# ─────────────────────────────────────────────────────────────────────────
# Choose which provider to use for each AI task.
# Valid values: "ollama" (default), "cloudflare", or "openrouter"
#
# Each task can use a different provider independently.

# Remediation: Generate code fix guidance for security findings
AI_REMEDIATION_PROVIDER=cloudflare

# Summary: Generate concise summaries of security findings
# DEFAULT: ollama (free, self-hosted)
AI_SUMMARY_PROVIDER=ollama

# Validation: Analyze findings to detect false positives
AI_VALIDATION_PROVIDER=cloudflare

# ─────────────────────────────────────────────────────────────────────────
# AI Task-Specific Models (Optional)
# ─────────────────────────────────────────────────────────────────────────
# Override default models per task. If not set, uses provider defaults.
#
# Cloudflare models must start with @cf/
# OpenRouter models use format: org/model (e.g., openai/gpt-4.1-mini)
# Ollama models use format: model-name:tag (e.g., gemma4:e4b)

# Remediation model (optional)
# Examples: @cf/openai/gpt-oss-120b, openai/gpt-4.1-mini
AI_REMEDIATION_MODEL=@cf/openai/gpt-oss-120b

# Summary model (optional)
# Examples: @cf/google/gemma-3-12b-it, xiaomi/mimo-v2-flash, gemma4:e4b
AI_SUMMARY_MODEL=gemma4:e4b

# Validation model (optional, defaults to summary model if not set)
# Examples: @cf/meta/llama-3.1-8b-instruct, openai/gpt-4.1-mini
AI_VALIDATION_MODEL=@cf/meta/llama-3.1-8b-instruct

# ============================================================================
# Example Configurations
# ============================================================================
# Uncomment one of these scenarios and comment out the provider selection above

# ─────────────────────────────────────────────────────────────────────────
# Scenario 0: All Ollama (FREE, Self-Hosted - Recommended for Free Tier)
# ─────────────────────────────────────────────────────────────────────────
# Requires: ollama installed and running locally
# Install: curl -fsSL https://ollama.ai/install.sh | sh
# Models:  ollama pull gemma4:e4b
#          ollama pull llama3.2:3b
#
# AI_REMEDIATION_PROVIDER=ollama
# AI_REMEDIATION_MODEL=gemma4:e4b
# AI_SUMMARY_PROVIDER=ollama
# AI_SUMMARY_MODEL=gemma4:e4b
# AI_VALIDATION_PROVIDER=ollama
# AI_VALIDATION_MODEL=gemma4:e4b
#
# OLLAMA_URL=http://localhost:11434

# ─────────────────────────────────────────────────────────────────────────
# Scenario 1: All Cloudflare (Fastest, most cost-effective for most tasks)
# ─────────────────────────────────────────────────────────────────────────
# AI_REMEDIATION_PROVIDER=cloudflare
# AI_REMEDIATION_MODEL=@cf/openai/gpt-oss-120b
# AI_SUMMARY_PROVIDER=cloudflare
# AI_SUMMARY_MODEL=@cf/google/gemma-3-12b-it
# AI_VALIDATION_PROVIDER=cloudflare
# AI_VALIDATION_MODEL=@cf/meta/llama-3.1-8b-instruct
#
# CF_ACCOUNT_ID=your_account_id
# CF_API_TOKEN=your_api_token

# ─────────────────────────────────────────────────────────────────────────
# Scenario 2: All OpenRouter (Highest quality, requires API key)
# ─────────────────────────────────────────────────────────────────────────
# AI_REMEDIATION_PROVIDER=openrouter
# AI_REMEDIATION_MODEL=openai/gpt-4.1-mini
# AI_SUMMARY_PROVIDER=openrouter
# AI_SUMMARY_MODEL=xiaomi/mimo-v2-flash
# AI_VALIDATION_PROVIDER=openrouter
# AI_VALIDATION_MODEL=openai/gpt-4.1-mini
#
# OPENROUTER_API_KEY=sk_your_api_key

# ─────────────────────────────────────────────────────────────────────────
# Scenario 3: Mixed Providers (Optimized per task)
# Recommended for production: Fast for high-volume tasks, accurate for critical ones
# ─────────────────────────────────────────────────────────────────────────
# AI_REMEDIATION_PROVIDER=cloudflare
# AI_REMEDIATION_MODEL=@cf/openai/gpt-oss-120b
#
# AI_SUMMARY_PROVIDER=cloudflare
# AI_SUMMARY_MODEL=@cf/google/gemma-3-12b-it
#
# AI_VALIDATION_PROVIDER=openrouter
# AI_VALIDATION_MODEL=openai/gpt-4.1-mini
#
# CF_ACCOUNT_ID=your_account_id
# CF_API_TOKEN=your_api_token
# OPENROUTER_API_KEY=sk_your_api_key

# ============================================================================
# Available Models
# ============================================================================
#
# Ollama (Self-Hosted, FREE):
#   Install: https://ollama.ai/download
#   Pull models: ollama pull <model-name>
#
#   Lightweight (Recommended for summaries):
#   - gemma4:e4b                         (Recommended, balanced speed/quality)
#   - llama3.2:3b                        (Very fast, minimal resources)
#   - phi3:3.8b                          (Good for code, compact)
#
#   Medium Weight:
#   - mistral:7b                         (Good all-rounder)
#   - llama3.1:8b                        (Better reasoning)
#   - gemma2:9b                          (High quality summaries)
#
#   Full list: https://ollama.ai/library
#
# Cloudflare Workers AI (@cf/ prefix):
#   Reasoning/Code:
#   - @cf/openai/gpt-oss-120b              (Good for code fixes, fast)
#   - @cf/meta/llama-3.1-8b-instruct       (Balanced, fast)
#   - @cf/meta/llama-3.1-70b-instruct      (More capable, slower)
#   - @cf/mistral/mistral-7b-instruct-v0.2 (Very fast, adequate)
#
#   Summaries:
#   - @cf/google/gemma-3-12b-it            (Recommended, balanced)
#   - @cf/meta/llama-3.1-8b-instruct       (Alternative)
#
#   Full list: https://developers.cloudflare.com/workers-ai/models/
#
# OpenRouter (no prefix):
#   High Quality:
#   - openai/gpt-4.1-mini                  (Recommended for critical tasks)
#   - openai/gpt-4-turbo                   (Very capable)
#   - anthropic/claude-3.5-sonnet          (Excellent)
#
#   Fast & Cost-Effective:
#   - xiaomi/mimo-v2-flash                 (Good for summaries)
#   - openai/gpt-3.5-turbo                 (Budget option)
#
#   Full list: https://openrouter.ai/docs#models

